    if ctrl.type=="dropdown" then return self:_Dropdown(p,ctrl) end
    if ctrl.type=="header"   then return self:_Header(p,ctrl)   end
    if ctrl.type=="label"    then return self:_Label(p,ctrl)    end
    if ctrl.type=="btnrow"   then return self:_BtnRow(p,ctrl)   end
end


function Components:MultiDropdown(parent, opts)
    local th      = self.theme
    local cn      = {}
    local options = opts.Options or {}
    local selected = {}
    local open = false

    if opts.Default then
        for _, v in ipairs(opts.Default) do selected[v] = true end
    end

    local wrapper = U.New("Frame", {
        Size = UDim2.new(1, 0, 0, 38),
        BackgroundTransparency = 1,
        ClipsDescendants = false,
        LayoutOrder = opts.LayoutOrder or 0,
        Parent = parent,
    })

    local mainFrame = U.New("Frame", {
        Size = UDim2.new(1, 0, 0, 38),
        BackgroundColor3 = th:Get("BG3"),
        BorderSizePixel = 0,
        Parent = wrapper,
    })
    U.Corner(mainFrame, CR_SM)
    U.Pad(mainFrame, 0, 10, 0, 10)

    U.New("TextLabel", {
        Size = UDim2.new(0.5, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = opts.Name or "Multi-Select",
        TextColor3 = th:Get("Text"),
        TextSize = 12,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = mainFrame,
    })

    local selLbl = U.New("TextLabel", {
        Size = UDim2.new(0.44, 0, 1, 0),
        Position = UDim2.new(0.5, 0, 0, 0),
        BackgroundTransparency = 1,
        Text = "None",
        TextColor3 = th:Get("AccentHi"),
        TextSize = 10,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Right,
        TextTruncate = Enum.TextTruncate.AtEnd,
        Parent = mainFrame,
    })

    local arrowLbl = U.New("TextLabel", {
        Size = UDim2.new(0, 18, 1, 0),
        Position = UDim2.new(1, -18, 0, 0),
        BackgroundTransparency = 1,
        Text = "‚Ėĺ",
        TextColor3 = th:Get("TextMuted"),
        TextSize = 12,
        Font = Enum.Font.Gotham,
        Parent = mainFrame,
    })

    local panel = U.New("ScrollingFrame", {
        Size = UDim2.new(1, 0, 0, 0),
        Position = UDim2.new(0, 0, 1, 3),
        BackgroundColor3 = th:Get("BG4"),
        BorderSizePixel = 0,
        ClipsDescendants = true,
        Visible = false,
        ZIndex = Z.DROPDOWN,
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = th:Get("Scrollbar"),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        CanvasSize = UDim2.new(0,0,0,0),
        ScrollingDirection = Enum.ScrollingDirection.Y,
        Parent = wrapper,
    })
    U.Corner(panel, CR_SM)
    U.Stroke(panel, th:Get("Border"), 1)
    U.List(panel, Enum.FillDirection.Vertical, 2)
    U.Pad(panel, 4, 4, 4, 4)

    local function getSelText()
        local keys = {}
        for k, v in pairs(selected) do if v then table.insert(keys, tostring(k)) end end
        return #keys == 0 and "None" or table.concat(keys, ", ")
    end

    local function buildItems()
        for _, ch in ipairs(panel:GetChildren()) do
            if ch:IsA("Frame") then ch:Destroy() end
        end
        for idx, opt in ipairs(options) do
            local isSel = selected[opt] == true
            local item = U.New("Frame", {
                Name = "Item_" .. idx,
                Size = UDim2.new(1, 0, 0, 30),
                BackgroundColor3 = isSel and th:Get("BG5") or th:Get("BG4"),
                BorderSizePixel = 0,
                ZIndex = Z.DROPDOWN + 1,
                Parent = panel,
            })
            U.Corner(item, UDim.new(0, 4))
            U.Pad(item, 0, 8, 0, 8)

            -- Checkbox
            local checkBg = U.New("Frame", {
                Size = UDim2.new(0, 15, 0, 15),
                Position = UDim2.new(0, 0, 0.5, -7.5),
                BackgroundColor3 = isSel and th:Get("Accent") or th:Get("BG3"),
                BorderSizePixel = 0,
                ZIndex = Z.DROPDOWN + 2,
                Parent = item,
            })
            U.Corner(checkBg, UDim.new(0, 3))
            U.Stroke(checkBg, isSel and th:Get("AccentLo") or th:Get("Border"), 1)

            if isSel then
                U.New("TextLabel", {
                    Size = UDim2.new(1,0,1,0),
                    BackgroundTransparency = 1,
                    Text = "‚úď",
                    TextColor3 = Color3.fromRGB(255,255,255),
                    TextSize = 10,
                    Font = Enum.Font.GothamBold,
                    ZIndex = Z.DROPDOWN + 3,
                    Parent = checkBg,
                })
            end

            U.New("TextLabel", {
                Size = UDim2.new(1, -24, 1, 0),
                Position = UDim2.new(0, 22, 0, 0),
                BackgroundTransparency = 1,
                Text = tostring(opt),
                TextColor3 = isSel and th:Get("AccentHi") or th:Get("Text"),
                TextSize = 11,
                Font = isSel and Enum.Font.GothamBold or Enum.Font.Gotham,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = Z.DROPDOWN + 2,
                Parent = item,
            })

            item.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    selected[opt] = not selected[opt]
                    selLbl.Text = getSelText()
                    local vals = {}
                    for k, v in pairs(selected) do if v then table.insert(vals, k) end end
                    if opts.Callback then pcall(opts.Callback, vals) end
                    buildItems()
                end
            end)
            item.MouseEnter:Connect(function()
                if not isSel then
                    self.anim:Play(item, {BackgroundColor3 = th:Get("BG5")}, TI.XFast)
                end
            end)
            item.MouseLeave:Connect(function()
                if not isSel then
                    self.anim:Play(item, {BackgroundColor3 = th:Get("BG4")}, TI.XFast)
                end
            end)
        end
    end
    buildItems()
    selLbl.Text = getSelText()

    local function toggleOpen()
        open = not open
        if open then
            panel.Visible = true
            local h = math.min(#options * 34 + 10, 172)
            self.anim:Play(panel, {Size = UDim2.new(1, 0, 0, h)}, TI.Medium)
            self.anim:Play(arrowLbl, {Rotation = 180}, TI.Fast)
            wrapper.Size = UDim2.new(1, 0, 0, 38 + h + 3)
        else
            self.anim:Play(panel, {Size = UDim2.new(1, 0, 0, 0)}, TI.Medium)
            self.anim:Play(arrowLbl, {Rotation = 0}, TI.Fast)
            task.delay(0.24, function()
                if not open and panel and panel.Parent then
                    panel.Visible = false
                    wrapper.Size = UDim2.new(1, 0, 0, 38)
                end
            end)
        end
    end

    U.Connect(cn, mainFrame.InputBegan, function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then toggleOpen() end
    end)

    if opts.Tooltip then self.tooltip:Attach(mainFrame, opts.Tooltip) end

    return {
        Frame    = wrapper,
        GetValue = function()
            local vals = {}
            for k, v in pairs(selected) do if v then table.insert(vals, k) end end
            return vals
        end,
        Destroy  = function() U.Disconn(cn) wrapper:Destroy() end,
    }
end


    local ic=({success="\xe2\x9c\x93",error="\xe2\x9c\x95",warning="\xe2\x9a\xa0",info="\xe2\x97\x8f"})[ntype] or "\xe2\x97\x8f"
    local toast=New("Frame",{Parent=self._toastCont,BackgroundColor3=T.ToastBg,Size=UDim2.new(1,0,0,body and 58 or 42),ZIndex=601,BorderSizePixel=0,BackgroundTransparency=1})

-- ---- SLIDER ----
function ComponentFactory:MakeSlider(parent, opts)
    local opts = opts or {}
    local min       = opts.Min     or 0
    local max       = opts.Max     or 100
    local value     = opts.Default or min
    local step      = opts.Step    or 1
    local connections = {}
    local theme = self.Theme
    local dragging = false

    local frame = Utils.Create("Frame", {
        Name                    = "Slider_" .. (opts.Name or ""),
        Size                    = UDim2.new(1, 0, 0, 52),
        BackgroundColor3        = theme:Get("SurfaceAlt"),
        BackgroundTransparency  = 0,
        LayoutOrder             = opts.LayoutOrder or 0,
        Parent                  = parent,
    })
    Utils.AddCorner(frame, CORNER_SMALL)
    Utils.AddPadding(frame, 8, 10, 8, 10)

    local header = Utils.Create("Frame", {
        Name = "Header",
        Size = UDim2.new(1, 0, 0, 18),
        BackgroundTransparency = 1,
        Parent = frame,
    })

    Utils.Create("TextLabel", {
        Name                    = "Name",
        Size                    = UDim2.new(0.7, 0, 1, 0),
        BackgroundTransparency  = 1,
        Text                    = opts.Name or "Slider",
        TextColor3              = theme:Get("Text"),
        TextSize                = 13,
        Font                    = Enum.Font.Gotham,
        TextXAlignment          = Enum.TextXAlignment.Left,
        Parent                  = header,
    })

    local valueLabel = Utils.Create("TextLabel", {
        Name                    = "Value",
        Size                    = UDim2.new(0.3, 0, 1, 0),
        Position                = UDim2.new(0.7, 0, 0, 0),
        BackgroundTransparency  = 1,
        Text                    = tostring(value),
        TextColor3              = theme:Get("Accent"),
        TextSize                = 13,
        Font                    = Enum.Font.GothamBold,
        TextXAlignment          = Enum.TextXAlignment.Right,
        Parent                  = header,
    })

    local track = Utils.Create("Frame", {
        Name                    = "Track",
        Size                    = UDim2.new(1, 0, 0, 6),
        Position                = UDim2.new(0, 0, 1, -6),
        BackgroundColor3        = theme:Get("Border"),
        BorderSizePixel         = 0,
        Parent                  = frame,
    })
    Utils.AddCorner(track, UDim.new(1, 0))

    local fill = Utils.Create("Frame", {
        Name                    = "Fill",
        Size                    = UDim2.new(0, 0, 1, 0),
        BackgroundColor3        = theme:Get("Accent"),
        BorderSizePixel         = 0,
        Parent                  = track,
    })
    Utils.AddCorner(fill, UDim.new(1, 0))

    local thumb = Utils.Create("Frame", {
        Name                    = "Thumb",
        Size                    = UDim2.new(0, 14, 0, 14),
        AnchorPoint             = Vector2.new(0.5, 0.5),
        Position                = UDim2.new(0, 0, 0.5, 0),
        BackgroundColor3        = theme:Get("White"),
        BorderSizePixel         = 0,
        ZIndex                  = track.ZIndex + 1,
        Parent                  = track,
    })
    Utils.AddCorner(thumb, UDim.new(1, 0))
    Utils.AddStroke(thumb, theme:Get("Accent"), 2)

    local function setValue(v, animate)
        v = Utils.Round(Utils.Clamp(v, min, max) / step) * step
        value = Utils.Clamp(v, min, max)
        valueLabel.Text = tostring(value)
        local t = (value - min) / (max - min)
        local targetFill = UDim2.new(t, 0, 1, 0)
        local targetThumb = UDim2.new(t, 0, 0.5, 0)
        if animate then
            self.Anim:Play(fill, {Size = targetFill}, TWEEN_SHORT)
            self.Anim:Play(thumb, {Position = targetThumb}, TWEEN_SHORT)
        else
            fill.Size = targetFill
            thumb.Position = targetThumb
        end
        if opts.Callback then pcall(opts.Callback, value) end
        if opts.Flag then self.Config:SetFlag(opts.Flag, value) end
    end

    setValue(value, false)

    local function handleInput(input)
        local relX = input.Position.X - track.AbsolutePosition.X
        local t = Utils.Clamp(relX / track.AbsoluteSize.X, 0, 1)
        setValue(min + (max - min) * t, false)
    end

    Utils.Connect(connections, track.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            handleInput(input)
        end
    end)

    Utils.Connect(connections, UserInputService.InputChanged, function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            handleInput(input)
        end
    end)

    Utils.Connect(connections, UserInputService.InputEnded, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    Utils.Connect(connections, thumb.MouseEnter, function()
        self.Anim:Scale(thumb, UDim2.new(0, 18, 0, 18), TWEEN_SHORT)
    end)
    Utils.Connect(connections, thumb.MouseLeave, function()
        if not dragging then
            self.Anim:Scale(thumb, UDim2.new(0, 14, 0, 14), TWEEN_SHORT)
        end
    end)

    Utils.Connect(connections, frame.MouseEnter, function()
        self.Anim:Play(frame, {BackgroundColor3 = theme:Get("Surface")}, TWEEN_SHORT)
    end)
    Utils.Connect(connections, frame.MouseLeave, function()
        self.Anim:Play(frame, {BackgroundColor3 = theme:Get("SurfaceAlt")}, TWEEN_SHORT)
    end)

    if opts.Tooltip then self.Tooltip:Attach(frame, opts.Tooltip) end

    if opts.Flag then
        self.Config:Register(opts.Flag, value, function(v)
            setValue(v, true)
        end)
    end

    return {
        Frame    = frame,
        GetValue = function() return value end,
        SetValue = function(_, v) setValue(v, true) end,
        Destroy  = function()
            Utils.Disconnect(connections)
            frame:Destroy()
        end,
    }
end


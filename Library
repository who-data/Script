        local itemH=22; local listH=#opts*itemH+6
        DropF=New("Frame",{Parent=self.Gui,BackgroundColor3=T.DropBg,Size=UDim2.new(0,Box.AbsoluteSize.X,0,listH),ZIndex=50,ClipsDescendants=true})
        Corn(6,DropF); Stro(T.Accent,1,DropF)
        New("ImageLabel",{Parent=DropF,BackgroundTransparency=1,Position=UDim2.new(0,-8,0,-8),Size=UDim2.new(1,16,1,16),ZIndex=49,Image="rbxassetid://6014261993",ImageColor3=Color3.new(0,0,0),ImageTransparency=0.5,ScaleType=Enum.ScaleType.Slice,SliceCenter=Rect.new(49,49,450,450)})
        local ap=Box.AbsolutePosition; local as=Box.AbsoluteSize
        DropF.Position=UDim2.new(0,ap.X,0,ap.Y+as.Y+3)
        List(DropF,nil,0); Pad(3,3,3,3,DropF)
        for _,opt in ipairs(opts) do
            local isS=(opt==val)
            local Item=New("TextButton",{Parent=DropF,BackgroundColor3=isS and Color3.fromRGB(22,20,36) or T.DropBg,BackgroundTransparency=isS and 0 or 1,Size=UDim2.new(1,0,0,itemH),Font=isS and Enum.Font.GothamBold or Enum.Font.Gotham,Text=tostring(opt),TextColor3=isS and T.TextAccent or T.TextSec,TextSize=11,TextXAlignment=Enum.TextXAlignment.Left,AutoButtonColor=false,ZIndex=51})
            Pad(8,0,0,0,Item); Corn(3,Item)
            Item.MouseEnter:Connect(function() Item.BackgroundTransparency=0; Tw(Item,{BackgroundColor3=T.DropHover,TextColor3=T.TextPri},.08) end)
            Item.MouseLeave:Connect(function()
                if not isS then Item.BackgroundTransparency=1; Item.TextColor3=T.TextSec
                else Item.BackgroundTransparency=0; Item.BackgroundColor3=Color3.fromRGB(22,20,36) end
            end)
            Item.MouseButton1Click:Connect(function() task.defer(function() SetVal(opt) end) end)
        end
        Ov=New("TextButton",{Parent=self.Gui,BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),Text="",ZIndex=48})
        Ov.MouseButton1Click:Connect(function() Close() end)
    end)
    ctrl._setValue=SetVal; ctrl._getValue=function() return val end
    return Wrap
end


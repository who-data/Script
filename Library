function Library:_Bread(cat, sec)
    for _,c in ipairs(self.BreadF:GetChildren()) do
        if c~=self.BreadA and not c:IsA("UIListLayout") then c:Destroy() end
    end
    self.BreadA.Text = cat or ""
    if sec then
        Label(self.BreadF,"›",14,C.TDIM,Enum.Font.Gotham,
            Enum.TextXAlignment.Center,nil,UDim2.new(0,10,1,0),7)
        Label(self.BreadF,sec,12,C.TACC,Enum.Font.GothamBold,
            Enum.TextXAlignment.Left,nil,UDim2.new(0,130,1,0),7)
    end
end

-- =========================================================
--  ADD CATEGORY
-- =========================================================
function Library:AddCategory(name)
    local cat={Name=name,_secs={},_open=false,_ui=self}

    local row = New("TextButton",{Parent=self.SideScroll,
        BackgroundTransparency=1,Size=UDim2.new(1,0,0,34),
        Text="",AutoButtonColor=false,ZIndex=7})
    Corner(4,row)

    row.MouseEnter:Connect(function()
        if not cat._open then TW(row,{BackgroundColor3=C.HOVER},.08); row.BackgroundTransparency=0 end
    end)
    row.MouseLeave:Connect(function()
        if not cat._open then row.BackgroundTransparency=1 end
    end)

    -- Ícone anel + dot
    local ring=New("Frame",{Parent=row,BackgroundTransparency=1,
        Position=UDim2.new(0,10,0.5,-8),Size=UDim2.new(0,16,0,16),ZIndex=8})
    Corner(8,ring); Stroke(C.TSEC,1.3,ring)
    local dot=New("Frame",{Parent=row,BackgroundColor3=C.TSEC,
        Position=UDim2.new(0,14,0.5,-4),Size=UDim2.new(0,8,0,8),ZIndex=9})
    Corner(4,dot)

    Label(row,name,12,C.TPRI,Enum.Font.GothamBold,
        Enum.TextXAlignment.Left,UDim2.new(0,32,0,0),UDim2.new(1,-52,1,0),8)

    local chev=Label(row,"›",15,C.TDIM,Enum.Font.GothamBold,
        Enum.TextXAlignment.Center,UDim2.new(1,-22,0,0),UDim2.new(0,18,1,0),8)

    -- Container de seções
    local sf=New("Frame",{Parent=self.SideScroll,BackgroundTransparency=1,
        Size=UDim2.new(1,0,0,0),ClipsDescendants=true,Visible=false,ZIndex=7})
    local sl=Layout(sf)

    cat._row=row; cat._sf=sf; cat._sl=sl; cat._chev=chev
    cat._ring=ring; cat._dot=dot

    row.MouseButton1Click:Connect(function()
        cat._open = not cat._open
        if cat._open then
            sf.Visible=true
            sf.Size=UDim2.new(1,0,0,sl.AbsoluteContentSize.Y)
            chev.Text="↓"
            TW(row,{BackgroundColor3=C.HOVER},.08); row.BackgroundTransparency=0
            -- Atualiza ícone para accent
            Stroke(C.ACC,1.3,ring); dot.BackgroundColor3=C.ACC
            if #cat._secs>0 and not cat._secs[1]._active then
                cat._secs[1]._btn.MouseButton1Click:Fire()
            end
        else
            sf.Visible=false; sf.Size=UDim2.new(1,0,0,0)
            chev.Text="›"; row.BackgroundTransparency=1
            Stroke(C.TSEC,1.3,ring); dot.BackgroundColor3=C.TSEC
        end
    end)

    self._cats[#self._cats+1]=cat
    return cat
end


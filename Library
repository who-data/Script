-- TAB
-- ============================================================
local Tab={}; Tab.__index=Tab

function Tab.new(scroll)
    local self=setmetatable({},Tab)
    self._scroll=scroll; self._subs={}; self._activeSub=nil; self._subBar=nil
    return self
end

function Tab:_bar()
    if self._subBar then return end
    self._subBar=ins("Frame",{Size=UDim2.new(1,0,0,32),BackgroundTransparency=1,Parent=self._scroll})
    hlist(self._subBar,4)
    ins("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-1),
        BackgroundColor3=C.Border,BorderSizePixel=0,Parent=self._subBar})
end

function Tab:AddSubTab(name)
    self:_bar()
    local first=#self._subs==0

    local btn=ins("TextButton",{Size=UDim2.new(0,0,1,-4),AutomaticSize=Enum.AutomaticSize.X,
        BackgroundTransparency=1,Text=name,
        TextColor3=first and C.TextAcc or C.TextDim,
        Font=C.Fsemi,TextSize=12,AutoButtonColor=false,Parent=self._subBar})
    pad(btn,0,12,0,12)

    local ind=ins("Frame",{
        Size=first and UDim2.new(1,0,0,2) or UDim2.new(0,0,0,2),
        Position=UDim2.new(0,0,1,0),
        BackgroundColor3=C.Accent,BorderSizePixel=0,Parent=btn})

    local holder=ins("Frame",{Size=UDim2.new(1,0,0,0),BackgroundTransparency=1,Visible=first,Parent=self._scroll})
    local hl=vlist(holder,8); pad(holder,4,0,4,0)

    hl:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        holder.Size=UDim2.new(1,0,0,hl.AbsoluteContentSize.Y+8)
    end)

    local idx=#self._subs+1
    self._subs[idx]={btn=btn,ind=ind,holder=holder}
    if first then self._activeSub=1 end

    btn.MouseButton1Click:Connect(function()
        if self._activeSub==idx then return end
        local old=self._subs[self._activeSub]
        if old then old.holder.Visible=false; tw(old.btn,{TextColor3=C.TextDim}); tw(old.ind,{Size=UDim2.new(0,0,0,2)}) end
        self._activeSub=idx; holder.Visible=true
        tw(btn,{TextColor3=C.TextAcc}); tw(ind,{Size=UDim2.new(1,0,0,2)})
    end)

    return Section.new(holder,nil)
end

function Tab:AddSection(title)
    return Section.new(self._scroll,title)
end


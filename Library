function Window:Tab(name, icon)
    -- ScrollingFrame: AutomaticCanvasSize=Y makes it scroll as content grows
    local scroll = N("ScrollingFrame",{
        Size=UDim2.new(1,0,1,-36), Position=UDim2.new(0,0,0,36),
        BackgroundTransparency=1, BorderSizePixel=0,
        ScrollBarThickness=3, ScrollBarImageColor3=P.acc,
        AutomaticCanvasSize=Enum.AutomaticSize.Y,
        CanvasSize=UDim2.new(0,0,0,0),
        Visible=false, Parent=self._ca,
    })
    UIPad(scroll, 8, 10, 12, 14)
    VList(scroll, 8)

    local first = #self._tabs == 0

    -- Sidebar button
    local tbtn = N("TextButton",{
        Size=UDim2.new(1,0,0,36), BackgroundTransparency=1,
        Text="", AutoButtonColor=false, Parent=self._tabList,
    })

    local bar = N("Frame",{
        Size = first and UDim2.new(0,2,0.65,0) or UDim2.new(0,0,0.65,0),
        Position=UDim2.new(0,0,0.175,0),
        BackgroundColor3=P.acc, BorderSizePixel=0, Parent=tbtn,
    })
    local icLbl = N("TextLabel",{
        Size=UDim2.new(0,22,1,0), Position=UDim2.new(0,14,0,0),
        BackgroundTransparency=1, Text=icon or "",
        TextColor3=first and P.txtAcc or P.txtSub,
        Font=P.Fb, TextSize=14, Parent=tbtn,
    })
    local nmLbl = N("TextLabel",{
        Size=UDim2.new(1,-40,1,0), Position=UDim2.new(0,38,0,0),
        BackgroundTransparency=1, Text=name,
        TextColor3=first and P.txtAcc or P.txtSub,
        Font=P.Fsm, TextSize=12,
        TextXAlignment=Enum.TextXAlignment.Left, Parent=tbtn,
    })
    local hov = N("Frame",{
        Size=UDim2.new(1,0,1,0), BackgroundColor3=P.acc,
        BackgroundTransparency=1, ZIndex=0, Parent=tbtn,
    })

    local tabObj = Tab.new(scroll)

    if first then
        scroll.Visible=true; self._active=tabObj
        self._ttl.Text = name:upper()
    end

    tbtn.MouseEnter:Connect(function()
        if self._active ~= tabObj then tw(hov,{BackgroundTransparency=0.92}) end
    end)
    tbtn.MouseLeave:Connect(function() tw(hov,{BackgroundTransparency=1}) end)

    tbtn.MouseButton1Click:Connect(function()
        if self._active == tabObj then return end
        for _,t in ipairs(self._tabs) do
            if t.obj == self._active then
                t.obj._scroll.Visible = false
                tw(t.bar,{Size=UDim2.new(0,0,0.65,0)})
                tw(t.ic,{TextColor3=P.txtSub})
                tw(t.nm,{TextColor3=P.txtSub})
                break
            end
        end
        self._active = tabObj
        scroll.Visible = true
        self._ttl.Text = name:upper()
        tw(bar,{Size=UDim2.new(0,2,0.65,0)})
        tw(icLbl,{TextColor3=P.txtAcc})
        tw(nmLbl,{TextColor3=P.txtAcc})
        tw(hov,{BackgroundTransparency=1})
    end)

    table.insert(self._tabs, {obj=tabObj,bar=bar,ic=icLbl,nm=nmLbl})
    return tabObj
end

function Window:Destroy() self._gui:Destroy() end
function Window:Toggle()
    self._min = not self._min
    tw(self._main,{Size=UDim2.new(0,self._W,0,self._min and 36 or self._H)},.2)
end


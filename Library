                TextColor3           = C.TEXT,
                TextSize             = 11,
                TextXAlignment       = Enum.TextXAlignment.Left,
                ZIndex               = 5,
            })
            -- value display badge
            local valBadge = new("Frame", {
                Parent           = row,
                BackgroundColor3 = C.ACCENT_DIM,
                BorderSizePixel  = 0,
                Position         = UDim2.new(1, -58, 0, 5),
                Size             = UDim2.new(0, 46, 0, 18),
                ZIndex           = 5,
            })
            corner(4, valBadge)
            stroke(C.ACCENT, 1, valBadge)
            local valLbl = new("TextLabel", {
                Parent               = valBadge,
                BackgroundTransparency = 1,
                Size                 = UDim2.new(1, 0, 1, 0),
                Font                 = Enum.Font.GothamBold,
                Text                 = tostring(val) .. sfx,
                TextColor3           = C.ACCENT2,
                TextSize             = 10,
                ZIndex               = 6,
            })

            -- track background
            local trackBG = new("Frame", {
                Parent           = row,
                BackgroundColor3 = C.SLIDER_BG,
                BorderSizePixel  = 0,
                Position         = UDim2.new(0, 14, 1, -16),
                Size             = UDim2.new(1, -28, 0, 6),
                ZIndex           = 5,
            })
            corner(100, trackBG)
            stroke(C.BORDER, 1, trackBG)

            local p0   = (val - mn) / (mx - mn)
            local fill = new("Frame", {
                Parent           = trackBG,
                BackgroundColor3 = C.ACCENT,
                BorderSizePixel  = 0,
                Size             = UDim2.new(p0, 0, 1, 0),
                ZIndex           = 6,
            })
            corner(100, fill)
            gradient(C.ACCENT2, C.ACCENT, 0, fill)

            -- knob
            local knob = new("Frame", {
                Parent           = trackBG,
                BackgroundColor3 = C.WHITE,
                BorderSizePixel  = 0,
                Position         = UDim2.new(p0, -7, 0.5, -7),
                Size             = UDim2.new(0, 14, 0, 14),
                ZIndex           = 7,
            })
            corner(100, knob)
            stroke(C.ACCENT2, 2, knob)

            local S = {}
            local drag2 = false
            local function upd(x)
                local p   = math.clamp((x - trackBG.AbsolutePosition.X) / trackBG.AbsoluteSize.X, 0, 1)
                val = math.floor(mn + p * (mx - mn) + 0.5)
                p   = (val - mn) / (mx - mn)
                fill.Size     = UDim2.new(p, 0, 1, 0)
                knob.Position = UDim2.new(p, -7, 0.5, -7)
                valLbl.Text   = tostring(val) .. sfx
                pcall(cb, val)
            end
            trackBG.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    drag2 = true
                    upd(i.Position.X)
                    tween(knob, { Size = UDim2.new(0, 16, 0, 16), Position = UDim2.new((val - mn) / (mx - mn), -8, 0.5, -8) })
                end
            end)
            UserInputService.InputChanged:Connect(function(i)
                if drag2 and i.UserInputType == Enum.UserInputType.MouseMovement then
                    upd(i.Position.X)
                end
            end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    drag2 = false
                    tween(knob, { Size = UDim2.new(0, 14, 0, 14) })
                end
            end)
            function S:Set(v)
                val = math.clamp(v, mn, mx)
                local p = (val - mn) / (mx - mn)
                fill.Size     = UDim2.new(p, 0, 1, 0)
                knob.Position = UDim2.new(p, -7, 0.5, -7)
                valLbl.Text   = tostring(val) .. sfx
                pcall(cb, val)
            end
            function S:Get() return val end
            return S
        end


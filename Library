            -- Dropdown list
            local DropList = Create("Frame", {
                Parent = Row,
                BackgroundColor3 = Theme.Dropdown,
                BorderSizePixel = 0,
                Position = UDim2.new(0, 0, 1, 2),
                Size = UDim2.new(1, 0, 0, 0),
                Visible = false,
                ZIndex = 10,
            })
            Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = DropList })
            Create("UIStroke", { Color = Theme.Border, Thickness = 1, Parent = DropList })

            local DropLayout = Create("UIListLayout", {
                Parent = DropList,
                FillDirection = Enum.FillDirection.Vertical,
                Padding = UDim.new(0, 0),
            })

            local open = false
            local function toggleDrop()
                open = not open
                if open then
                    -- Clear + rebuild
                    for _, c in ipairs(DropList:GetChildren()) do
                        if c:IsA("TextButton") then c:Destroy() end
                    end
                    for _, opt in ipairs(options) do
                        local OptBtn = Create("TextButton", {
                            Parent = DropList,
                            BackgroundColor3 = Theme.Dropdown,
                            BackgroundTransparency = 0,
                            BorderSizePixel = 0,
                            Size = UDim2.new(1, 0, 0, 28),
                            Font = Enum.Font.Gotham,
                            Text = opt,
                            TextColor3 = opt == selected and Theme.Accent or Theme.Text,
                            TextSize = 10,
                            ZIndex = 11,
                            AutoButtonColor = false,
                        })
                        OptBtn.MouseEnter:Connect(function()
                            Tween(OptBtn, { BackgroundColor3 = Theme.ItemHover })
                        end)
                        OptBtn.MouseLeave:Connect(function()
                            Tween(OptBtn, { BackgroundColor3 = Theme.Dropdown })
                        end)
                        OptBtn.MouseButton1Click:Connect(function()
                            selected = opt
                            if SubLbl then SubLbl.Text = opt end
                            pcall(cb, opt)
                            toggleDrop()
                        end)
                    end
                    local h = #options * 28
                    DropList.Visible = true
                    DropList.Size = UDim2.new(1, 0, 0, 0)
                    Tween(DropList, { Size = UDim2.new(1, 0, 0, math.min(h, 140)) }, 0.15)
                    Tween(ArrowIcon, { Rotation = 90 })
                else
                    Tween(DropList, { Size = UDim2.new(1, 0, 0, 0) }, 0.15)
                    task.delay(0.15, function() DropList.Visible = false end)
                    Tween(ArrowIcon, { Rotation = 0 })
                end
            end

            Row.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    toggleDrop()
                end
            end)

            local Dropdown = {}
            function Dropdown:Set(v)
                selected = v
                if SubLbl then SubLbl.Text = v end
                pcall(cb, v)
            end
            function Dropdown:Get() return selected end
            function Dropdown:SetOptions(newOpts)
                options = newOpts
                selected = newOpts[1] or "None"
                if SubLbl then SubLbl.Text = selected end
            end

            return Dropdown
        end


        Font                    = Enum.Font.Gotham,
        TextXAlignment          = Enum.TextXAlignment.Left,
        ClearTextOnFocus        = opts.ClearOnFocus or false,
        Parent                  = inputBg,
    })

    Utils.Connect(connections, input.Focused, function()
        self.Anim:Play(inputBg, {BackgroundColor3 = theme:Get("BackgroundAlt")}, TWEEN_SHORT)
        local stroke = inputBg:FindFirstChildOfClass("UIStroke")
        if stroke then
            self.Anim:Play(stroke, {Color = theme:Get("Accent")}, TWEEN_SHORT)
        end
    end)

    Utils.Connect(connections, input.FocusLost, function(enter)
        value = input.Text
        self.Anim:Play(inputBg, {BackgroundColor3 = theme:Get("Background")}, TWEEN_SHORT)
        local stroke = inputBg:FindFirstChildOfClass("UIStroke")
        if stroke then
            self.Anim:Play(stroke, {Color = theme:Get("Border")}, TWEEN_SHORT)

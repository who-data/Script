-- ══════════════════════════════════════════════
--  TOGGLE WINDOW
-- ══════════════════════════════════════════════
function ShadowUI:_Toggle()
    self._visible = not self._visible
    if self._visible then
        self.Win.Visible = true
        Tween(self.Win, {Size = UDim2.new(0,660,0,448)}, .2, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        self._floatLbl.Text = "◀"
    else
        Tween(self.Win, {Size = UDim2.new(0,0,0,448)}, .18)
        task.delay(.2, function()
            if not self._visible then self.Win.Visible = false end
        end)
        self._floatLbl.Text = "▶"
    end
end


function Theme.new()
    local self = setmetatable({ _c = {}, _listeners = {} }, Theme)
    for k, v in pairs(DEFAULT_THEME) do self._c[k] = v end
    return self
end

function Theme:Get(k)
    return self._c[k] or DEFAULT_THEME[k] or Color3.new(1,0,1)
end

function Theme:Set(tbl)
    for k, v in pairs(tbl) do self._c[k] = v end
    for _, fn in ipairs(self._listeners) do pcall(fn, self._c) end
end

function Theme:OnChange(fn)
    table.insert(self._listeners, fn)
    return function()
        for i, f in ipairs(self._listeners) do
            if f == fn then table.remove(self._listeners, i) return end
        end
    end
end


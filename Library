    -- Toggle track
    local Tr = New("Frame", {
        Parent=row, BackgroundColor3=val and T.TogOn or T.TogOff,
        Position=UDim2.new(1,-30,0.5,-7), Size=UDim2.new(0,28,0,14), ZIndex=4,
    })
    Corn(7, Tr)

    -- Toggle thumb
    local Th = New("Frame", {
        Parent=Tr, BackgroundColor3=T.White,
        Position=val and UDim2.new(1,-13,0.5,-5) or UDim2.new(0,2,0.5,-5),
        Size=UDim2.new(0,10,0,10), ZIndex=5,
    })
    Corn(5, Th)

    -- Hit button cobrindo a row inteira

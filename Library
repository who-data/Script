        -- Expand from centre
        self.Clip.Visible = true
        self.Clip.Size    = UDim2.new(0, W * 0.6, 0, H * 0.6)
        self.Win.BackgroundTransparency = 0.6
        Tw(self.Clip, { Size = UDim2.new(0, W, 0, H) },
            0.28, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        Tw(self.Win, { BackgroundTransparency = 0 }, 0.22)
        self._floatLbl.Text = "◀"
    else
        -- Collapse to centre
        Tw(self.Clip, { Size = UDim2.new(0, 0, 0, H * 0.5) },
            0.18, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
        Tw(self.Win, { BackgroundTransparency = 0.8 }, 0.16)
        task.delay(0.2, function()
            if not self._visible then
                self.Clip.Visible = false
                self.Clip.Size    = UDim2.new(0, W, 0, H)
                self.Win.BackgroundTransparency = 0
            end
        end)
        self._floatLbl.Text = "▶"
    end
end

-- ══════════════════════════════════════════════════════════════════
--  BREADCRUMB
-- ══════════════════════════════════════════════════════════════════
function ShadowUI:_Bread(catName, secName)
    for _, c in ipairs(self.BreadFrame:GetChildren()) do
        if c ~= self.BreadCat and not c:IsA("UIListLayout") then
            c:Destroy()
        end
    end
    self.BreadCat.Text = catName or ""
    if secName then
        Lbl(self.BreadFrame, "›", 14, T.TxtDim, Enum.Font.Gotham,
            Enum.TextXAlignment.Center, nil, UDim2.new(0, 10, 1, 0), 12)
        Lbl(self.BreadFrame, secName, 11, T.TxtAcc, Enum.Font.GothamBold,
            Enum.TextXAlignment.Left, nil, UDim2.new(0, 130, 1, 0), 12)
    end
end

-- ══════════════════════════════════════════════════════════════════
--  TOOLTIP HELPERS
-- ══════════════════════════════════════════════════════════════════
function ShadowUI:_ShowTooltip(txt, x, y)
    if not txt or txt == "" then return end
    self._tooltipLbl.Text = txt
    -- Auto-size width based on content
    local estimW = math.min(240, math.max(100, #txt * 6 + 20))
    self._tooltip.Size     = UDim2.new(0, estimW, 0, 26)
    self._tooltip.Position = UDim2.new(0, x + 12, 0, y - 6)
    self._tooltip.Visible  = true
end

function ShadowUI:_HideTooltip()
    self._tooltip.Visible = false
end

--- Attaches tooltip to a hit button. Shows on hover, hides on leave.
function ShadowUI:_AttachTooltip(btn, text)
    if not text or text == "" then return end
    btn.MouseEnter:Connect(function()
        local mp = UIS:GetMouseLocation()
        self:_ShowTooltip(text, mp.X, mp.Y)
    end)
    btn.MouseMoved:Connect(function(x, y)
        self._tooltip.Position = UDim2.new(0, x + 14, 0, y - 8)
    end)
    btn.MouseLeave:Connect(function() self:_HideTooltip() end)
end

-- ══════════════════════════════════════════════════════════════════
--  TOAST NOTIFICATIONS
-- ══════════════════════════════════════════════════════════════════
--[[
    type can be: "success" | "error" | "info" | "warning"
    duration in seconds (default 3.5)
]]
function ShadowUI:Notify(title, body, ntype, duration)
    ntype    = ntype    or "info"
    duration = duration or 3.5

    local accentCol = T.ToastInf
    if ntype == "success" then accentCol = T.ToastSuc
    elseif ntype == "error"   then accentCol = T.ToastErr
    elseif ntype == "warning" then accentCol = T.ToastWrn
    end

    local icon = "ℹ"
    if ntype == "success" then icon = "✓"
    elseif ntype == "error"   then icon = "✕"
    elseif ntype == "warning" then icon = "⚠"
    end

    -- Build toast frame
    local toast = New("Frame", {
        Parent               = self._toastContainer,
        BackgroundColor3     = T.ToastBg,
        Size                 = UDim2.new(1, 0, 0, TOAST_H),
        ZIndex               = 601,
        BorderSizePixel      = 0,
        BackgroundTransparency = 1,
    })
    Corner(8, toast)
    Stroke(T.Border, 1, toast)

    -- Accent left stripe
    local stripe = New("Frame", {
        Parent           = toast,
        BackgroundColor3 = accentCol,
        Position         = UDim2.new(0, 0, 0.1, 0),
        Size             = UDim2.new(0, 3, 0.8, 0),
        ZIndex           = 602,
        BorderSizePixel  = 0,
    })
    Corner(2, stripe)

    -- Icon
    New("TextLabel", {
        Parent               = toast,
        BackgroundTransparency = 1,
        Position             = UDim2.new(0, 10, 0, 0),
        Size                 = UDim2.new(0, 24, 1, 0),
        Font                 = Enum.Font.GothamBold,
        Text                 = icon,
        TextColor3           = accentCol,
        TextSize             = 16,
        TextXAlignment       = Enum.TextXAlignment.Center,
        ZIndex               = 602,
    })

    -- Title
    Lbl(toast, title or "", 12, T.TxtPri, Enum.Font.GothamBold,
        Enum.TextXAlignment.Left,
        UDim2.new(0, 38, 0, 6), UDim2.new(1, -44, 0, 16), 602)

    -- Body
    if body and body ~= "" then
        Lbl(toast, body, 10, T.TxtSec, Enum.Font.Gotham,
            Enum.TextXAlignment.Left,
            UDim2.new(0, 38, 0, 24), UDim2.new(1, -44, 0, 26), 602, true)
    end

    -- Progress bar
    local progBg = New("Frame", {
        Parent           = toast,
        BackgroundColor3 = T.Border,
        Position         = UDim2.new(0, 0, 1, -3),
        Size             = UDim2.new(1, 0, 0, 2),
        ZIndex           = 603,
        BorderSizePixel  = 0,
    })
    local prog = New("Frame", {
        Parent           = progBg,
        BackgroundColor3 = accentCol,
        Size             = UDim2.new(1, 0, 1, 0),
        ZIndex           = 604,
        BorderSizePixel  = 0,
    })

    -- Slide in
    toast.BackgroundTransparency = 0.15
    Tw(toast, { BackgroundTransparency = 0 }, 0.2)

    -- Shrink progress bar over duration
    Tw(prog, { Size = UDim2.new(0, 0, 1, 0) }, duration, Enum.EasingStyle.Linear)

    -- Slide out after duration
    task.delay(duration, function()
        Tw(toast, { BackgroundTransparency = 1 }, 0.3)
        task.delay(0.35, function()
            pcall(function() toast:Destroy() end)
        end)
    end)
end

-- ══════════════════════════════════════════════════════════════════
--  ADD CATEGORY
-- ══════════════════════════════════════════════════════════════════
--[[
    cfg fields:
        name   string  — display name
        icon   string  — single char / emoji shown in dot (optional)
]]
function ShadowUI:AddCategory(nameOrCfg, legacyIcon)
    local name, icon
    if type(nameOrCfg) == "table" then
        name = nameOrCfg.name or nameOrCfg[1] or "Category"
        icon = nameOrCfg.icon
    else
        name = nameOrCfg or "Category"
        icon = legacyIcon
    end

    local cat = { Name = name, _secs = {}, _open = false, _icon = icon }

    -- Row button
    local row = New("TextButton", {
        Parent               = self.SideScroll,
        BackgroundTransparency = 1,
        Size                 = UDim2.new(1, 0, 0, 38),
        Text                 = "",
        AutoButtonColor      = false,
        ZIndex               = 10,
    })
    Corner(6, row)
    Pad(5, 5, 0, 0, row)

    row.MouseEnter:Connect(function()
        if not cat._open then
            row.BackgroundTransparency = 0
            Tw(row, { BackgroundColor3 = T.RowHov }, 0.08)
        end
    end)
    row.MouseLeave:Connect(function()
        if not cat._open then row.BackgroundTransparency = 1 end
    end)

    -- Icon ring
    local ring = New("Frame", {
        Parent               = row,
        BackgroundTransparency = 1,
        Position             = UDim2.new(0, 5, 0.5, -7),
        Size                 = UDim2.new(0, 14, 0, 14),
        ZIndex               = 11,
    })
    Corner(7, ring)
    cat._icoStroke = Stroke(T.TxtSec, 1.2, ring)

    -- Dot (or icon char)
    if icon then
        local iconLbl = New("TextLabel", {
            Parent               = row,
            BackgroundTransparency = 1,
            Position             = UDim2.new(0, 5, 0.5, -8),
            Size                 = UDim2.new(0, 14, 0, 16),
            Font                 = Enum.Font.Gotham,
            Text                 = icon,
            TextColor3           = T.TxtSec,
            TextSize             = 10,
            TextXAlignment       = Enum.TextXAlignment.Center,
            ZIndex               = 12,
        })
        cat._dot = iconLbl
    else
        local dot = New("Frame", {
            Parent           = row,
            BackgroundColor3 = T.TxtSec,
            Position         = UDim2.new(0, 8, 0.5, -4),
            Size             = UDim2.new(0, 8, 0, 8),
            ZIndex           = 12,
            BorderSizePixel  = 0,
        })
        Corner(4, dot)
        cat._dot = dot
    end

    -- Category name label
    Lbl(row, name, 11, T.TxtPri, Enum.Font.GothamBold,
        Enum.TextXAlignment.Left,
        UDim2.new(0, 25, 0, 0), UDim2.new(1, -44, 1, 0), 11)

    -- Chevron
    cat._chev = Lbl(row, "›", 14, T.TxtDim, Enum.Font.GothamBold,
        Enum.TextXAlignment.Center,
        UDim2.new(1, -18, 0, 0), UDim2.new(0, 14, 1, 0), 11)

    -- Collapsible section frame
    local sf = New("Frame", {
        Parent               = self.SideScroll,
        BackgroundTransparency = 1,
        Size                 = UDim2.new(1, 0, 0, 0),
        ClipsDescendants     = true,
        Visible              = false,
        ZIndex               = 10,
    })
    local sl = ListL(sf)
    cat._row = row; cat._sf = sf; cat._sl = sl

    row.MouseButton1Click:Connect(function()
        cat._open = not cat._open
        if cat._open then
            sf.Visible = true
            sf.Size    = UDim2.new(1, 0, 0, sl.AbsoluteContentSize.Y)
            cat._chev.Text = "↓"
            row.BackgroundTransparency = 0
            Tw(row, { BackgroundColor3 = T.RowHov }, 0.08)
            cat._icoStroke.Color = T.Accent

            -- Tween dot / icon colour
            if cat._dot:IsA("Frame") then
                Tw(cat._dot, { BackgroundColor3 = T.Accent }, 0.12)
            else
                Tw(cat._dot, { TextColor3 = T.TxtAcc }, 0.12)
            end

            -- Auto-select first section
            if #cat._secs > 0 and not cat._secs[1]._active then
                task.defer(function()
                    cat._secs[1]._btn.MouseButton1Click:Fire()
                end)
            end
        else
            sf.Visible = false
            sf.Size    = UDim2.new(1, 0, 0, 0)
            cat._chev.Text = "›"
            row.BackgroundTransparency = 1
            cat._icoStroke.Color = T.TxtSec

            if cat._dot:IsA("Frame") then
                Tw(cat._dot, { BackgroundColor3 = T.TxtSec }, 0.12)
            else
                Tw(cat._dot, { TextColor3 = T.TxtSec }, 0.12)
            end
        end
    end)

    self._cats[#self._cats + 1] = cat
    return cat
end

-- ══════════════════════════════════════════════════════════════════
--  ADD SECTION
-- ══════════════════════════════════════════════════════════════════
function ShadowUI:AddSection(cat, name)
    local sec = {
        Name    = name,
        _cat    = cat,
        _active = false,
        _left   = {},
        _right  = {},
    }

    local btn = New("TextButton", {
        Parent               = cat._sf,
        BackgroundTransparency = 1,
        Size                 = UDim2.new(1, 0, 0, 29),
        Text                 = "",
        AutoButtonColor      = false,
        ZIndex               = 11,
    })
    Corner(5, btn)

    -- Active indicator bar
    local bar = New("Frame", {
        Parent           = btn,
        BackgroundColor3 = T.Accent,
        Position         = UDim2.new(0, 3, 0.18, 0),
        Size             = UDim2.new(0, 2, 0.64, 0),
        ZIndex           = 13,
        Visible          = false,
        BorderSizePixel  = 0,
    })
    Corner(1, bar)

    -- Diamond indicator
    local dia = New("Frame", {
        Parent           = btn,
        BackgroundColor3 = T.AccentDim,
        Position         = UDim2.new(0, 14, 0.5, -4),
        Size             = UDim2.new(0, 8, 0, 8),
        Rotation         = 45,
        ZIndex           = 12,
        BorderSizePixel  = 0,
    })

    local lbl = Lbl(btn, name, 11, T.TxtSec, Enum.Font.Gotham,
        Enum.TextXAlignment.Left,
        UDim2.new(0, 28, 0, 0), UDim2.new(1, -32, 1, 0), 12)

    sec._btn = btn; sec._bar = bar; sec._dia = dia; sec._lbl = lbl

    btn.MouseEnter:Connect(function()
        if not sec._active then
            btn.BackgroundTransparency = 0
            Tw(btn, { BackgroundColor3 = T.RowHov }, 0.08)
        end
    end)
    btn.MouseLeave:Connect(function()
        if not sec._active then btn.BackgroundTransparency = 1 end
    end)

    btn.MouseButton1Click:Connect(function()
        -- Deactivate current
        if self._active then
            local p = self._active
            p._active           = false
            p._lbl.TextColor3   = T.TxtSec
            Tw(p._dia, { BackgroundColor3 = T.AccentDim }, 0.1)
            p._bar.Visible      = false
            p._btn.BackgroundTransparency = 1
        end
        -- Activate new
        sec._active            = true
        Tw(lbl, { TextColor3 = T.TxtAcc }, 0.1)
        Tw(dia, { BackgroundColor3 = T.Accent }, 0.1)
        bar.Visible            = true
        btn.BackgroundColor3   = T.RowHov
        btn.BackgroundTransparency = 0
        self._active           = sec

        self:_Bread(cat.Name, name)
        self:_Render(sec)
    end)

    cat._secs[#cat._secs + 1] = sec
    task.defer(function()
        cat._sf.Size = UDim2.new(1, 0, 0, cat._sl.AbsoluteContentSize.Y + 2)
    end)
    return sec
end

-- ══════════════════════════════════════════════════════════════════
--  RENDER SECTION
-- ══════════════════════════════════════════════════════════════════
function ShadowUI:_Render(sec)
    CloseAnyDrop()
    self:_HideTooltip()

    -- Clear panels
    for _, pnl in ipairs({ self.LeftPanel, self.RightPanel }) do
        for _, c in ipairs(pnl:GetChildren()) do
            if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then
                c:Destroy()
            end
        end
    end

    -- Clear tab list
    for _, c in ipairs(self.TabList:GetChildren()) do
        if not c:IsA("UIListLayout") then c:Destroy() end
    end

    -- Rebuild tabs
    for _, s in ipairs(sec._cat._secs) do
        local act = (s == sec)
        local tab = New("Frame", {
            Parent               = self.TabList,
            BackgroundTransparency = 1,
            Size                 = UDim2.new(0, 86, 1, 0),
            ZIndex               = 7,
        })

        -- Active underline
        if act then
            local ul = New("Frame", {
                Parent           = tab,
                BackgroundColor3 = T.Accent,
                Position         = UDim2.new(0, 4, 1, -2),
                Size             = UDim2.new(1, -8, 0, 2),
                ZIndex           = 9,
                BorderSizePixel  = 0,
            })
            Corner(1, ul)
        end

        -- Diamond dot
        New("Frame", {
            Parent           = tab,
            BackgroundColor3 = act and T.Accent or T.AccentDim,
            Position         = UDim2.new(0, 8, 0.5, -3),
            Size             = UDim2.new(0, 6, 0, 6),
            Rotation         = 45,
            ZIndex           = 8,
            BorderSizePixel  = 0,
        })

        Lbl(tab, s.Name, 10,
            act and T.TxtAcc or T.TxtSec,
            act and Enum.Font.GothamBold or Enum.Font.Gotham,
            Enum.TextXAlignment.Left,
            UDim2.new(0, 19, 0, 0), UDim2.new(1, -19, 1, 0), 8)

        local th = New("TextButton", {
            Parent               = tab,
            BackgroundTransparency = 1,
            Size                 = UDim2.new(1, 0, 1, 0),
            Text                 = "",
            ZIndex               = 10,
        })
        local _s = s
        th.MouseButton1Click:Connect(function()
            _s._btn.MouseButton1Click:Fire()
        end)
    end

    -- Build controls
    for _, ctrl in ipairs(sec._left)  do self:_Build(self.LeftPanel,  ctrl) end
    for _, ctrl in ipairs(sec._right) do self:_Build(self.RightPanel, ctrl) end
end

-- ══════════════════════════════════════════════════════════════════
--  CONTROL BUILDER DISPATCHER
-- ══════════════════════════════════════════════════════════════════
function ShadowUI:_Build(panel, ctrl)
    if ctrl.type == "toggle"      then return self:_BToggle(panel, ctrl)   end
    if ctrl.type == "slider"      then return self:_BSlider(panel, ctrl)   end
    if ctrl.type == "dropdown"    then return self:_BDropdown(panel, ctrl) end
    if ctrl.type == "header"      then return self:_BHeader(panel, ctrl)   end
    if ctrl.type == "label"       then return self:_BLabel(panel, ctrl)    end
    if ctrl.type == "button"      then return self:_BButton(panel, ctrl)   end
    if ctrl.type == "textinput"   then return self:_BTextInput(panel, ctrl)end
    if ctrl.type == "colorpicker" then return self:_BColorPicker(panel, ctrl) end
    if ctrl.type == "keybind"     then return self:_BKeybind(panel, ctrl)  end
    if ctrl.type == "_custom"     then return ctrl._fn(panel)              end
end

-- ══════════════════════════════════════════════════════════════════
--  ① TOGGLE CONTROL
-- ══════════════════════════════════════════════════════════════════
--[[
    cfg fields (all optional):
        text        string   — label
        default     bool     — initial state
        description string   — tooltip on hover
        gear        bool     — show gear icon (calls ctrl.gearCallback)
        id          string   — key for config save/load
        callback    fn(bool)
]]
function ShadowUI:_BToggle(panel, ctrl)
    local val  = ctrl._val ~= nil and ctrl._val or (ctrl.default or false)
    local wrap = Row(panel, 38)
    Corner(5, wrap)

    -- Hover background
    local bg = New("Frame", {
        Parent               = wrap,
        BackgroundColor3     = T.RowHov,
        BackgroundTransparency = 1,
        Size                 = UDim2.new(1, 0, 1, 0),
        ZIndex               = 2,
        BorderSizePixel      = 0,
    })
    Corner(5, bg)

    local rOff = -36

    -- Gear button (optional)
    if ctrl.gear then
        local g = New("TextButton", {
            Parent               = wrap,
            BackgroundTransparency = 1,
            Position             = UDim2.new(1, -54, 0.5, -8),
            Size                 = UDim2.new(0, 16, 0, 16),
            Font                 = Enum.Font.Gotham,
            Text                 = "⚙",
            TextColor3           = T.TxtDim,
            TextSize             = 13,
            ZIndex               = 5,
        })
        g.MouseEnter:Connect(function() Tw(g, { TextColor3 = T.TxtAcc }, 0.08) end)
        g.MouseLeave:Connect(function() Tw(g, { TextColor3 = T.TxtDim }, 0.08) end)
        g.MouseButton1Click:Connect(function()
            if ctrl.gearCallback then ctrl.gearCallback() end
        end)
        rOff = -58
    end

    -- Label + optional subtext
    local textH = ctrl.description and 18 or 38
    if ctrl.description then
        wrap.Size = UDim2.new(1, 0, 0, 44)
        textH = 20
    end

    local txt = Lbl(wrap, ctrl.text or "Toggle", 11,
        val and T.TxtPri or T.TxtSec, Enum.Font.Gotham,
        Enum.TextXAlignment.Left,
        UDim2.new(0, 5, 0, ctrl.description and 4 or 0),
        UDim2.new(1, rOff, 0, 18), 4)

    if ctrl.description then
        Lbl(wrap, ctrl.description, 10, T.TxtDim, Enum.Font.Gotham,
            Enum.TextXAlignment.Left,
            UDim2.new(0, 5, 0, 22), UDim2.new(1, rOff, 0, 16), 4)
    end

    -- Toggle track
    local track = New("Frame", {
        Parent           = wrap,
        BackgroundColor3 = val and T.TogOn or T.TogOff,
        Position         = UDim2.new(1, -32, 0.5, -7),
        Size             = UDim2.new(0, 28, 0, 14),
        ZIndex           = 4,
        BorderSizePixel  = 0,
    })
    Corner(7, track)

    -- Thumb
    local thumb = New("Frame", {
        Parent           = track,
        BackgroundColor3 = T.White,
        Position         = val
            and UDim2.new(1, -13, 0.5, -5)
            or  UDim2.new(0,   2, 0.5, -5),
        Size             = UDim2.new(0, 10, 0, 10),
        ZIndex           = 5,
        BorderSizePixel  = 0,
    })
    Corner(5, thumb)

    -- Hit area
    local hit = New("TextButton", {
        Parent               = wrap,
        BackgroundTransparency = 1,
        Size                 = UDim2.new(1, 0, 1, 0),
        Text                 = "",
        ZIndex               = 7,
    })
    hit.MouseEnter:Connect(function() Tw(bg, { BackgroundTransparency = 0.82 }, 0.08) end)
    hit.MouseLeave:Connect(function() Tw(bg, { BackgroundTransparency = 1 }, 0.08) end)

    if ctrl.tooltip then self:_AttachTooltip(hit, ctrl.tooltip) end

    local function Set(v)
        val         = v
        ctrl._val   = v
        Tw(track, { BackgroundColor3 = v and T.TogOn or T.TogOff }, 0.14)
        Tw(thumb, {
            Position = v
                and UDim2.new(1, -13, 0.5, -5)
                or  UDim2.new(0,   2, 0.5, -5)
        }, 0.14)
        txt.TextColor3 = v and T.TxtPri or T.TxtSec
        if ctrl.callback then ctrl.callback(v) end
    end

    hit.MouseButton1Click:Connect(function() Set(not val) end)
    ctrl._setValue = Set
    ctrl._getValue = function() return val end
    return wrap
end

-- ══════════════════════════════════════════════════════════════════
--  ② SLIDER CONTROL
-- ══════════════════════════════════════════════════════════════════
--[[
    cfg fields:
        text        string
        min         number  (default 0)
        max         number  (default 100)
        step        number  (default 0 = continuous)
        format      string  (default "%.2f")
        default     number
        suffix      string  — appended to value display (e.g. "px", "%")
        description string  — tooltip
        id          string
        callback    fn(number)
]]
function ShadowUI:_BSlider(panel, ctrl)
    local mn   = ctrl.min    or 0
    local mx   = ctrl.max    or 100
    local stp  = ctrl.step   or 0
    local fmt  = ctrl.format or "%.2f"
    local sfx  = ctrl.suffix or ""
    local val  = ctrl._val ~= nil and ctrl._val or (ctrl.default or mn)

    local function Snap(v)
        if stp > 0 then v = math.round((v - mn) / stp) * stp + mn end
        return math.clamp(v, mn, mx)
    end

    local wrapH = ctrl.description and 60 or 54
    local wrap  = Row(panel, wrapH)
    Corner(5, wrap)

    -- Header row
    local hdr = New("Frame", {
        Parent               = wrap,
        BackgroundTransparency = 1,
        Position             = UDim2.new(0, 5, 0, 4),
        Size                 = UDim2.new(1, -10, 0, 16),
        ZIndex               = 3,
    })
    Lbl(hdr, ctrl.text or "Slider", 11, T.TxtSec, Enum.Font.Gotham,
        Enum.TextXAlignment.Left, nil, UDim2.new(0.65, 0, 1, 0), 3)
    local valLbl = Lbl(hdr,
        string.format(fmt, val) .. sfx, 11, T.TxtAcc, Enum.Font.GothamBold,
        Enum.TextXAlignment.Right,
        UDim2.new(0.65, 0, 0, 0), UDim2.new(0.35, 0, 1, 0), 3)

    if ctrl.description then
        Lbl(wrap, ctrl.description, 10, T.TxtDim, Enum.Font.Gotham,
            Enum.TextXAlignment.Left,
            UDim2.new(0, 5, 0, 20), UDim2.new(1, -10, 0, 14), 3)
    end

    -- Track holder
    local holder = New("Frame", {
        Parent               = wrap,
        BackgroundTransparency = 1,
        Position             = UDim2.new(0, 5, 0, ctrl.description and 38 or 28),
        Size                 = UDim2.new(1, -10, 0, 20),
        ZIndex               = 3,
    })

    local track = New("Frame", {
        Parent           = holder,
        BackgroundColor3 = T.SlTrack,
        Position         = UDim2.new(0, 0, 0.5, -3),
        Size             = UDim2.new(1, 0, 0, 6),
        ZIndex           = 4,
        BorderSizePixel  = 0,
    })
    Corner(3, track)

    local pct  = (val - mn) / (mx - mn)
    local fill = New("Frame", {
        Parent           = track,
        BackgroundColor3 = T.Accent,
        Size             = UDim2.new(pct, 0, 1, 0),
        ZIndex           = 5,
        BorderSizePixel  = 0,
    })
    Corner(3, fill)
    New("UIGradient", {
        Parent = fill,
        Color  = ColorSequence.new{
            ColorSequenceKeypoint.new(0, T.Accent),
            ColorSequenceKeypoint.new(1, T.AccentHi),
        },
    })

    local thumb = New("Frame", {
        Parent           = track,
        BackgroundColor3 = T.White,
        Position         = UDim2.new(pct, -7, 0.5, -7),
        Size             = UDim2.new(0, 14, 0, 14),
        ZIndex           = 6,
        BorderSizePixel  = 0,
    })
    Corner(7, thumb)
    Stroke(T.Accent, 1.5, thumb)

    local function Update(absX)
        local ap = track.AbsolutePosition.X
        local as = track.AbsoluteSize.X
        if as <= 0 then return end
        local p  = math.clamp((absX - ap) / as, 0, 1)
        local v  = Snap(mn + p * (mx - mn))
        val = v; ctrl._val = v
        local np = (v - mn) / (mx - mn)
        fill.Size      = UDim2.new(np, 0, 1, 0)
        thumb.Position = UDim2.new(np, -7, 0.5, -7)
        valLbl.Text    = string.format(fmt, v) .. sfx
        if ctrl.callback then ctrl.callback(v) end
    end

    local dragging = false
    local hitZ = New("TextButton", {
        Parent               = holder,
        BackgroundTransparency = 1,
        Size                 = UDim2.new(1, 0, 1, 0),
        Text                 = "",
        ZIndex               = 10,
    })

    if ctrl.tooltip then self:_AttachTooltip(hitZ, ctrl.tooltip) end

    hitZ.MouseButton1Down:Connect(function(x) dragging = true; Update(x) end)

    local mc = UIS.InputChanged:Connect(function(i)
        if not dragging then return end
        if i.UserInputType == Enum.UserInputType.MouseMovement
        or i.UserInputType == Enum.UserInputType.Touch then
            Update(i.Position.X)
        end
    end)
    local uc = UIS.InputEnded:Connect(function(i)
        if dragging and (
            i.UserInputType == Enum.UserInputType.MouseButton1 or
            i.UserInputType == Enum.UserInputType.Touch) then
            dragging = false
        end
    end)
    wrap.AncestryChanged:Connect(function()
        if not wrap.Parent then
            pcall(function() mc:Disconnect() end)
            pcall(function() uc:Disconnect() end)
        end
    end)

    ctrl._setValue = function(v)
        v = Snap(v); val = v; ctrl._val = v
        local np = (v - mn) / (mx - mn)
        fill.Size      = UDim2.new(np, 0, 1, 0)
        thumb.Position = UDim2.new(np, -7, 0.5, -7)
        valLbl.Text    = string.format(fmt, v) .. sfx
        if ctrl.callback then ctrl.callback(v) end
    end
    ctrl._getValue = function() return val end
    return wrap
end


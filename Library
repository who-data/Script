--  CONFIG TAB (built-in)
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
function ShadowUI:_BuildConfigTab()
    local T = self._T

    -- Add ⚙ Config category at end of sidebar
    local configCat = self:AddCategory("⚙ Config")
    local sec = self:AddSection(configCat, "Settings")

    -- We'll build the config panel manually (not via sec._left/right)
    -- Auto-click config section so it renders
    -- Actually we'll build it as a custom rendered section

    -- ── Theme Section ──
    self:SectionHeader(sec, "left", {text="UI Theme"})

    local themeNames = {}
    for k in pairs(THEMES) do themeNames[#themeNames+1] = k end
    table.sort(themeNames)

    local themeDrop = self:Dropdown(sec, "left", {
        text="Theme",
        options=themeNames,
        default=self._themeName,
        callback=function(v)
            self:ApplyTheme(v)
        end,
    })

    -- ── Config Section ──
    self:SectionHeader(sec, "right", {text="Configuration"})

    -- Config name display
    self:Label(sec, "right", {
        text="Active: default",
        color=T.TextAccent,
    })
    self._configLabel = sec._right[#sec._right]

    -- Config dropdown
    local cfgDrop = self:Dropdown(sec, "right", {
        text="Select Config",
        options=self:_GetConfigList(),
        default=self._activeConfig,
        callback=function(v)
            self._activeConfig = v
        end,
    })
    self._cfgDropRef = cfgDrop

    -- Buttons row
    self:SectionHeader(sec, "right", {text="Actions"})

    -- Save button
    self:_ConfigButton(sec, "right", "💾  Save Config", function()
        self:SaveConfig(self._activeConfig)
        self:_Notify("Config saved: "..self._activeConfig)
    end)

    -- Load button
    self:_ConfigButton(sec, "right", "📂  Load Config", function()
        if self._cfgDropRef then
            local name = self._cfgDropRef._getValue()
            self:LoadConfig(name)
            self:_Notify("Config loaded: "..name)
        end
    end)

    -- New button
    self:_ConfigButton(sec, "right", "✨  New Config", function()
        self:_PromptInput("Config Name", "Enter config name...", function(name)
            if name and name~="" then
                local clean = SanitizeName(name)
                self._activeConfig = clean
                self:SaveConfig(clean)
                self:_RefreshConfigDropdown()
                self:_Notify("Created: "..clean)
            end
        end)
    end)

    -- Delete button
    self:_ConfigButton(sec, "right", "🗑  Delete Config", function()
        local name = self._activeConfig
        if name == "default" then
            self:_Notify("Cannot delete default config!")
            return
        end
        local path = GetConfigPath(self._configTitle, name)
        pcall(delfile, path)
        self._activeConfig = "default"
        self:_RefreshConfigDropdown()
        self:_Notify("Deleted: "..name)
    end)

    -- Auto-load toggle
    local autoTog = self:Toggle(sec, "right", {
        text="Auto Load on Start",
        default=self._autoLoad,
        callback=function(v)
            self._autoLoad = v
        end,
    })
end

function ShadowUI:_ConfigButton(sec, side, text, callback)
    local T = self._T
    local cfg = {type="configbtn", text=text, callback=callback}
    local list = (side=="right") and sec._right or sec._left
    list[#list+1] = cfg
    if sec._active then
        local panel = (side=="right") and self.RightScroll or self.LeftScroll
        self:_BuildConfigBtn(panel, cfg)
    end
    return cfg
end


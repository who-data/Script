    local av=ins("Frame",{Size=UDim2.new(1,0,0,62),BackgroundTransparency=1,Parent=sb})
    local avbg=ins("Frame",{Size=UDim2.new(0,36,0,36),Position=UDim2.new(0,12,0.5,-18),

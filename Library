-- ══════════════════════════════════════════════
--  TOGGLE  — anima APENAS o Clip.Size
--  AnchorPoint 0.5,0.5 garante que o collapse
--  acontece a partir do centro, sem descentralizar.
-- ══════════════════════════════════════════════
function ShadowUI:_Toggle()
    self._visible = not self._visible
    if self._visible then
        self.Clip.Visible = true
        self.Clip.Size    = UDim2.new(0, 0, 0, H)   -- começa colapsado
        Tw(self.Clip, {Size=UDim2.new(0,W,0,H)},
            .24, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        self._floatLbl.Text = "◀"
    else
        Tw(self.Clip, {Size=UDim2.new(0,0,0,H)},
            .16, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
        task.delay(.18, function()
            if not self._visible then
                self.Clip.Visible = false
                self.Clip.Size    = UDim2.new(0,W,0,H)  -- restaura para próxima abertura
            end
        end)
        self._floatLbl.Text = "▶"
    end
end


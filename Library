local U = {}

function U.New(class, props, children)
    local inst = Instance.new(class)
    if props then
        for k, v in pairs(props) do
            if k ~= "Parent" then
                inst[k] = v
            end
        end
    end
    for _, ch in ipairs(children or {}) do ch.Parent = inst end
    if props and props.Parent then inst.Parent = props.Parent end
    return inst
end

function U.Corner(parent, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = r or CR
    c.Parent = parent
    return c
end

function U.Stroke(parent, color, thick, trans, mode)
    local s = Instance.new("UIStroke")
    s.Color       = color or Color3.fromRGB(50, 50, 70)
    s.Thickness   = thick or 1
    s.Transparency = trans or 0
    s.ApplyStrokeMode = mode or Enum.ApplyStrokeMode.Border
    s.Parent = parent
    return s
end

function U.Pad(parent, top, right, bot, left)
    local p = Instance.new("UIPadding")
    p.PaddingTop    = UDim.new(0, top   or 8)
    p.PaddingRight  = UDim.new(0, right or 8)
    p.PaddingBottom = UDim.new(0, bot   or 8)
    p.PaddingLeft   = UDim.new(0, left  or 8)
    p.Parent = parent
    return p
end

function U.List(parent, dir, spacing, ha, va, so)
    local l = Instance.new("UIListLayout")
    l.FillDirection       = dir     or Enum.FillDirection.Vertical
    l.Padding             = UDim.new(0, spacing or 6)
    l.HorizontalAlignment = ha      or Enum.HorizontalAlignment.Left
    l.VerticalAlignment   = va      or Enum.VerticalAlignment.Top
    l.SortOrder           = so      or Enum.SortOrder.LayoutOrder
    l.Parent = parent
    return l
end

function U.Gradient(parent, c0, c1, rot)
    local g = Instance.new("UIGradient")
    g.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, c0 or Color3.fromRGB(255,255,255)),
        ColorSequenceKeypoint.new(1, c1 or Color3.fromRGB(150,150,150)),
    })
    g.Rotation = rot or 90
    g.Parent = parent
    return g
end

function U.Scroll(frame)
    frame.ScrollBarThickness   = 4
    frame.ScrollBarImageColor3 = Color3.fromRGB(60, 60, 90)
    frame.ScrollingDirection   = Enum.ScrollingDirection.Y
    frame.BorderSizePixel      = 0
    frame.AutomaticCanvasSize  = Enum.AutomaticSize.Y
    frame.CanvasSize           = UDim2.new(0,0,0,0)
    frame.ScrollBarImageTransparency = 0
    return frame
end

function U.AutoCanvas(listParent, scroll, extraH)
    local layout = listParent:FindFirstChildOfClass("UIListLayout")
    if not layout then return end
    local function upd()
        scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + (extraH or 16))
    end
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(upd)
    task.defer(upd)
end

function U.Connect(bag, sig, fn)
    local c = sig:Connect(fn)
    table.insert(bag, c)
    return c
end

function U.Disconn(bag)
    for _, c in ipairs(bag) do
        if c and c.Connected then c:Disconnect() end
    end
    table.clear(bag)
end

function U.Clamp(v, lo, hi) return math.max(lo, math.min(hi, v)) end
function U.Round(n, step) return math.floor(n / step + 0.5) * step end

function U.MeasureText(text, size, font)
    return TextService:GetTextSize(text, size, font or Enum.Font.Gotham, Vector2.new(9999, 9999))
end

function U.GetViewport()
    return workspace.CurrentCamera.ViewportSize
end

function U.DeepCopy(t)
    if type(t) ~= "table" then return t end
    local c = {}
    for k, v in pairs(t) do c[k] = U.DeepCopy(v) end
    return c
end

function U.ColorToHex(c)
    return string.format("%02X%02X%02X",
        math.floor(c.R * 255),
        math.floor(c.G * 255),
        math.floor(c.B * 255))
end

function U.HexToColor(hex)
    hex = hex:gsub("#", "")
    if #hex ~= 6 then return nil end
    local r = tonumber(hex:sub(1,2), 16)
    local g = tonumber(hex:sub(3,4), 16)
    local b = tonumber(hex:sub(5,6), 16)
    if r and g and b then
        return Color3.fromRGB(r, g, b)
    end
    return nil
end


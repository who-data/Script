-- ──────────────────────────────────────────────
--  SLIDER  (CORRIGIDO)
-- ──────────────────────────────────────────────
function ShadowUI:_Slider(parent,ctrl)
    local mn=ctrl.min or 0; local mx=ctrl.max or 100
    local stp=ctrl.step or 0; local fmt=ctrl.format or "%.2f"
    local val=ctrl._val~=nil and ctrl._val or (ctrl.default or mn)
    local function Snap(v)
        if stp and stp>0 then v=math.round((v-mn)/stp)*stp+mn end
        return math.clamp(v,mn,mx)
    end
    local Wrap=MkRow(parent,44); Corn(4,Wrap)
    local TR=New("Frame",{Parent=Wrap,BackgroundTransparency=1,Position=UDim2.new(0,0,0,3),Size=UDim2.new(1,0,0,15),ZIndex=3})
    MkLbl(TR,ctrl.text or "Slider",11,T.TextSec,Enum.Font.Gotham,Enum.TextXAlignment.Left,nil,UDim2.new(0.68,0,1,0),3)
    local VL=MkLbl(TR,string.format(fmt,val),11,T.TextAccent,Enum.Font.GothamBold,Enum.TextXAlignment.Right,UDim2.new(0.68,0,0,0),UDim2.new(0.32,0,1,0),3)
    local Trk=New("Frame",{Parent=Wrap,BackgroundColor3=T.SliderTrack,Position=UDim2.new(0,0,0,26),Size=UDim2.new(1,0,0,4),ZIndex=3})
    Corn(2,Trk)
    local pct=(val-mn)/(mx-mn)
    local Fill=New("Frame",{Parent=Trk,BackgroundColor3=T.SliderFill,Size=UDim2.new(pct,0,1,0),ZIndex=4}); Corn(2,Fill)
    local Th=New("Frame",{Parent=Trk,BackgroundColor3=T.SliderThumb,Position=UDim2.new(pct,-6,0.5,-6),Size=UDim2.new(0,12,0,12),ZIndex=5}); Corn(6,Th); Stro(T.Accent,1.5,Th)
    local function Set(v)
        v=Snap(v); val=v; ctrl._val=v
        local p=(v-mn)/(mx-mn)
        Fill.Size=UDim2.new(p,0,1,0); Th.Position=UDim2.new(p,-6,0.5,-6); VL.Text=string.format(fmt,v)
        if ctrl.callback then ctrl.callback(v) end
    end
    -- Drag corrigido: conexões locais criadas/destruidas por drag
    local dragging=false; local cc, ce
    local HitZone=New("TextButton",{Parent=Trk,BackgroundTransparency=1,Position=UDim2.new(0,0,0.5,-10),Size=UDim2.new(1,0,0,20),Text="",ZIndex=8})
    local function GetPct(absX)
        local ap=Trk.AbsolutePosition.X; local as=Trk.AbsoluteSize.X
        if as==0 then return 0 end
        return math.clamp((absX-ap)/as,0,1)
    end
    HitZone.MouseButton1Down:Connect(function(x)
        dragging=true; Set(mn+GetPct(x)*(mx-mn)); Tw(Th,{Size=UDim2.new(0,14,0,14)},.06)
        cc=UserInputService.InputChanged:Connect(function(i)
            if dragging and i.UserInputType==Enum.UserInputType.MouseMovement then
                Set(mn+GetPct(i.Position.X)*(mx-mn))
            end
        end)
        ce=UserInputService.InputEnded:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 then
                dragging=false; Tw(Th,{Size=UDim2.new(0,12,0,12)},.06)
                if cc then cc:Disconnect(); cc=nil end
                if ce then ce:Disconnect(); ce=nil end
            end
        end)
    end)
    ctrl._setValue=Set; ctrl._getValue=function() return val end
    return Wrap
end


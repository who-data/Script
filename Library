        Font                 = Enum.Font.Gotham,
        Text                 = selected,
        TextColor3           = Theme.TextPrimary,
        TextSize             = 11,
        TextXAlignment       = Enum.TextXAlignment.Left,
        TextTruncate         = Enum.TextTruncate.AtEnd,
    })
    local Arrow = Create("TextLabel", {
        Parent               = DropBtn,
        BackgroundTransparency = 1,
        Position             = UDim2.new(1, -16, 0, 0),
        Size                 = UDim2.new(0, 12, 1, 0),
        Font                 = Enum.Font.GothamBold,
        Text                 = "▾",
        TextColor3           = Theme.TextSecondary,
        TextSize             = 10,
    })

    -- Dropdown list (overlay)
    local DropList = Create("Frame", {
        Parent           = self.Window,
        BackgroundColor3 = Theme.Dropdown,
        BorderSizePixel  = 0,
        Visible          = false,
        ZIndex           = 10,
        Size             = UDim2.new(0, 140, 0, 0),
    })
    RoundCorner(DropList, 8)
    Create("UIStroke", { Color = Theme.BorderGlow, Thickness = 1, Parent = DropList })

    local DropListLayout = Create("UIListLayout", {
        Parent    = DropList,
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding   = UDim.new(0, 1),
    })
    Create("UIPadding", {
        PaddingTop    = UDim.new(0, 4),
        PaddingBottom = UDim.new(0, 4),
        PaddingLeft   = UDim.new(0, 4),
        PaddingRight  = UDim.new(0, 4),
        Parent        = DropList,
    })

    local function CloseDropdown()
        isOpen = false
        DropList.Visible = false
        Tween(Arrow, { TextColor3 = Theme.TextSecondary }, 0.1)
        Arrow.Text = "▾"
    end

    local function RebuildOptions()
        for _, c in ipairs(DropList:GetChildren()) do
            if c:IsA("TextButton") then c:Destroy() end
        end
        for _, opt in ipairs(options) do
            local Item = Create("TextButton", {
                Parent           = DropList,
                BackgroundColor3 = Theme.Dropdown,
                BorderSizePixel  = 0,
                Size             = UDim2.new(1, 0, 0, 26),
                Font             = Enum.Font.Gotham,
                Text             = opt,
                TextColor3       = opt == selected and Theme.AccentColor or Theme.TextPrimary,
                TextSize         = 11,
                AutoButtonColor  = false,
                ZIndex           = 11,
            })
            RoundCorner(Item, 5)
            Item.MouseEnter:Connect(function() Tween(Item, { BackgroundColor3 = Theme.DropdownHover }, 0.1) end)
            Item.MouseLeave:Connect(function() Tween(Item, { BackgroundColor3 = Theme.Dropdown }, 0.1) end)
            Item.MouseButton1Click:Connect(function()
                selected     = opt
                SelLabel.Text = opt
                CloseDropdown()
                if ctrl.callback then ctrl.callback(selected) end
                RebuildOptions()
            end)
        end
        local h = DropListLayout.AbsoluteContentSize.Y + 10
        DropList.Size = UDim2.new(0, 140, 0, h)
    end

    DropBtn.MouseButton1Click:Connect(function()
        if isOpen then
            CloseDropdown()
        else
            isOpen = true
            RebuildOptions()
            local abs = DropBtn.AbsolutePosition
            local win = self.Window.AbsolutePosition
            DropList.Position = UDim2.new(0, abs.X - win.X, 0, abs.Y - win.Y + DropBtn.AbsoluteSize.Y + 2)
            DropList.Visible  = true
            Arrow.Text        = "▴"
            Tween(Arrow, { TextColor3 = Theme.AccentColor }, 0.1)
        end
    end)

    DropBtn.MouseEnter:Connect(function() Tween(DropBtn, { BackgroundColor3 = Theme.DropdownHover }, 0.1) end)
    DropBtn.MouseLeave:Connect(function() Tween(DropBtn, { BackgroundColor3 = Theme.Dropdown }, 0.1) end)

    ctrl._value = function() return selected end
    ctrl._set   = function(v) selected = v; SelLabel.Text = v; RebuildOptions() end
end


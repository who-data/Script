function Tab.new(sidebarList, contentArea, opts, comps, onSelect)
    local self = setmetatable({
        _comps    = comps,
        _sections = {},
        Name      = opts.Name or "Tab",
        Active    = false,
        LayoutOrder = opts.LayoutOrder or 1,
    }, Tab)

    local th   = comps.theme
    local anim = comps.anim

    -- Sidebar button
    local btn = U.New("Frame", {
        Name = "Tab_" .. self.Name,
        Size = UDim2.new(1, 0, 0, 38),
        BackgroundColor3 = th:Get("BG2"),
        BorderSizePixel = 0,
        LayoutOrder = self.LayoutOrder,
        Parent = sidebarList,
    })
    U.Corner(btn, CR_SM)

    -- Active indicator bar (left edge)
    local indicator = U.New("Frame", {
        Name = "Indicator",
        Size = UDim2.new(0, 3, 0, 0),
        Position = UDim2.new(0, 0, 0.5, 0),
        AnchorPoint = Vector2.new(0, 0.5),
        BackgroundColor3 = th:Get("Accent"),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ZIndex = 2,
        Parent = btn,
    })
    U.Corner(indicator, UDim.new(1, 0))
    U.Gradient(indicator, th:Get("AccentHi"), th:Get("AccentLo"), 90)

    local iconLbl
    if opts.Icon and opts.Icon ~= "" then
        iconLbl = U.New("TextLabel", {
            Name = "Icon",
            Size = UDim2.new(0, 22, 1, 0),
            Position = UDim2.new(0, 10, 0, 0),
            BackgroundTransparency = 1,
            Text = opts.Icon,
            TextColor3 = th:Get("TextMuted"),
            TextSize = 14,
            Font = Enum.Font.Gotham,
            ZIndex = 2,
            Parent = btn,
        })
    end

    local nameOffset = opts.Icon and 36 or 10
    local tabLbl = U.New("TextLabel", {
        Name = "Label",
        Size = UDim2.new(1, -(nameOffset + 6), 1, 0),
        Position = UDim2.new(0, nameOffset, 0, 0),
        BackgroundTransparency = 1,
        Text = self.Name,
        TextColor3 = th:Get("TextMuted"),
        TextSize = 12,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 2,
        Parent = btn,
    })

    -- Content scroll frame
    local scroll = U.New("ScrollingFrame", {
        Name = "TabScroll_" .. self.Name,
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Visible = false,
        ZIndex = Z.CONTENT,
        ScrollBarThickness = 4,
        ScrollBarImageColor3 = th:Get("Scrollbar"),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        CanvasSize = UDim2.new(0,0,0,0),
        ScrollingDirection = Enum.ScrollingDirection.Y,
        Parent = contentArea,
    })

    local innerList = U.New("Frame", {
        Name = "InnerList",
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        Parent = scroll,
    })
    U.List(innerList, Enum.FillDirection.Vertical, 8)
    U.Pad(innerList, 10, 10, 14, 10)

    -- Click
    btn.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            if onSelect then pcall(onSelect, self) end
        end
    end)
    btn.MouseEnter:Connect(function()
        if not self.Active then
            anim:Play(btn, {BackgroundColor3 = th:Get("BG3")}, TI.Fast)
            anim:Play(tabLbl, {TextColor3 = th:Get("TextLo")}, TI.Fast)
            if iconLbl then anim:Play(iconLbl, {TextColor3 = th:Get("TextLo")}, TI.Fast) end
        end
    end)
    btn.MouseLeave:Connect(function()
        if not self.Active then
            anim:Play(btn, {BackgroundColor3 = th:Get("BG2")}, TI.Fast)
            anim:Play(tabLbl, {TextColor3 = th:Get("TextMuted")}, TI.Fast)
            if iconLbl then anim:Play(iconLbl, {TextColor3 = th:Get("TextMuted")}, TI.Fast) end
        end
    end)

    self.Btn       = btn
    self.Label     = tabLbl
    self.Icon      = iconLbl
    self.Indicator = indicator
    self.Scroll    = scroll
    self.InnerList = innerList
    return self
end

function Tab:SetActive(state)
    self.Active = state
    local th   = self._comps.theme
    local anim = self._comps.anim
    if state then
        anim:Play(self.Btn, {BackgroundColor3 = th:Get("BG4")}, TI.Fast)
        anim:Play(self.Label, {TextColor3 = th:Get("TextHi")}, TI.Fast)
        anim:Play(self.Indicator, {
            BackgroundTransparency = 0,
            Size = UDim2.new(0, 3, 0.55, 0),
        }, TI.Spring)
        self.Label.Font = Enum.Font.GothamBold
        if self.Icon then anim:Play(self.Icon, {TextColor3 = th:Get("AccentHi")}, TI.Fast) end
        self.Scroll.Visible = true
    else
        anim:Play(self.Btn, {BackgroundColor3 = th:Get("BG2")}, TI.Fast)
        anim:Play(self.Label, {TextColor3 = th:Get("TextMuted")}, TI.Fast)
        anim:Play(self.Indicator, {BackgroundTransparency = 1, Size = UDim2.new(0, 3, 0, 0)}, TI.Fast)
        self.Label.Font = Enum.Font.Gotham
        if self.Icon then anim:Play(self.Icon, {TextColor3 = th:Get("TextMuted")}, TI.Fast) end
        self.Scroll.Visible = false
    end
end

function Tab:CreateSection(opts)
    opts = (type(opts) == "string") and {Name = opts} or opts
    opts.LayoutOrder = #self._sections + 1
    local sec = Section.new(self.InnerList, opts, self._comps)
    table.insert(self._sections, sec)
    return sec
end


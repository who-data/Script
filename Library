    ins("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-1),BackgroundColor3=C.Border,BorderSizePixel=0,ZIndex=10,Parent=top})

    local dot=ins("Frame",{Size=UDim2.new(0,8,0,8),Position=UDim2.new(0,14,0.5,-4),
        BackgroundColor3=C.Accent,BorderSizePixel=0,ZIndex=11,Parent=top}); corner(dot,UDim.new(1,0))

    ins("TextLabel",{Size=UDim2.new(0,170,1,0),Position=UDim2.new(0,28,0,0),BackgroundTransparency=1,Text=tag,
        TextColor3=C.TextDim,Font=C.Fb,TextSize=11,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=11,Parent=top})

    ins("TextLabel",{Size=UDim2.new(0,260,1,0),Position=UDim2.new(0.5,-130,0,0),BackgroundTransparency=1,
        Text=title.."  "..sub,TextColor3=C.Text,Font=C.Fbold,TextSize=13,ZIndex=11,Parent=top})
    ins("TextLabel",{Size=UDim2.new(0,260,1,0),Position=UDim2.new(0.5,-130,0,0),BackgroundTransparency=1,
        Text=string.rep(" ",#title+2)..sub,TextColor3=C.Accent,Font=C.Fbold,TextSize=13,ZIndex=12,Parent=top})

    for i,d in ipairs({{"–","min"},{"□","res"},{"×","cls"}}) do

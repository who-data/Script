    hit.MouseEnter:Connect(function()
        Tw(btnFrame, {
            BackgroundColor3       = hoverCol,
            BackgroundTransparency = 0,
        }, 0.1)
    end)
    hit.MouseLeave:Connect(function()
        Tw(btnFrame, {
            BackgroundColor3       = bgCol,
            BackgroundTransparency = style == "ghost" and 1 or 0,
        }, 0.1)
    end)
    hit.MouseButton1Click:Connect(function()
        -- Click flash
        Tw(btnFrame, { BackgroundColor3 = T.AccentHi }, 0.06)
        task.delay(0.1, function()
            Tw(btnFrame, { BackgroundColor3 = hoverCol }, 0.1)
        end)
        if ctrl.callback then ctrl.callback() end
    end)

    if ctrl.tooltip then self:_AttachTooltip(hit, ctrl.tooltip) end

    ctrl._getValue = function() return nil end
    ctrl._setValue = function() end
    return wrap
end


-- ──────────────────────────────────────────────
--  ABA CONFIG
-- ──────────────────────────────────────────────
function ShadowUI:_BuildConfigTab()
    local cat=self:AddCategory("⚙  Config")
    local sec=self:AddSection(cat,"Settings")
    local function AddCtrl(s,side,cfg)
        local list=(side=="right") and s._right or s._left
        list[#list+1]=cfg
        if s._active then
            local panel=(side=="right") and self.RightScroll or self.LeftScroll
            self:_Build(panel,cfg)
        end
        return cfg
    end
    -- Tema
    local themeNames={}; for k,_ in pairs(THEMES) do themeNames[#themeNames+1]=k end; table.sort(themeNames)
    AddCtrl(sec,"left",{type="dropdown",text="UI Theme",options=themeNames,_val=self._currentTheme,callback=function(v) self._currentTheme=v; self:_ApplyTheme(v) end})
    -- Auto Load
    AddCtrl(sec,"left",{type="toggle",text="Auto Load Config",_val=self._autoLoad,callback=function(v) self._autoLoad=v end})
    AddCtrl(sec,"left",{type="header",text="Save Slots"})
    -- Config slot dropdown
    local configDropCfg={type="dropdown",text="Config Slot",options=SaveSystem.List(),_val=self._currentConfig,callback=function(v) self._currentConfig=v end}
    self._configDropCfg=configDropCfg
    AddCtrl(sec,"right",configDropCfg)
    AddCtrl(sec,"right",{type="header",text="Actions"})
    AddCtrl(sec,"right",{type="btnrow"})
end

-- ──────────────────────────────────────────────
--  CONFIG DATA
-- ──────────────────────────────────────────────
function ShadowUI:_CollectConfigData()
    local data={theme=self._currentTheme,autoLoad=self._autoLoad,controls={}}
    for _,ctrl in ipairs(self._controls) do
        if ctrl.id and ctrl._getValue then data.controls[ctrl.id]=ctrl._getValue() end
    end
    return data
end

function ShadowUI:_ApplyConfigData(data)
    if not data then return end
    if data.theme then self:_ApplyTheme(data.theme) end
    if data.autoLoad~=nil then self._autoLoad=data.autoLoad end
    if data.controls then
        for _,ctrl in ipairs(self._controls) do
            if ctrl.id and data.controls[ctrl.id]~=nil and ctrl._setValue then
                ctrl._setValue(data.controls[ctrl.id])
            end
        end
    end
end

-- ──────────────────────────────────────────────
--  APLICAR TEMA
-- ──────────────────────────────────────────────
function ShadowUI:_ApplyTheme(name)
    local theme=THEMES[name]; if not theme then return end
    self._currentTheme=name
    for k,v in pairs(theme) do T[k]=v end
    pcall(function()
        self.Win.BackgroundColor3=T.Bg
        self.Header.BackgroundColor3=T.Header
        self.Sidebar.BackgroundColor3=T.Sidebar
        self.Content.BackgroundColor3=T.Bg
        self.TabBar.BackgroundColor3=T.SubHeader
        self.ToggleBtn.BackgroundColor3=T.Accent
        if self._accentLine then self._accentLine.BackgroundColor3=T.Accent end
    end)
    if self._activeSec then self:_Render(self._activeSec) end
end


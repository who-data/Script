local Config = {}
Config.__index = Config

function Config.new(folderName)
    local self = setmetatable({
        _folder = folderName or "NexusUI_v3",
        _flags  = {},
    }, Config)
    pcall(function()
        if not isfolder(self._folder) then makefolder(self._folder) end
    end)
    return self
end

function Config:RegisterFlag(flag, default, setter)
    self._flags[flag] = { value = default, default = default, setter = setter }
end

function Config:SetFlag(flag, val)
    if self._flags[flag] then self._flags[flag].value = val end
end

function Config:GetFlag(flag)
    return self._flags[flag] and self._flags[flag].value
end

function Config:Save(name)
    name = name or "default"
    local data = {}
    for k, v in pairs(self._flags) do data[k] = v.value end
    pcall(function()
        writefile(self._folder .. "/" .. name .. ".json", HttpService:JSONEncode(data))
    end)
end

function Config:Load(name)
    name = name or "default"
    local ok, data = pcall(function()
        return HttpService:JSONDecode(readfile(self._folder .. "/" .. name .. ".json"))
    end)
    if not ok or not data then return false end
    for k, v in pairs(data) do
        if self._flags[k] then
            self._flags[k].value = v
            if self._flags[k].setter then pcall(self._flags[k].setter, v) end
        end
    end
    return true
end

function Config:List()
    local list = {}
    pcall(function()
        for _, f in ipairs(listfiles(self._folder)) do
            local n = f:match("([^/\\]+)%.json$")
            if n then table.insert(list, n) end
        end
    end)
    return list
end

function Config:Delete(name)
    pcall(function() delfile(self._folder .. "/" .. name .. ".json") end)
end


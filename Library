        Position = UDim2.new(1, 0, 0, 0),
        BackgroundColor3 = th:Get("Border"),
        BorderSizePixel = 0,
        ZIndex = Z.SIDEBAR + 1,
        Parent = sidebarBg,
    })

    local sidebarScroll = U.New("ScrollingFrame", {
        Name = "SidebarScroll",
        Size = UDim2.new(1, -1, 1, 0),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ZIndex = Z.SIDEBAR + 1,
        ScrollBarThickness = 0,
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        CanvasSize = UDim2.new(0,0,0,0),
        ScrollingDirection = Enum.ScrollingDirection.Y,
        Parent = sidebarBg,
    })

    local sidebarList = U.New("Frame", {
        Name = "SidebarList",
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        ZIndex = Z.SIDEBAR + 1,
        Parent = sidebarScroll,
    })
    U.List(sidebarList, Enum.FillDirection.Vertical, 3)
    U.Pad(sidebarList, 8, 6, 8, 6)

    -- Sidebar header label
    U.New("TextLabel", {
        Size = UDim2.new(1, 0, 0, 18),
        BackgroundTransparency = 1,
        Text = "MODULES",
        TextColor3 = th:Get("TextMuted"),
        TextSize = 9,
        Font = Enum.Font.GothamBold,
        LayoutOrder = 0,
        Parent = sidebarList,
    })

    -- Content area
    local contentArea = U.New("Frame", {
        Name = "ContentArea",
        Size = UDim2.new(1, -(SIDEBAR_W + 1), 1, 0),
        Position = UDim2.new(0, SIDEBAR_W + 1, 0, 0),
        BackgroundTransparency = 1,
        ZIndex = Z.CONTENT,
        ClipsDescendants = true,
        Parent = body,
    })

    -- ‚ĒÄ‚ĒÄ DRAG SYSTEM ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    do
        local dragging, dragStart, rootStart = false, nil, nil
        topBar.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging  = true
                dragStart = inp.Position
                rootStart = root.Position
            end
        end)
        topBar.InputEnded:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end)
        UserInputService.InputChanged:Connect(function(inp)
            if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
                local d = inp.Position - dragStart
                root.Position = UDim2.new(
                    rootStart.X.Scale, rootStart.X.Offset + d.X,
                    rootStart.Y.Scale, rootStart.Y.Offset + d.Y)
            end
        end)
    end

    -- ‚ĒÄ‚ĒÄ OPEN ANIMATION ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    root.BackgroundTransparency = 1
    root.Size = UDim2.new(0, size.X.Offset * 0.6, 0, size.Y.Offset * 0.6)
    root.Position = UDim2.new(pos.X.Scale, pos.X.Offset + size.X.Offset * 0.2,
                              pos.Y.Scale, pos.Y.Offset + size.Y.Offset * 0.2)
    task.defer(function()
        anim:Play(root, {
            Size = size,
            Position = pos,
            BackgroundTransparency = 0,
        }, TI.Spring)
    end)

    -- ‚ĒÄ‚ĒÄ TOGGLE KEY ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    if toggleKey then
        lib._input:Bind(toggleKey, function()
            self._visible = not self._visible
            root.Visible = self._visible
        end)
    end

    self._sg          = sg
    self._root        = root
    self._sidebarList = sidebarList
    self._contentArea = contentArea
    self._size        = size
    self._pos         = pos
    return self
end

function Window:CreateTab(opts)
    opts = (type(opts) == "string") and {Name = opts} or opts
    opts.LayoutOrder = #self._tabs + 1

    local tab = Tab.new(
        self._sidebarList,
        self._contentArea,
        opts,
        self._lib._comps,
        function(t) self:_selectTab(t) end
    )

    table.insert(self._tabs, tab)
    if #self._tabs == 1 then self:_selectTab(tab) end
    return tab
end

function Window:_selectTab(tab)
    if self._active == tab then return end
    if self._active then self._active:SetActive(false) end
    self._active = tab
    tab:SetActive(true)
end

function Window:Toggle()
    self._visible = not self._visible
    self._root.Visible = self._visible
end

function Window:Destroy()
    local anim = self._lib._anim
    anim:Play(self._root, {Size=UDim2.new(0,0,0,0), BackgroundTransparency=1}, TI.Medium)
    task.delay(0.26, function()
        if self._sg and self._sg.Parent then self._sg:Destroy() end
    end)
end


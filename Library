function ShadowUI:_Label(parent, ctrl)
    local row = MkRow(parent, 20)
    Lbl(row, ctrl.text or "", 11, ctrl.color or T.TextSec, Enum.Font.Gotham,
        Enum.TextXAlignment.Left, nil, UDim2.new(1,0,1,0), 3)
    return row
end

-- ══════════════════════════════════════════════
--  PUBLIC API
-- ══════════════════════════════════════════════
local function Add(sec, side, cfg)
    local list = (side=="right") and sec._right or sec._left
    list[#list+1]=cfg
    if sec._active then
        local ui    = sec._ui
        local panel = (side=="right") and ui.RightScroll or ui.LeftScroll
        ui:_Build(panel, cfg)
    end
    return cfg
end

function ShadowUI:Toggle(sec, side, cfg)
    cfg=cfg or {}; cfg.type="toggle";   return Add(sec,side,cfg) end
function ShadowUI:Slider(sec, side, cfg)
    cfg=cfg or {}; cfg.type="slider";   return Add(sec,side,cfg) end
function ShadowUI:Dropdown(sec, side, cfg)
    cfg=cfg or {}; cfg.type="dropdown"; return Add(sec,side,cfg) end
function ShadowUI:SectionHeader(sec, side, cfg)
    cfg=cfg or {}; cfg.type="header";   return Add(sec,side,cfg) end
function ShadowUI:Label(sec, side, cfg)
    cfg=cfg or {}; cfg.type="label";    return Add(sec,side,cfg) end

function ShadowUI:BindToggleKey(key)
    UserInputService.InputBegan:Connect(function(i,gpe)
        if gpe then return end
        if i.KeyCode==key then
            self._visible=not self._visible
            self.Win.Visible=self._visible
        end
    end)
end

function ShadowUI:Destroy() self.Gui:Destroy() end

-- ══════════════════════════════════════════════
return ShadowUI
-- ══════════════════════════════════════════════

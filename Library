        Text="",TextColor3=C.TextAcc,Font=C.Fbold,TextSize=11,
        TextXAlignment=Enum.TextXAlignment.Left,LetterSpacing=2,Parent=th})
    ins("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-1),BackgroundColor3=C.Border,BorderSizePixel=0,Parent=th})

    self._tabList=tabList; self._ca=ca; self._ttl=ttl
    return self
end

function Win:AddTab(name,icon)
    local scroll=ins("ScrollingFrame",{
        Size=UDim2.new(1,0,1,-36),Position=UDim2.new(0,0,0,36),
        BackgroundTransparency=1,BorderSizePixel=0,
        ScrollBarThickness=3,ScrollBarImageColor3=C.Accent,
        AutomaticCanvasSize=Enum.AutomaticSize.Y,
        CanvasSize=UDim2.new(0,0,0,0),
        Visible=false,Parent=self._ca,
    })
    pad(scroll,8,10,12,14)
    vlist(scroll,8)

    local first=#self._tabs==0
    local tbtn=ins("TextButton",{Size=UDim2.new(1,0,0,36),BackgroundTransparency=1,Text="",AutoButtonColor=false,Parent=self._tabList})
    local bar=ins("Frame",{Size=first and UDim2.new(0,2,0.65,0) or UDim2.new(0,0,0.65,0),
        Position=UDim2.new(0,0,0.175,0),BackgroundColor3=C.Accent,BorderSizePixel=0,Parent=tbtn})
    local ic=ins("TextLabel",{Size=UDim2.new(0,22,1,0),Position=UDim2.new(0,14,0,0),BackgroundTransparency=1,
        Text=icon or "",TextColor3=first and C.TextAcc or C.TextSub,Font=C.Fb,TextSize=14,Parent=tbtn})
    local nm=ins("TextLabel",{Size=UDim2.new(1,-40,1,0),Position=UDim2.new(0,38,0,0),BackgroundTransparency=1,
        Text=name,TextColor3=first and C.TextAcc or C.TextSub,Font=C.Fsemi,TextSize=12,
        TextXAlignment=Enum.TextXAlignment.Left,Parent=tbtn})
    local hov=ins("Frame",{Size=UDim2.new(1,0,1,0),BackgroundColor3=C.Accent,BackgroundTransparency=1,ZIndex=0,Parent=tbtn})

    local tabObj=Tab.new(scroll)
    if first then scroll.Visible=true; self._active=tabObj; self._ttl.Text=name:upper() end

    tbtn.MouseEnter:Connect(function() if self._active~=tabObj then tw(hov,{BackgroundTransparency=0.92}) end end)
    tbtn.MouseLeave:Connect(function() tw(hov,{BackgroundTransparency=1}) end)
    tbtn.MouseButton1Click:Connect(function()
        if self._active==tabObj then return end
        for _,t in ipairs(self._tabs) do
            if t.obj==self._active then
                t.obj._scroll.Visible=false
                tw(t.bar,{Size=UDim2.new(0,0,0.65,0)}); tw(t.ic,{TextColor3=C.TextSub}); tw(t.nm,{TextColor3=C.TextSub})
                break
            end
        end
        self._active=tabObj; scroll.Visible=true; self._ttl.Text=name:upper()
        tw(bar,{Size=UDim2.new(0,2,0.65,0)}); tw(ic,{TextColor3=C.TextAcc}); tw(nm,{TextColor3=C.TextAcc}); tw(hov,{BackgroundTransparency=1})
    end)

    table.insert(self._tabs,{obj=tabObj,bar=bar,ic=ic,nm=nm})
    return tabObj
end

function Win:Destroy() self._gui:Destroy() end
function Win:Toggle()
    self._min=not self._min
    tw(self._main,{Size=UDim2.new(0,self._W,0,self._min and 36 or self._H)},0.2)
end

function DB:CreateWindow(opts) return Win.new(opts) end
function DB:SetTheme(t) for k,v in pairs(t) do C[k]=v end end

return DB

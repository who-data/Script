--  CONSTRUCTOR
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
function ShadowUI.new(config)
    config = config or {}
    local self      = setmetatable({}, ShadowUI)
    self.Title      = config.Title    or "Shadow UI"
    self.Subtitle   = config.Subtitle or "Welcome Back"
    self.Username   = config.Username or LocalPlayer.Name
    self.Expiry     = config.Expiry   or "∞"
    self._sidebar   = {}
    self._visible   = true
    self._activeSec = nil
    self._controls  = {}   -- all registered controls for save/load

    -- Theme setup
    self._themeName = config.Theme or "Dark"
    self._T         = THEMES[self._themeName] or THEMES["Dark"]

    -- Config state
    self._configTitle  = self.Title
    self._activeConfig = "default"
    self._autoLoad     = config.AutoLoad ~= false -- default true

    -- Show splash then build UI
    local accentCol = self._T.Accent
    CreateSplash(self.Title, self.Subtitle..", "..self.Username, accentCol, function()
        self:_Build()
        -- Auto-load after build
        if self._autoLoad then
            local meta = SafeRead(GetMetaPath(self._configTitle))
            if meta then
                local ok, data = pcall(HttpService.JSONDecode, HttpService, meta)
                if ok and data.lastConfig then
                    self:LoadConfig(data.lastConfig)
                end
            end
        end
    end)

    return self
end


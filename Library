--  SAVE SYSTEM
-- ──────────────────────────────────────────────
local CONFIG_FOLDER = "ShadowUI_Configs"
local SaveSystem = {}

function SaveSystem.EnsureFolder()
    if not isfolder then return false end
    if not isfolder(CONFIG_FOLDER) then makefolder(CONFIG_FOLDER) end
    return true
end

function SaveSystem.List()
    local list = {"default"}
    if not isfolder then return list end
    SaveSystem.EnsureFolder()
    pcall(function()
        for _,f in ipairs(listfiles(CONFIG_FOLDER)) do
            local name = f:match("([^/\\]+)%.json$")
            if name and name ~= "default" then list[#list+1]=name end
        end
    end)
    return list
end

function SaveSystem.Load(name)
    if not readfile then return nil end
    SaveSystem.EnsureFolder()
    local ok, data = pcall(function()
        return HttpService:JSONDecode(readfile(CONFIG_FOLDER.."/"..name..".json"))
    end)
    return ok and data or nil
end

function SaveSystem.Save(name, data)
    if not writefile then return false end
    SaveSystem.EnsureFolder()
    return pcall(function()
        writefile(CONFIG_FOLDER.."/"..name..".json", HttpService:JSONEncode(data))
    end)
end

function SaveSystem.Delete(name)
    if name=="default" or not delfile then return false end
    return pcall(function() delfile(CONFIG_FOLDER.."/"..name..".json") end)
end


-- =========================================================
--  UTIL
-- =========================================================
local function New(cls, props, kids)
    local o = Instance.new(cls)
    for k,v in pairs(props) do if k~="Parent" then o[k]=v end end
    if kids then for _,c in ipairs(kids) do c.Parent=o end end
    if props.Parent then o.Parent=props.Parent end
    return o
end

local function TW(obj, goal, t, sty, dir)
    Tween:Create(obj,
        TweenInfo.new(t or .14, sty or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out),
        goal):Play()
end

local function Corner(r, p)
    return New("UICorner",{CornerRadius=UDim.new(0,r or 6),Parent=p})
end

local function Stroke(col, t, p)
    return New("UIStroke",{Color=col,Thickness=t or 1,
        ApplyStrokeMode=Enum.ApplyStrokeMode.Border,Parent=p})
end

local function Padding(l,r,t,b,p)
    return New("UIPadding",{
        PaddingLeft=UDim.new(0,l),PaddingRight=UDim.new(0,r),
        PaddingTop=UDim.new(0,t),PaddingBottom=UDim.new(0,b),Parent=p})
end

local function Layout(p, dir, gap)
    return New("UIListLayout",{Parent=p,
        FillDirection=dir or Enum.FillDirection.Vertical,
        SortOrder=Enum.SortOrder.LayoutOrder,
        Padding=UDim.new(0,gap or 0)})
end

local function AutoSize(scroll, lay, extra)
    lay:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        scroll.CanvasSize = UDim2.new(0,0,0, lay.AbsoluteContentSize.Y+(extra or 6))
    end)
end

local function Label(p, txt, size, color, font, xa, pos, sz, z)
    return New("TextLabel",{Parent=p,BackgroundTransparency=1,
        Text=txt or "",TextSize=size or 12,TextColor3=color or C.TPRI,
        Font=font or Enum.Font.Gotham,
        TextXAlignment=xa or Enum.TextXAlignment.Left,
        TextYAlignment=Enum.TextYAlignment.Center,
        Position=pos or UDim2.new(0,0,0,0),
        Size=sz or UDim2.new(1,0,1,0),
        ZIndex=z or 3,TextTruncate=Enum.TextTruncate.AtEnd})
end

local function Row(p, h, z)
    return New("Frame",{Parent=p,BackgroundTransparency=1,
        Size=UDim2.new(1,0,0,h or 30),ZIndex=z or 2})
end

local function Btn(p, txt, bg, tc, z)
    local b = New("TextButton",{Parent=p,BackgroundColor3=bg or C.ACC,
        Size=UDim2.new(1,0,1,0),Text=txt or "",
        Font=Enum.Font.GothamBold,TextColor3=tc or C.WHITE,
        TextSize=11,AutoButtonColor=false,ZIndex=z or 4})
    Corner(5,b); Stroke(C.BORDER,1,b)
    return b
end

local function MakeDraggable(win, handle)
    local dragging, dragInput, mousePos, framePos
    handle.InputBegan:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 then
            dragging=true; mousePos=inp.Position; framePos=win.Position
            inp.Changed:Connect(function()
                if inp.UserInputState==Enum.UserInputState.End then dragging=false end
            end)
        end
    end)
    handle.InputChanged:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseMovement then dragInput=inp end
    end)
    UIS.InputChanged:Connect(function(inp)
        if inp==dragInput and dragging then
            local d=inp.Position-mousePos
            win.Position=UDim2.new(framePos.X.Scale,framePos.X.Offset+d.X,
                                   framePos.Y.Scale,framePos.Y.Offset+d.Y)
        end
    end)
end

-- Configs
local DIR = "ShadowUI"
local EXT = ".json"
local function Write(path,data) pcall(function()
    if not isfolder(DIR) then makefolder(DIR) end
    writefile(path,data)
end) end
local function Read(path) local ok,d=pcall(readfile,path); return ok and d or nil end
local function Configs()
    local t={"default"}
    pcall(function()
        if not isfolder(DIR) then return end
        for _,f in ipairs(listfiles(DIR)) do
            local n=(f:match("[^/\\]+$") or f):gsub(EXT.."$","")
            if n~="default" and n~="__al" then t[#t+1]=n end
        end
    end)
    return t
end

-- Dropdown global
local _dropClose = nil
local function CloseDropdown()
    if _dropClose then pcall(_dropClose); _dropClose=nil end
end


function ShadowUI:_Toggle()
    self._visible=not self._visible
    if self._visible then
        self.Clip.Visible=true; self.Clip.Size=UDim2.new(0,W*.55,0,H*.55); self.Win.BackgroundTransparency=0.7
        Tw(self.Clip,{Size=UDim2.new(0,W,0,H)},.3,Enum.EasingStyle.Back,Enum.EasingDirection.Out)
        Tw(self.Win,{BackgroundTransparency=0},.24); self._floatLbl.Text="\xe2\x97\x80"
    else
        Tw(self.Clip,{Size=UDim2.new(0,W*.4,0,H*.4)},.2,Enum.EasingStyle.Quint,Enum.EasingDirection.In)
        Tw(self.Win,{BackgroundTransparency=0.85},.18)
        task.delay(.22,function() if not self._visible then self.Clip.Visible=false; self.Clip.Size=UDim2.new(0,W,0,H); self.Win.BackgroundTransparency=0 end end)
        self._floatLbl.Text="\xe2\x96\xb6"
    end
end

function ShadowUI:_Bread(catName,secName)
    for _,c in ipairs(self.BreadFrame:GetChildren()) do
        if c~=self.BreadCat and not c:IsA("UIListLayout") then c:Destroy() end
    end
    self.BreadCat.Text=catName or ""
    if secName then
        Lbl(self.BreadFrame,"\xe2\x80\xba",14,T.TxtDim,Enum.Font.Gotham,Enum.TextXAlignment.Center,nil,UDim2.new(0,10,1,0),12)
        Lbl(self.BreadFrame,secName,11,T.TxtAcc,Enum.Font.GothamBold,Enum.TextXAlignment.Left,nil,UDim2.new(0,130,1,0),12)
    end
end

function ShadowUI:_ShowTooltip(txt,x,y)
    if not txt or txt=="" then return end
    self._tooltipLbl.Text=txt
    local w=math.min(240,math.max(100,#txt*5.5+20))
    self._tooltip.Size=UDim2.new(0,w,0,26); self._tooltip.Position=UDim2.new(0,x+14,0,y-8); self._tooltip.Visible=true
end
function ShadowUI:_HideTooltip() self._tooltip.Visible=false end
function ShadowUI:_AttachTooltip(btn,text)
    if not text or text=="" then return end
    btn.MouseEnter:Connect(function() local mp=UIS:GetMouseLocation(); self:_ShowTooltip(text,mp.X,mp.Y) end)
    btn.MouseMoved:Connect(function(x,y) self._tooltip.Position=UDim2.new(0,x+14,0,y-8) end)
    btn.MouseLeave:Connect(function() self:_HideTooltip() end)
end


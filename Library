function Components:Toggle(parent, opts)
    local th  = self.theme
    local cn  = {}
    local val = opts.Default or false

    local frame = U.New("Frame", {
        Size = UDim2.new(1, 0, 0, 38),
        BackgroundColor3 = th:Get("BG3"),
        BorderSizePixel = 0,
        LayoutOrder = opts.LayoutOrder or 0,
        ClipsDescendants = false,
        Parent = parent,
    })
    U.Corner(frame, CR_SM)
    U.Pad(frame, 0, 10, 0, 10)

    U.New("TextLabel", {
        Name = "Name",
        Size = UDim2.new(1, -58, 1, 0),
        BackgroundTransparency = 1,
        Text = opts.Name or "Toggle",
        TextColor3 = th:Get("Text"),
        TextSize = 12,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = frame,
    })

    -- Track background
    local track = U.New("Frame", {
        Name = "Track",
        Size = UDim2.new(0, 40, 0, 22),
        Position = UDim2.new(1, -40, 0.5, -11),
        BackgroundColor3 = th:Get("BG5"),
        BorderSizePixel = 0,
        ZIndex = 2,
        Parent = frame,
    })
    U.Corner(track, CR_FULL)
    U.Stroke(track, th:Get("Border"), 1)

    -- Thumb
    local thumb = U.New("Frame", {
        Name = "Thumb",
        Size = UDim2.new(0, 16, 0, 16),
        Position = UDim2.new(0, 3, 0.5, -8),
        BackgroundColor3 = th:Get("TextMuted"),
        BorderSizePixel = 0,
        ZIndex = 3,
        Parent = track,
    })
    U.Corner(thumb, CR_FULL)

    -- Glow dot on thumb when active
    local glow = U.New("Frame", {
        Size = UDim2.new(0, 6, 0, 6),
        Position = UDim2.new(0.5, -3, 0.5, -3),
        BackgroundColor3 = th:Get("Accent"),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ZIndex = 4,
        Parent = thumb,
    })
    U.Corner(glow, CR_FULL)

    local function visualise(v, animate)
        local thumbTarget = v and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)
        local trackColor  = v and th:Get("Accent")            or th:Get("BG5")
        local thumbColor  = v and th:Get("White")             or th:Get("TextMuted")
        local strokeColor = v and th:Get("AccentLo")          or th:Get("Border")
        local glowTrans   = v and 0                           or 1
        if animate then
            self.anim:Play(thumb, {Position = thumbTarget, BackgroundColor3 = thumbColor}, TI.Fast)
            self.anim:Play(track, {BackgroundColor3 = trackColor}, TI.Fast)
            self.anim:Play(glow,  {BackgroundTransparency = glowTrans}, TI.Fast)
            local stk = track:FindFirstChildOfClass("UIStroke")
            if stk then self.anim:Play(stk, {Color = strokeColor}, TI.Fast) end
        else
            thumb.Position = thumbTarget
            thumb.BackgroundColor3 = thumbColor
            track.BackgroundColor3 = trackColor
            glow.BackgroundTransparency = glowTrans
            local stk = track:FindFirstChildOfClass("UIStroke")
            if stk then stk.Color = strokeColor end
        end
    end

    visualise(val, false)

    local function toggle()
        val = not val
        visualise(val, true)
        self.anim:Ripple(frame,
            frame.AbsoluteSize.X / 2, frame.AbsoluteSize.Y / 2,
            val and th:Get("Accent") or th:Get("BG5"))
        if opts.Callback then pcall(opts.Callback, val) end
        if opts.Flag then self.config:SetFlag(opts.Flag, val) end
    end

    U.Connect(cn, frame.InputBegan, function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then toggle() end
    end)
    local hcn = self:_hover(frame, th:Get("BG4"), th:Get("BG3"))
    for _, c in ipairs(hcn) do table.insert(cn, c) end

    if opts.Keybind then
        self.input:Bind(opts.Keybind, toggle)
    end

    if opts.Tooltip then self.tooltip:Attach(frame, opts.Tooltip) end

    if opts.Flag then
        self.config:RegisterFlag(opts.Flag, val, function(v)
            val = v
            visualise(v, true)
        end)
    end

    return {
        Frame    = frame,
        GetValue = function() return val end,
        SetValue = function(_, v)
            val = v
            visualise(v, true)
            if opts.Callback then pcall(opts.Callback, v) end
        end,
        Toggle   = toggle,
        Destroy  = function() U.Disconn(cn) frame:Destroy() end,
    }
end


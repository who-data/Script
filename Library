function ShadowUI:AddCategory(name)
    local cat = { Name=name, _sections={}, _expanded=false, _ui=self }

    local Row = New("TextButton", {
        Parent=self.SideList, BackgroundTransparency=1,
        Size=UDim2.new(1,0,0,30), Text="",
        Font=Enum.Font.GothamBold, AutoButtonColor=false, ZIndex=4,
    })

    -- Hover
    Row.MouseEnter:Connect(function() Tw(Row, {BackgroundColor3=T.RowHover}, .1); Row.BackgroundTransparency=0 end)
    Row.MouseLeave:Connect(function() Row.BackgroundTransparency=1 end)

    -- Ícone: anel + ponto
    New("Frame", {
        Parent=Row, BackgroundTransparency=1,
        Position=UDim2.new(0,8,0.5,-8), Size=UDim2.new(0,16,0,16), ZIndex=5,
    }, { Corn(8), Stro(T.White, 1.3) })
    New("Frame", {
        Parent=Row, BackgroundColor3=T.White,
        Position=UDim2.new(0,12,0.5,-4), Size=UDim2.new(0,8,0,8), ZIndex=6,
    }, { Corn(4) })

    Lbl(Row, name, 12, T.TextPri, Enum.Font.GothamBold,
        Enum.TextXAlignment.Left, UDim2.new(0,30,0,0), UDim2.new(1,-50,1,0), 5)

    local Chev = Lbl(Row, "‹", 13, T.TextSec, Enum.Font.GothamBold,
        Enum.TextXAlignment.Center, UDim2.new(1,-20,0,0), UDim2.new(0,16,1,0), 5)

    local SF = New("Frame", {
        Parent=self.SideList, BackgroundTransparency=1,
        Size=UDim2.new(1,0,0,0), ClipsDescendants=true, Visible=false, ZIndex=4,
    })
    local SL = List(SF)

    cat._row=Row; cat._sf=SF; cat._sl=SL; cat._chev=Chev

    Row.MouseButton1Click:Connect(function()
        cat._expanded = not cat._expanded
        if cat._expanded then
            SF.Visible=true
            SF.Size=UDim2.new(1,0,0,SL.AbsoluteContentSize.Y)
            Chev.Text="›"
            if #cat._sections>0 and not cat._sections[1]._active then
                cat._sections[1]._btn.MouseButton1Click:Fire()
            end
        else
            SF.Visible=false; SF.Size=UDim2.new(1,0,0,0); Chev.Text="‹"
        end
    end)

    self._sidebar[#self._sidebar+1]=cat
    return cat
end

-- ──────────────────────────────────────────────
--  ADD SECTION
-- ──────────────────────────────────────────────
function ShadowUI:AddSection(cat, name)
    local sec = { Name=name, _cat=cat, _active=false, _left={}, _right={}, _ui=self }

    local Btn = New("TextButton", {
        Parent=cat._sf, BackgroundTransparency=1,
        Size=UDim2.new(1,0,0,24), Text="",
        AutoButtonColor=false, ZIndex=5,
    })

    Btn.MouseEnter:Connect(function()
        if not sec._active then Tw(Btn,{BackgroundColor3=T.RowHover},.08); Btn.BackgroundTransparency=0 end
    end)
    Btn.MouseLeave:Connect(function() Btn.BackgroundTransparency=1 end)

    -- Linha accent lateral quando ativo
    local AccBar = New("Frame", {
        Parent=Btn, BackgroundColor3=T.Accent,
        Position=UDim2.new(0,0,0.15,0), Size=UDim2.new(0,2,0.7,0),
        ZIndex=7, Visible=false,
    })
    Corn(1, AccBar)

    -- Diamond
    local Dia = New("Frame", {
        Parent=Btn, BackgroundColor3=T.AccentDim,
        Position=UDim2.new(0,18,0.5,-4), Size=UDim2.new(0,8,0,8),
        Rotation=45, ZIndex=6,
    })

    local Lbl_ = Lbl(Btn, name, 11, T.TextSec, Enum.Font.Gotham,
        Enum.TextXAlignment.Left, UDim2.new(0,32,0,0), UDim2.new(1,-36,1,0), 6)

    sec._btn=Btn; sec._dia=Dia; sec._lbl=Lbl_; sec._accBar=AccBar

    Btn.MouseButton1Click:Connect(function()
        if self._activeSec then
            local p=self._activeSec
            p._active=false; p._lbl.TextColor3=T.TextSec
            p._dia.BackgroundColor3=T.AccentDim
            p._accBar.Visible=false
            p._btn.BackgroundTransparency=1
        end
        sec._active=true; Lbl_.TextColor3=T.TextAccent
        Dia.BackgroundColor3=T.Accent; AccBar.Visible=true
        Btn.BackgroundColor3=T.RowHover; Btn.BackgroundTransparency=0
        self._activeSec=sec
        self:_Bread(cat.Name, name)
        self:_Render(sec)
    end)

    cat._sections[#cat._sections+1]=sec
    cat._sf.Size=UDim2.new(1,0,0,cat._sl.AbsoluteContentSize.Y+24)
    return sec
end

-- ──────────────────────────────────────────────
--  RENDER SECTION
-- ──────────────────────────────────────────────
function ShadowUI:_Render(sec)
    for _, p in ipairs({self.LeftScroll, self.RightScroll}) do
        for _, c in ipairs(p:GetChildren()) do
            if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then c:Destroy() end
        end
    end
    for _, c in ipairs(self.TabList:GetChildren()) do
        if not c:IsA("UIListLayout") then c:Destroy() end
    end

    -- Tabs
    for _, s in ipairs(sec._cat._sections) do
        local act = (s==sec)
        local T_ = New("Frame", {
            Parent=self.TabList, BackgroundTransparency=1,
            Size=UDim2.new(0,80,1,0), ZIndex=3,
        })
        -- Underline accent na tab ativa
        if act then
            New("Frame", {
                Parent=T_, BackgroundColor3=T.Accent,
                Position=UDim2.new(0,0,1,-2), Size=UDim2.new(1,0,0,2), ZIndex=5,
            })
        end
        New("Frame", {
            Parent=T_, BackgroundColor3=act and T.Accent or T.AccentDim,
            Position=UDim2.new(0,3,0.5,-4), Size=UDim2.new(0,7,0,7),
            Rotation=45, ZIndex=4,
        })
        Lbl(T_, s.Name, 11, act and T.TextPri or T.TextSec, Enum.Font.Gotham,
            Enum.TextXAlignment.Left, UDim2.new(0,14,0,0), UDim2.new(1,-14,1,0), 4)
    end

    for _, ctrl in ipairs(sec._left)  do self:_Build(self.LeftScroll,  ctrl) end
    for _, ctrl in ipairs(sec._right) do self:_Build(self.RightScroll, ctrl) end
end

-- ──────────────────────────────────────────────
--  BUILD DISPATCHER
-- ──────────────────────────────────────────────
function ShadowUI:_Build(p, ctrl)
    if ctrl.type=="toggle"    then return self:_Toggle(p, ctrl)    end
    if ctrl.type=="slider"    then return self:_Slider(p, ctrl)    end
    if ctrl.type=="dropdown"  then return self:_Dropdown(p, ctrl)  end
    if ctrl.type=="header"    then return self:_Header(p, ctrl)    end
    if ctrl.type=="label"     then return self:_Label(p, ctrl)     end
end

-- ──────────────────────────────────────────────
--  TOGGLE
-- ──────────────────────────────────────────────
function ShadowUI:_Toggle(parent, ctrl)
    local val = ctrl._val ~= nil and ctrl._val or (ctrl.default or false)
    local row = MkRow(parent, 30)

    -- Hover sutil no row
    local HBtn = New("TextButton", {
        Parent=row, BackgroundTransparency=1,
        Size=UDim2.new(1,0,1,0), Text="", ZIndex=5,
    })
    HBtn.MouseEnter:Connect(function() Tw(row,{BackgroundColor3=T.RowHover},.08); row.BackgroundTransparency=0 end)
    HBtn.MouseLeave:Connect(function() row.BackgroundTransparency=1 end)

    -- Gear
    local rOff = -38
    if ctrl.gear then
        local G = New("TextButton", {
            Parent=row, BackgroundTransparency=1,
            Position=UDim2.new(1,-54,0.5,-8), Size=UDim2.new(0,16,0,16),
            Font=Enum.Font.Gotham, Text="⚙", TextColor3=T.TextSec, TextSize=13, ZIndex=6,
        })
        G.MouseEnter:Connect(function() G.TextColor3=T.TextPri end)
        G.MouseLeave:Connect(function() G.TextColor3=T.TextSec end)
        rOff = -58
    end

    local L = Lbl(row, ctrl.text or "Toggle", 12,
        val and T.TextPri or T.TextDim, Enum.Font.Gotham,
        Enum.TextXAlignment.Left, UDim2.new(0,0,0,0), UDim2.new(1, rOff, 1, 0), 3)

    -- Track
    local Tr = New("Frame", {
        Parent=row, BackgroundColor3=val and T.ToggleOn or T.ToggleOff,
        Position=UDim2.new(1,-28,0.5,-7), Size=UDim2.new(0,24,0,14), ZIndex=3,
    })
    Corn(7, Tr)

    local Th = New("Frame", {
        Parent=Tr, BackgroundColor3=T.White,
        Position=val and UDim2.new(1,-12,0.5,-5) or UDim2.new(0,2,0.5,-5),
        Size=UDim2.new(0,10,0,10), ZIndex=4,
    })
    Corn(5, Th)

    local function Set(v)
        val=v; ctrl._val=v
        Tw(Tr,{BackgroundColor3=v and T.ToggleOn or T.ToggleOff},.12)
        Tw(Th,{Position=v and UDim2.new(1,-12,0.5,-5) or UDim2.new(0,2,0.5,-5)},.12)
        L.TextColor3=v and T.TextPri or T.TextDim
        if ctrl.callback then ctrl.callback(v) end
    end

    HBtn.MouseButton1Click:Connect(function() Set(not val) end)
    ctrl._setValue=Set; ctrl._getValue=function() return val end
    return row
end

-- ──────────────────────────────────────────────
--  SLIDER
-- ──────────────────────────────────────────────
function ShadowUI:_Slider(parent, ctrl)
    local mn  = ctrl.min    or 0
    local mx  = ctrl.max    or 100
    local stp = ctrl.step   or 0
    local fmt = ctrl.format or "%.2f"
    local val = ctrl._val   ~= nil and ctrl._val or (ctrl.default or mn)

    local function Snap(v)
        if stp and stp>0 then v=math.round((v-mn)/stp)*stp+mn end
        return math.clamp(v, mn, mx)
    end

    local Wrap = MkRow(parent, 42)

    -- Top row
    local TR = New("Frame", {
        Parent=Wrap, BackgroundTransparency=1,
        Position=UDim2.new(0,0,0,2), Size=UDim2.new(1,0,0,14), ZIndex=3,
    })
    Lbl(TR, ctrl.text or "Slider", 11, T.TextSec, Enum.Font.Gotham,
        Enum.TextXAlignment.Left, nil, UDim2.new(0.7,0,1,0), 3)
    local VL = Lbl(TR, string.format(fmt,val), 11, T.TextAccent, Enum.Font.GothamBold,
        Enum.TextXAlignment.Right, UDim2.new(0.7,0,0,0), UDim2.new(0.3,0,1,0), 3)

    -- Track bg
    local Trk = New("Frame", {
        Parent=Wrap, BackgroundColor3=T.SliderTrack,
        Position=UDim2.new(0,0,0,24), Size=UDim2.new(1,0,0,3), ZIndex=3,
    })
    Corn(2, Trk)

    local pct = (val-mn)/(mx-mn)

    -- Fill colorido (accent)
    local Fill = New("Frame", {
        Parent=Trk, BackgroundColor3=T.SliderFill,
        Size=UDim2.new(pct,0,1,0), ZIndex=4,
    })
    Corn(2, Fill)

    -- Thumb
    local Th = New("Frame", {
        Parent=Trk, BackgroundColor3=T.SliderThumb,
        Position=UDim2.new(pct,-5,0.5,-5), Size=UDim2.new(0,10,0,10), ZIndex=5,
    })
    Corn(5, Th)
    -- Borda sutil no thumb
    Stro(T.Accent, 1, Th)

    local function Set(v)
        v=Snap(v); val=v; ctrl._val=v
        local p=(v-mn)/(mx-mn)
        Fill.Size=UDim2.new(p,0,1,0)
        Th.Position=UDim2.new(p,-5,0.5,-5)
        VL.Text=string.format(fmt,v)
        if ctrl.callback then ctrl.callback(v) end
    end

    local drag=false
    Trk.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then
            drag=true
            Set(mn+math.clamp((i.Position.X-Trk.AbsolutePosition.X)/Trk.AbsoluteSize.X,0,1)*(mx-mn))
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if drag and i.UserInputType==Enum.UserInputType.MouseMovement then
            Set(mn+math.clamp((i.Position.X-Trk.AbsolutePosition.X)/Trk.AbsoluteSize.X,0,1)*(mx-mn))
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end
    end)

    ctrl._setValue=Set; ctrl._getValue=function() return val end
    return Wrap
end

-- ──────────────────────────────────────────────
--  DROPDOWN  (overlay corrige clique atrás)
-- ──────────────────────────────────────────────
function ShadowUI:_Dropdown(parent, ctrl)
    local opts = ctrl.options or {}
    local val  = ctrl._val ~= nil and ctrl._val or (ctrl.default or opts[1])

    local Wrap = MkRow(parent, 46)

    Lbl(Wrap, ctrl.text or "Dropdown", 11, T.TextSec, Enum.Font.Gotham,
        Enum.TextXAlignment.Left, UDim2.new(0,0,0,2), UDim2.new(1,0,0,12), 3)

    local Box = New("Frame", {
        Parent=Wrap, BackgroundColor3=T.DropBg,
        Position=UDim2.new(0,0,0,16), Size=UDim2.new(1,0,0,24), ZIndex=3,
    })
    Corn(5, Box); Stro(T.DropBorder, 1, Box)

    local Sel = Lbl(Box, tostring(val), 12, T.TextPri, Enum.Font.Gotham,
        Enum.TextXAlignment.Left, UDim2.new(0,8,0,0), UDim2.new(1,-22,1,0), 4)

    -- Seta
    Lbl(Box, "▾", 11, T.TextSec, Enum.Font.GothamBold,
        Enum.TextXAlignment.Center, UDim2.new(1,-18,0,0), UDim2.new(0,14,1,0), 4)

    local open=false
    local DropF=nil

    local function Close()
        if DropF then DropF:Destroy(); DropF=nil end
        open=false
        Stro(T.DropBorder, 1, Box)
    end

    local function SetVal(v)
        val=v; ctrl._val=v; Sel.Text=tostring(v)
        Close()
        if ctrl.callback then ctrl.callback(v) end
    end

    local OBtn = New("TextButton", {
        Parent=Box, BackgroundTransparency=1,
        Size=UDim2.new(1,0,1,0), Text="", ZIndex=5,
    })

    OBtn.MouseButton1Click:Connect(function()
        if open then Close(); return end
        open=true
        -- Destaca borda do box quando aberto
        Stro(T.Accent, 1, Box)

        local itemH=22
        local listH=#opts*itemH+6

        -- Frame do dropdown renderizado no ScreenGui (ZIndex alto, não clipado)
        DropF = New("Frame", {
            Parent=self.Gui,
            BackgroundColor3=T.DropBg,
            Size=UDim2.new(0, Box.AbsoluteSize.X, 0, listH),
            ZIndex=30, ClipsDescendants=true,
        })
        Corn(5, DropF); Stro(T.Accent, 1, DropF)

        -- Posiciona no mundo relativo ao ScreenGui
        local function UpdatePos()
            local ap = Box.AbsolutePosition
            local as = Box.AbsoluteSize
            DropF.Position = UDim2.new(0, ap.X, 0, ap.Y+as.Y+3)
            DropF.Size     = UDim2.new(0, as.X, 0, listH)
        end
        UpdatePos()

        List(DropF, nil, 0)
        Pad(3,3,3,3, DropF)

        for _, opt in ipairs(opts) do
            local isSelected = (opt==val)
            local Item = New("TextButton", {
                Parent=DropF,
                BackgroundColor3=isSelected and T.RowHover or T.DropBg,
                BackgroundTransparency=isSelected and 0 or 1,
                Size=UDim2.new(1,0,0,itemH),
                Font=Enum.Font.Gotham,
                Text=tostring(opt),
                TextColor3=isSelected and T.TextAccent or T.TextSec,
                TextSize=11,
                TextXAlignment=Enum.TextXAlignment.Left,
                AutoButtonColor=false, ZIndex=31,
            })
            Pad(8,0,0,0, Item)
            Corn(3, Item)

            Item.MouseEnter:Connect(function()
                Item.BackgroundTransparency=0
                Tw(Item,{BackgroundColor3=T.DropHover},.08)
                if not isSelected then Item.TextColor3=T.TextPri end
            end)
            Item.MouseLeave:Connect(function()
                if not isSelected then
                    Item.BackgroundTransparency=1
                    Item.TextColor3=T.TextSec
                end
            end)
            Item.MouseButton1Click:Connect(function() SetVal(opt) end)
        end

        -- Overlay invisível captura cliques fora do dropdown
        local ov = GetOverlay(self.Gui)
        ov.Visible=true
        ov.Size=UDim2.new(1,0,1,0)
        _dropCloseCallbacks[#_dropCloseCallbacks+1] = Close
    end)

    -- Hover no box
    OBtn.MouseEnter:Connect(function() Tw(Box,{BackgroundColor3=T.DropHover},.08) end)
    OBtn.MouseLeave:Connect(function() if not open then Tw(Box,{BackgroundColor3=T.DropBg},.08) end end)

    ctrl._setValue=SetVal; ctrl._getValue=function() return val end
    return Wrap
end

-- ──────────────────────────────────────────────
--  SECTION HEADER
-- ──────────────────────────────────────────────
function ShadowUI:_Header(parent, ctrl)
    local row = MkRow(parent, 26)
    local rOff = 0

    if ctrl.gear then
        local G = New("TextButton", {
            Parent=row, BackgroundTransparency=1,
            Position=UDim2.new(1,-18,0.5,-8), Size=UDim2.new(0,16,0,16),
            Font=Enum.Font.Gotham, Text="⚙", TextColor3=T.TextSec, TextSize=13, ZIndex=3,
        })
        G.MouseEnter:Connect(function() G.TextColor3=T.TextPri end)
        G.MouseLeave:Connect(function() G.TextColor3=T.TextSec end)
        rOff=20
    end

    if ctrl.toggle ~= nil then
        local tv = ctrl.toggle or false
        local TTr = New("Frame", {
            Parent=row, BackgroundColor3=tv and T.ToggleOn or T.ToggleOff,
            Position=UDim2.new(1,-(24+rOff),0.5,-7), Size=UDim2.new(0,22,0,13), ZIndex=3,
        })
        Corn(7, TTr)
        local TTh = New("Frame", {
            Parent=TTr, BackgroundColor3=T.White,
            Position=tv and UDim2.new(1,-11,0.5,-5) or UDim2.new(0,2,0.5,-5),
            Size=UDim2.new(0,9,0,9), ZIndex=4,
        })
        Corn(5, TTh)
        local TB = New("TextButton", {
            Parent=TTr, BackgroundTransparency=1, Size=UDim2.new(1,0,1,0), Text="", ZIndex=5,
        })
        TB.MouseButton1Click:Connect(function()
            tv=not tv
            Tw(TTr,{BackgroundColor3=tv and T.ToggleOn or T.ToggleOff},.12)
            Tw(TTh,{Position=tv and UDim2.new(1,-11,0.5,-5) or UDim2.new(0,2,0.5,-5)},.12)
            if ctrl.callback then ctrl.callback(tv) end
        end)
        rOff=rOff+26
    end

    -- Texto cinza
    Lbl(row, ctrl.text or "", 11, T.TextSec, Enum.Font.Gotham,
        Enum.TextXAlignment.Left, nil, UDim2.new(1,-(rOff+4),1,0), 3)

    -- Linha separadora embaixo
    New("Frame", {
        Parent=row, BackgroundColor3=T.Border,
        Position=UDim2.new(0,0,1,-1), Size=UDim2.new(1,0,0,1), ZIndex=3,
    })

    return row
end


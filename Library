-- ══════════════════════════════════════════════
--  SLIDER  — CORRIGIDO
--  Usa AbsolutePosition/AbsoluteSize SÓ dentro do callback
--  e ancora o drag ao UIS global.
-- ══════════════════════════════════════════════
function ShadowUI:_BSlider(parent, ctrl)
    local mn  = ctrl.min    or 0
    local mx  = ctrl.max    or 100
    local stp = ctrl.step   or 0
    local fmt = ctrl.format or "%.2f"
    local val = ctrl._val~=nil and ctrl._val or (ctrl.default or mn)

    local function Snap(v)
        if stp and stp>0 then
            v = math.round((v-mn)/stp)*stp+mn
        end
        return math.clamp(v,mn,mx)
    end

    local Wrap=MkRow(parent,44)
    Corn(4,Wrap)

    local TR=New("Frame",{
        Parent=Wrap, BackgroundTransparency=1,
        Position=UDim2.new(0,0,0,3), Size=UDim2.new(1,0,0,15), ZIndex=3,
    })
    MkTxt(TR,ctrl.text or "Slider",11,T.TxtSec,Enum.Font.Gotham,
        Enum.TextXAlignment.Left,nil,UDim2.new(0.66,0,1,0),3)
    local VL=MkTxt(TR,string.format(fmt,val),11,T.TxtAcc,Enum.Font.GothamBold,
        Enum.TextXAlignment.Right,UDim2.new(0.66,0,0,0),UDim2.new(0.34,0,1,0),3)

    -- Track container (altura visual 4px, mas hit zone maior via HitZone)
    local TrkHolder=New("Frame",{
        Parent=Wrap, BackgroundTransparency=1,
        Position=UDim2.new(0,0,0,24), Size=UDim2.new(1,0,0,16), ZIndex=3,
    })

    local Trk=New("Frame",{
        Parent=TrkHolder, BackgroundColor3=T.SlTrack,
        Position=UDim2.new(0,0,0.5,-2), Size=UDim2.new(1,0,0,4), ZIndex=4,
    })
    Corn(2,Trk)

    local pct=(val-mn)/(mx-mn)

    local Fill=New("Frame",{
        Parent=Trk, BackgroundColor3=T.SlFill,
        Size=UDim2.new(pct,0,1,0), ZIndex=5,
    })
    Corn(2,Fill)

    local Th=New("Frame",{
        Parent=Trk, BackgroundColor3=T.SlThumb,
        Position=UDim2.new(pct,-6,0.5,-6), Size=UDim2.new(0,12,0,12), ZIndex=6,
    })
    Corn(6,Th)
    Stro(T.Accent,1.5,Th)

    -- Função que atualiza o slider dado um X absoluto
    local function SetFromAbsX(absX)
        local ap = Trk.AbsolutePosition.X
        local as = Trk.AbsoluteSize.X
        if as == 0 then return end
        local p  = math.clamp((absX - ap) / as, 0, 1)
        local v  = Snap(mn + p*(mx-mn))
        val = v; ctrl._val = v
        local np = (v-mn)/(mx-mn)
        Fill.Size     = UDim2.new(np, 0, 1, 0)
        Th.Position   = UDim2.new(np, -6, 0.5, -6)
        VL.Text       = string.format(fmt, v)
        if ctrl.callback then ctrl.callback(v) end
    end

    -- Hit zone invisível cobre o TrkHolder inteiro
    local dragging = false
    local HZ=New("TextButton",{
        Parent=TrkHolder, BackgroundTransparency=1,
        Size=UDim2.new(1,0,1,0), Text="", ZIndex=10,
    })

    HZ.MouseButton1Down:Connect(function(x,_)
        dragging=true
        Tw(Th,{Size=UDim2.new(0,14,0,14),Position=UDim2.new(
            math.clamp((x-Trk.AbsolutePosition.X)/math.max(Trk.AbsoluteSize.X,1),0,1),-7,0.5,-7)},.06)
        SetFromAbsX(x)
    end)

    -- Captura global do mouse enquanto dragging=true
    local moveConn = UIS.InputChanged:Connect(function(i)
        if dragging and i.UserInputType==Enum.UserInputType.MouseMovement then
            SetFromAbsX(i.Position.X)
        end
    end)
    local upConn = UIS.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 and dragging then
            dragging=false
            Tw(Th,{Size=UDim2.new(0,12,0,12)},.06)
        end
    end)

    -- Limpa conexões quando o frame for destruído
    Wrap.AncestryChanged:Connect(function()
        if not Wrap.Parent then
            moveConn:Disconnect()
            upConn:Disconnect()
        end
    end)

    local function Set(v)
        v=Snap(v); val=v; ctrl._val=v
        local p=(v-mn)/(mx-mn)
        Fill.Size=UDim2.new(p,0,1,0)
        Th.Position=UDim2.new(p,-6,0.5,-6)
        VL.Text=string.format(fmt,v)
        if ctrl.callback then ctrl.callback(v) end
    end

    ctrl._setValue=Set; ctrl._getValue=function() return val end
    return Wrap
end

-- ══════════════════════════════════════════════
--  DROPDOWN
-- ══════════════════════════════════════════════
function ShadowUI:_BDropdown(parent, ctrl)
    local opts=ctrl.options or {}
    local val =ctrl._val~=nil and ctrl._val or (ctrl.default or opts[1])

    local Wrap=MkRow(parent,46)
    MkTxt(Wrap,ctrl.text or "Dropdown",11,T.TxtSec,Enum.Font.Gotham,
        Enum.TextXAlignment.Left,UDim2.new(0,0,0,2),UDim2.new(1,0,0,12),3)

    local Box=New("Frame",{
        Parent=Wrap, BackgroundColor3=T.DropBg,
        Position=UDim2.new(0,0,0,16), Size=UDim2.new(1,0,0,24), ZIndex=3,
    })
    Corn(5,Box); Stro(T.Border,1,Box)

    local Sel=MkTxt(Box,tostring(val or ""),12,T.TxtPri,Enum.Font.Gotham,
        Enum.TextXAlignment.Left,UDim2.new(0,8,0,0),UDim2.new(1,-22,1,0),4)
    MkTxt(Box,"▾",11,T.TxtSec,Enum.Font.GothamBold,
        Enum.TextXAlignment.Center,UDim2.new(1,-18,0,0),UDim2.new(0,14,1,0),4)

    local open=false
    local DropF,OvF=nil,nil

    local function Close()
        open=false
        if DropF and DropF.Parent then DropF:Destroy() end
        if OvF  and OvF.Parent  then OvF:Destroy()  end
        DropF=nil; OvF=nil
        Stro(T.Border,1,Box)
        if _activeDropClose==Close then _activeDropClose=nil end
    end

    local function SetVal(v)
        val=v; ctrl._val=v; Sel.Text=tostring(v)
        task.defer(Close)
        if ctrl.callback then ctrl.callback(v) end
    end

    local OBtn=New("TextButton",{
        Parent=Box, BackgroundTransparency=1,
        Size=UDim2.new(1,0,1,0), Text="", ZIndex=5,
    })
    OBtn.MouseEnter:Connect(function() Tw(Box,{BackgroundColor3=T.DropHov},.08) end)
    OBtn.MouseLeave:Connect(function() if not open then Tw(Box,{BackgroundColor3=T.DropBg},.08) end end)

    OBtn.MouseButton1Click:Connect(function()
        CloseActiveDropdown()
        if open then return end
        open=true; _activeDropClose=Close
        Stro(T.Accent,1,Box)

        local itemH=22
        local listH=#opts*itemH+6

        -- Overlay fecha ao clicar fora
        OvF=New("TextButton",{
            Parent=self.Gui, BackgroundTransparency=1,
            Size=UDim2.new(1,0,1,0), Text="", ZIndex=48,
        })
        OvF.MouseButton1Click:Connect(Close)

        DropF=New("Frame",{
            Parent=self.Gui, BackgroundColor3=T.DropBg,
            Size=UDim2.new(0,Box.AbsoluteSize.X,0,listH),
            ZIndex=50, ClipsDescendants=true,
        })
        Corn(6,DropF); Stro(T.Accent,1,DropF)
        New("ImageLabel",{
            Parent=DropF, BackgroundTransparency=1,
            Position=UDim2.new(0,-8,0,-8), Size=UDim2.new(1,16,1,16), ZIndex=49,
            Image="rbxassetid://6014261993", ImageColor3=Color3.new(0,0,0),
            ImageTransparency=0.5, ScaleType=Enum.ScaleType.Slice,
            SliceCenter=Rect.new(49,49,450,450),
        })

        -- Posição
        local ap=Box.AbsolutePosition; local as=Box.AbsoluteSize
        DropF.Position=UDim2.new(0,ap.X,0,ap.Y+as.Y+3)
        DropF.Size=UDim2.new(0,as.X,0,listH)

        ListL(DropF,nil,0); Pad(3,3,3,3,DropF)

        for _, opt in ipairs(opts) do
            local isS=(opt==val)
            local Item=New("TextButton",{
                Parent=DropF,
                BackgroundColor3=isS and T.RowHov or T.DropBg,
                BackgroundTransparency=isS and 0 or 1,
                Size=UDim2.new(1,0,0,itemH),
                Font=isS and Enum.Font.GothamBold or Enum.Font.Gotham,
                Text=tostring(opt),
                TextColor3=isS and T.TxtAcc or T.TxtSec,
                TextSize=11, TextXAlignment=Enum.TextXAlignment.Left,
                AutoButtonColor=false, ZIndex=51,
            })
            Pad(8,0,0,0,Item); Corn(3,Item)
            Item.MouseEnter:Connect(function()
                Item.BackgroundTransparency=0
                Tw(Item,{BackgroundColor3=T.DropHov,TextColor3=T.TxtPri},.08)
            end)
            Item.MouseLeave:Connect(function()
                if not isS then Item.BackgroundTransparency=1; Item.TextColor3=T.TxtSec
                else Item.BackgroundColor3=T.RowHov end
            end)
            Item.MouseButton1Click:Connect(function() SetVal(opt) end)
        end
    end)

    ctrl._setValue=SetVal; ctrl._getValue=function() return val end
    return Wrap
end


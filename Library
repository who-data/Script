            local isSel = (opt == val)
            local item = U.New("Frame", {
                Name = "Item_" .. tostring(idx),
                Size = UDim2.new(1, 0, 0, 28),
                BackgroundColor3 = isSel and th:Get("BG5") or th:Get("BG4"),
                BorderSizePixel = 0,
                ZIndex = Z.DROPDOWN + 1,
                Parent = panel,
            })
            U.Corner(item, UDim.new(0, 4))
            U.Pad(item, 0, 8, 0, 8)

            if isSel then
                local mark = U.New("Frame", {
                    Size = UDim2.new(0, 3, 0.6, 0),
                    Position = UDim2.new(0, 0, 0.2, 0),
                    BackgroundColor3 = th:Get("Accent"),
                    BorderSizePixel = 0,
                    ZIndex = Z.DROPDOWN + 2,
                    Parent = item,
                })
                U.Corner(mark, UDim.new(0, 3))
            end

            U.New("TextLabel", {
                Size = UDim2.new(1, isSel and -10 or 0, 1, 0),
                Position = UDim2.new(0, isSel and 8 or 0, 0, 0),
                BackgroundTransparency = 1,
                Text = tostring(opt),
                TextColor3 = isSel and th:Get("AccentHi") or th:Get("Text"),
                TextSize = 11,
                Font = isSel and Enum.Font.GothamBold or Enum.Font.Gotham,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = Z.DROPDOWN + 2,
                Parent = item,
            })

            item.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    val = opt
                    selLbl.Text = tostring(opt)
                    if opts.Callback then pcall(opts.Callback, val) end
                    if opts.Flag then self.config:SetFlag(opts.Flag, val) end
                    buildItems()
                end
            end)
            item.MouseEnter:Connect(function()
                if not isSel then
                    self.anim:Play(item, {BackgroundColor3 = th:Get("BG5")}, TI.XFast)
                end
            end)
            item.MouseLeave:Connect(function()
                if not isSel then
                    self.anim:Play(item, {BackgroundColor3 = th:Get("BG4")}, TI.XFast)
                end
            end)
        end
    end
    buildItems()

    local function computePanelH()
        return math.min(#options * 32 + 10, MAX_H)
    end

    local function toggleOpen()
        open = not open
        if open then
            panel.Visible = true
            self.anim:Play(panel, {Size = UDim2.new(1, 0, 0, computePanelH())}, TI.Medium)
            self.anim:Play(arrowLbl, {Rotation = 180}, TI.Fast)
            self.anim:Play(mainFrame, {BackgroundColor3 = th:Get("BG4")}, TI.Fast)
            wrapper.Size = UDim2.new(1, 0, 0, 38 + computePanelH() + 3)
        else
            self.anim:Play(panel, {Size = UDim2.new(1, 0, 0, 0)}, TI.Medium)
            self.anim:Play(arrowLbl, {Rotation = 0}, TI.Fast)
            self.anim:Play(mainFrame, {BackgroundColor3 = th:Get("BG3")}, TI.Fast)
            task.delay(0.24, function()
                if not open and panel and panel.Parent then
                    panel.Visible = false
                    wrapper.Size = UDim2.new(1, 0, 0, 38)
                end
            end)
        end
    end

    U.Connect(cn, mainFrame.InputBegan, function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then toggleOpen() end
    end)

    if opts.Tooltip then self.tooltip:Attach(mainFrame, opts.Tooltip) end
    if opts.Flag then
        self.config:RegisterFlag(opts.Flag, val, function(v)
            val = v
            selLbl.Text = tostring(v)
            buildItems()
        end)
    end

    return {
        Frame      = wrapper,
        GetValue   = function() return val end,
        SetOptions = function(_, newOpts)
            options = newOpts
            buildItems()
        end,
        SetValue   = function(_, v)
            val = v
            selLbl.Text = tostring(v)
            buildItems()
        end,
        Close      = function() if open then toggleOpen() end end,
        Destroy    = function() U.Disconn(cn) wrapper:Destroy() end,
    }
end


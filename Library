-- Premium Roblox UI Library
-- Base architecture for large hubs

local Library = {}
Library.__index = Library

local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")

local Player = Players.LocalPlayer
local PlayerGui = Player:WaitForChild("PlayerGui")

local Theme = {
    Background = Color3.fromRGB(18,18,18),
    Secondary = Color3.fromRGB(25,25,25),
    Accent = Color3.fromRGB(120,80,255),
    Text = Color3.fromRGB(255,255,255),
    Outline = Color3.fromRGB(40,40,40)
}

local function Tween(obj,props,time)
    TweenService:Create(
        obj,
        TweenInfo.new(time or 0.2,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),
        props
    ):Play()
end

local function Create(class,props)
    local obj = Instance.new(class)
    for i,v in pairs(props) do
        obj[i] = v
    end
    return obj
end

function Library:SetTheme(t)
    for i,v in pairs(t) do
        Theme[i] = v
    end
end

function Library:CreateWindow(options)

    local Window = {}
    Window.Tabs = {}

    local ScreenGui = Create("ScreenGui",{
        Name = "PremiumUILib",
        ResetOnSpawn = false,
        Parent = PlayerGui
    })

    local Main = Create("Frame",{
        Parent = ScreenGui,
        Size = options.Size or UDim2.new(0,600,0,420),
        BackgroundColor3 = Theme.Background,
        BorderSizePixel = 0,
        Position = UDim2.new(0.5,-300,0.5,-200)
    })

    Create("UICorner",{CornerRadius=UDim.new(0,8),Parent=Main})

    local Top = Create("Frame",{
        Parent = Main,
        Size = UDim2.new(1,0,0,40),
        BackgroundColor3 = Theme.Secondary,
        BorderSizePixel = 0
    })

    Create("UICorner",{CornerRadius=UDim.new(0,8),Parent=Top})

    local Title = Create("TextLabel",{
        Parent = Top,
        Size = UDim2.new(1,0,1,0),
        BackgroundTransparency = 1,
        Text = options.Title or "UI Library",
        Font = Enum.Font.GothamBold,
        TextSize = 16,
        TextColor3 = Theme.Text
    })

    local TabsHolder = Create("Frame",{
        Parent = Main,
        Size = UDim2.new(0,150,1,-40),
        Position = UDim2.new(0,0,0,40),
        BackgroundColor3 = Theme.Secondary,
        BorderSizePixel = 0
    })

    local TabsLayout = Create("UIListLayout",{
        Parent = TabsHolder,
        Padding = UDim.new(0,4)
    })

    local Content = Create("Frame",{
        Parent = Main,
        Size = UDim2.new(1,-150,1,-40),
        Position = UDim2.new(0,150,0,40),
        BackgroundTransparency = 1
    })

    local dragging
    local dragInput
    local dragStart
    local startPos

    Top.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = Main.Position
        end
    end)

    Top.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging then
            local delta = input.Position - dragStart
            Main.Position = startPos + UDim2.new(0,delta.X,0,delta.Y)
        end
    end)

    function Window:CreateTab(name)

        local Tab = {}
        Tab.Sections = {}

        local Button = Create("TextButton",{
            Parent = TabsHolder,
            Size = UDim2.new(1,0,0,30),
            BackgroundColor3 = Theme.Background,
            BorderSizePixel = 0,
            Text = name,
            Font = Enum.Font.Gotham,
            TextSize = 14,
            TextColor3 = Theme.Text
        })

        Create("UICorner",{CornerRadius=UDim.new(0,6),Parent=Button})

        local Page = Create("ScrollingFrame",{
            Parent = Content,
            Visible = false,
            Size = UDim2.new(1,0,1,0),
            CanvasSize = UDim2.new(0,0,0,0),
            ScrollBarThickness = 4,
            BackgroundTransparency = 1
        })

        local Layout = Create("UIListLayout",{
            Parent = Page,
            Padding = UDim.new(0,10)
        })

        Button.MouseButton1Click:Connect(function()

            for _,t in pairs(Window.Tabs) do
                t.Page.Visible = false
            end

            Page.Visible = true

        end)

        function Tab:CreateSection(name)

            local Section = {}

            local Frame = Create("Frame",{
                Parent = Page,
                Size = UDim2.new(1,-10,0,120),
                BackgroundColor3 = Theme.Secondary,
                BorderSizePixel = 0
            })

            Create("UICorner",{CornerRadius=UDim.new(0,6),Parent=Frame})

            local Title = Create("TextLabel",{
                Parent = Frame,
                Size = UDim2.new(1,0,0,20),
                BackgroundTransparency = 1,
                Text = name,
                Font = Enum.Font.GothamBold,
                TextSize = 14,
                TextColor3 = Theme.Text
            })

            local Container = Create("Frame",{
                Parent = Frame,
                Position = UDim2.new(0,0,0,20),
                Size = UDim2.new(1,0,1,-20),
                BackgroundTransparency = 1
            })

            local Layout = Create("UIListLayout",{
                Parent = Container,
                Padding = UDim.new(0,6)
            })

            function Section:CreateButton(text,callback)

                local Button = Create("TextButton",{
                    Parent = Container,
                    Size = UDim2.new(1,-10,0,26),
                    BackgroundColor3 = Theme.Background,
                    BorderSizePixel = 0,
                    Text = text,
                    Font = Enum.Font.Gotham,
                    TextSize = 13,
                    TextColor3 = Theme.Text
                })

                Create("UICorner",{CornerRadius=UDim.new(0,4),Parent=Button})

                Button.MouseButton1Click:Connect(function()
                    callback()
                end)

            end

            function Section:CreateToggle(text,default,callback)

                local Enabled = default

                local Toggle = Create("TextButton",{
                    Parent = Container,
                    Size = UDim2.new(1,-10,0,26),
                    BackgroundColor3 = Theme.Background,
                    BorderSizePixel = 0,
                    Text = text.." : "..tostring(Enabled),
                    Font = Enum.Font.Gotham,
                    TextSize = 13,
                    TextColor3 = Theme.Text
                })

                Create("UICorner",{CornerRadius=UDim.new(0,4),Parent=Toggle})

                Toggle.MouseButton1Click:Connect(function()

                    Enabled = not Enabled

                    Toggle.Text = text.." : "..tostring(Enabled)

                    callback(Enabled)

                end)

            end

            function Section:CreateSlider(text,min,max,default,callback)

                local Value = default

                local FrameSlider = Create("Frame",{
                    Parent = Container,
                    Size = UDim2.new(1,-10,0,30),
                    BackgroundColor3 = Theme.Background,
                    BorderSizePixel = 0
                })

                Create("UICorner",{CornerRadius=UDim.new(0,4),Parent=FrameSlider})

                local Label = Create("TextLabel",{
                    Parent = FrameSlider,
                    Size = UDim2.new(1,0,0,14),
                    BackgroundTransparency = 1,
                    Text = text.." : "..Value,
                    Font = Enum.Font.Gotham,
                    TextSize = 12,
                    TextColor3 = Theme.Text
                })

                local Bar = Create("Frame",{
                    Parent = FrameSlider,
                    Position = UDim2.new(0,6,0,18),
                    Size = UDim2.new(1,-12,0,6),
                    BackgroundColor3 = Theme.Secondary,
                    BorderSizePixel = 0
                })

                Create("UICorner",{CornerRadius=UDim.new(0,3),Parent=Bar})

                local Fill = Create("Frame",{
                    Parent = Bar,
                    Size = UDim2.new((Value-min)/(max-min),0,1,0),
                    BackgroundColor3 = Theme.Accent,
                    BorderSizePixel = 0
                })

                Create("UICorner",{CornerRadius=UDim.new(0,3),Parent=Fill})

                Bar.InputBegan:Connect(function(input)

                    if input.UserInputType == Enum.UserInputType.MouseButton1 then

                        local pos = (input.Position.X - Bar.AbsolutePosition.X)/Bar.AbsoluteSize.X
                        Value = math.floor(min + (max-min)*pos)

                        Fill.Size = UDim2.new(pos,0,1,0)

                        Label.Text = text.." : "..Value

                        callback(Value)

                    end

                end)

            end

            return Section
        end

        Tab.Page = Page
        table.insert(Window.Tabs,Tab)

        return Tab
    end

    function Window:Notify(title,text)

        local Notif = Create("Frame",{
            Parent = ScreenGui,
            Size = UDim2.new(0,260,0,60),
            Position = UDim2.new(1,-280,1,-80),
            BackgroundColor3 = Theme.Secondary,
            BorderSizePixel = 0
        })

        Create("UICorner",{CornerRadius=UDim.new(0,6),Parent=Notif})

        local T = Create("TextLabel",{
            Parent = Notif,
            Size = UDim2.new(1,0,0,20),
            BackgroundTransparency = 1,
            Text = title,
            Font = Enum.Font.GothamBold,
            TextSize = 14,
            TextColor3 = Theme.Text
        })

        local D = Create("TextLabel",{
            Parent = Notif,
            Position = UDim2.new(0,0,0,20),
            Size = UDim2.new(1,0,1,-20),
            BackgroundTransparency = 1,
            Text = text,
            Font = Enum.Font.Gotham,
            TextSize = 12,
            TextColor3 = Theme.Text
        })

        Tween(Notif,{Position = UDim2.new(1,-280,1,-140)},0.3)

        task.delay(3,function()

            Tween(Notif,{Position = UDim2.new(1,-280,1,0)},0.3)

            task.wait(.3)

            Notif:Destroy()

        end)

    end

    return Window
end

return Library

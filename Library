--  THEME APPLICATION
-- ══════════════════════════════════════════════════════════════════
function ShadowUI:_Theme(name)
    local th=Themes[name]; if not th then return end
    self._theme=name; for k,v in pairs(th) do T[k]=v end
    pcall(function()
        self.Win.BackgroundColor3=T.Bg; self.Hdr.BackgroundColor3=T.Header
        self.Sidebar.BackgroundColor3=T.Sidebar; self.Content.BackgroundColor3=T.Panel
        self.TabBar.BackgroundColor3=T.TabBar; self._accentLine.BackgroundColor3=T.Accent
        self.FloatBtn.BackgroundColor3=T.AccentDim; self._sideStripe.BackgroundColor3=T.Accent
        self._winStroke.Color=T.CardBorder; self._logoStroke.Color=T.Accent; self._logoDot.BackgroundColor3=T.Accent
        if self._watermark then self._watermark.BackgroundColor3=T.Card end
    end)
    if self._active then self:_Render(self._active) end
end

-- ══════════════════════════════════════════════════════════════════
--  SAVE / LOAD
-- ══════════════════════════════════════════════════════════════════
function ShadowUI:SaveConfig(name)
    name=name or "default"
    local d={theme=self._theme,v={},version=VERSION}
    for id,c in pairs(self._ctrls) do
        if c._getValue then
            local v=c._getValue()
            if typeof(v)=="Color3" then v={_t="Color3",r=v.R,g=v.G,b=v.B}
            elseif typeof(v)=="EnumItem" then v={_t="KeyCode",n=v.Name} end
            d.v[id]=v
        end
    end
    local ok,j=pcall(HS.JSONEncode,HS,d); if ok then SafeWrite(CFG_DIR.."/"..name..CFG_EXT,j) end
end

function ShadowUI:LoadConfig(name)
    name=name or "default"
    local raw=SafeRead(CFG_DIR.."/"..name..CFG_EXT); if not raw then return end
    local ok,d=pcall(HS.JSONDecode,HS,raw); if not ok or type(d)~="table" then return end
    if d.theme then self:_Theme(d.theme) end
    if d.v then
        for id,v in pairs(d.v) do
            local c=self._ctrls[id]
            if c and c._setValue then
                if type(v)=="table" and v._t=="Color3" then v=Color3.new(v.r,v.g,v.b)
                elseif type(v)=="table" and v._t=="KeyCode" then v=Enum.KeyCode[v.n] or Enum.KeyCode.Unknown end
                c._setValue(v)
            end
        end
    end
end

function ShadowUI:_AutoLoadGet()
    local r=SafeRead(CFG_DIR.."/__auto"..CFG_EXT); if not r then return false end
    local ok,d=pcall(HS.JSONDecode,HS,r); return ok and d and d.on or false
end
function ShadowUI:_AutoLoadName()
    local r=SafeRead(CFG_DIR.."/__auto"..CFG_EXT); if not r then return nil end
    local ok,d=pcall(HS.JSONDecode,HS,r); return ok and d and d.cfg or nil
end
function ShadowUI:_AutoLoadSet(on,cfg)
    local ok,j=pcall(HS.JSONEncode,HS,{on=on,cfg=cfg or "default"}); if ok then SafeWrite(CFG_DIR.."/__auto"..CFG_EXT,j) end
end

-- ══════════════════════════════════════════════════════════════════
--  PUBLIC API
-- ══════════════════════════════════════════════════════════════════
local function _addCtrl(self,sec,side,cfg)
    if cfg.id then self._ctrls[cfg.id]=cfg end
    local list=side=="right" and sec._right or sec._left
    list[#list+1]=cfg
    if sec._active then
        local panel=side=="right" and self.RightPanel or self.LeftPanel
        self:_Build(panel,cfg)
    end
    return cfg
end

function ShadowUI:Toggle(sec,side,cfg)      cfg=cfg or{};cfg.type="toggle";      return _addCtrl(self,sec,side,cfg) end
function ShadowUI:Slider(sec,side,cfg)      cfg=cfg or{};cfg.type="slider";      return _addCtrl(self,sec,side,cfg) end
function ShadowUI:Dropdown(sec,side,cfg)    cfg=cfg or{};cfg.type="dropdown";    return _addCtrl(self,sec,side,cfg) end
function ShadowUI:SectionHeader(sec,side,cfg) cfg=cfg or{};cfg.type="header";    return _addCtrl(self,sec,side,cfg) end
function ShadowUI:Label(sec,side,cfg)       cfg=cfg or{};cfg.type="label";       return _addCtrl(self,sec,side,cfg) end
function ShadowUI:Button(sec,side,cfg)      cfg=cfg or{};cfg.type="button";      return _addCtrl(self,sec,side,cfg) end
function ShadowUI:TextInput(sec,side,cfg)   cfg=cfg or{};cfg.type="textinput";   return _addCtrl(self,sec,side,cfg) end
function ShadowUI:ColorPicker(sec,side,cfg) cfg=cfg or{};cfg.type="colorpicker"; return _addCtrl(self,sec,side,cfg) end
function ShadowUI:Keybind(sec,side,cfg)     cfg=cfg or{};cfg.type="keybind";     return _addCtrl(self,sec,side,cfg) end
function ShadowUI:Custom(sec,side,fn)       return _addCtrl(self,sec,side,{type="_custom",_fn=fn}) end

function ShadowUI:BindToggleKey(key)
    local conn=UIS.InputBegan:Connect(function(i,gpe)
        if gpe then return end; if i.KeyCode==key then self:_Toggle() end
    end)
    table.insert(self._conns,conn)
end

function ShadowUI:Finalize()
    self:_BuildConfig()
    for _,cat in ipairs(self._cats) do
        if cat.Name~="Config" then task.defer(function() cat._row.MouseButton1Click:Fire() end); return end
    end
end

function ShadowUI:Destroy()
    for _,conn in ipairs(self._conns) do pcall(function() conn:Disconnect() end) end
    self._conns={}; pcall(function() self.Gui:Destroy() end)
end

return ShadowUI

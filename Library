function SUI:_TV()
    self._vis = not self._vis
    if self._vis then
        self.Win.Visible=true; TW(self.Win,{Size=UDim2.new(0,820,0,460)},.18); self.FI.Text="◀"
    else
        TW(self.Win,{Size=UDim2.new(0,0,0,460)},.18)
        task.delay(.19,function() if not self._vis then self.Win.Visible=false end end)
        self.FI.Text="▶"
    end
end


--  SECTION HEADER
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
function ShadowUI:_Header(parent, ctrl)
    local T = self._T
    local row=MkRow(parent,28)
    local rOff=0

    if ctrl.gear then
        local G=New("TextButton",{
            Parent=row, BackgroundTransparency=1,
            Position=UDim2.new(1,-20,0.5,-8), Size=UDim2.new(0,16,0,16),
            Font=Enum.Font.Gotham, Text="⚙",
            TextColor3=T.TextSec, TextSize=13, ZIndex=4,
        })
        G.MouseEnter:Connect(function() Tw(G,{TextColor3=T.TextAccent},.08) end)
        G.MouseLeave:Connect(function() Tw(G,{TextColor3=T.TextSec},.08) end)
        rOff=22
    end

    if ctrl.toggle~=nil then
        local tv=ctrl.toggle or false
        local TTr=New("Frame",{
            Parent=row, BackgroundColor3=tv and T.ToggleOn or T.ToggleOff,
            Position=UDim2.new(1,-(26+rOff),0.5,-7), Size=UDim2.new(0,24,0,13), ZIndex=4,
        })
        Corn(7,TTr)
        local TTh=New("Frame",{
            Parent=TTr, BackgroundColor3=T.White,
            Position=tv and UDim2.new(1,-12,0.5,-5) or UDim2.new(0,2,0.5,-5),
            Size=UDim2.new(0,9,0,9), ZIndex=5,
        })
        Corn(5,TTh)
        local TB=New("TextButton",{
            Parent=TTr, BackgroundTransparency=1,
            Size=UDim2.new(1,0,1,0), Text="", ZIndex=6,
        })
        TB.MouseButton1Click:Connect(function()
            tv=not tv
            Tw(TTr,{BackgroundColor3=tv and T.ToggleOn or T.ToggleOff},.12)
            Tw(TTh,{Position=tv and UDim2.new(1,-12,0.5,-5) or UDim2.new(0,2,0.5,-5)},.12)
            if ctrl.callback then ctrl.callback(tv) end
        end)
        rOff=rOff+28
    end

    MkLbl(row, ctrl.text or "", 11, T.TextSec, Enum.Font.Gotham,
        Enum.TextXAlignment.Left, nil, UDim2.new(1,-(rOff+4),1,0), 3)

    New("Frame",{
        Parent=row, BackgroundColor3=T.Border,
        Position=UDim2.new(0,0,1,-1), Size=UDim2.new(1,0,0,1), ZIndex=3,
    })

    return row
end


local Tab = {}
Tab.__index = Tab

function Tab.new(scroll)
    local self = setmetatable({}, Tab)
    self._scroll = scroll
    self._subTabs = {}
    self._activeSubIdx = nil
    self._subBar = nil
    self._subContents = {}
    return self
end

function Tab:_EnsureSubBar()
    if self._subBar then return end
    self._subBar = New("Frame", {
        Size = UDim2.new(1, 0, 0, 32),
        BackgroundTransparency = 1,
        AutomaticSize = Enum.AutomaticSize.None,
        LayoutOrder = -9999,
        Parent = self._scroll,
    })
    List(self._subBar, 4, Enum.FillDirection.Horizontal)
    New("Frame", {
        Size = UDim2.new(1, 0, 0, 1),
        Position = UDim2.new(0, 0, 1, -1),
        BackgroundColor3 = T.Border,
        BorderSizePixel = 0,
        Parent = self._subBar,
    })
end

function Tab:AddSubTab(name)
    self:_EnsureSubBar()

    local isFirst = #self._subTabs == 0

    local btn = New("TextButton", {
        Size = UDim2.new(0, 0, 1, -4),
        AutomaticSize = Enum.AutomaticSize.X,
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = isFirst and T.TextAccent or T.TextDim,
        Font = T.FontSemi,
        TextSize = 12,
        AutoButtonColor = false,
        Parent = self._subBar,
    })
    Pad(btn, 0, 12, 0, 12)

    local ind = New("Frame", {
        Size = isFirst and UDim2.new(1, 0, 0, 2) or UDim2.new(0, 0, 0, 2),
        Position = UDim2.new(0, 0, 1, 2),
        BackgroundColor3 = T.Accent,
        BorderSizePixel = 0,
        Parent = btn,
    })

    -- content
    local holder = New("Frame", {
        Size = UDim2.new(1, 0, 0, 0),
        BackgroundTransparency = 1,
        AutomaticSize = Enum.AutomaticSize.Y,
        Visible = isFirst,
        Parent = self._scroll,
    })
    List(holder, 0)

    local idx = #self._subTabs + 1
    self._subTabs[idx] = { btn=btn, ind=ind, holder=holder }
    self._subContents[idx] = holder
    if isFirst then self._activeSubIdx = 1 end

    btn.MouseButton1Click:Connect(function()
        if self._activeSubIdx == idx then return end
        local old = self._subTabs[self._activeSubIdx]
        if old then
            old.holder.Visible = false
            Tween(old.btn, { TextColor3 = T.TextDim })
            Tween(old.ind, { Size = UDim2.new(0, 0, 0, 2) })
        end
        self._activeSubIdx = idx
        holder.Visible = true
        Tween(btn, { TextColor3 = T.TextAccent })
        Tween(ind, { Size = UDim2.new(1, 0, 0, 2) })
    end)

    local sec = Section.new(holder, nil)
    return sec
end

function Tab:AddSection(title)
    return Section.new(self._scroll, title)
end


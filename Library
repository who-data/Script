--  SPLASH / INITIALIZATION SCREEN
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
local function CreateSplash(title, subtitle, accentColor, onDone)
    local SplashGui = New("ScreenGui",{
        Name="ShadowUI_Splash", Parent=PlayerGui,
        ResetOnSpawn=false, ZIndexBehavior=Enum.ZIndexBehavior.Sibling,
        DisplayOrder=999,
    })

    -- Full overlay
    local Overlay = New("Frame",{
        Parent=SplashGui, BackgroundColor3=Color3.fromRGB(5,5,8),
        Size=UDim2.new(1,0,1,0), ZIndex=1,
    })

    -- Animated background particles (subtle dots)
    for i=1,12 do
        local dot = New("Frame",{
            Parent=Overlay,
            BackgroundColor3=accentColor,
            Size=UDim2.new(0,2,0,2),
            Position=UDim2.new(math.random()*0.9+0.05, 0, math.random()*0.9+0.05, 0),
            ZIndex=2,
            BackgroundTransparency=0.7,
        })
        Corn(1, dot)
        -- Float animation
        local startY = dot.Position.Y.Scale
        task.spawn(function()
            local t = math.random()*math.pi*2
            while dot and dot.Parent do
                t = t + 0.016
                dot.Position = UDim2.new(
                    dot.Position.X.Scale, 0,
                    startY + math.sin(t * (0.3 + math.random()*0.3)) * 0.02, 0
                )
                RunService.Heartbeat:Wait()
            end
        end)
    end

    -- Glow lines (top & bottom)
    local topLine = New("Frame",{
        Parent=Overlay, BackgroundColor3=accentColor,
        Size=UDim2.new(0,0,0,1), Position=UDim2.new(0.5,0,0,0),
        ZIndex=3,
    })
    New("UIGradient",{
        Color=ColorSequence.new{
            ColorSequenceKeypoint.new(0,Color3.new(0,0,0)),
            ColorSequenceKeypoint.new(0.5,accentColor),
            ColorSequenceKeypoint.new(1,Color3.new(0,0,0)),
        },
        Parent=topLine,
    })

    -- Center card
    local Card = New("Frame",{
        Parent=Overlay, BackgroundColor3=Color3.fromRGB(10,10,14),
        Size=UDim2.new(0,380,0,220),
        Position=UDim2.new(0.5,-190,0.5,-110),
        ZIndex=4,
        BackgroundTransparency=1,
    })
    Corn(16, Card)

    local CardStroke = Stro(accentColor, 1, Card)
    CardStroke.Transparency = 0.6

    -- Logo mark (animated diamond)
    local LogoWrap = New("Frame",{
        Parent=Card, BackgroundTransparency=1,
        Position=UDim2.new(0.5,-24,0,28), Size=UDim2.new(0,48,0,48), ZIndex=6,
    })
    local Diamond = New("Frame",{
        Parent=LogoWrap, BackgroundColor3=accentColor,
        Size=UDim2.new(1,0,1,0), Rotation=45, ZIndex=7,
        BackgroundTransparency=0,
    })
    Corn(6, Diamond)
    -- Inner diamond
    New("Frame",{
        Parent=LogoWrap,
        BackgroundColor3=Color3.fromRGB(10,10,14),
        Position=UDim2.new(0.25,0,0.25,0), Size=UDim2.new(0.5,0,0.5,0),
        Rotation=45, ZIndex=8,
    })

    -- Title
    local TitleLbl = New("TextLabel",{
        Parent=Card, BackgroundTransparency=1,
        Position=UDim2.new(0,0,0,86), Size=UDim2.new(1,0,0,30),
        Text=title, TextSize=22,
        TextColor3=Color3.fromRGB(220,220,235),
        Font=Enum.Font.GothamBlack,
        TextXAlignment=Enum.TextXAlignment.Center,
        ZIndex=6, TextTransparency=1,
    })

    -- Subtitle
    local SubLbl = New("TextLabel",{
        Parent=Card, BackgroundTransparency=1,
        Position=UDim2.new(0,0,0,118), Size=UDim2.new(1,0,0,18),
        Text=subtitle, TextSize=12,
        TextColor3=Color3.fromRGB(80,80,100),
        Font=Enum.Font.Gotham,
        TextXAlignment=Enum.TextXAlignment.Center,
        ZIndex=6, TextTransparency=1,
    })

    -- Progress bar background
    local ProgBg = New("Frame",{
        Parent=Card, BackgroundColor3=Color3.fromRGB(22,22,28),
        Position=UDim2.new(0.1,0,0,158), Size=UDim2.new(0.8,0,0,4),
        ZIndex=6,
    })
    Corn(2, ProgBg)

    local ProgFill = New("Frame",{
        Parent=ProgBg, BackgroundColor3=accentColor,
        Size=UDim2.new(0,0,1,0), ZIndex=7,
    })
    Corn(2, ProgFill)
    New("UIGradient",{
        Color=ColorSequence.new{
            ColorSequenceKeypoint.new(0, accentColor),
            ColorSequenceKeypoint.new(1, Color3.new(1,1,1)),
        },
        Parent=ProgFill,
    })

    -- Status text
    local StatusLbl = New("TextLabel",{
        Parent=Card, BackgroundTransparency=1,
        Position=UDim2.new(0,0,0,170), Size=UDim2.new(1,0,0,14),
        Text="Initializing...", TextSize=10,
        TextColor3=Color3.fromRGB(55,55,70),
        Font=Enum.Font.Gotham,
        TextXAlignment=Enum.TextXAlignment.Center,
        ZIndex=6,
    })

    -- Version badge
    New("TextLabel",{
        Parent=Card, BackgroundTransparency=1,
        Position=UDim2.new(0,0,0,196), Size=UDim2.new(1,0,0,12),
        Text="SHADOW UI  v2.0", TextSize=9,
        TextColor3=Color3.fromRGB(40,40,52),
        Font=Enum.Font.GothamBold,
        TextXAlignment=Enum.TextXAlignment.Center,
        ZIndex=6, LetterSpacing=4,
    })

    -- ── ANIMATION SEQUENCE ──────────────────
    -- Animate top line expand
    Tw(topLine, {Size=UDim2.new(1,0,0,1), Position=UDim2.new(0,0,0,0)}, 0.5, Enum.EasingStyle.Quad)

    -- Card fade in
    task.delay(0.1, function()
        Tw(Card, {BackgroundTransparency=0}, 0.4, Enum.EasingStyle.Quad)
    end)

    -- Diamond pulse
    task.spawn(function()
        task.wait(0.15)
        Tw(Diamond, {Rotation=90}, 0.5, Enum.EasingStyle.Back)
        task.wait(0.25)
        Tw(Diamond, {Rotation=45}, 0.3, Enum.EasingStyle.Quad)
    end)

    -- Text reveals
    task.delay(0.35, function()
        Tw(TitleLbl, {TextTransparency=0}, 0.4)
    end)
    task.delay(0.5, function()
        Tw(SubLbl, {TextTransparency=0}, 0.3)
    end)

    -- Loading steps
    local steps = {
        {0.05, "Loading modules..."},
        {0.30, "Setting up UI..."},
        {0.55, "Applying theme..."},
        {0.75, "Loading configs..."},
        {0.90, "Almost ready..."},
        {1.00, "Done!"},
    }

    task.spawn(function()
        task.wait(0.6)
        for _, step in ipairs(steps) do
            Tw(ProgFill, {Size=UDim2.new(step[1],0,1,0)}, 0.35, Enum.EasingStyle.Quad)
            StatusLbl.Text = step[2]
            task.wait(0.28)
        end
        task.wait(0.15)

        -- Exit animation
        Tw(Card, {BackgroundTransparency=1}, 0.3)
        Tw(TitleLbl, {TextTransparency=1}, 0.25)
        Tw(SubLbl, {TextTransparency=1}, 0.2)
        Tw(StatusLbl, {TextTransparency=1}, 0.2)
        Tw(ProgBg, {BackgroundTransparency=1}, 0.2)
        Tw(topLine, {BackgroundTransparency=1}, 0.25)

        task.wait(0.05)
        Tw(Overlay, {BackgroundTransparency=1}, 0.35, Enum.EasingStyle.Quad)

        task.wait(0.4)
        SplashGui:Destroy()
        if onDone then onDone() end
    end)

    return SplashGui
end


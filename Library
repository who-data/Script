-- SECTION
-- ============================================================
local Section={}; Section.__index=Section

function Section.new(parent,title)
    local self=setmetatable({},Section)

    local wrap=ins("Frame",{Size=UDim2.new(1,0,0,0),BackgroundTransparency=1,Parent=parent})

    local headerH=0
    if title then
        headerH=28
        local hdr=ins("Frame",{Size=UDim2.new(1,0,0,28),BackgroundTransparency=1,Parent=wrap})
        ins("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
            Text=title:upper(),TextColor3=C.TextAcc,Font=C.Fbold,TextSize=10,
            LetterSpacing=2,TextXAlignment=Enum.TextXAlignment.Left,Parent=hdr})
        ins("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-1),
            BackgroundColor3=C.Border,BorderSizePixel=0,Parent=hdr})
    end

    local content=ins("Frame",{Size=UDim2.new(1,0,0,0),
        Position=UDim2.new(0,0,0,headerH),
        BackgroundTransparency=1,Parent=wrap})
    local cl=vlist(content,0)

    cl:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        local ch=cl.AbsoluteContentSize.Y
        content.Size=UDim2.new(1,0,0,ch)
        wrap.Size=UDim2.new(1,0,0,headerH+ch)
    end)

    self._c=content
    return self
end

function Section:AddToggle(n,o)      return Toggle(self._c,n,o) end
function Section:AddSlider(n,o)      return Slider(self._c,n,o) end
function Section:AddDropdown(n,o)    return Dropdown(self._c,n,o) end
function Section:AddTextBox(n,o)     return TextBox(self._c,n,o) end
function Section:AddButton(n,o)      return Button(self._c,n,o) end
function Section:AddKeybind(n,o)     return Keybind(self._c,n,o) end
function Section:AddColorPicker(n,o) return ColorPicker(self._c,n,o) end
function Section:AddLabel(t,o)       return Label(self._c,t,o) end


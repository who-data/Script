    local sub=opts.SubTitle or "PREMIUM"
    local tag=opts.Tag or "discord.gg/deathball"
    local W=opts.Width or 560; local H=opts.Height or 420
    self._tabs={}; self._active=nil; self._min=false; self._W=W; self._H=H


function SUI:_MkConfig()
    local cat = self:AddCategory("Config")
    local sec = self:AddSection(cat,"Settings")

    local function DualBtn(p,lT,lBg,lFn,rT,rBg,rFn)
        local r = PlainF(p,30)
        local function Half(xp,xs,txt,bg,fn)
            local f=N("Frame",{Parent=r,BackgroundTransparency=1,Position=xp,Size=xs,ZIndex=3})
            local b=N("TextButton",{Parent=f,BackgroundColor3=bg,Size=UDim2.new(1,0,1,0),
                Text=txt,Font=Enum.Font.GothamSemibold,TextColor3=T.WH,TextSize=11,
                AutoButtonColor=false,ZIndex=4})
            Cr(5,b); Sk(T.BRD,1,b)
            b.MouseEnter:Connect(function() TW(b,{BackgroundColor3=bg:Lerp(T.WH,0.1)}) end)
            b.MouseLeave:Connect(function() TW(b,{BackgroundColor3=bg}) end)
            b.MouseButton1Click:Connect(function() if fn then fn() end end)
        end
        Half(UDim2.new(0,0,0,0),  UDim2.new(0.5,-3,1,0), lT,lBg,lFn)
        Half(UDim2.new(0.5,3,0,0),UDim2.new(0.5,-3,1,0), rT,rBg,rFn)
        return r
    end

    local cfgCtrl={type="dropdown",text="Config File",options=Cfgs(),default="default"}
    local names={}; for k in pairs(Themes) do names[#names+1]=k end; table.sort(names)

    sec._left = {
        {type="header",text="UI Theme"},
        {type="dropdown",text="Theme",options=names,default=self._theme,
            callback=function(v) self:_ApplyT(v) end},
        {type="header",text="Config Files"},
        cfgCtrl,
        {type="raw",fn=function(p)
            return DualBtn(p,
                "Save", T.ACC, function()
                    local n=cfgCtrl._getValue and cfgCtrl._getValue() or "default"
                    self:Save(n); cfgCtrl.options=Cfgs()
                end,
                "Load", Color3.fromRGB(34,34,48), function()
                    local n=cfgCtrl._getValue and cfgCtrl._getValue() or "default"
                    self:Load(n)
                end)
        end},
        {type="raw",fn=function(p)
            return DualBtn(p,
                "New",    Color3.fromRGB(34,34,48), function()
                    local n="cfg_"..tostring(os.time())
                    self:Save(n); cfgCtrl.options=Cfgs()
                    if cfgCtrl._setValue then cfgCtrl._setValue(n) end
                end,
                "Delete", T.RED, function()
                    local n=cfgCtrl._getValue and cfgCtrl._getValue() or "default"
                    if n~="default" then
                        pcall(delfile,DIR.."/"..n..EXT)
                        cfgCtrl.options=Cfgs()
                        if cfgCtrl._setValue then cfgCtrl._setValue("default") end
                    end
                end)
        end},
        {type="header",text="Auto Load"},
        {type="toggle",text="Auto Load on Start",default=self:_GetAL(),
            callback=function(v) self:_SetAL(v) end},
    }
end

function SUI:_ApplyT(name)
    ApplyTheme(name); self._theme=name
    self.Win.BackgroundColor3=T.BG; self.Hdr.BackgroundColor3=T.HDR
    self.Side.BackgroundColor3=T.SIDE; self.Con.BackgroundColor3=T.BG
    self.TBar.BackgroundColor3=T.SUBHDR; self._aline.BackgroundColor3=T.ACC
    if self._active then self:_Render(self._active) end
end

function SUI:Save(name)
    local d={theme=self._theme,v={}}
    for id,c in pairs(self._flags) do if c._getValue then d.v[id]=c._getValue() end end
    local ok,j=pcall(HTTP.JSONEncode,HTTP,d); if ok then Wr(DIR.."/"..name..EXT,j) end
end
function SUI:Load(name)
    local raw=Rd(DIR.."/"..name..EXT); if not raw then return end
    local ok,d=pcall(HTTP.JSONDecode,HTTP,raw); if not ok then return end
    if d.theme then self:_ApplyT(d.theme) end
    if d.v then for id,v in pairs(d.v) do local c=self._flags[id]; if c and c._setValue then c._setValue(v) end end end
end
function SUI:_GetAL()
    local r=Rd(DIR.."/__al"..EXT); if not r then return false end
    local ok,d=pcall(HTTP.JSONDecode,HTTP,r); return ok and d and d.on or false
end
function SUI:_SetAL(v)
    local ok,j=pcall(HTTP.JSONEncode,HTTP,{on=v,cfg="default"}); if ok then Wr(DIR.."/__al"..EXT,j) end
end

-- ============================================================
-- PUBLIC API
-- ============================================================
local function Add(sec,side,cfg)
    local list=(side=="right") and sec._right or sec._left
    list[#list+1]=cfg
    if sec._active then
        sec._ui:_Build((side=="right") and sec._ui.RP or sec._ui.LP,cfg)
    end
    return cfg
end

function SUI:Toggle(s,side,cfg)   cfg=cfg or{}; cfg.type="toggle";   if cfg.id then self._flags[cfg.id]=cfg end; return Add(s,side,cfg) end
function SUI:Slider(s,side,cfg)   cfg=cfg or{}; cfg.type="slider";   if cfg.id then self._flags[cfg.id]=cfg end; return Add(s,side,cfg) end
function SUI:Dropdown(s,side,cfg) cfg=cfg or{}; cfg.type="dropdown"; if cfg.id then self._flags[cfg.id]=cfg end; return Add(s,side,cfg) end
function SUI:SectionHeader(s,side,cfg) cfg=cfg or{}; cfg.type="header"; return Add(s,side,cfg) end
function SUI:Label(s,side,cfg)    cfg=cfg or{}; cfg.type="label";    return Add(s,side,cfg) end

-- ★ Chamar DEPOIS de registrar todas as categorias do usuário
function SUI:Build()
    -- Config SEMPRE em último
    self:_MkConfig()

    -- Auto load
    if self:_GetAL() then
        local r=Rd(DIR.."/__al"..EXT)
        if r then local ok,d=pcall(HTTP.JSONDecode,HTTP,r); if ok and d and d.cfg then self:Load(d.cfg) end end
    end

    -- ★ ABRE PRIMEIRA CATEGORIA AUTOMATICAMENTE
    -- task.delay(0.15) garante que a UI terminou de renderizar
    -- e que AbsoluteSize/AbsolutePosition estão disponíveis
    task.delay(0.15, function()
        for _,cat in ipairs(self._cats) do
            if cat.Name ~= "Config" then
                -- Simula clique real na linha da categoria
                cat._row.MouseButton1Click:Fire()
                return
            end
        end
    end)
end

function SUI:BindKey(key)
    UIS.InputBegan:Connect(function(i,gpe)
        if gpe then return end
        if i.KeyCode==key then self:_TV() end
    end)
end

function SUI:Destroy() SliderMgr:Clear(); self.Gui:Destroy() end

return SUI

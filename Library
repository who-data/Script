-- =========================================================
--  ABA CONFIG (sempre em último via Build())
-- =========================================================
function Library:_MakeConfig()
    local cat=self:AddCategory("Config")
    local sec=self:AddSection(cat,"Settings")

    local function DualBtn(p, lTxt,lBg,lCb, rTxt,rBg,rCb)
        local r=Row(p,28)
        local function Half(xp,xs,txt,bg,cb)
            local f=New("Frame",{Parent=r,BackgroundTransparency=1,Position=xp,Size=xs,ZIndex=3})
            local b=Btn(f,txt,bg,C.WHITE,4)
            b.MouseEnter:Connect(function() TW(b,{BackgroundColor3=bg:Lerp(C.WHITE,0.12)},.08) end)
            b.MouseLeave:Connect(function() TW(b,{BackgroundColor3=bg},.08) end)
            b.MouseButton1Click:Connect(function() if cb then cb() end end)
        end
        Half(UDim2.new(0,0,0,0),  UDim2.new(0.5,-3,1,0), lTxt,lBg,lCb)
        Half(UDim2.new(0.5,3,0,0),UDim2.new(0.5,-3,1,0), rTxt,rBg,rCb)
        return r
    end

    local cfgCtrl={type="dropdown",text="Config File",
        options=Configs(),default="default"}

    sec._left={
        {type="header",text="UI Theme"},
        (function()
            local names={}; for k in pairs({Dark=1,Midnight=1,Rose=1}) do names[#names+1]=k end
            table.sort(names)
            return {type="dropdown",text="Theme",options=names,default=self._theme,
                callback=function(v) self:_Theme(v) end}
        end)(),
        {type="header",text="Config Files"},
        cfgCtrl,
        {type="raw",fn=function(p)
            return DualBtn(p,
                "Save",   C.ACC, function()
                    local n=cfgCtrl._getValue and cfgCtrl._getValue() or "default"
                    self:Save(n); cfgCtrl.options=Configs()
                end,
                "Load",   Color3.fromRGB(36,36,50), function()
                    local n=cfgCtrl._getValue and cfgCtrl._getValue() or "default"
                    self:Load(n)
                end)
        end},
        {type="raw",fn=function(p)
            return DualBtn(p,
                "New",    Color3.fromRGB(36,36,50), function()
                    local n="cfg_"..tostring(os.time())
                    self:Save(n); cfgCtrl.options=Configs()
                    if cfgCtrl._setValue then cfgCtrl._setValue(n) end
                end,
                "Delete", C.RED, function()
                    local n=cfgCtrl._getValue and cfgCtrl._getValue() or "default"
                    if n~="default" then
                        pcall(delfile,DIR.."/"..n..EXT)
                        cfgCtrl.options=Configs()
                        if cfgCtrl._setValue then cfgCtrl._setValue("default") end
                    end
                end)
        end},
        {type="header",text="Auto Load"},
        {type="toggle",text="Auto Load on Start",
            default=self:_GetAL(),
            callback=function(v) self:_SetAL(v) end},
    }
end

-- =========================================================
--  THEME
-- =========================================================
local Themes={
    Dark={BG=Color3.fromRGB(12,12,15),SIDE=Color3.fromRGB(16,16,20),HDR=Color3.fromRGB(13,13,17),SUBHDR=Color3.fromRGB(15,15,19),ACC=Color3.fromRGB(112,100,255),ACCHI=Color3.fromRGB(155,145,255)},
    Midnight={BG=Color3.fromRGB(5,8,18),SIDE=Color3.fromRGB(8,12,24),HDR=Color3.fromRGB(6,9,20),SUBHDR=Color3.fromRGB(7,10,22),ACC=Color3.fromRGB(64,160,255),ACCHI=Color3.fromRGB(110,190,255)},
    Rose={BG=Color3.fromRGB(13,10,12),SIDE=Color3.fromRGB(18,13,17),HDR=Color3.fromRGB(14,11,14),SUBHDR=Color3.fromRGB(15,12,16),ACC=Color3.fromRGB(236,72,153),ACCHI=Color3.fromRGB(255,130,190)},
}
function Library:_Theme(name)
    local th=Themes[name]; if not th then return end
    self._theme=name
    for k,v in pairs(th) do C[k]=v end
    self.Win.BackgroundColor3=C.BG
    self.Hdr.BackgroundColor3=C.HDR
    self.Side.BackgroundColor3=C.SIDE
    self.Content.BackgroundColor3=C.BG
    self.TabBar.BackgroundColor3=C.SUBHDR
    self._al.BackgroundColor3=C.ACC
    if self._active then self:_Render(self._active) end
end

-- =========================================================
--  SAVE / LOAD
-- =========================================================
function Library:Save(name)
    local data={theme=self._theme,v={}}
    for id,ctrl in pairs(self._flags) do
        if ctrl._getValue then data.v[id]=ctrl._getValue() end
    end
    local ok,j=pcall(Http.JSONEncode,Http,data)
    if ok then Write(DIR.."/"..name..EXT,j) end
end

function Library:Load(name)
    local raw=Read(DIR.."/"..name..EXT); if not raw then return end
    local ok,d=pcall(Http.JSONDecode,Http,raw); if not ok then return end
    if d.theme then self:_Theme(d.theme) end
    if d.v then
        for id,v in pairs(d.v) do
            local ctrl=self._flags[id]
            if ctrl and ctrl._setValue then ctrl._setValue(v) end
        end
    end
end

function Library:_GetAL()
    local r=Read(DIR.."/__al"..EXT); if not r then return false end
    local ok,d=pcall(Http.JSONDecode,Http,r); return ok and d and d.on or false
end
function Library:_SetAL(v)
    local ok,j=pcall(Http.JSONEncode,Http,{on=v,cfg="default"})
    if ok then Write(DIR.."/__al"..EXT,j) end
end

-- =========================================================
--  PUBLIC API
-- =========================================================
local function AddCtrl(sec,side,cfg)
    local list=(side=="right") and sec._right or sec._left
    list[#list+1]=cfg
    if sec._active then
        local panel=(side=="right") and sec._ui.RP or sec._ui.LP
        sec._ui:_Build(panel,cfg)
    end
    return cfg
end

function Library:Toggle(sec,side,cfg)
    cfg=cfg or{}; cfg.type="toggle"
    if cfg.id then self._flags[cfg.id]=cfg end
    return AddCtrl(sec,side,cfg)
end
function Library:Slider(sec,side,cfg)
    cfg=cfg or{}; cfg.type="slider"
    if cfg.id then self._flags[cfg.id]=cfg end
    return AddCtrl(sec,side,cfg)
end
function Library:Dropdown(sec,side,cfg)
    cfg=cfg or{}; cfg.type="dropdown"
    if cfg.id then self._flags[cfg.id]=cfg end
    return AddCtrl(sec,side,cfg)
end
function Library:SectionHeader(sec,side,cfg)
    cfg=cfg or{}; cfg.type="header"; return AddCtrl(sec,side,cfg)
end
function Library:Label(sec,side,cfg)
    cfg=cfg or{}; cfg.type="label"; return AddCtrl(sec,side,cfg)
end

-- Chamar depois de registrar todas as categorias do usuário
function Library:Build()
    self:_MakeConfig()  -- Config SEMPRE por último

    -- Auto load
    if self:_GetAL() then
        local r=Read(DIR.."/__al"..EXT)
        if r then
            local ok,d=pcall(Http.JSONDecode,Http,r)
            if ok and d and d.cfg then self:Load(d.cfg) end
        end
    end

    -- Abre a 1ª categoria/seção do usuário (não Config)
    task.defer(function()
        task.wait()  -- aguarda 1 frame para AbsoluteSize estar pronto
        for _,cat in ipairs(self._cats) do
            if cat.Name~="Config" then
                cat._row.MouseButton1Click:Fire()
                return
            end
        end
    end)
end

function Library:BindKey(key)
    UIS.InputBegan:Connect(function(i,gpe)
        if gpe then return end
        if i.KeyCode==key then self:_ToggleVis() end
    end)
end

function Library:Destroy() self.Gui:Destroy() end

return Library

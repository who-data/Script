    Lbl(toast,title or "",12,T.TxtPri,Enum.Font.GothamBold,Enum.TextXAlignment.Left,UDim2.new(0,36,0,body and 8 or 0),UDim2.new(1,-40,0,body and 18 or 42),603)
    if body and body~="" then Lbl(toast,body,10,T.TxtSec,Enum.Font.Gotham,Enum.TextXAlignment.Left,UDim2.new(0,36,0,26),UDim2.new(1,-40,0,26),603,true) end
    local pbg=New("Frame",{Parent=toast,BackgroundColor3=T.CardBorder,AnchorPoint=Vector2.new(0,1),Position=UDim2.new(0,0,1,0),Size=UDim2.new(1,0,0,2),ZIndex=603,BorderSizePixel=0}); Corner(1,pbg)

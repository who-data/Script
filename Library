-- ────────────────────────────────────────────────────────────────
--  PUBLIC API: AddControl
-- ────────────────────────────────────────────────────────────────
function ShadowUI:AddToggle(section, side, name, default, callback, opts)
    opts = opts or {}
    local ref = { _value = default or false }
    local ctrl = {
        type     = "toggle",
        name     = name,
        default  = default,
        callback = callback,
        hasGear  = opts.hasGear,
        onGear   = opts.onGear,
        _ref     = ref,
    }
    if side == "left" then
        section._left[#section._left + 1] = ctrl
    else
        section._right[#section._right + 1] = ctrl
    end
    return ref
end

function ShadowUI:AddSlider(section, side, name, min, max, default, step, callback, opts)
    opts = opts or {}
    local ref = { _value = default or min }
    local ctrl = {
        type     = "slider",
        name     = name,
        min      = min,
        max      = max,
        default  = default,
        step     = step,
        callback = callback,
        enabled  = opts.enabled,
        _ref     = ref,
    }
    if side == "left" then
        section._left[#section._left + 1] = ctrl
    else
        section._right[#section._right + 1] = ctrl
    end
    return ref
end

function ShadowUI:AddDropdown(section, side, name, options, default, callback, opts)
    opts = opts or {}
    local ref = { _value = default or (options and options[1]) }
    local ctrl = {
        type     = "dropdown",
        name     = name,
        options  = options or {},
        default  = default,
        callback = callback,
        enabled  = opts.enabled,
        _ref     = ref,
    }
    if side == "left" then
        section._left[#section._left + 1] = ctrl
    else
        section._right[#section._right + 1] = ctrl
    end
    return ref
end

function ShadowUI:AddSectionHeader(section, side, name)
    local ctrl = { type = "section_header", name = name }
    if side == "left" then
        section._left[#section._left + 1] = ctrl
    else
        section._right[#section._right + 1] = ctrl
    end
end

function ShadowUI:AddLabel(section, side, name)
    local ctrl = { type = "label", name = name }
    if side == "left" then
        section._left[#section._left + 1] = ctrl
    else
        section._right[#section._right + 1] = ctrl
    end
end

-- ────────────────────────────────────────────────────────────────
--  TOGGLE VISIBILITY (keybind)
-- ────────────────────────────────────────────────────────────────
function ShadowUI:SetToggleKey(key)
    UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        if input.KeyCode == key then
            self._visible = not self._visible
            self.Window.Visible = self._visible
        end
    end)
end

return ShadowUI

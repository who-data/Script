--  UTILS
-- ══════════════════════════════════════════════
local function New(cls, props, children)
    local o = Instance.new(cls)
    for k, v in pairs(props) do if k ~= "Parent" then o[k] = v end end
    if children then for _, c in ipairs(children) do c.Parent = o end end
    if props.Parent then o.Parent = props.Parent end
    return o
end

local function Tw(obj, goal, t, sty, dir)
    local ok, err = pcall(function()
        TweenService:Create(obj,
            TweenInfo.new(t or .14, sty or Enum.EasingStyle.Quint, dir or Enum.EasingDirection.Out),
            goal):Play()
    end)
end

local function Corn(r, p)
    return New("UICorner", { CornerRadius = UDim.new(0, r or 4), Parent = p })
end
local function Stro(c, t, p)
    return New("UIStroke", {
        Color=c, Thickness=t or 1,
        ApplyStrokeMode=Enum.ApplyStrokeMode.Border,
        Parent=p,
    })
end
local function Pad(l, r, t, b, p)
    return New("UIPadding", {
        PaddingLeft=UDim.new(0,l), PaddingRight=UDim.new(0,r),
        PaddingTop=UDim.new(0,t), PaddingBottom=UDim.new(0,b),
        Parent=p,
    })
end
local function ListL(p, dir, gap)
    return New("UIListLayout", {
        Parent=p, FillDirection=dir or Enum.FillDirection.Vertical,
        SortOrder=Enum.SortOrder.LayoutOrder, Padding=UDim.new(0, gap or 0),
    })
end
local function AutoCanvas(sc, lay, extra)
    local function update()
        sc.CanvasSize = UDim2.new(0,0,0, lay.AbsoluteContentSize.Y + (extra or 8))
    end
    lay:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(update)
    update()
end
local function MkTxt(p, txt, sz, col, fnt, xa, pos, size, z)
    return New("TextLabel", {
        Parent=p, BackgroundTransparency=1,
        Text=txt or "", TextSize=sz or 12,
        TextColor3=col or T.TxtPri,
        Font=fnt or Enum.Font.Gotham,
        TextXAlignment=xa or Enum.TextXAlignment.Left,
        TextYAlignment=Enum.TextYAlignment.Center,
        Position=pos or UDim2.new(0,0,0,0),
        Size=size or UDim2.new(1,0,1,0),
        ZIndex=z or 2,
        TextTruncate=Enum.TextTruncate.AtEnd,
    })
end
local function MkRow(p, h, z)
    return New("Frame", {
        Parent=p, BackgroundTransparency=1,
        Size=UDim2.new(1,0,0,h or 32), ZIndex=z or 2,
    })
end
local function Sep(p, z)
    local f = New("Frame", {
        Parent=p, BackgroundColor3=T.Border,
        Size=UDim2.new(1,0,0,1), ZIndex=z or 2,
        BackgroundTransparency=0,
    })
    return f
end

local function MakeDraggable(win, handle)
    local drag, inp, st, sp
    handle.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or
           i.UserInputType == Enum.UserInputType.Touch then
            drag=true; st=i.Position; sp=win.Position
            i.Changed:Connect(function()
                if i.UserInputState == Enum.UserInputState.End then drag=false end
            end)
        end
    end)
    handle.InputChanged:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseMovement or
           i.UserInputType == Enum.UserInputType.Touch then inp=i end
    end)
    UIS.InputChanged:Connect(function(i)
        if i==inp and drag then
            local d=i.Position-st
            win.Position=UDim2.new(sp.X.Scale, sp.X.Offset+d.X, sp.Y.Scale, sp.Y.Offset+d.Y)
        end
    end)
end


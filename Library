function Components:Keybind(parent, opts)
    local th = self.theme
    local cn = {}
    local key = opts.Default or Enum.KeyCode.Unknown
    local listening = false

    local frame = U.New("Frame", {
        Size = UDim2.new(1, 0, 0, 38),
        BackgroundColor3 = th:Get("BG3"),
        BorderSizePixel = 0,
        LayoutOrder = opts.LayoutOrder or 0,
        Parent = parent,
    })
    U.Corner(frame, CR_SM)
    U.Pad(frame, 0, 10, 0, 10)

    U.New("TextLabel", {
        Size = UDim2.new(0.62, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = opts.Name or "Keybind",
        TextColor3 = th:Get("Text"),
        TextSize = 12,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = frame,
    })

    local keyBg = U.New("Frame", {
        Size = UDim2.new(0, 72, 0, 24),
        Position = UDim2.new(1, -72, 0.5, -12),
        BackgroundColor3 = th:Get("BG"),
        BorderSizePixel = 0,
        Parent = frame,
    })
    U.Corner(keyBg, CR_SM)
    local kStroke = U.Stroke(keyBg, th:Get("Border"), 1)

    local keyLbl = U.New("TextLabel", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = key == Enum.KeyCode.Unknown and "None" or key.Name,
        TextColor3 = th:Get("AccentHi"),
        TextSize = 11,
        Font = Enum.Font.GothamBold,
        Parent = keyBg,
    })

    local function setListening(state)
        listening = state
        if state then
            keyLbl.Text = "..."
            self.anim:Play(keyLbl, {TextColor3 = th:Get("Warning")}, TI.Fast)
            self.anim:Play(kStroke, {Color = th:Get("Warning")}, TI.Fast)
        else
            keyLbl.Text = key == Enum.KeyCode.Unknown and "None" or key.Name
            self.anim:Play(keyLbl, {TextColor3 = th:Get("AccentHi")}, TI.Fast)
            self.anim:Play(kStroke, {Color = th:Get("Border")}, TI.Fast)
        end
    end

    U.Connect(cn, frame.InputBegan, function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            setListening(not listening)
        end
    end)
    U.Connect(cn, UserInputService.InputBegan, function(inp, gp)
        if not listening then return end
        if inp.UserInputType == Enum.UserInputType.Keyboard then
            key = inp.KeyCode
            setListening(false)
            if opts.Callback then pcall(opts.Callback, key) end
            if opts.Flag then self.config:SetFlag(opts.Flag, key.Name) end
        end
    end)

    local hcn = self:_hover(frame, th:Get("BG4"), th:Get("BG3"))
    for _, c in ipairs(hcn) do table.insert(cn, c) end

    if opts.Tooltip then self.tooltip:Attach(frame, opts.Tooltip) end
    if opts.Flag then
        self.config:RegisterFlag(opts.Flag, key.Name, function(v)
            local kc = Enum.KeyCode[v]
            if kc then key = kc; keyLbl.Text = kc.Name end
        end)
    end

    return {
        Frame   = frame,
        GetKey  = function() return key end,
        SetKey  = function(_, k) key = k; keyLbl.Text = k.Name end,
        Destroy = function() U.Disconn(cn) frame:Destroy() end,
    }
end


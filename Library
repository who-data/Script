-- RENDER
-- ============================================================
function SUI:_Render(sec)
    -- ★ CRÍTICO: limpa TODOS os overlays de slider antes de tudo
    SliderMgr:Clear()
    CloseDD()

    for _,p in ipairs({self.LP,self.RP}) do
        for _,c in ipairs(p:GetChildren()) do
            if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then c:Destroy() end
        end
    end
    for _,c in ipairs(self.TList:GetChildren()) do
        if not c:IsA("UIListLayout") then c:Destroy() end
    end

    -- Tabs
    for _,s in ipairs(sec._cat._secs) do
        local act = (s==sec)
        local t = N("Frame",{Parent=self.TList,BackgroundTransparency=1,
            Size=UDim2.new(0,90,1,0),ZIndex=3})
        if act then
            N("Frame",{Parent=t,BackgroundColor3=T.ACC,
                Position=UDim2.new(0,0,1,-2),Size=UDim2.new(1,0,0,2),ZIndex=5})
        end
        N("Frame",{Parent=t,BackgroundColor3=act and T.ACC or T.ACCLO,
            Position=UDim2.new(0,7,0.5,-3),Size=UDim2.new(0,7,0,7),
            Rotation=45,ZIndex=4})
        Lb(t,s.Name,11,act and T.TACC or T.TSEC,
            act and Enum.Font.GothamBold or Enum.Font.Gotham,
            Enum.TextXAlignment.Left,UDim2.new(0,19,0,0),UDim2.new(1,-19,1,0),4)
    end

    for _,ctrl in ipairs(sec._left)  do self:_Build(self.LP,  ctrl) end
    for _,ctrl in ipairs(sec._right) do self:_Build(self.RP, ctrl) end
end

-- ============================================================
-- BUILD
-- ============================================================
function SUI:_Build(p, ctrl)
    if ctrl.type=="toggle"   then return self:_Toggle(p,ctrl)   end
    if ctrl.type=="slider"   then return self:_Slider(p,ctrl)   end
    if ctrl.type=="dropdown" then return self:_Dropdown(p,ctrl) end
    if ctrl.type=="header"   then return self:_Header(p,ctrl)   end
    if ctrl.type=="label"    then return self:_Label(p,ctrl)    end
    if ctrl.type=="raw"      then return ctrl.fn(p)             end
end


--  DROPDOWN
-- ──────────────────────────────────────────────
function ShadowUI:_BuildDropdown(parent, ctrl)
    local row     = MakeRow(parent, 36)
    local options = ctrl.options or {}
    local value   = ctrl.default or options[1]

    Create("TextLabel", {
        Parent               = row,
        BackgroundTransparency = 1,
        Position             = UDim2.new(0, 0, 0, 0),
        Size                 = UDim2.new(1, 0, 0, 16),
        Font                 = Enum.Font.Gotham,
        Text                 = ctrl.text or "Dropdown",
        TextColor3           = Theme.TextSecondary,
        TextSize             = 11,
        TextXAlignment       = Enum.TextXAlignment.Left,
    })

    local Box = Create("Frame", {
        Parent           = row,
        BackgroundColor3 = Theme.Dropdown,
        BorderSizePixel  = 0,
        Position         = UDim2.new(0, 0, 0, 18),
        Size             = UDim2.new(1, 0, 0, 22),
    })
    Create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = Box })

    local Selected = Create("TextLabel", {
        Parent               = Box,
        BackgroundTransparency = 1,
        Position             = UDim2.new(0, 8, 0, 0),
        Size                 = UDim2.new(1, -24, 1, 0),
        Font                 = Enum.Font.Gotham,
        Text                 = tostring(value),
        TextColor3           = Theme.TextPrimary,
        TextSize             = 12,
        TextXAlignment       = Enum.TextXAlignment.Left,
    })

    Create("TextLabel", {
        Parent               = Box,
        BackgroundTransparency = 1,
        Position             = UDim2.new(1, -20, 0, 0),
        Size                 = UDim2.new(0, 16, 1, 0),
        Font                 = Enum.Font.GothamBold,
        Text                 = "▾",
        TextColor3           = Theme.TextSecondary,
        TextSize             = 12,
    })

    local open = false
    local DropList

    local function CloseList()
        if DropList then DropList:Destroy() DropList = nil end
        open = false
    end

    local function SetValue(v)
        value         = v
        Selected.Text = tostring(v)
        CloseList()
        if ctrl.callback then ctrl.callback(v) end
    end

    local Btn = Create("TextButton", {
        Parent               = Box,
        BackgroundTransparency = 1,
        BorderSizePixel      = 0,
        Size                 = UDim2.new(1, 0, 1, 0),
        Text                 = "",
        ZIndex               = 2,
    })
    Btn.MouseButton1Click:Connect(function()
        if open then CloseList() return end
        open    = true
        DropList = Create("Frame", {
            Parent           = Box,
            BackgroundColor3 = Theme.Dropdown,
            BorderSizePixel  = 0,
            Position         = UDim2.new(0, 0, 1, 2),
            Size             = UDim2.new(1, 0, 0, #options * 22),
            ZIndex           = 10,
            ClipsDescendants = true,
        })
        Create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = DropList })
        Create("UIListLayout", { Parent = DropList, SortOrder = Enum.SortOrder.LayoutOrder })
        for _, opt in ipairs(options) do
            local Item = Create("TextButton", {
                Parent               = DropList,
                BackgroundColor3     = Theme.Dropdown,
                BorderSizePixel      = 0,
                Size                 = UDim2.new(1, 0, 0, 22),
                Font                 = Enum.Font.Gotham,
                Text                 = tostring(opt),
                TextColor3           = Theme.TextPrimary,
                TextSize             = 12,
                AutoButtonColor      = false,
                ZIndex               = 11,
            })
            Item.MouseEnter:Connect(function() Item.BackgroundColor3 = Theme.DropdownHover end)
            Item.MouseLeave:Connect(function() Item.BackgroundColor3 = Theme.Dropdown end)
            Item.MouseButton1Click:Connect(function() SetValue(opt) end)
        end
    end)

    ctrl._setValue = SetValue
    ctrl._getValue = function() return value end
    return row
end


    self.Active = state
    local theme = self.Factory.Theme
    local anim  = self.Factory.Anim
    if state then
        anim:Play(self.Button, {BackgroundColor3 = theme:Get("SurfaceAlt")}, TWEEN_SHORT)
        anim:Play(self.Label, {TextColor3 = theme:Get("Text"), }, TWEEN_SHORT)
        anim:Play(self.ActiveBar, {BackgroundTransparency = 0, Size = UDim2.new(0, 3, 0.6, 0)}, TWEEN_SHORT)
        self.Label.Font = Enum.Font.GothamBold
        self.Scroll.Visible = true
    else
        anim:Play(self.Button, {BackgroundColor3 = theme:Get("Background")}, TWEEN_SHORT)
        anim:Play(self.Label, {TextColor3 = theme:Get("TextMuted")}, TWEEN_SHORT)
        anim:Play(self.ActiveBar, {BackgroundTransparency = 1, Size = UDim2.new(0, 3, 0.5, 0)}, TWEEN_SHORT)
        self.Label.Font = Enum.Font.Gotham
        self.Scroll.Visible = false
    end
end

function Tab:CreateSection(opts)
    local opts = type(opts) == "string" and {Name = opts} or opts
    opts.LayoutOrder = #self.Sections + 1
    local section = Section.new(self.ContentList, opts, self.Factory)
    table.insert(self.Sections, section)
    return section
end

function Tab:CreateSubTab(name)
    -- SubTabs within a tab
    local subtab = {Name = name, Sections = {}}
    table.insert(self.SubTabs, subtab)
    return subtab
end


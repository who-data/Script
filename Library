    Pad(6,6,0,0, Row)

    Row.MouseEnter:Connect(function()
        if not cat._expanded then
            Tw(Row, {BackgroundColor3=T.RowHov}, .08)
            Row.BackgroundTransparency=0
        end
    end)
    Row.MouseLeave:Connect(function()
        if not cat._expanded then Row.BackgroundTransparency=1 end
    end)

    -- Ícone
    local IcoRing = New("Frame", {
        Parent=Row, BackgroundTransparency=1,
        Position=UDim2.new(0,5,0.5,-7), Size=UDim2.new(0,14,0,14), ZIndex=7,
    })
    Corn(7, IcoRing)
    Stro(T.TxtSec, 1.2, IcoRing)
    New("Frame", {
        Parent=Row, BackgroundColor3=T.TxtSec,
        Position=UDim2.new(0,9,0.5,-4), Size=UDim2.new(0,8,0,8), ZIndex=8,
    })
    Corn(4, Row:FindFirstChildOfClass("Frame"))
    cat._icoRing = IcoRing

    MkTxt(Row, name, 11, T.TxtPri, Enum.Font.GothamBold,
        Enum.TextXAlignment.Left,
        UDim2.new(0,24,0,0), UDim2.new(1,-44,1,0), 7)

    local Chev = MkTxt(Row, "›", 14, T.TxtDim, Enum.Font.GothamBold,
        Enum.TextXAlignment.Center,
        UDim2.new(1,-18,0,0), UDim2.new(0,14,1,0), 7)

    -- Container das subseções
    local SF = New("Frame", {
        Parent=self.SideList, BackgroundTransparency=1,
        Size=UDim2.new(1,0,0,0), ClipsDescendants=true, Visible=false, ZIndex=6,
    })
    local SL = ListL(SF)
    cat._row=Row; cat._sf=SF; cat._sl=SL; cat._chev=Chev

    Row.MouseButton1Click:Connect(function()
        cat._expanded = not cat._expanded
        if cat._expanded then
            SF.Visible=true
            SF.Size=UDim2.new(1,0,0,SL.AbsoluteContentSize.Y)
            Chev.Text="↓"; Row.BackgroundTransparency=0
            Tw(Row, {BackgroundColor3=T.RowHov}, .08)
            Stro(T.Accent, 1.3, IcoRing)
            if #cat._sections>0 and not cat._sections[1]._active then
                cat._sections[1]._btn.MouseButton1Click:Fire()
            end
        else
            SF.Visible=false; SF.Size=UDim2.new(1,0,0,0)
            Chev.Text="›"; Row.BackgroundTransparency=1
            Stro(T.TxtSec, 1.2, IcoRing)
        end
    end)

    self._sidebar[#self._sidebar+1]=cat
    return cat
end

-- ══════════════════════════════════════════════
--  ADD SECTION
-- ══════════════════════════════════════════════
function ShadowUI:AddSection(cat, name)
    local sec = {Name=name, _cat=cat, _active=false, _left={}, _right={}, _ui=self}

    local Btn = New("TextButton", {
        Parent=cat._sf, BackgroundTransparency=1,
        Size=UDim2.new(1,0,0,27), Text="",
        AutoButtonColor=false, ZIndex=7,
    })
    Corn(4, Btn)

    -- Accent bar lateral
    local AccBar = New("Frame", {
        Parent=Btn, BackgroundColor3=T.Accent,
        Position=UDim2.new(0,3,0.18,0), Size=UDim2.new(0,2,0.64,0),
        ZIndex=9, Visible=false,
    })
    Corn(1, AccBar)

    -- Diamond
    local Dia = New("Frame", {
        Parent=Btn, BackgroundColor3=T.AccentDim,
        Position=UDim2.new(0,14,0.5,-4), Size=UDim2.new(0,8,0,8),
        Rotation=45, ZIndex=8,
    })

    local Lbl_ = MkTxt(Btn, name, 11, T.TxtSec, Enum.Font.Gotham,
        Enum.TextXAlignment.Left, UDim2.new(0,28,0,0), UDim2.new(1,-32,1,0), 8)

    sec._btn=Btn; sec._dia=Dia; sec._lbl=Lbl_; sec._accBar=AccBar

    Btn.MouseEnter:Connect(function()
        if not sec._active then
            Tw(Btn, {BackgroundColor3=T.RowHov}, .08)
            Btn.BackgroundTransparency=0
        end
    end)
    Btn.MouseLeave:Connect(function()
        if not sec._active then Btn.BackgroundTransparency=1 end
    end)

    Btn.MouseButton1Click:Connect(function()
        if self._activeSec then
            local p=self._activeSec
            p._active=false; p._lbl.TextColor3=T.TxtSec
            p._dia.BackgroundColor3=T.AccentDim
            p._accBar.Visible=false; p._btn.BackgroundTransparency=1
        end
        sec._active=true; Lbl_.TextColor3=T.TxtAcc
        Dia.BackgroundColor3=T.Accent; AccBar.Visible=true
        Btn.BackgroundColor3=T.RowHov; Btn.BackgroundTransparency=0
        self._activeSec=sec
        self:_Bread(cat.Name, name)
        self:_Render(sec)
    end)

    cat._sections[#cat._sections+1]=sec
    cat._sf.Size=UDim2.new(1,0,0,cat._sl.AbsoluteContentSize.Y+27)
    return sec
end

-- ══════════════════════════════════════════════
--  RENDER
-- ══════════════════════════════════════════════
function ShadowUI:_Render(sec)
    CloseActiveDropdown()
    for _, p in ipairs({self.LeftScroll,self.RightScroll}) do
        for _, c in ipairs(p:GetChildren()) do
            if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then c:Destroy() end
        end
    end
    for _, c in ipairs(self.TabList:GetChildren()) do
        if not c:IsA("UIListLayout") then c:Destroy() end
    end

    -- Tabs
    for _, s in ipairs(sec._cat._sections) do
        local act = (s==sec)
        local Tab = New("Frame", {
            Parent=self.TabList, BackgroundTransparency=1,
            Size=UDim2.new(0,80,1,0), ZIndex=3,
        })
        if act then
            New("Frame", {
                Parent=Tab, BackgroundColor3=T.Accent,
                Position=UDim2.new(0,0,1,-2), Size=UDim2.new(1,0,0,2), ZIndex=5,
            })
        end
        New("Frame", {
            Parent=Tab, BackgroundColor3=act and T.Accent or T.AccentDim,
            Position=UDim2.new(0,5,0.5,-3), Size=UDim2.new(0,6,0,6),
            Rotation=45, ZIndex=4,
        })
        MkTxt(Tab, s.Name, 10, act and T.TxtAcc or T.TxtSec,
            act and Enum.Font.GothamBold or Enum.Font.Gotham,
            Enum.TextXAlignment.Left, UDim2.new(0,16,0,0), UDim2.new(1,-16,1,0), 4)
    end

    for _, ctrl in ipairs(sec._left)  do self:_Build(self.LeftScroll, ctrl) end
    for _, ctrl in ipairs(sec._right) do self:_Build(self.RightScroll, ctrl) end
end

-- ══════════════════════════════════════════════
--  BUILD
-- ══════════════════════════════════════════════
function ShadowUI:_Build(p, ctrl)
    if ctrl.type=="toggle"   then return self:_BToggle(p,ctrl)   end
    if ctrl.type=="slider"   then return self:_BSlider(p,ctrl)   end
    if ctrl.type=="dropdown" then return self:_BDropdown(p,ctrl) end
    if ctrl.type=="header"   then return self:_BHeader(p,ctrl)   end
    if ctrl.type=="label"    then return self:_BLabel(p,ctrl)    end
    if ctrl.type=="__custom" then return ctrl._build(p)          end
end

-- ══════════════════════════════════════════════
--  TOGGLE
-- ══════════════════════════════════════════════
function ShadowUI:_BToggle(parent, ctrl)

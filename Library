-- ──────────────────────────────────────────────
function ShadowUI:AddSection(category, name)
    local sec = { Name = name, _cat = category, _active = false, _left = {}, _right = {}, _self = self }

    local Btn = Create("TextButton", {
        Parent               = category._sectionsFrame,
        BackgroundTransparency = 1,
        Size                 = UDim2.new(1, 0, 0, 26),
        Font                 = Enum.Font.Gotham,
        Text                 = "",
        AutoButtonColor      = false,
        ZIndex               = 5,
    })

    local Diamond = Create("Frame", {
        Parent           = Btn,
        BackgroundColor3 = Theme.AccentDim,
        BorderSizePixel  = 0,
        Position         = UDim2.new(0, 22, 0.5, -5),
        Size             = UDim2.new(0, 9, 0, 9),
        Rotation         = 45,
        ZIndex           = 6,
    })

    local Label = Create("TextLabel", {
        Parent               = Btn,
        BackgroundTransparency = 1,
        Position             = UDim2.new(0, 38, 0, 0),
        Size                 = UDim2.new(1, -42, 1, 0),
        Font                 = Enum.Font.Gotham,
        Text                 = name,
        TextColor3           = Theme.TextSecondary,
        TextSize             = 12,
        TextXAlignment       = Enum.TextXAlignment.Left,
        ZIndex               = 6,
    })

    sec._button  = Btn
    sec._label   = Label
    sec._diamond = Diamond

    Btn.MouseButton1Click:Connect(function()
        if self._activeSection then
            local prev = self._activeSection
            prev._active                   = false
            prev._label.TextColor3         = Theme.TextSecondary
            prev._diamond.BackgroundColor3 = Theme.AccentDim
        end
        sec._active              = true
        Label.TextColor3         = Theme.TextPrimary
        Diamond.BackgroundColor3 = Theme.White
        self._activeSection      = sec
        self:_UpdateBreadcrumb(category.Name, name)
        self:_RefreshPanels(sec)
    end)

    category._sections[#category._sections + 1] = sec
    local total = category._sectionsList.AbsoluteContentSize.Y + 26
    category._sectionsFrame.Size = UDim2.new(1, 0, 0, total)

    return sec
end

-- ──────────────────────────────────────────────
--  REFRESH PANELS
-- ──────────────────────────────────────────────
function ShadowUI:_RefreshPanels(section)
    for _, panel in ipairs({ self.LeftPanel, self.RightPanel }) do
        for _, c in ipairs(panel:GetChildren()) do
            if c:IsA("Frame") or c:IsA("TextButton") then c:Destroy() end
        end
    end
    for _, c in ipairs(self.TabBarList:GetChildren()) do
        if not c:IsA("UIListLayout") then c:Destroy() end
    end

    for _, s in ipairs(section._cat._sections) do
        local isActive = (s.Name == section.Name)
        local Tab = Create("Frame", {
            Parent               = self.TabBarList,
            BackgroundTransparency = 1,
            Size                 = UDim2.new(0, 90, 1, 0),
            ZIndex               = 3,
        })
        Create("Frame", {
            Parent           = Tab,
            BackgroundColor3 = isActive and Theme.White or Theme.AccentDim,
            BorderSizePixel  = 0,
            Position         = UDim2.new(0, 2, 0.5, -4),
            Size             = UDim2.new(0, 8, 0, 8),
            Rotation         = 45,
            ZIndex           = 4,
        })
        Create("TextLabel", {
            Parent               = Tab,
            BackgroundTransparency = 1,
            Position             = UDim2.new(0, 16, 0, 0),
            Size                 = UDim2.new(1, -16, 1, 0),
            Font                 = Enum.Font.Gotham,
            Text                 = s.Name,
            TextColor3           = isActive and Theme.TextPrimary or Theme.TextSecondary,
            TextSize             = 11,
            TextXAlignment       = Enum.TextXAlignment.Left,
            ZIndex               = 4,
        })
    end

    for _, ctrl in ipairs(section._left)  do self:_BuildControl(self.LeftPanel,  ctrl) end
    for _, ctrl in ipairs(section._right) do self:_BuildControl(self.RightPanel, ctrl) end
end

-- ──────────────────────────────────────────────
--  CONTROL DISPATCHER
-- ──────────────────────────────────────────────
function ShadowUI:_BuildControl(parent, ctrl)
    if ctrl.type == "toggle"         then return self:_BuildToggle(parent, ctrl)        end
    if ctrl.type == "slider"         then return self:_BuildSlider(parent, ctrl)        end
    if ctrl.type == "dropdown"       then return self:_BuildDropdown(parent, ctrl)      end
    if ctrl.type == "section_header" then return self:_BuildSectionHeader(parent, ctrl) end
    if ctrl.type == "label"          then return self:_BuildLabel(parent, ctrl)         end
end


    local acBar = N("Frame",{Parent=row,BackgroundColor3=T.ACC,
        Position=UDim2.new(0,2,0.2,0),Size=UDim2.new(0,2,0.6,0),
        ZIndex=9,Visible=false}); Cr(1,acBar)

    -- Ícone duplo anel
    local r1 = N("Frame",{Parent=row,BackgroundTransparency=1,
        Position=UDim2.new(0,11,0.5,-8),Size=UDim2.new(0,16,0,16),ZIndex=8})
    Cr(8,r1); Sk(T.TSEC,1.3,r1)
    local r2 = N("Frame",{Parent=row,BackgroundColor3=T.TSEC,
        Position=UDim2.new(0,15,0.5,-4),Size=UDim2.new(0,8,0,8),ZIndex=9})
    Cr(4,r2)

    Lb(row,name,12,T.TPRI,Enum.Font.GothamBold,
        Enum.TextXAlignment.Left,UDim2.new(0,34,0,0),UDim2.new(1,-56,1,0),8)
    local chev = Lb(row,"›",16,T.TDIM,Enum.Font.GothamBold,
        Enum.TextXAlignment.Center,UDim2.new(1,-22,0,0),UDim2.new(0,18,1,0),8)

    -- Container das seções
    local sf  = N("Frame",{Parent=self.SS,BackgroundTransparency=1,
        Size=UDim2.new(1,0,0,0),ClipsDescendants=true,Visible=false,ZIndex=7})
    local sfl = Ly(sf)
    cat._row=row; cat._sf=sf; cat._sfl=sfl; cat._chev=chev
    cat._r1=r1; cat._r2=r2; cat._acBar=acBar

    row.MouseEnter:Connect(function()
        if not cat._open then TW(row,{BackgroundColor3=T.EHOV},.08); row.BackgroundTransparency=0 end
    end)
    row.MouseLeave:Connect(function()
        if not cat._open then row.BackgroundTransparency=1 end
    end)

    row.MouseButton1Click:Connect(function()
        cat._open = not cat._open
        if cat._open then
            sf.Visible=true
            sf.Size=UDim2.new(1,0,0,sfl.AbsoluteContentSize.Y)
            chev.Text="↓"
            TW(row,{BackgroundColor3=T.EHOV},.08); row.BackgroundTransparency=0
            acBar.Visible=true; Sk(T.ACC,1.3,r1); r2.BackgroundColor3=T.ACC
            if #cat._secs>0 and not cat._secs[1]._active then
                cat._secs[1]._btn.MouseButton1Click:Fire()
            end
        else
            sf.Visible=false; sf.Size=UDim2.new(1,0,0,0); chev.Text="›"
            row.BackgroundTransparency=1; acBar.Visible=false
            Sk(T.TSEC,1.3,r1); r2.BackgroundColor3=T.TSEC
        end
    end)

    self._cats[#self._cats+1] = cat
    return cat
end


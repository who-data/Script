function ShadowUI:GetThemeNames()
    local names = {}
    for k in pairs(Themes) do names[#names + 1] = k end
    return names
end

-- ══════════════════════════════════════════════════════════════════
--  CATEGORY (sidebar top-level)
-- ══════════════════════════════════════════════════════════════════
function ShadowUI:AddCategory(name)
    local cat = { Name = name, _sections = {}, _expanded = false, _self = self }

    -- Category row
    local Row = Create("TextButton", {
        Parent               = self.SidebarList,
        BackgroundColor3     = Theme.Sidebar,
        BorderSizePixel      = 0,
        Size                 = UDim2.new(1, 0, 0, 34),
        Font                 = Enum.Font.GothamBold,
        Text                 = "",
        AutoButtonColor      = false,
    })
    Create("UIPadding", { PaddingLeft = UDim.new(0, 2), PaddingRight = UDim.new(0, 2), Parent = Row })

    -- Hover tint
    Row.MouseEnter:Connect(function() Tween(Row, { BackgroundColor3 = Theme.RowHover }, 0.1) end)
    Row.MouseLeave:Connect(function() Tween(Row, { BackgroundColor3 = Theme.Sidebar }, 0.1) end)

    -- Category icon dot (filled circle)
    local CatDot = Create("Frame", {
        Parent           = Row,
        BackgroundColor3 = Theme.AccentColor,
        BorderSizePixel  = 0,
        Position         = UDim2.new(0, 12, 0.5, -5),
        Size             = UDim2.new(0, 10, 0, 10),
    })
    RoundCorner(CatDot, 5)

    Create("TextLabel", {
        Parent               = Row,
        BackgroundTransparency = 1,
        Position             = UDim2.new(0, 30, 0, 0),
        Size                 = UDim2.new(1, -44, 1, 0),
        Font                 = Enum.Font.GothamBold,
        Text                 = name,
        TextColor3           = Theme.TextPrimary,
        TextSize             = 13,
        TextXAlignment       = Enum.TextXAlignment.Left,
    })

    -- Chevron indicator
    local Chevron = Create("TextLabel", {
        Parent               = Row,
        BackgroundTransparency = 1,
        Position             = UDim2.new(1, -22, 0, 0),
        Size                 = UDim2.new(0, 18, 1, 0),
        Font                 = Enum.Font.GothamBold,
        Text                 = "›",
        TextColor3           = Theme.TextSecondary,
        TextSize             = 14,
    })

    local SectionsFrame = Create("Frame", {
        Parent               = self.SidebarList,
        BackgroundTransparency = 1,
        Size                 = UDim2.new(1, 0, 0, 0),
        ClipsDescendants     = true,
        Visible              = false,
    })
    local SectionsList = Create("UIListLayout", {
        Parent    = SectionsFrame,
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding   = UDim.new(0, 0),
    })

    cat._row           = Row
    cat._sectionsFrame = SectionsFrame
    cat._sectionsList  = SectionsList
    cat._chevron       = Chevron
    cat._dot           = CatDot

    Row.MouseButton1Click:Connect(function()
        cat._expanded = not cat._expanded
        if cat._expanded then
            Chevron.Text          = "⌄"
            Chevron.TextColor3    = Theme.AccentColor
            CatDot.BackgroundColor3 = Theme.AccentColor
            SectionsFrame.Size    = UDim2.new(1, 0, 0, SectionsList.AbsoluteContentSize.Y)
            SectionsFrame.Visible = true
            if #cat._sections > 0 and not cat._sections[1]._active then
                cat._sections[1]._button.MouseButton1Click:Fire()
            end
        else
            Chevron.Text          = "›"
            Chevron.TextColor3    = Theme.TextSecondary
            CatDot.BackgroundColor3 = Theme.AccentColor
            SectionsFrame.Visible = false
            SectionsFrame.Size    = UDim2.new(1, 0, 0, 0)
        end
    end)

    self._sidebar[#self._sidebar + 1] = cat
    return cat
end

-- ══════════════════════════════════════════════════════════════════
--  SECTION (sub-tab under a category)
-- ══════════════════════════════════════════════════════════════════
function ShadowUI:AddSection(category, name)
    local sec = { Name = name, _cat = category, _active = false, _left = {}, _right = {}, _self = self }
    local indent = 26

    local Btn = Create("TextButton", {
        Parent               = category._sectionsFrame,
        BackgroundColor3     = Theme.Sidebar,
        BorderSizePixel      = 0,
        Size                 = UDim2.new(1, 0, 0, 28),
        Font                 = Enum.Font.Gotham,
        Text                 = "",
        AutoButtonColor      = false,
    })

    Btn.MouseEnter:Connect(function()
        if not sec._active then Tween(Btn, { BackgroundColor3 = Theme.RowHover }, 0.1) end
    end)
    Btn.MouseLeave:Connect(function()
        if not sec._active then Tween(Btn, { BackgroundColor3 = Theme.Sidebar }, 0.1) end
    end)

    -- Active indicator bar
    local ActiveBar = Create("Frame", {
        Parent           = Btn,
        BackgroundColor3 = Theme.AccentColor,
        BorderSizePixel  = 0,
        Position         = UDim2.new(0, 0, 0.15, 0),
        Size             = UDim2.new(0, 2, 0.7, 0),
        Visible          = false,
    })
    RoundCorner(ActiveBar, 2)

    local Diamond = Create("Frame", {
        Parent           = Btn,
        BackgroundColor3 = Theme.AccentDim,
        BorderSizePixel  = 0,
        Position         = UDim2.new(0, indent, 0.5, -4),
        Size             = UDim2.new(0, 7, 0, 7),
        Rotation         = 45,
    })
    local Label = Create("TextLabel", {
        Parent               = Btn,
        BackgroundTransparency = 1,
        Position             = UDim2.new(0, indent + 14, 0, 0),
        Size                 = UDim2.new(1, -(indent + 18), 1, 0),
        Font                 = Enum.Font.Gotham,
        Text                 = name,
        TextColor3           = Theme.TextSecondary,
        TextSize             = 12,
        TextXAlignment       = Enum.TextXAlignment.Left,
    })

    sec._button   = Btn
    sec._label    = Label
    sec._diamond  = Diamond
    sec._activeBar = ActiveBar

    Btn.MouseButton1Click:Connect(function()
        if self._activeSection then
            self._activeSection._active                 = false
            self._activeSection._label.TextColor3       = Theme.TextSecondary
            self._activeSection._diamond.BackgroundColor3 = Theme.AccentDim
            self._activeSection._activeBar.Visible      = false
            Tween(self._activeSection._button, { BackgroundColor3 = Theme.Sidebar }, 0.12)
        end
        sec._active              = true
        Label.TextColor3         = Theme.TextPrimary
        Diamond.BackgroundColor3 = Theme.AccentColor
        ActiveBar.Visible        = true
        Tween(Btn, { BackgroundColor3 = Theme.RowHover }, 0.12)
        self._activeSection       = sec
        self.BreadcrumbLabel.Text = category.Name .. "  ›  " .. name
        self:_RefreshPanels(sec)
    end)

    category._sections[#category._sections + 1] = sec
    local total = category._sectionsList.AbsoluteContentSize.Y + 28
    category._sectionsFrame.Size = UDim2.new(1, 0, 0, total)

    return sec
end

-- ══════════════════════════════════════════════════════════════════
--  REFRESH PANELS
-- ══════════════════════════════════════════════════════════════════
function ShadowUI:_RefreshPanels(section)
    for _, c in ipairs(self.LeftPanel:GetChildren()) do
        if c:IsA("Frame") or c:IsA("TextButton") then c:Destroy() end
    end
    for _, c in ipairs(self.RightPanel:GetChildren()) do
        if c:IsA("Frame") or c:IsA("TextButton") then c:Destroy() end
    end
    for _, c in ipairs(self.TabBarList:GetChildren()) do
        if not c:IsA("UIListLayout") then c:Destroy() end
    end

    -- Rebuild tab bar pills
    for _, s in ipairs(section._cat._sections) do
        local isActive = (s.Name == section.Name)

        local Pill = Create("TextButton", {
            Parent               = self.TabBarList,
            BackgroundColor3     = isActive and Theme.ButtonBg or Color3.fromRGB(0,0,0),
            BackgroundTransparency = isActive and 0 or 1,
            BorderSizePixel      = 0,
            Size                 = UDim2.new(0, 0, 0, 22),
            AutoButtonColor      = false,
            Text                 = "",
            AutomaticSize        = Enum.AutomaticSize.X,
        })
        RoundCorner(Pill, 6)
        if isActive then
            Create("UIStroke", { Color = Theme.BorderGlow, Thickness = 1, Parent = Pill })
        end
        Create("UIPadding", {
            PaddingLeft  = UDim.new(0, 10),
            PaddingRight = UDim.new(0, 10),
            Parent       = Pill,
        })

        -- Mini dot
        local PillDot = Create("Frame", {
            Parent           = Pill,
            BackgroundColor3 = isActive and Theme.AccentColor or Theme.AccentDim,
            BorderSizePixel  = 0,
            Position         = UDim2.new(0, 0, 0.5, -3),
            Size             = UDim2.new(0, 6, 0, 6),
            Rotation         = 45,
        })
        Create("TextLabel", {
            Parent               = Pill,
            BackgroundTransparency = 1,
            Position             = UDim2.new(0, 12, 0, 0),
            Size                 = UDim2.new(1, -12, 1, 0),
            Font                 = Enum.Font.Gotham,
            Text                 = s.Name,
            TextColor3           = isActive and Theme.TextPrimary or Theme.TextSecondary,
            TextSize             = 11,
            TextXAlignment       = Enum.TextXAlignment.Left,
        })

        if not isActive then
            Pill.MouseEnter:Connect(function()
                Tween(Pill, { BackgroundTransparency = 0.7, BackgroundColor3 = Theme.RowHover }, 0.1)
            end)
            Pill.MouseLeave:Connect(function()
                Tween(Pill, { BackgroundTransparency = 1 }, 0.1)
            end)
            Pill.MouseButton1Click:Connect(function()
                s._button.MouseButton1Click:Fire()
            end)
        end
    end

    for _, ctrl in ipairs(section._left)  do self:_BuildControl(self.LeftPanel,  ctrl) end
    for _, ctrl in ipairs(section._right) do self:_BuildControl(self.RightPanel, ctrl) end
end

-- ══════════════════════════════════════════════════════════════════
--  CONTROL DISPATCH
-- ══════════════════════════════════════════════════════════════════
function ShadowUI:_BuildControl(parent, ctrl)
    if ctrl.type == "toggle"         then return self:_BuildToggle(parent, ctrl)        end
    if ctrl.type == "slider"         then return self:_BuildSlider(parent, ctrl)        end
    if ctrl.type == "dropdown"       then return self:_BuildDropdown(parent, ctrl)      end
    if ctrl.type == "section_header" then return self:_BuildSectionHeader(parent, ctrl) end
    if ctrl.type == "label"          then return self:_BuildLabel(parent, ctrl)         end
    if ctrl.type == "config"         then return self:_BuildConfig(parent, ctrl)        end
end

local function MakeRow(parent, height)
    return Create("Frame", {
        Parent               = parent,
        BackgroundTransparency = 1,
        BorderSizePixel      = 0,
        Size                 = UDim2.new(1, 0, 0, height or 38),
    })
end

local function ControlWrap(parent, height)
    local wrap = Create("Frame", {
        Parent           = parent,
        BackgroundColor3 = Theme.ControlBg,
        BorderSizePixel  = 0,
        Size             = UDim2.new(1, 0, 0, height or 38),
    })
    RoundCorner(wrap, 8)
    Create("UIStroke", { Color = Theme.Border, Thickness = 1, Parent = wrap })
    -- Margin frame
    local margin = Create("Frame", {
        Parent               = parent,
        BackgroundTransparency = 1,
        BorderSizePixel      = 0,
        Size                 = UDim2.new(1, 0, 0, 4),
    })
    return wrap
end

-- ══════════════════════════════════════════════════════════════════
--  TOGGLE
-- ══════════════════════════════════════════════════════════════════
function ShadowUI:_BuildToggle(parent, ctrl)
    local wrap  = ControlWrap(parent, 38)
    local value = ctrl.default or false

    Create("TextLabel", {
        Parent               = wrap,
        BackgroundTransparency = 1,
        Position             = UDim2.new(0, 12, 0, 0),
        Size                 = UDim2.new(1, -70, 1, 0),
        Font                 = Enum.Font.Gotham,
        Text                 = ctrl.name or "Toggle",
        TextColor3           = Theme.TextPrimary,
        TextSize             = 12,
        TextXAlignment       = Enum.TextXAlignment.Left,
    })
    if ctrl.description then
        Create("TextLabel", {
            Parent               = wrap,
            BackgroundTransparency = 1,
            Position             = UDim2.new(0, 12, 0.52, 0),
            Size                 = UDim2.new(1, -70, 0, 14),
            Font                 = Enum.Font.Gotham,
            Text                 = ctrl.description,
            TextColor3           = Theme.TextSecondary,
            TextSize             = 10,
            TextXAlignment       = Enum.TextXAlignment.Left,
        })
    end

    -- Track
    local Track = Create("Frame", {
        Parent           = wrap,
        BackgroundColor3 = value and Theme.ToggleOn or Theme.ToggleOff,
        BorderSizePixel  = 0,
        Position         = UDim2.new(1, -50, 0.5, -9),
        Size             = UDim2.new(0, 36, 0, 18),
    })
    RoundCorner(Track, 9)

    -- Thumb
    local Thumb = Create("Frame", {
        Parent           = Track,
        BackgroundColor3 = Theme.White,
        BorderSizePixel  = 0,
        Position         = value and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7),
        Size             = UDim2.new(0, 14, 0, 14),
    })
    RoundCorner(Thumb, 7)

    local ToggleBtn = Create("TextButton", {
        Parent               = wrap,
        BackgroundTransparency = 1,
        Position             = UDim2.new(0, 0, 0, 0),
        Size                 = UDim2.new(1, 0, 1, 0),
        Text                 = "",
        AutoButtonColor      = false,
    })

    ToggleBtn.MouseButton1Click:Connect(function()
        value = not value
        Tween(Track, { BackgroundColor3 = value and Theme.ToggleOn or Theme.ToggleOff }, 0.15)
        Tween(Thumb, { Position = value and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7) }, 0.15)
        if ctrl.callback then ctrl.callback(value) end
    end)

    -- Hover highlight
    ToggleBtn.MouseEnter:Connect(function()
        Tween(wrap, { BackgroundColor3 = Theme.PanelAlt }, 0.1)
    end)
    ToggleBtn.MouseLeave:Connect(function()
        Tween(wrap, { BackgroundColor3 = Theme.ControlBg }, 0.1)
    end)

    ctrl._track = Track
    ctrl._thumb = Thumb
    ctrl._value = function() return value end
    ctrl._set   = function(v)
        value = v
        Tween(Track, { BackgroundColor3 = v and Theme.ToggleOn or Theme.ToggleOff }, 0.15)
        Tween(Thumb, { Position = v and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7) }, 0.15)
    end
end

-- ══════════════════════════════════════════════════════════════════
--  SLIDER
-- ══════════════════════════════════════════════════════════════════
function ShadowUI:_BuildSlider(parent, ctrl)
    local wrap  = ControlWrap(parent, 50)
    local min   = ctrl.min     or 0
    local max   = ctrl.max     or 100
    local value = ctrl.default or min
    local step  = ctrl.step    or 1

    -- Label row
    local NameLabel = Create("TextLabel", {
        Parent               = wrap,
        BackgroundTransparency = 1,
        Position             = UDim2.new(0, 12, 0, 6),
        Size                 = UDim2.new(0.6, -12, 0, 16),
        Font                 = Enum.Font.Gotham,
        Text                 = ctrl.name or "Slider",
        TextColor3           = Theme.TextPrimary,
        TextSize             = 12,
        TextXAlignment       = Enum.TextXAlignment.Left,
    })
    local ValLabel = Create("TextLabel", {
        Parent               = wrap,
        BackgroundTransparency = 1,
        Position             = UDim2.new(0.6, 0, 0, 6),
        Size                 = UDim2.new(0.4, -12, 0, 16),
        Font                 = Enum.Font.GothamBold,
        Text                 = tostring(value),
        TextColor3           = Theme.AccentColor,
        TextSize             = 12,
        TextXAlignment       = Enum.TextXAlignment.Right,
    })

    -- Track bg
    local TrackBg = Create("Frame", {
        Parent           = wrap,
        BackgroundColor3 = Theme.SliderTrack,
        BorderSizePixel  = 0,
        Position         = UDim2.new(0, 12, 0, 32),
        Size             = UDim2.new(1, -24, 0, 5),
    })
    RoundCorner(TrackBg, 3)

    local pct  = (value - min) / (max - min)
    local Fill = Create("Frame", {
        Parent           = TrackBg,
        BackgroundColor3 = Theme.SliderFill,
        BorderSizePixel  = 0,
        Position         = UDim2.new(0, 0, 0, 0),
        Size             = UDim2.new(pct, 0, 1, 0),
    })
    RoundCorner(Fill, 3)

    local Thumb = Create("Frame", {
        Parent           = TrackBg,
        BackgroundColor3 = Theme.SliderThumb,
        BorderSizePixel  = 0,
        Position         = UDim2.new(pct, -6, 0.5, -6),
        Size             = UDim2.new(0, 12, 0, 12),
    })
    RoundCorner(Thumb, 6)
    Create("UIStroke", { Color = Theme.SliderFill, Thickness = 1.5, Parent = Thumb })

    local Hitbox = Create("TextButton", {
        Parent               = TrackBg,
        BackgroundTransparency = 1,
        Size                 = UDim2.new(1, 0, 0, 24),
        Position             = UDim2.new(0, 0, 0.5, -12),
        Text                 = "",
        AutoButtonColor      = false,
    })

    local function UpdateSlider(inputX)
        local abs  = TrackBg.AbsolutePosition.X
        local sz   = TrackBg.AbsoluteSize.X
        local raw  = math.clamp((inputX - abs) / sz, 0, 1)
        local stepped = math.floor(raw * (max - min) / step + 0.5) * step + min
        stepped = math.clamp(stepped, min, max)
        value   = stepped
        local newPct = (value - min) / (max - min)
        Tween(Fill,  { Size     = UDim2.new(newPct, 0, 1, 0) }, 0.05)
        Tween(Thumb, { Position = UDim2.new(newPct, -6, 0.5, -6) }, 0.05)
        ValLabel.Text = tostring(math.floor(value * 100 + 0.5) / 100)
        if ctrl.callback then ctrl.callback(value) end
    end

    local sliding = false
    Hitbox.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            sliding = true
            UpdateSlider(inp.Position.X)
        end
    end)
    Hitbox.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if sliding and inp.UserInputType == Enum.UserInputType.MouseMovement then
            UpdateSlider(inp.Position.X)
        end
    end)

    ctrl._value = function() return value end
    ctrl._set   = function(v)
        value = math.clamp(v, min, max)
        local p = (value - min) / (max - min)
        Fill.Size     = UDim2.new(p, 0, 1, 0)
        Thumb.Position = UDim2.new(p, -6, 0.5, -6)
        ValLabel.Text = tostring(value)
    end
end


        -- ── Toggle ──────────────────────────────────────────────────────────────
        function Tab:AddToggle(o, tl)
            o     = o or {}
            tl    = tl or mainList
            local state = o.Default or false
            local cb    = o.Callback or function() end
            local row   = baseRow(o.Name, o.Description, 46, tl)

            -- pill track
            local pill = new("Frame", {
                Parent           = row,
                BackgroundColor3 = state and C.ACCENT or C.TOGGLE_OFF,
                BorderSizePixel  = 0,
                Position         = UDim2.new(1, -58, 0.5, -12),
                Size             = UDim2.new(0, 44, 0, 24),
                ZIndex           = 6,
            })
            corner(100, pill)
            stroke(state and C.ACCENT3 or C.BORDER, 1, pill)

            -- fill gradient on active
            local pillFill = new("Frame", {
                Parent               = pill,
                BackgroundColor3     = C.ACCENT2,
                BackgroundTransparency = state and 0.7 or 1,
                BorderSizePixel      = 0,
                Size                 = UDim2.new(1, 0, 1, 0),
                ZIndex               = 6,
            })
            corner(100, pillFill)
            gradient(C.ACCENT2, C.ACCENT, 0, pillFill)

            -- knob
            local knob = new("Frame", {
                Parent           = pill,
                BackgroundColor3 = C.WHITE,
                BorderSizePixel  = 0,
                Position         = state and UDim2.new(1, -22, 0.5, -10) or UDim2.new(0, 2, 0.5, -10),
                Size             = UDim2.new(0, 20, 0, 20),
                ZIndex           = 7,
            })
            corner(100, knob)

            local T = {}
            function T:Set(v)
                state = v
                local pillColor   = state and C.ACCENT or C.TOGGLE_OFF
                local strokeColor = state and C.ACCENT3 or C.BORDER
                local knobPos     = state and UDim2.new(1, -22, 0.5, -10) or UDim2.new(0, 2, 0.5, -10)
                tween(pill,     { BackgroundColor3 = pillColor })
                tween(pillFill, { BackgroundTransparency = state and 0.7 or 1 })
                tween(knob,     { Position = knobPos })
                for _, s in ipairs(pill:GetChildren()) do
                    if s:IsA("UIStroke") then tween(s, { Color = strokeColor }) end
                end
                pcall(cb, state)
            end
            function T:Get() return state end
            row.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    T:Set(not state)
                end
            end)
            return T
        end


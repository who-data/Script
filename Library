-- UTIL
-- ============================================================
local function N(c, p, ch)
    local o = Instance.new(c)
    for k,v in pairs(p) do if k ~= "Parent" then o[k] = v end end
    if ch then for _,x in ipairs(ch) do x.Parent = o end end
    if p.Parent then o.Parent = p.Parent end
    return o
end
local function TW(o, g, t) TS:Create(o,TweenInfo.new(t or .13,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),g):Play() end
local function Cr(r,p)    return N("UICorner",{CornerRadius=UDim.new(0,r or 6),Parent=p}) end
local function Sk(c,t,p)  return N("UIStroke",{Color=c,Thickness=t or 1,ApplyStrokeMode=Enum.ApplyStrokeMode.Border,Parent=p}) end
local function Pd(l,r,t,b,p) return N("UIPadding",{PaddingLeft=UDim.new(0,l),PaddingRight=UDim.new(0,r),PaddingTop=UDim.new(0,t),PaddingBottom=UDim.new(0,b),Parent=p}) end
local function Ly(p,d,g)  return N("UIListLayout",{Parent=p,FillDirection=d or Enum.FillDirection.Vertical,SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,g or 0)}) end
local function AC(sc,lay,ex)
    lay:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        sc.CanvasSize=UDim2.new(0,0,0,lay.AbsoluteContentSize.Y+(ex or 8))
    end)
end
local function Lb(p,t,sz,c,f,xa,pos,s,z)
    return N("TextLabel",{Parent=p,BackgroundTransparency=1,Text=t or "",TextSize=sz or 12,
        TextColor3=c or T.TPRI,Font=f or Enum.Font.Gotham,
        TextXAlignment=xa or Enum.TextXAlignment.Left,
        TextYAlignment=Enum.TextYAlignment.Center,
        Position=pos or UDim2.new(0,0,0,0),Size=s or UDim2.new(1,0,1,0),
        ZIndex=z or 3,TextTruncate=Enum.TextTruncate.AtEnd})
end
local function ElemF(p, h)
    local f = N("Frame",{Parent=p,BackgroundColor3=T.ELEM,Size=UDim2.new(1,0,0,h or 34),ZIndex=2})
    Cr(6,f); Sk(T.BRD,1,f); return f
end
local function PlainF(p, h)
    return N("Frame",{Parent=p,BackgroundTransparency=1,Size=UDim2.new(1,0,0,h or 34),ZIndex=2})
end

local function MkDrag(win, hdl)
    local d,inp,mp,fp
    hdl.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then
            d=true;mp=i.Position;fp=win.Position
            i.Changed:Connect(function() if i.UserInputState==Enum.UserInputState.End then d=false end end)
        end
    end)
    hdl.InputChanged:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseMovement then inp=i end end)
    UIS.InputChanged:Connect(function(i)
        if i==inp and d then local dv=i.Position-mp; win.Position=UDim2.new(fp.X.Scale,fp.X.Offset+dv.X,fp.Y.Scale,fp.Y.Offset+dv.Y) end
    end)
end

-- Config IO
local DIR="ShadowUI"; local EXT=".json"
local function Wr(path,data) pcall(function() if not isfolder(DIR) then makefolder(DIR) end; writefile(path,data) end) end
local function Rd(path) local ok,d=pcall(readfile,path); return ok and d or nil end
local function Cfgs()
    local t={"default"}
    pcall(function()
        if not isfolder(DIR) then return end
        for _,f in ipairs(listfiles(DIR)) do
            local n=(f:match("[^/\\]+$") or f):gsub(EXT.."$","")
            if n~="default" and n~="__al" then t[#t+1]=n end
        end
    end)
    return t
end

-- ============================================================
-- SLIDER MANAGER GLOBAL
-- Todos os hitBtns dos sliders ficam aqui.
-- _Render() chama SliderMgr:Clear() antes de recriar a seção,
-- destruindo TODOS os overlays antigos de uma vez.
-- ============================================================
local SliderMgr = {_list = {}}

function SliderMgr:Add(hitBtn, syncConn, dragConn)
    self._list[#self._list+1] = {hitBtn=hitBtn, sync=syncConn, drag=dragConn}
end

function SliderMgr:Clear()
    for _,s in ipairs(self._list) do
        if s.drag  then pcall(function() s.drag:Disconnect()  end) end
        if s.sync  then pcall(function() s.sync:Disconnect()  end) end
        if s.hitBtn and s.hitBtn.Parent then pcall(function() s.hitBtn:Destroy() end) end
    end
    self._list = {}
end


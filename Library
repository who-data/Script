    local theme = library.Theme
    local anim  = library.Anim

    local screenGui = Utils.Create("ScreenGui", {
        Name           = "NexusKeySystem",
        ResetOnSpawn   = false,
        DisplayOrder   = 300,
    })
    pcall(function() screenGui.Parent = CoreGui end)
    if not screenGui.Parent then
        screenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
    end

    Utils.Create("Frame", {
        Name                    = "Overlay",
        Size                    = UDim2.new(1, 0, 1, 0),
        BackgroundColor3        = Color3.fromRGB(0, 0, 0),
        BackgroundTransparency  = 0.5,
        Parent                  = screenGui,
    })

    local card = Utils.Create("Frame", {
        Name                    = "Card",
        Size                    = UDim2.new(0, 400, 0, 240),
        Position                = UDim2.new(0.5, -200, 0.5, -120),
        BackgroundColor3        = theme:Get("Surface"),
        BorderSizePixel         = 0,
        Parent                  = screenGui,
    })
    Utils.AddCorner(card, CORNER_LARGE)
    Utils.AddStroke(card, theme:Get("Border"))
    Utils.AddPadding(card, 24, 24, 24, 24)

    local topAccent = Utils.Create("Frame", {
        Name                    = "TopAccent",
        Size                    = UDim2.new(1, 0, 0, 3),
        BackgroundColor3        = theme:Get("Accent"),
        BorderSizePixel         = 0,
        Parent                  = card,
    })
    Utils.AddGradient(topAccent, theme:Get("AccentLight"), theme:Get("AccentDark"))

    Utils.Create("TextLabel", {
        Name                    = "Title",
        Size                    = UDim2.new(1, 0, 0, 24),
        Position                = UDim2.new(0, 0, 0, 12),
        BackgroundTransparency  = 1,
        Text                    = opts.Title or "Key System",
        TextColor3              = theme:Get("Text"),
        TextSize                = 18,
        Font                    = Enum.Font.GothamBold,
        Parent                  = card,
    })

    Utils.Create("TextLabel", {
        Name                    = "Subtitle",
        Size                    = UDim2.new(1, 0, 0, 16),
        Position                = UDim2.new(0, 0, 0, 40),
        BackgroundTransparency  = 1,
        Text                    = opts.Subtitle or "Enter your key to continue",
        TextColor3              = theme:Get("TextSecondary"),
        TextSize                = 12,
        Font                    = Enum.Font.Gotham,
        Parent                  = card,
    })

    local inputBg = Utils.Create("Frame", {
        Name                    = "InputBg",
        Size                    = UDim2.new(1, 0, 0, 36),
        Position                = UDim2.new(0, 0, 0, 70),
        BackgroundColor3        = theme:Get("Background"),
        BorderSizePixel         = 0,
        Parent                  = card,
    })
    Utils.AddCorner(inputBg, CORNER_SMALL)
    Utils.AddStroke(inputBg, theme:Get("Border"))
    Utils.AddPadding(inputBg, 0, 10, 0, 10)

    local keyInput = Utils.Create("TextBox", {
        Name                    = "KeyInput",
        Size                    = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency  = 1,
        Text                    = "",
        PlaceholderText         = "Enter key here...",
        TextColor3              = theme:Get("Text"),
        PlaceholderColor3       = theme:Get("TextMuted"),
        TextSize                = 13,
        Font                    = Enum.Font.Code,
        TextXAlignment          = Enum.TextXAlignment.Left,
        Parent                  = inputBg,
    })

    local statusLabel = Utils.Create("TextLabel", {
        Name                    = "Status",
        Size                    = UDim2.new(1, 0, 0, 16),
        Position                = UDim2.new(0, 0, 0, 112),
        BackgroundTransparency  = 1,
        Text                    = "",
        TextColor3              = theme:Get("Error"),
        TextSize                = 11,
        Font                    = Enum.Font.Gotham,
        Parent                  = card,
    })

    local submitBtn = Utils.Create("Frame", {
        Name                    = "Submit",
        Size                    = UDim2.new(1, 0, 0, 36),
        Position                = UDim2.new(0, 0, 0, 136),
        BackgroundColor3        = theme:Get("Accent"),
        BorderSizePixel         = 0,
        Parent                  = card,
    })
    Utils.AddCorner(submitBtn, CORNER_SMALL)
    Utils.AddGradient(submitBtn, theme:Get("AccentLight"), theme:Get("AccentDark"), 135)

    Utils.Create("TextLabel", {
        Size                    = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency  = 1,
        Text                    = "Verify Key",
        TextColor3              = Color3.fromRGB(255, 255, 255),
        TextSize                = 13,
        Font                    = Enum.Font.GothamBold,
        Parent                  = submitBtn,
    })

    if opts.GetKeyUrl then
        local linkBtn = Utils.Create("TextLabel", {
            Name                    = "GetKey",
            Size                    = UDim2.new(1, 0, 0, 16),
            Position                = UDim2.new(0, 0, 0, 182),
            BackgroundTransparency  = 1,
            Text                    = "Get Key →",
            TextColor3              = theme:Get("Accent"),
            TextSize                = 12,
            Font                    = Enum.Font.Gotham,
            Parent                  = card,
        })
    end

    submitBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local enteredKey = keyInput.Text
            if opts.Key and enteredKey == opts.Key then
                statusLabel.Text = "✓ Key accepted!"
                statusLabel.TextColor3 = theme:Get("Success")
                anim:Play(submitBtn, {BackgroundColor3 = theme:Get("Success")}, TWEEN_SHORT)
                task.delay(1, function()
                    anim:Play(card, {
                        Size = UDim2.new(0, 0, 0, 0),
                        Position = UDim2.new(0.5, 0, 0.5, 0)
                    }, TWEEN_MEDIUM)
                    task.delay(0.3, function()
                        screenGui:Destroy()
                        if opts.OnSuccess then pcall(opts.OnSuccess) end
                    end)
                end)
            elseif opts.Validate then
                local ok = pcall(opts.Validate, enteredKey)
                if ok then
                    statusLabel.Text = "✓ Key accepted!"
                    statusLabel.TextColor3 = theme:Get("Success")
                    task.delay(1, function()
                        screenGui:Destroy()
                        if opts.OnSuccess then pcall(opts.OnSuccess) end
                    end)
                else
                    statusLabel.Text = "✗ Invalid key. Please try again."
                    statusLabel.TextColor3 = theme:Get("Error")
                    anim:Pulse(submitBtn, theme:Get("Accent"), theme:Get("Error"), "BackgroundColor3")
                end
            else
                statusLabel.Text = "✗ Invalid key."
                statusLabel.TextColor3 = theme:Get("Error")
            end
        end
    end)

    anim:Play(card, {Size = UDim2.new(0, 400, 0, 240),
        Position = UDim2.new(0.5, -200, 0.5, -120)}, TWEEN_SPRING)

    self.ScreenGui = screenGui
    return self
end

-- ============================================================
-- NEXUSUI LIBRARY CORE
-- ============================================================

function NexusUI.new()
    local self = setmetatable({}, NexusUI)
    self.Theme        = ThemeManager.new()
    self.Anim         = AnimationManager.new()
    self.InputHandler = InputHandler.new()
    self.Config       = ConfigSystem.new("NexusUI")
    self.Notifications = nil
    self.Windows      = {}
    self._initialized = false

    self.Factory = ComponentFactory.new(
        self.Theme,
        self.Anim,
        nil,
        self.Config,
        self.InputHandler
    )

    self:_Init()
    return self
end

function NexusUI:_Init()
    if self._initialized then return end
    self._initialized = true
    self.InputHandler:Start()

    -- Build notification container
    self.Notifications = NotificationSystem.new(self.Theme, self.Anim)

    -- Build tooltip (attach to CoreGui overlay)
    local tooltipGui = Utils.Create("ScreenGui", {
        Name           = "NexusTooltip",
        ResetOnSpawn   = false,
        DisplayOrder   = 500,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
    })
    pcall(function() tooltipGui.Parent = CoreGui end)
    if not tooltipGui.Parent then
        tooltipGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
    end

    local ttCanvas = Utils.Create("Frame", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Parent = tooltipGui,
    })

    self.TooltipSystem = TooltipSystem.new(self.Theme, self.Anim, ttCanvas)
    self.Factory.Tooltip = self.TooltipSystem
end

function NexusUI:SetTheme(themeTable)
    self.Theme:Set(themeTable)
end

function NexusUI:CreateWindow(opts)
    local window = Window.new(opts, self)
    table.insert(self.Windows, window)
    return window
end

function NexusUI:Notify(opts)
    if self.Notifications then
        self.Notifications:Send(opts)
    end
end

function NexusUI:CreateModal(opts)
    return Modal.new(opts, self)
end

function NexusUI:KeySystem(opts)
    return KeySystem.new(opts, self)
end

function NexusUI:SaveConfig(name)
    self.Config:Save(name)
    self:Notify({
        Title   = "Config Saved",
        Text    = "Saved as: " .. (name or "default"),
        Type    = "success",
        Duration = 2,
    })
end

function NexusUI:LoadConfig(name)
    local ok = self.Config:Load(name)
    if ok then
        self:Notify({
            Title   = "Config Loaded",
            Text    = "Loaded: " .. (name or "default"),
            Type    = "success",
            Duration = 2,
        })
    else
        self:Notify({
            Title   = "Config Error",
            Text    = "Could not load: " .. (name or "default"),
            Type    = "error",
            Duration = 3,
        })
    end
    return ok
end

function NexusUI:Destroy()
    for _, window in ipairs(self.Windows) do
        pcall(function() window:Destroy() end)
    end
    if self.Notifications then
        self.Notifications:Destroy()
    end
    self.InputHandler:Stop()
    self.Anim:CancelAll()
    self.Windows = {}
end

-- ============================================================
-- RETURN LIBRARY INSTANCE
-- ============================================================

return NexusUI.new()

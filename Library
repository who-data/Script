function Components:Slider(parent, opts)
    local th  = self.theme
    local cn  = {}
    local min_  = opts.Min     or 0
    local max_  = opts.Max     or 100
    local step  = opts.Step    or 1
    local val   = U.Clamp(opts.Default or min_, min_, max_)
    local dragging = false

    local frame = U.New("Frame", {
        Size = UDim2.new(1, 0, 0, 54),
        BackgroundColor3 = th:Get("BG3"),
        BorderSizePixel = 0,
        LayoutOrder = opts.LayoutOrder or 0,
        Parent = parent,
    })
    U.Corner(frame, CR_SM)
    U.Pad(frame, 8, 10, 8, 10)

    -- Header row
    local header = U.New("Frame", {
        Size = UDim2.new(1, 0, 0, 16),
        BackgroundTransparency = 1,
        Parent = frame,
    })

    U.New("TextLabel", {
        Size = UDim2.new(0.65, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = opts.Name or "Slider",
        TextColor3 = th:Get("Text"),
        TextSize = 12,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = header,
    })

    local valLbl = U.New("TextLabel", {
        Size = UDim2.new(0.35, 0, 1, 0),
        Position = UDim2.new(0.65, 0, 0, 0),
        BackgroundTransparency = 1,
        Text = tostring(val),
        TextColor3 = th:Get("AccentHi"),
        TextSize = 12,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Right,
        Parent = header,
    })

    -- Track
    local track = U.New("Frame", {
        Size = UDim2.new(1, 0, 0, 6),
        Position = UDim2.new(0, 0, 1, -6),
        BackgroundColor3 = th:Get("BG5"),
        BorderSizePixel = 0,
        Parent = frame,
    })
    U.Corner(track, CR_FULL)

    local fill = U.New("Frame", {
        Size = UDim2.new(0, 0, 1, 0),
        BackgroundColor3 = th:Get("Accent"),
        BorderSizePixel = 0,
        Parent = track,
    })
    U.Corner(fill, CR_FULL)
    U.Gradient(fill, th:Get("AccentHi"), th:Get("Accent"))

    local thumb = U.New("Frame", {
        Size = UDim2.new(0, 15, 0, 15),
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0, 0, 0.5, 0),
        BackgroundColor3 = th:Get("White"),
        BorderSizePixel = 0,
        ZIndex = track.ZIndex + 2,
        Parent = track,
    })
    U.Corner(thumb, CR_FULL)
    U.Stroke(thumb, th:Get("Accent"), 2)

    -- Value popup above thumb
    local popup = U.New("Frame", {
        Size = UDim2.new(0, 40, 0, 20),
        AnchorPoint = Vector2.new(0.5, 1),
        Position = UDim2.new(0, 0, 0, -4),
        BackgroundColor3 = th:Get("BG5"),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ZIndex = track.ZIndex + 5,
        Visible = false,
        Parent = thumb,
    })
    U.Corner(popup, CR_SM)
    local popupLbl = U.New("TextLabel", {
        Size = UDim2.new(1,0,1,0),
        BackgroundTransparency = 1,
        TextColor3 = th:Get("TextHi"),
        TextSize = 11,
        Font = Enum.Font.GothamBold,
        ZIndex = track.ZIndex + 6,
        Parent = popup,
    })

    local function applyVal(v, animate)
        v = U.Round(U.Clamp(v, min_, max_), step)
        val = v
        valLbl.Text = tostring(v)
        popupLbl.Text = tostring(v)
        local t = (v - min_) / (max_ - min_)
        local fTarget = UDim2.new(t, 0, 1, 0)
        local pTarget = UDim2.new(t, 0, 0.5, 0)
        if animate then
            self.anim:Play(fill,  {Size = fTarget},     TI.XFast)
            self.anim:Play(thumb, {Position = pTarget}, TI.XFast)
        else
            fill.Size     = fTarget
            thumb.Position = pTarget
        end
        if opts.Callback then pcall(opts.Callback, v) end
        if opts.Flag then self.config:SetFlag(opts.Flag, v) end
    end

    local function calcFromMouse(inp)
        local rel = U.Clamp((inp.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        applyVal(min_ + (max_ - min_) * rel, false)
    end

    applyVal(val, false)

    U.Connect(cn, track.InputBegan, function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            popup.Visible = true
            self.anim:Play(thumb, {Size = UDim2.new(0, 18, 0, 18)}, TI.Fast)
            calcFromMouse(inp)
        end
    end)
    U.Connect(cn, UserInputService.InputChanged, function(inp)
        if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
            calcFromMouse(inp)
        end
    end)
    U.Connect(cn, UserInputService.InputEnded, function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 and dragging then
            dragging = false
            popup.Visible = false
            self.anim:Play(thumb, {Size = UDim2.new(0, 15, 0, 15)}, TI.Fast)
        end
    end)
    U.Connect(cn, thumb.MouseEnter, function()
        if not dragging then
            self.anim:Play(thumb, {Size = UDim2.new(0, 18, 0, 18)}, TI.Fast)
        end
    end)
    U.Connect(cn, thumb.MouseLeave, function()
        if not dragging then
            self.anim:Play(thumb, {Size = UDim2.new(0, 15, 0, 15)}, TI.Fast)
        end
    end)
    local hcn = self:_hover(frame, th:Get("BG4"), th:Get("BG3"))
    for _, c in ipairs(hcn) do table.insert(cn, c) end

    if opts.Tooltip then self.tooltip:Attach(frame, opts.Tooltip) end
    if opts.Flag then
        self.config:RegisterFlag(opts.Flag, val, function(v) applyVal(v, true) end)
    end

    return {
        Frame    = frame,
        GetValue = function() return val end,
        SetValue = function(_, v) applyVal(v, true) end,
        Destroy  = function() U.Disconn(cn) frame:Destroy() end,
    }
end


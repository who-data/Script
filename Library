--  CONFIG SYSTEM (writefile/readfile/listfiles)
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
local function SanitizeName(name)
    return tostring(name):gsub("[^%w%s%-_]",""):gsub("%s+","_"):sub(1,32)
end

local function GetConfigDir(title)
    return "_ShadowUI_Configs/"..SanitizeName(title).."/"
end

local function GetConfigPath(title, configName)
    return GetConfigDir(title)..SanitizeName(configName)..".json"
end

local function GetMetaPath(title)
    return GetConfigDir(title).."_meta.json"
end

local function FsExists(path)
    return pcall(readfile, path)
end

local function SafeWrite(path, data)
    local ok, err = pcall(writefile, path, data)
    return ok, err
end

local function SafeRead(path)
    local ok, data = pcall(readfile, path)
    if ok then return data end
    return nil
end

local function SafeList(dir)
    local ok, files = pcall(listfiles, dir)
    if ok then return files end
    return {}
end

local function EnsureDir(dir)
    pcall(makefolder, dir)
    pcall(makefolder, dir:match("(.+)/") or dir)
end


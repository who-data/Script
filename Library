--  CONFIG TAB
-- ══════════════════════════════════════════════════════════════════
function ShadowUI:_BuildConfig()
    local cat=self:AddCategory({name="Config",icon="\xe2\x9a\x99"})
    local sec=self:AddSection(cat,"Settings")
    local tNames={}; for k in pairs(Themes) do table.insert(tNames,k) end; table.sort(tNames)
    local cfgDrop={type="dropdown",text="Config File",options=ListCfgs(),default="default",id="_cfg_file"}
    self._ctrls["_cfg_file"]=cfgDrop
    local cfgName={type="textinput",text="New Config Name",placeholder="my_config",default="",id="_cfg_newname"}
    self._ctrls["_cfg_newname"]=cfgName
    sec._left={
        {type="header",text="Theme"},
        {type="dropdown",text="UI Theme",options=tNames,default=self._theme,tooltip="Switch colour theme",callback=function(v) self:_Theme(v) end},
        {type="header",text="Config Files"},
        cfgDrop,cfgName,
        {type="button",text="\xf0\x9f\x92\xbe  Save Config",tooltip="Save current settings",callback=function()
            local nc=self._ctrls["_cfg_newname"]; local fc=self._ctrls["_cfg_file"]
            local name=(nc and nc._getValue and nc._getValue()~="") and nc._getValue() or (fc and fc._getValue and fc._getValue() or "default")
            self:SaveConfig(name); if fc then fc.options=ListCfgs() end
            self:Notify("Config Saved","Saved as '"..name.."'","success",3)
        end},
        {type="button",text="\xf0\x9f\x93\x82  Load Config",tooltip="Load settings from selected file",callback=function()
            local c=self._ctrls["_cfg_file"]; local n=c and c._getValue and c._getValue() or "default"
            self:LoadConfig(n); self:Notify("Config Loaded","Loaded '"..n.."'","info",3)
        end},
        {type="button",text="\xf0\x9f\x97\x91  Delete Config",style="danger",tooltip="Permanently delete selected file",callback=function()
            local c=self._ctrls["_cfg_file"]; local n=c and c._getValue and c._getValue() or "default"
            if n~="default" then
                pcall(delfile,CFG_DIR.."/"..n..CFG_EXT); c.options=ListCfgs()
                if c._setValue then c._setValue("default") end
                self:Notify("Config Deleted","'"..n.."' removed","warning",3)
            else self:Notify("Cannot Delete","Default config cannot be deleted","error",3) end
        end},
        {type="header",text="Auto Load"},
        {type="toggle",text="Auto Load on Start",description="Load default config automatically at startup",default=self:_AutoLoadGet(),callback=function(v) self:_AutoLoadSet(v) end},
    }
    for _,ctrl in ipairs(sec._left) do if ctrl.id then self._ctrls[ctrl.id]=ctrl end end
    task.defer(function()
        if self:_AutoLoadGet() then local n=self:_AutoLoadName(); if n then self:LoadConfig(n) end end
    end)
end


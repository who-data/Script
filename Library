-- ── Helpers ───────────────────────────────────────────────────────────────────
local function tw(o,props,t,s,d)
    TS:Create(o,TweenInfo.new(t or .15, s or Enum.EasingStyle.Quart, d or Enum.EasingDirection.Out),props):Play()
end

local function N(cls, props)
    local o = Instance.new(cls)
    for k,v in pairs(props) do
        if k ~= "Parent" then o[k] = v end
    end
    if props.Parent then o.Parent = props.Parent end
    return o
end

local function UICorner(parent, rad)
    return N("UICorner",{CornerRadius=rad or UDim.new(0,6), Parent=parent})
end

local function UIStroke(parent, col, thick)
    local s = N("UIStroke",{
        Color=col or P.border,
        Thickness=thick or 1,
        ApplyStrokeMode=Enum.ApplyStrokeMode.Border,
        Parent=parent,
    })
    return s
end

local function UIPad(parent, t, r, b, l)
    return N("UIPadding",{
        PaddingTop=UDim.new(0,t or 0), PaddingRight=UDim.new(0,r or 0),
        PaddingBottom=UDim.new(0,b or 0), PaddingLeft=UDim.new(0,l or 0),
        Parent=parent,
    })
end

local function VList(parent, gap)
    return N("UIListLayout",{
        FillDirection=Enum.FillDirection.Vertical,
        HorizontalAlignment=Enum.HorizontalAlignment.Left,
        SortOrder=Enum.SortOrder.LayoutOrder,
        Padding=UDim.new(0, gap or 0),
        Parent=parent,
    })
end

local function HList(parent, gap)
    return N("UIListLayout",{
        FillDirection=Enum.FillDirection.Horizontal,
        VerticalAlignment=Enum.VerticalAlignment.Center,
        SortOrder=Enum.SortOrder.LayoutOrder,
        Padding=UDim.new(0, gap or 0),
        Parent=parent,
    })
end

-- KEY: AutomaticSize.Y frame — grows to fit children via UIListLayout
local function AutoFrame(parent, extraProps)
    local props = {
        Size = UDim2.new(1,0,0,0),
        BackgroundTransparency = 1,
        AutomaticSize = Enum.AutomaticSize.Y,
        Parent = parent,
    }
    if extraProps then
        for k,v in pairs(extraProps) do props[k]=v end
    end
    return N("Frame", props)
end

-- Dragging utility
local function MakeDraggable(frame, handle)
    local dragging, dragStart, frameStart
    handle.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging=true; dragStart=i.Position; frameStart=frame.Position
        end
    end)
    handle.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging=false end
    end)
    UIS.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            local d = i.Position - dragStart
            frame.Position = UDim2.new(frameStart.X.Scale, frameStart.X.Offset+d.X,
                                       frameStart.Y.Scale, frameStart.Y.Offset+d.Y)
        end
    end)
end

-- ── COMPONENT: Toggle ─────────────────────────────────────────────────────────
local function MakeToggle(parent, name, opts)
    opts = opts or {}
    local val = opts.Default == true
    local cb  = opts.Callback or function() end
    local desc= opts.Description

    -- Row: fixed height, AutomaticSize off so UIListLayout of parent accounts for it
    local row = N("Frame",{
        Size = UDim2.new(1,0,0, desc and 50 or 40),
        BackgroundColor3 = P.row,
        BackgroundTransparency = 1,
        Parent = parent,
    })

    -- separator line at bottom
    N("Frame",{Size=UDim2.new(1,0,0,1), Position=UDim2.new(0,0,1,-1),
        BackgroundColor3=P.sep, BorderSizePixel=0, Parent=row})

    N("TextLabel",{
        Size=UDim2.new(1,-58,0,16),
        Position=UDim2.new(0,0,0, desc and 8 or 12),
        BackgroundTransparency=1, Text=name,
        TextColor3=P.txt, Font=P.Fsm, TextSize=13,
        TextXAlignment=Enum.TextXAlignment.Left, Parent=row,
    })
    if desc then
        N("TextLabel",{
            Size=UDim2.new(1,-58,0,13), Position=UDim2.new(0,0,0,27),
            BackgroundTransparency=1, Text=desc,
            TextColor3=P.txtDim, Font=P.Fb, TextSize=11,
            TextXAlignment=Enum.TextXAlignment.Left, Parent=row,
        })
    end

    local track = N("Frame",{
        Size=UDim2.new(0,40,0,20), Position=UDim2.new(1,-40,0.5,-10),
        BackgroundColor3 = val and P.acc or P.off,
        BorderSizePixel=0, Parent=row,
    })
    UICorner(track, UDim.new(0,10))

    local knob = N("Frame",{
        Size=UDim2.new(0,14,0,14),
        Position = val and UDim2.new(0,22,0.5,-7) or UDim2.new(0,4,0.5,-7),
        BackgroundColor3=P.white, BorderSizePixel=0, Parent=track,
    })
    UICorner(knob, UDim.new(1,0))

    local function Set(v, silent)
        val = v
        tw(track, {BackgroundColor3 = v and P.acc or P.off})
        tw(knob,  {Position = v and UDim2.new(0,22,0.5,-7) or UDim2.new(0,4,0.5,-7)})
        if not silent then cb(v) end
    end

    local btn = N("TextButton",{
        Size=UDim2.new(1,0,1,0), BackgroundTransparency=1, Text="", ZIndex=3, Parent=row,
    })
    btn.MouseButton1Click:Connect(function() Set(not val) end)

    return { Set=Set, Get=function() return val end }
end

-- ── COMPONENT: Slider ─────────────────────────────────────────────────────────
local function MakeSlider(parent, name, opts)
    opts = opts or {}
    local mn  = opts.Min or 0
    local mx  = opts.Max or 100
    local val = math.clamp(opts.Default or mn, mn, mx)
    local suf = opts.Suffix or ""
    local dec = opts.Decimals or 0
    local cb  = opts.Callback or function() end
    local function R(n) local m=10^dec; return math.floor(n*m+0.5)/m end

    local row = N("Frame",{
        Size=UDim2.new(1,0,0,54),
        BackgroundTransparency=1, Parent=parent,
    })
    N("Frame",{Size=UDim2.new(1,0,0,1), Position=UDim2.new(0,0,1,-1),
        BackgroundColor3=P.sep, BorderSizePixel=0, Parent=row})

    N("TextLabel",{
        Size=UDim2.new(1,-72,0,16), Position=UDim2.new(0,0,0,6),
        BackgroundTransparency=1, Text=name,
        TextColor3=P.txt, Font=P.Fsm, TextSize=13,
        TextXAlignment=Enum.TextXAlignment.Left, Parent=row,
    })

    local vLbl = N("TextLabel",{
        Size=UDim2.new(0,68,0,16), Position=UDim2.new(1,-68,0,6),
        BackgroundTransparency=1, Text=tostring(R(val))..suf,
        TextColor3=P.txtAcc, Font=P.Fsm, TextSize=12,
        TextXAlignment=Enum.TextXAlignment.Right, Parent=row,
    })

    local trackBG = N("Frame",{
        Size=UDim2.new(1,0,0,4), Position=UDim2.new(0,0,0,34),
        BackgroundColor3=Color3.fromRGB(34,34,34), BorderSizePixel=0, Parent=row,
    })
    UICorner(trackBG, UDim.new(0,2))

    local pct0 = (val-mn)/(mx-mn)
    local fill = N("Frame",{
        Size=UDim2.new(pct0,0,1,0),
        BackgroundColor3=P.acc, BorderSizePixel=0, Parent=trackBG,
    })
    UICorner(fill, UDim.new(0,2))

    local knob = N("Frame",{
        Size=UDim2.new(0,12,0,12), Position=UDim2.new(pct0,-6,0.5,-6),
        BackgroundColor3=P.acc, BorderSizePixel=0, ZIndex=2, Parent=trackBG,
    })
    UICorner(knob, UDim.new(1,0))

    local function Set(v, silent)
        v = R(math.clamp(v,mn,mx)); val = v
        local p = (v-mn)/(mx-mn)
        fill.Size   = UDim2.new(p,0,1,0)
        knob.Position = UDim2.new(p,-6,0.5,-6)
        vLbl.Text   = tostring(v)..suf
        if not silent then cb(v) end
    end

    local holding = false
    local function fromMouse()
        local ax=trackBG.AbsolutePosition.X; local aw=trackBG.AbsoluteSize.X
        Set(mn + (mx-mn)*math.clamp((Mouse.X-ax)/aw, 0,1))
    end

    trackBG.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then holding=true; fromMouse() end
    end)
    UIS.InputChanged:Connect(function(i)
        if holding and i.UserInputType==Enum.UserInputType.MouseMovement then fromMouse() end
    end)
    UIS.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then holding=false end
    end)

    return { Set=Set, Get=function() return val end }
end

-- ── COMPONENT: Dropdown ───────────────────────────────────────────────────────
local function MakeDropdown(parent, name, opts)
    opts = opts or {}
    local list  = opts.List or {}
    local val   = opts.Default or list[1] or "None"
    local cb    = opts.Callback or function() end
    local open  = false

    local row = N("Frame",{
        Size=UDim2.new(1,0,0,40),
        BackgroundTransparency=1, Parent=parent,
    })
    N("Frame",{Size=UDim2.new(1,0,0,1), Position=UDim2.new(0,0,1,-1),
        BackgroundColor3=P.sep, BorderSizePixel=0, Parent=row})

    N("TextLabel",{
        Size=UDim2.new(1,-158,1,0), BackgroundTransparency=1,
        Text=name, TextColor3=P.txt, Font=P.Fsm, TextSize=13,
        TextXAlignment=Enum.TextXAlignment.Left, Parent=row,
    })

    local btn = N("TextButton",{
        Size=UDim2.new(0,148,0,26), Position=UDim2.new(1,-148,0.5,-13),
        BackgroundColor3=P.input, Text="", AutoButtonColor=false, Parent=row,
    })
    UICorner(btn); local bsk = UIStroke(btn, P.border)

    local lbl = N("TextLabel",{
        Size=UDim2.new(1,-24,1,0), Position=UDim2.new(0,8,0,0),
        BackgroundTransparency=1, Text=val,
        TextColor3=P.txtSub, Font=P.Fb, TextSize=12,
        TextXAlignment=Enum.TextXAlignment.Left, Parent=btn,
    })
    local arr = N("TextLabel",{
        Size=UDim2.new(0,18,1,0), Position=UDim2.new(1,-20,0,0),
        BackgroundTransparency=1, Text="▾",
        TextColor3=P.acc, Font=P.Fbd, TextSize=11, Parent=btn,
    })

    -- dropdown list panel — child of row so it overlays below
    local panel = N("Frame",{
        Size=UDim2.new(0,148,0,0),
        Position=UDim2.new(1,-148,1,2),
        BackgroundColor3=Color3.fromRGB(18,18,18),
        ClipsDescendants=true, ZIndex=80, Visible=false, Parent=row,
    })
    UICorner(panel); UIStroke(panel, P.border)
    local pList = VList(panel, 0)

    local function Build()
        for _,c in ipairs(panel:GetChildren()) do
            if c:IsA("TextButton") then c:Destroy() end
        end
        for _,opt in ipairs(list) do
            local it = N("TextButton",{
                Size=UDim2.new(1,0,0,28), BackgroundTransparency=1,
                Text="  "..opt,
                TextColor3 = opt==val and P.txtAcc or P.txtSub,
                Font=P.Fb, TextSize=12,
                TextXAlignment=Enum.TextXAlignment.Left,
                ZIndex=81, Parent=panel,
            })
            it.MouseEnter:Connect(function()
                it.BackgroundColor3=P.acc; it.BackgroundTransparency=0.85
            end)
            it.MouseLeave:Connect(function() it.BackgroundTransparency=1 end)
            it.MouseButton1Click:Connect(function()
                val=opt; lbl.Text=opt; cb(opt)
                open=false
                tw(panel,{Size=UDim2.new(0,148,0,0)}, .12)
                tw(arr,{Rotation=0})
                task.delay(.13, function() panel.Visible=false end)
                for _,c2 in ipairs(panel:GetChildren()) do
                    if c2:IsA("TextButton") then
                        c2.TextColor3 = (c2.Text:gsub("^%s+",""))==opt and P.txtAcc or P.txtSub
                    end
                end
            end)
        end
    end
    Build()

    btn.MouseButton1Click:Connect(function()
        open = not open
        if open then
            panel.Visible=true
            local h = math.min(#list*28, 168)
            tw(panel,{Size=UDim2.new(0,148,0,h)}, .15)
            tw(arr,{Rotation=180})
        else
            tw(panel,{Size=UDim2.new(0,148,0,0)}, .12)
            tw(arr,{Rotation=0})
            task.delay(.13, function() panel.Visible=false end)
        end
    end)

    return {
        Set=function(v,s) val=v; lbl.Text=v; if not s then cb(v) end end,
        Get=function() return val end,
        Refresh=function(newList) list=newList; Build() end,
    }
end

-- ── COMPONENT: Button ─────────────────────────────────────────────────────────
local function MakeButton(parent, name, opts)
    opts = opts or {}
    local cb   = opts.Callback or function() end
    local desc = opts.Description

    local row = N("Frame",{
        Size=UDim2.new(1,0,0, desc and 52 or 46),
        BackgroundTransparency=1, Parent=parent,
    })
    N("Frame",{Size=UDim2.new(1,0,0,1), Position=UDim2.new(0,0,1,-1),
        BackgroundColor3=P.sep, BorderSizePixel=0, Parent=row})

    if desc then
        N("TextLabel",{
            Size=UDim2.new(1,-118,0,15), Position=UDim2.new(0,0,0,7),
            BackgroundTransparency=1, Text=name,
            TextColor3=P.txt, Font=P.Fsm, TextSize=13,
            TextXAlignment=Enum.TextXAlignment.Left, Parent=row,
        })
        N("TextLabel",{
            Size=UDim2.new(1,-118,0,13), Position=UDim2.new(0,0,0,24),
            BackgroundTransparency=1, Text=desc,
            TextColor3=P.txtDim, Font=P.Fb, TextSize=11,
            TextXAlignment=Enum.TextXAlignment.Left, Parent=row,
        })
    end

    local b = N("TextButton",{
        Size  = desc and UDim2.new(0,108,0,28) or UDim2.new(1,0,0,30),
        Position = desc and UDim2.new(1,-108,0.5,-14) or UDim2.new(0,0,0,8),
        BackgroundColor3=Color3.fromRGB(28,28,28),
        Text = desc and "Execute" or name,
        TextColor3=P.txt, Font=P.Fsm, TextSize=12,
        AutoButtonColor=false, Parent=row,
    })
    UICorner(b); local bsk = UIStroke(b, P.border)

    b.MouseEnter:Connect(function()
        tw(b,{BackgroundColor3=P.acc}); tw(bsk,{Color=P.accBright}); tw(b,{TextColor3=P.white})
    end)
    b.MouseLeave:Connect(function()
        tw(b,{BackgroundColor3=Color3.fromRGB(28,28,28)}); tw(bsk,{Color=P.border}); tw(b,{TextColor3=P.txt})
    end)
    b.MouseButton1Click:Connect(function()
        tw(b,{BackgroundColor3=P.accDim},.07)
        task.delay(.1, function() tw(b,{BackgroundColor3=P.acc}) end)
        cb()
    end)
    return { Fire=cb }
end

-- ── COMPONENT: Keybind ────────────────────────────────────────────────────────
local function MakeKeybind(parent, name, opts)
    opts = opts or {}
    local key = opts.Default or Enum.KeyCode.Unknown
    local cb  = opts.Callback or function() end
    local listening = false

    local row = N("Frame",{
        Size=UDim2.new(1,0,0,40), BackgroundTransparency=1, Parent=parent,
    })
    N("Frame",{Size=UDim2.new(1,0,0,1), Position=UDim2.new(0,0,1,-1),
        BackgroundColor3=P.sep, BorderSizePixel=0, Parent=row})

    N("TextLabel",{
        Size=UDim2.new(1,-128,1,0), BackgroundTransparency=1, Text=name,
        TextColor3=P.txt, Font=P.Fsm, TextSize=13,
        TextXAlignment=Enum.TextXAlignment.Left, Parent=row,
    })

    local kb = N("TextButton",{
        Size=UDim2.new(0,118,0,26), Position=UDim2.new(1,-118,0.5,-13),
        BackgroundColor3=P.input,
        Text=key and key.Name or "None",
        TextColor3=P.txtAcc, Font=P.Fmn, TextSize=11,
        AutoButtonColor=false, Parent=row,
    })
    UICorner(kb); UIStroke(kb, P.border)

    local function SetKey(k, silent)
        key=k; kb.Text=k and k.Name or "None"; kb.TextColor3=P.txtAcc
        if not silent then cb(k) end
    end

    kb.MouseButton1Click:Connect(function()
        listening=true; kb.Text="..."; kb.TextColor3=P.accBright
    end)
    UIS.InputBegan:Connect(function(i, gp)
        if listening and not gp and i.UserInputType==Enum.UserInputType.Keyboard then
            listening=false; SetKey(i.KeyCode)
        elseif not listening and key~=Enum.KeyCode.Unknown and i.KeyCode==key then
            cb(key)
        end
    end)
    return { Set=SetKey, Get=function() return key end }
end

-- ── COMPONENT: Colorpicker ────────────────────────────────────────────────────
local function MakeColorpicker(parent, name, opts)
    opts = opts or {}
    local color = opts.Default or Color3.fromRGB(255,60,120)
    local cb    = opts.Callback or function() end
    local open  = false

    local row = N("Frame",{
        Size=UDim2.new(1,0,0,40), BackgroundTransparency=1, Parent=parent,
    })
    N("Frame",{Size=UDim2.new(1,0,0,1), Position=UDim2.new(0,0,1,-1),
        BackgroundColor3=P.sep, BorderSizePixel=0, Parent=row})

    N("TextLabel",{
        Size=UDim2.new(1,-54,1,0), BackgroundTransparency=1, Text=name,
        TextColor3=P.txt, Font=P.Fsm, TextSize=13,
        TextXAlignment=Enum.TextXAlignment.Left, Parent=row,
    })

    local preview = N("TextButton",{
        Size=UDim2.new(0,44,0,22), Position=UDim2.new(1,-44,0.5,-11),
        BackgroundColor3=color, Text="", AutoButtonColor=false, Parent=row,
    })
    UICorner(preview); UIStroke(preview, P.border)

    -- panel below row
    local panel = N("Frame",{
        Size=UDim2.new(0,190,0,110), Position=UDim2.new(1,-190,1,2),
        BackgroundColor3=Color3.fromRGB(18,18,18),
        Visible=false, ZIndex=80, Parent=row,
    })
    UICorner(panel); UIStroke(panel, P.border); UIPad(panel,8,8,8,8)

    local rv = math.floor(color.R*255)
    local gv = math.floor(color.G*255)
    local bv = math.floor(color.B*255)
    local chanColors = {Color3.fromRGB(255,75,75), Color3.fromRGB(75,210,75), Color3.fromRGB(75,125,255)}
    local chanNames  = {"R","G","B"}
    local fills = {}

    local function UpdateColor()
        color = Color3.fromRGB(rv,gv,bv)
        preview.BackgroundColor3 = color
        cb(color)
    end

    for i=1,3 do
        N("TextLabel",{
            Size=UDim2.new(0,12,0,12), Position=UDim2.new(0,0,0,(i-1)*28+4),
            BackgroundTransparency=1, Text=chanNames[i],
            TextColor3=chanColors[i], Font=P.Fbd, TextSize=10, ZIndex=81, Parent=panel,
        })
        local tr = N("Frame",{
            Size=UDim2.new(1,-16,0,4), Position=UDim2.new(0,16,0,(i-1)*28+4),
            BackgroundColor3=Color3.fromRGB(34,34,34), BorderSizePixel=0, ZIndex=81, Parent=panel,
        })
        UICorner(tr, UDim.new(0,2))
        local initVals = {rv,gv,bv}
        local fl = N("Frame",{
            Size=UDim2.new(initVals[i]/255,0,1,0),
            BackgroundColor3=chanColors[i], BorderSizePixel=0, ZIndex=82, Parent=tr,
        })
        UICorner(fl, UDim.new(0,2))
        fills[i] = fl

        local dg = false
        tr.InputBegan:Connect(function(inp)
            if inp.UserInputType==Enum.UserInputType.MouseButton1 then dg=true end
        end)
        UIS.InputEnded:Connect(function(inp)
            if inp.UserInputType==Enum.UserInputType.MouseButton1 then dg=false end
        end)
        UIS.InputChanged:Connect(function(inp)
            if dg and inp.UserInputType==Enum.UserInputType.MouseMovement then
                local pct = math.clamp((Mouse.X-tr.AbsolutePosition.X)/tr.AbsoluteSize.X,0,1)
                fl.Size = UDim2.new(pct,0,1,0)
                local nv = math.floor(pct*255)
                if i==1 then rv=nv elseif i==2 then gv=nv else bv=nv end
                UpdateColor()
            end
        end)
    end

    preview.MouseButton1Click:Connect(function() open=not open; panel.Visible=open end)
    return {
        Set=function(c)
            color=c; rv=math.floor(c.R*255); gv=math.floor(c.G*255); bv=math.floor(c.B*255)
            preview.BackgroundColor3=c
            for i,fl in ipairs(fills) do
                fl.Size=UDim2.new((i==1 and rv or i==2 and gv or bv)/255,0,1,0)
            end
        end,
        Get=function() return color end,
    }
end

-- ── COMPONENT: Textbox ────────────────────────────────────────────────────────
local function MakeTextbox(parent, name, opts)
    opts = opts or {}
    local cb = opts.Callback or function() end
    local ph = opts.Placeholder or "Type here..."

    local row = N("Frame",{
        Size=UDim2.new(1,0,0,56), BackgroundTransparency=1, Parent=parent,
    })
    N("Frame",{Size=UDim2.new(1,0,0,1), Position=UDim2.new(0,0,1,-1),
        BackgroundColor3=P.sep, BorderSizePixel=0, Parent=row})

    N("TextLabel",{
        Size=UDim2.new(1,0,0,16), Position=UDim2.new(0,0,0,4),
        BackgroundTransparency=1, Text=name,
        TextColor3=P.txt, Font=P.Fsm, TextSize=13,
        TextXAlignment=Enum.TextXAlignment.Left, Parent=row,
    })

    local box = N("TextBox",{
        Size=UDim2.new(1,0,0,26), Position=UDim2.new(0,0,0,24),
        BackgroundColor3=P.input, Text="",
        PlaceholderText=ph, PlaceholderColor3=P.txtDim,
        TextColor3=P.txt, Font=P.Fb, TextSize=12,
        ClearTextOnFocus=false,
        TextXAlignment=Enum.TextXAlignment.Left, Parent=row,
    })
    UICorner(box); UIPad(box,0,0,0,8)
    local sk = UIStroke(box, P.border)

    box.Focused:Connect(function() tw(sk,{Color=P.acc}) end)
    box.FocusLost:Connect(function(enter)
        tw(sk,{Color=P.border})
        if enter then cb(box.Text) end
    end)

    return { Set=function(v) box.Text=v end, Get=function() return box.Text end }
end

-- ── COMPONENT: Label ──────────────────────────────────────────────────────────
local function MakeLabel(parent, text, opts)
    opts=opts or {}
    local lbl = N("TextLabel",{
        Size=UDim2.new(1,0,0,28), BackgroundTransparency=1,
        Text=text, TextColor3=opts.Color or P.txtSub,
        Font=opts.Bold and P.Fbd or P.Fb,
        TextSize=opts.Size or 12,
        TextXAlignment=Enum.TextXAlignment.Left,
        TextWrapped=true, Parent=parent,
    })
    return { Set=function(t) lbl.Text=t end, Get=function() return lbl.Text end }
end

-- ── SECTION ───────────────────────────────────────────────────────────────────
-- KEY INSIGHT: Section is just an AutomaticSize.Y frame with a VList.
-- All components have FIXED pixel heights → UIListLayout sums them → frame grows.
-- No callbacks needed. It just works.

local Section = {}
Section.__index = Section

function Section.new(parent, title)
    local self = setmetatable({}, Section)

    -- outer wrapper, auto-grows
    local wrap = AutoFrame(parent)

    if title then
        -- fixed 30px header
        local hdr = N("Frame",{
            Size=UDim2.new(1,0,0,30),
            BackgroundTransparency=1, Parent=wrap,
        })
        N("TextLabel",{
            Size=UDim2.new(1,0,1,0), BackgroundTransparency=1,
            Text=title:upper(), TextColor3=P.txtAcc,
            Font=P.Fbd, TextSize=10, LetterSpacing=2,
            TextXAlignment=Enum.TextXAlignment.Left, Parent=hdr,
        })
        N("Frame",{
            Size=UDim2.new(1,0,0,1), Position=UDim2.new(0,0,1,-1),
            BackgroundColor3=P.border, BorderSizePixel=0, Parent=hdr,
        })
    end

    -- content frame: AutomaticSize.Y + VList → grows as items are added
    local content = AutoFrame(wrap)
    VList(content, 0)

    self._c = content
    return self
end

function Section:Toggle(name,opts)      return MakeToggle(self._c,name,opts) end
function Section:Slider(name,opts)      return MakeSlider(self._c,name,opts) end
function Section:Dropdown(name,opts)    return MakeDropdown(self._c,name,opts) end
function Section:Button(name,opts)      return MakeButton(self._c,name,opts) end
function Section:Keybind(name,opts)     return MakeKeybind(self._c,name,opts) end
function Section:Colorpicker(name,opts) return MakeColorpicker(self._c,name,opts) end
function Section:Textbox(name,opts)     return MakeTextbox(self._c,name,opts) end
function Section:Label(text,opts)       return MakeLabel(self._c,text,opts) end

-- ── TAB ───────────────────────────────────────────────────────────────────────
local Tab = {}
Tab.__index = Tab

function Tab.new(scroll)
    local self = setmetatable({}, Tab)
    self._scroll = scroll
    self._subtabs = {}
    self._activeSub = nil
    self._subBar = nil
    return self
end

function Tab:_ensureBar()
    if self._subBar then return end

    self._subBar = N("Frame",{
        Size=UDim2.new(1,0,0,32),
        BackgroundTransparency=1,
        Parent=self._scroll,
    })
    HList(self._subBar, 4)
    N("Frame",{
        Size=UDim2.new(1,0,0,1), Position=UDim2.new(0,0,1,-1),
        BackgroundColor3=P.border, BorderSizePixel=0, Parent=self._subBar,
    })
end

function Tab:Subtab(name)
    self:_ensureBar()

    local isFirst = #self._subtabs == 0

    local btn = N("TextButton",{
        Size=UDim2.new(0,0,1,-4),
        AutomaticSize=Enum.AutomaticSize.X,
        BackgroundTransparency=1,
        Text=name,
        TextColor3 = isFirst and P.txtAcc or P.txtDim,
        Font=P.Fsm, TextSize=12, AutoButtonColor=false,
        Parent=self._subBar,
    })
    UIPad(btn,0,12,0,12)

    local ind = N("Frame",{
        Size = isFirst and UDim2.new(1,0,0,2) or UDim2.new(0,0,0,2),
        Position=UDim2.new(0,0,1,0),
        BackgroundColor3=P.acc, BorderSizePixel=0, Parent=btn,
    })

    -- content: AutomaticSize.Y frame
    local holder = AutoFrame(self._scroll, {Visible=isFirst})
    VList(holder, 8)
    UIPad(holder, 4, 0, 4, 0)

    local idx = #self._subtabs + 1
    self._subtabs[idx] = {btn=btn, ind=ind, holder=holder}
    if isFirst then self._activeSub = 1 end

    btn.MouseButton1Click:Connect(function()
        if self._activeSub == idx then return end
        local old = self._subtabs[self._activeSub]
        if old then
            old.holder.Visible = false
            tw(old.btn,{TextColor3=P.txtDim})
            tw(old.ind,{Size=UDim2.new(0,0,0,2)})
        end
        self._activeSub = idx
        holder.Visible = true
        tw(btn,{TextColor3=P.txtAcc})
        tw(ind,{Size=UDim2.new(1,0,0,2)})
    end)

    local sec = Section.new(holder, nil)
    return sec
end

function Tab:Section(title)
    return Section.new(self._scroll, title)
end


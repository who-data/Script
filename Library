    Utils.AddPadding(frame, 0, 10, 0, 10)

    Utils.Create("TextLabel", {
        Name                    = "Name",
        Size                    = UDim2.new(0.65, 0, 1, 0),
        BackgroundTransparency  = 1,
        Text                    = opts.Name or "Keybind",
        TextColor3              = theme:Get("Text"),
        TextSize                = 13,
        Font                    = Enum.Font.Gotham,
        TextXAlignment          = Enum.TextXAlignment.Left,
        Parent                  = frame,
    })

    local keyBg = Utils.Create("Frame", {
        Name                    = "KeyBg",
        Size                    = UDim2.new(0, 70, 0, 22),
        Position                = UDim2.new(1, -70, 0.5, -11),
        BackgroundColor3        = theme:Get("Background"),
        BorderSizePixel         = 0,
        Parent                  = frame,
    })
    Utils.AddCorner(keyBg, CORNER_SMALL)
    Utils.AddStroke(keyBg, theme:Get("Border"))

    local keyLabel = Utils.Create("TextLabel", {
        Name                    = "Key",
        Size                    = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency  = 1,
        Text                    = currentKey == Enum.KeyCode.Unknown and "None" or currentKey.Name,
        TextColor3              = theme:Get("Accent"),
        TextSize                = 11,
        Font                    = Enum.Font.GothamBold,
        Parent                  = keyBg,
    })

    Utils.Connect(connections, frame.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            listening = not listening
            if listening then
                keyLabel.Text = "..."
                keyLabel.TextColor3 = theme:Get("Warning")
                self.Anim:Play(keyBg, {BackgroundColor3 = theme:Get("SurfaceAlt")}, TWEEN_SHORT)
            else
                keyLabel.Text = currentKey == Enum.KeyCode.Unknown and "None" or currentKey.Name
                keyLabel.TextColor3 = theme:Get("Accent")
                self.Anim:Play(keyBg, {BackgroundColor3 = theme:Get("Background")}, TWEEN_SHORT)
            end
        end
    end)

    Utils.Connect(connections, UserInputService.InputBegan, function(input, gp)
        if not listening then return end
        if input.UserInputType == Enum.UserInputType.Keyboard then
            currentKey = input.KeyCode
            keyLabel.Text = currentKey.Name
            keyLabel.TextColor3 = theme:Get("Accent")
            self.Anim:Play(keyBg, {BackgroundColor3 = theme:Get("Background")}, TWEEN_SHORT)
            listening = false
            if opts.Callback then pcall(opts.Callback, currentKey) end
            if opts.Flag then self.Config:SetFlag(opts.Flag, currentKey.Name) end
        end
    end)

    if opts.Tooltip then self.Tooltip:Attach(frame, opts.Tooltip) end

    return {
        Frame    = frame,
        GetKey   = function() return currentKey end,
        SetKey   = function(_, key)
            currentKey = key
            keyLabel.Text = key.Name
        end,
        Destroy  = function()
            Utils.Disconnect(connections)
            frame:Destroy()
        end,
    }
end


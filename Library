            BackgroundTransparency=1,Text=d[1],TextColor3=C.TextDim,Font=C.Fbold,TextSize=14,
            AutoButtonColor=false,ZIndex=13,Parent=top})
        wb.MouseEnter:Connect(function() tw(wb,{TextColor3=C.Accent}) end)
        wb.MouseLeave:Connect(function() tw(wb,{TextColor3=C.TextDim}) end)
        wb.MouseButton1Click:Connect(function()
            if d[2]=="cls" then tw(main,{Size=UDim2.new(0,W,0,0)},0.2); task.delay(0.22,function()gui:Destroy()end)
            elseif d[2]=="min" then self._min=not self._min; tw(main,{Size=UDim2.new(0,W,0,self._min and 36 or H)},0.2) end
        end)
    end

    drag(main,top)

    local body=ins("Frame",{Size=UDim2.new(1,0,1,-36),Position=UDim2.new(0,0,0,36),BackgroundTransparency=1,Parent=main})


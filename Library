-- ══════════════════════════════════════════════
--  TOGGLE VISIBILIDADE
-- ══════════════════════════════════════════════
function ShadowUI:_ToggleVisible()
    self._visible = not self._visible
    if self._visible then
        self.Win.Visible = true
        self.Win.Size = UDim2.new(0,0,0,440)
        Tw(self.Win, {Size=UDim2.new(0,660,0,440)}, .2, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        self.FloatIcon.Text = "◀"
    else
        Tw(self.Win, {Size=UDim2.new(0,0,0,440)}, .18)
        task.delay(.2, function() if not self._visible then self.Win.Visible=false end end)
        self.FloatIcon.Text = "▶"
    end
end


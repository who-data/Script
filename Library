--  THEME APPLICATION
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
function ShadowUI:ApplyTheme(name)
    local theme = THEMES[name]
    if not theme then return end
    self._themeName = name
    self._T = theme

    if not self.Win then return end

    -- Re-apply all colors to main UI elements
    local T = theme
    self.Win.BackgroundColor3 = T.Bg
    self._winStro.Color = T.Border
    self.Header.BackgroundColor3 = T.Header
    self._accentLine.BackgroundColor3 = T.Accent
    self.Sidebar.BackgroundColor3 = T.Sidebar
    self.Content.BackgroundColor3 = T.Bg
    self.TabBar.BackgroundColor3 = T.SubHeader
    self.ToggleBtn.BackgroundColor3 = T.Accent

    -- Update breadcrumb labels
    self.BreadCat.TextColor3 = T.TextPri

    -- Force re-render current section
    if self._activeSec then
        self:_Render(self._activeSec)
    end
end

function ShadowUI:RegisterTheme(name, colors)
    THEMES[name] = colors
end

-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
--  CONFIG SAVE / LOAD
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
function ShadowUI:_GetConfigList()
    local dir = GetConfigDir(self._configTitle)
    local files = SafeList(dir)
    local list = {"default"}
    for _, f in ipairs(files) do
        local name = f:match("([^/\\]+)%.json$")
        if name and name ~= "_meta" and name ~= "default" then
            list[#list+1] = name
        end
    end
    return list
end

function ShadowUI:_RefreshConfigDropdown()
    if self._cfgDropRef then
        local newList = self:_GetConfigList()
        self._cfgDropRef.options = newList
        if self._cfgDropRef._setValue then
            self._cfgDropRef._setValue(self._activeConfig)
        end
        -- Rebuild if active
        if self._activeSec and self._activeSec._active then
            self:_Render(self._activeSec)
        end
    end
    if self._configLabel then
        self._configLabel.text = "Active: "..self._activeConfig
    end
end

function ShadowUI:SaveConfig(name)
    name = name or self._activeConfig
    local data = {
        theme = self._themeName,
        controls = {},
    }

    for _, ctrl in ipairs(self._controls) do
        if ctrl.id and ctrl._getValue then
            data.controls[ctrl.id] = ctrl._getValue()
        end
    end

    local dir = GetConfigDir(self._configTitle)
    EnsureDir(dir)

    local ok, encoded = pcall(HttpService.JSONEncode, HttpService, data)
    if ok then
        SafeWrite(GetConfigPath(self._configTitle, name), encoded)
        -- Save meta (last used)
        local meta = {lastConfig = name, theme = self._themeName}
        local mok, menc = pcall(HttpService.JSONEncode, HttpService, meta)
        if mok then SafeWrite(GetMetaPath(self._configTitle), menc) end
    end

    self._activeConfig = name
    if self._configLabel then
        self._configLabel.text = "Active: "..name
    end
end

function ShadowUI:LoadConfig(name)
    name = name or "default"
    local path = GetConfigPath(self._configTitle, name)
    local raw = SafeRead(path)
    if not raw then
        if name ~= "default" then
            self:_Notify("Config not found: "..name)
        end
        return
    end

    local ok, data = pcall(HttpService.JSONDecode, HttpService, raw)
    if not ok then
        self:_Notify("Config corrupted!")
        return
    end

    -- Apply theme
    if data.theme and THEMES[data.theme] then
        self:ApplyTheme(data.theme)
    end

    -- Apply controls
    if data.controls then
        for _, ctrl in ipairs(self._controls) do
            if ctrl.id and ctrl._setValue and data.controls[ctrl.id] ~= nil then
                ctrl._setValue(data.controls[ctrl.id])
            end
        end
    end

    self._activeConfig = name
    if self._configLabel then
        self._configLabel.text = "Active: "..name
    end

    -- Save meta
    local meta = {lastConfig = name, theme = self._themeName}
    local mok, menc = pcall(HttpService.JSONEncode, HttpService, meta)
    if mok then
        local dir = GetConfigDir(self._configTitle)
        EnsureDir(dir)
        SafeWrite(GetMetaPath(self._configTitle), menc)
    end
end


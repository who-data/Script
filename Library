                Parent = parent,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 24),
                Font = Enum.Font.GothamBold,
                Text = opts.Text or "",
                TextColor3 = opts.Color or Theme.TextMuted,
                TextSize = 10,
                TextXAlignment = Enum.TextXAlignment.Left,
            })
            Create("UIPadding", {
                Parent = Lbl,
                PaddingLeft = UDim.new(0, 12),
            })
            return Lbl
        end

        -- Section divider
        local function buildSection(parent, opts)
            opts = opts or {}
            local Sec = Create("Frame", {
                Parent = parent,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 26),
            })

            Create("Frame", {
                Parent = Sec,
                BackgroundColor3 = Theme.Border,
                BorderSizePixel = 0,
                Position = UDim2.new(0, 0, 0.5, 0),
                Size = UDim2.new(1, 0, 0, 1),
            })

            local SecLabel = Create("TextLabel", {
                Parent = Sec,
                BackgroundColor3 = Theme.Content,
                BorderSizePixel = 0,
                Position = UDim2.new(0, 10, 0.1, 0),
                Size = UDim2.new(0, 0, 0.8, 0),
                AutomaticSize = Enum.AutomaticSize.X,
                Font = Enum.Font.GothamBold,
                Text = " ".. (opts.Name or "Section") .." ",
                TextColor3 = Theme.SectionLabel,
                TextSize = 10,
            })

            return Sec
        end

        -- ColorPicker (basic)
        local function buildColorPicker(parent, opts)
            opts = opts or {}
            local color = opts.Default or Color3.fromRGB(255, 80, 140)
            local cb    = opts.Callback or function() end

            local Row = makeItemBase(parent, opts.Name or "Color", nil, 44)

            local Preview = Create("Frame", {
                Parent = Row,
                BackgroundColor3 = color,
                Position = UDim2.new(1, -46, 0.5, -10),
                Size = UDim2.new(0, 38, 0, 20),
            })
            Create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = Preview })
            Create("UIStroke", { Color = Theme.Border, Thickness = 1, Parent = Preview })

            -- Simple RGB input panel
            local Panel = Create("Frame", {
                Parent = Row,
                BackgroundColor3 = Theme.Dropdown,
                BorderSizePixel = 0,
                Position = UDim2.new(0, 0, 1, 2),
                Size = UDim2.new(1, 0, 0, 0),
                Visible = false,
                ZIndex = 10,
            })
            Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = Panel })
            Create("UIStroke", { Color = Theme.Border, Thickness = 1, Parent = Panel })

            local open = false
            Preview.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    open = not open
                    Panel.Visible = open
                    if open then
                        Tween(Panel, { Size = UDim2.new(1, 0, 0, 80) }, 0.15)
                    else
                        Tween(Panel, { Size = UDim2.new(1, 0, 0, 0) }, 0.15)
                        task.delay(0.15, function() Panel.Visible = false end)
                    end
                end
            end)

            local channels = { {"R", color.R*255}, {"G", color.G*255}, {"B", color.B*255} }
            local vals = { color.R*255, color.G*255, color.B*255 }

            for i, ch in ipairs(channels) do
                local ChTrack = Create("Frame", {
                    Parent = Panel,
                    BackgroundColor3 = Theme.SliderBack,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0, 10, 0, 6 + (i-1)*22),
                    Size = UDim2.new(1, -20, 0, 16),
                    ZIndex = 11,
                })
                Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = ChTrack })

                local chFillColor = i==1 and Color3.fromRGB(200,40,40) or i==2 and Color3.fromRGB(40,200,40) or Color3.fromRGB(40,40,200)
                local ChFill = Create("Frame", {
                    Parent = ChTrack,
                    BackgroundColor3 = chFillColor,
                    BorderSizePixel = 0,
                    Size = UDim2.new(vals[i]/255, 0, 1, 0),
                    ZIndex = 11,
                })
                Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = ChFill })

                Create("TextLabel", {
                    Parent = ChTrack,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 6, 0, 0),
                    Size = UDim2.new(0, 16, 1, 0),
                    Font = Enum.Font.GothamBold,
                    Text = ch[1],
                    TextColor3 = Theme.White,
                    TextSize = 9,
                    ZIndex = 12,
                })

                local dragging = false
                local function updateCh(x)
                    local abs = ChTrack.AbsolutePosition
                    local sz  = ChTrack.AbsoluteSize
                    local p = math.clamp((x - abs.X) / sz.X, 0, 1)
                    vals[i] = math.floor(p * 255)
                    ChFill.Size = UDim2.new(p, 0, 1, 0)
                    local newColor = Color3.fromRGB(vals[1], vals[2], vals[3])
                    Preview.BackgroundColor3 = newColor
                    pcall(cb, newColor)
                end

                ChTrack.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = true; updateCh(input.Position.X)
                    end
                end)
                UserInputService.InputChanged:Connect(function(input)
                    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                        updateCh(input.Position.X)
                    end
                end)
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
                end)
            end

            local ColorPicker = {}
            function ColorPicker:Set(c)
                Preview.BackgroundColor3 = c
                vals = {c.R*255, c.G*255, c.B*255}
            end
            function ColorPicker:Get()
                return Color3.fromRGB(vals[1], vals[2], vals[3])
            end

            return ColorPicker
        end

        -- ‚ĒÄ‚ĒÄ _addItem dispatcher ‚ĒÄ‚ĒÄ
        Tab._addItem = function(listParent, kind, opts)
            if kind == "Toggle"      then return buildToggle(listParent, opts)
            elseif kind == "Slider"  then return buildSlider(listParent, opts)
            elseif kind == "Button"  then return buildButton(listParent, opts)
            elseif kind == "Dropdown" then return buildDropdown(listParent, opts)
            elseif kind == "Input"   then return buildInput(listParent, opts)
            elseif kind == "Label"   then return buildLabel(listParent, opts)
            elseif kind == "Section" then return buildSection(listParent, opts)
            elseif kind == "ColorPicker" then return buildColorPicker(listParent, opts)
            end
        end

        -- Public methods on Tab
        Tab.AddToggle    = function(self, opts) return Tab._addItem(ItemList, "Toggle", opts) end
        Tab.AddSlider    = function(self, opts) return Tab._addItem(ItemList, "Slider", opts) end
        Tab.AddButton    = function(self, opts) return Tab._addItem(ItemList, "Button", opts) end
        Tab.AddDropdown  = function(self, opts) return Tab._addItem(ItemList, "Dropdown", opts) end
        Tab.AddInput     = function(self, opts) return Tab._addItem(ItemList, "Input", opts) end
        Tab.AddLabel     = function(self, opts) return Tab._addItem(ItemList, "Label", opts) end
        Tab.AddSection   = function(self, opts) return Tab._addItem(ItemList, "Section", opts) end
        Tab.AddColorPicker = function(self, opts) return Tab._addItem(ItemList, "ColorPicker", opts) end

        return Tab
    end

    -- ‚ĒÄ‚ĒÄ Notification ‚ĒÄ‚ĒÄ
    local NotifContainer = Create("Frame", {
        Parent = ScreenGui,
        BackgroundTransparency = 1,
        AnchorPoint = Vector2.new(1, 1),
        Position = UDim2.new(1, -12, 1, -12),
        Size = UDim2.new(0, 280, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
    })
    Create("UIListLayout", {
        Parent = NotifContainer,
        FillDirection = Enum.FillDirection.Vertical,
        VerticalAlignment = Enum.VerticalAlignment.Bottom,
        Padding = UDim.new(0, 6),
        SortOrder = Enum.SortOrder.LayoutOrder,
    })

    function Window:Notify(opts)
        opts = opts or {}
        local title   = opts.Title    or "Notification"
        local desc    = opts.Message  or ""
        local duration = opts.Duration or 4
        local ntype   = opts.Type     or "info" -- info, success, warning, error

        local typeColors = {
            info    = Color3.fromRGB(80, 160, 255),
            success = Color3.fromRGB(80, 220, 120),
            warning = Color3.fromRGB(255, 180, 50),
            error   = Color3.fromRGB(255, 70, 70),
        }
        local accentColor = typeColors[ntype] or Theme.Accent

        local Notif = Create("Frame", {
            Parent = NotifContainer,
            BackgroundColor3 = Theme.Item,
            BorderSizePixel = 0,
            Size = UDim2.new(1, 0, 0, 60),
            BackgroundTransparency = 1,
        })
        Create("UICorner", { CornerRadius = UDim.new(0, 8), Parent = Notif })
        Create("UIStroke", { Color = accentColor, Thickness = 1, Parent = Notif })

        -- Left accent
        Create("Frame", {
            Parent = Notif,
            BackgroundColor3 = accentColor,
            BorderSizePixel = 0,
            Position = UDim2.new(0, 0, 0.1, 0),
            Size = UDim2.new(0, 3, 0.8, 0),
        })

        Create("TextLabel", {
            Parent = Notif,
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 14, 0, 8),
            Size = UDim2.new(1, -22, 0, 18),
            Font = Enum.Font.GothamBold,
            Text = title,
            TextColor3 = Theme.Text,
            TextSize = 11,
            TextXAlignment = Enum.TextXAlignment.Left,
        })

        Create("TextLabel", {
            Parent = Notif,
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 14, 0, 28),
            Size = UDim2.new(1, -22, 0, 24),
            Font = Enum.Font.Gotham,
            Text = desc,
            TextColor3 = Theme.TextMuted,
            TextSize = 10,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextWrapped = true,
        })

        -- Progress bar
        local ProgBG = Create("Frame", {
            Parent = Notif,
            BackgroundColor3 = Theme.SliderBack,
            BorderSizePixel = 0,
            Position = UDim2.new(0, 14, 1, -6),
            Size = UDim2.new(1, -28, 0, 3),
        })
        Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = ProgBG })
        local ProgFill = Create("Frame", {
            Parent = ProgBG,
            BackgroundColor3 = accentColor,
            BorderSizePixel = 0,
            Size = UDim2.new(1, 0, 1, 0),
        })
        Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = ProgFill })

        Tween(Notif, { BackgroundTransparency = 0 }, 0.2)
        Tween(ProgFill, { Size = UDim2.new(0, 0, 1, 0) }, duration, Enum.EasingStyle.Linear)

        task.delay(duration, function()
            Tween(Notif, { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 0) }, 0.2)
            task.delay(0.22, function() Notif:Destroy() end)
        end)
    end

    function Window:Destroy()
        ScreenGui:Destroy()
    end

    return Window
end


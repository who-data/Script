            Text                    = text,
            TextColor3              = Color3.fromRGB(255, 255, 255),
            TextSize                = 13,
            Font                    = Enum.Font.GothamBold,
            Parent                  = b,
        })
        b.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                if callback then pcall(callback) end
                screenGui:Destroy()
            end
        end)
        b.MouseEnter:Connect(function()
            anim:Play(b, {BackgroundColor3 = color:Lerp(Color3.fromRGB(255,255,255), 0.1)}, TWEEN_SHORT)
        end)
        b.MouseLeave:Connect(function()
            anim:Play(b, {BackgroundColor3 = color}, TWEEN_SHORT)
        end)
    end

    if opts.Buttons then
        for _, btnOpts in ipairs(opts.Buttons) do
            makeBtn(btnOpts.Text, btnOpts.Color or theme:Get("Accent"), btnOpts.Callback)
        end
    else
        makeBtn("Cancel", theme:Get("SurfaceAlt"), opts.OnCancel)
        makeBtn("Confirm", theme:Get("Accent"), opts.OnConfirm)
    end

    card.Size = UDim2.new(0, 0, 0, 0)
    card.Position = UDim2.new(0.5, 0, 0.5, 0)
    overlay.BackgroundTransparency = 1
    anim:Play(overlay, {BackgroundTransparency = 0.6}, TWEEN_SHORT)
    anim:Play(card, {
        Size = UDim2.new(0, 380, 0, 200),
        Position = UDim2.new(0.5, -190, 0.5, -100)
    }, TWEEN_SPRING)

    self.ScreenGui = screenGui
    self.Card      = card

    return self
end

function Modal:Destroy()
    if self.ScreenGui then self.ScreenGui:Destroy() end
end


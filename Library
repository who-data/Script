--[[
    cfg fields:
        text        string   — label
        placeholder string   — placeholder text
        default     string   — initial value
        numeric     bool     — only allow numeric input
        maxLen      number   — max character length
        description string
        id          string
        callback    fn(string)
]]
function ShadowUI:_BTextInput(panel, ctrl)
    local val  = ctrl._val ~= nil and ctrl._val or (ctrl.default or "")
    local wrapH = ctrl.description and 62 or 54
    local wrap  = Row(panel, wrapH)

    Lbl(wrap, ctrl.text or "Input", 10, T.TxtSec, Enum.Font.Gotham,
        Enum.TextXAlignment.Left,
        UDim2.new(0, 4, 0, 3), UDim2.new(1, -6, 0, 14), 3)

    if ctrl.description then
        Lbl(wrap, ctrl.description, 10, T.TxtDim, Enum.Font.Gotham,
            Enum.TextXAlignment.Left,
            UDim2.new(0, 4, 0, 17), UDim2.new(1, -6, 0, 12), 3)
    end

    local boxY = ctrl.description and 32 or 18
    local box  = New("Frame", {
        Parent           = wrap,
        BackgroundColor3 = T.InputBg,
        Position         = UDim2.new(0, 0, 0, boxY),
        Size             = UDim2.new(1, 0, 0, 28),
        ZIndex           = 3,
        BorderSizePixel  = 0,
    })
    Corner(6, box)
    local boxStr = Stroke(T.Border, 1, box)

    local tb = New("TextBox", {
        Parent               = box,
        BackgroundTransparency = 1,
        Position             = UDim2.new(0, 10, 0, 0),
        Size                 = UDim2.new(1, -14, 1, 0),
        Font                 = Enum.Font.Gotham,
        PlaceholderText      = ctrl.placeholder or "Enter value...",
        PlaceholderColor3    = T.TxtDim,
        Text                 = tostring(val),
        TextColor3           = T.TxtPri,
        TextSize             = 11,
        ClearTextOnFocus     = false,
        ZIndex               = 4,
    })

    if ctrl.maxLen then
        tb:GetPropertyChangedSignal("Text"):Connect(function()
            if #tb.Text > ctrl.maxLen then
                tb.Text = tb.Text:sub(1, ctrl.maxLen)
            end
        end)
    end

    if ctrl.numeric then
        tb:GetPropertyChangedSignal("Text"):Connect(function()
            local clean = tb.Text:gsub("[^%d%.-]", "")
            if clean ~= tb.Text then tb.Text = clean end
        end)
    end

    tb.Focused:Connect(function()
        Tw(boxStr, { Color = T.Accent }, 0.1)
        Tw(box, { BackgroundColor3 = T.InputHov }, 0.1)
    end)
    tb.FocusLost:Connect(function(enter)
        Tw(boxStr, { Color = T.Border }, 0.1)
        Tw(box, { BackgroundColor3 = T.InputBg }, 0.1)
        val = tb.Text; ctrl._val = val
        if ctrl.callback then ctrl.callback(val) end
    end)

    if ctrl.tooltip then
        -- attach to box frame since TextBox eats events
        box.MouseEnter:Connect(function()
            local mp = UIS:GetMouseLocation()
            self:_ShowTooltip(ctrl.tooltip, mp.X, mp.Y)
        end)
        box.MouseLeave:Connect(function() self:_HideTooltip() end)
    end

    ctrl._setValue = function(v)
        val = tostring(v); ctrl._val = val; tb.Text = val
        if ctrl.callback then ctrl.callback(val) end
    end
    ctrl._getValue = function() return val end
    return wrap
end


function ThemeManager.new()
    local self = setmetatable({}, ThemeManager)
    self.Current = {}
    self.Listeners = {}
    for k, v in pairs(ThemeManager.Defaults) do
        self.Current[k] = v
    end
    return self
end

function ThemeManager:Set(theme)
    for k, v in pairs(theme) do
        self.Current[k] = v
    end
    for _, cb in ipairs(self.Listeners) do
        pcall(cb, self.Current)
    end
end

function ThemeManager:Get(key)
    return self.Current[key] or ThemeManager.Defaults[key]
end

function ThemeManager:OnChange(callback)
    table.insert(self.Listeners, callback)
end

-- ============================================================
-- ANIMATION MANAGER
-- ============================================================

local AnimationManager = {}
AnimationManager.__index = AnimationManager

function AnimationManager.new()
    local self = setmetatable({}, AnimationManager)
    self.ActiveTweens = {}
    return self
end

function AnimationManager:Play(instance, props, info)
    local info = info or TWEEN_MEDIUM
    if self.ActiveTweens[instance] then
        self.ActiveTweens[instance]:Cancel()
    end
    local tween = TweenService:Create(instance, info, props)
    self.ActiveTweens[instance] = tween
    tween:Play()
    tween.Completed:Connect(function()
        if self.ActiveTweens[instance] == tween then
            self.ActiveTweens[instance] = nil
        end
    end)
    return tween
end

function AnimationManager:FadeIn(instance, duration)
    instance.BackgroundTransparency = 1
    return self:Play(instance, {BackgroundTransparency = 0},
        TweenInfo.new(duration or 0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out))
end

function AnimationManager:FadeOut(instance, duration, callback)
    local t = self:Play(instance, {BackgroundTransparency = 1},
        TweenInfo.new(duration or 0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out))
    if callback then t.Completed:Connect(callback) end
    return t
end

function AnimationManager:Slide(instance, targetPos, info)
    return self:Play(instance, {Position = targetPos}, info or TWEEN_MEDIUM)
end

function AnimationManager:Scale(instance, targetSize, info)
    return self:Play(instance, {Size = targetSize}, info or TWEEN_MEDIUM)
end

function AnimationManager:ColorShift(instance, prop, color, info)
    return self:Play(instance, {[prop] = color}, info or TWEEN_SHORT)
end

function AnimationManager:Pulse(instance, color1, color2, prop)
    local prop = prop or "BackgroundColor3"
    self:Play(instance, {[prop] = color2}, TWEEN_SHORT)
    task.delay(0.15, function()
        self:Play(instance, {[prop] = color1}, TWEEN_SHORT)
    end)
end

function AnimationManager:Ripple(parent, x, y, color)
    local ripple = Instance.new("Frame")
    ripple.Size = UDim2.new(0, 0, 0, 0)
    ripple.Position = UDim2.new(0, x, 0, y)
    ripple.AnchorPoint = Vector2.new(0.5, 0.5)
    ripple.BackgroundColor3 = color or Color3.fromRGB(255, 255, 255)
    ripple.BackgroundTransparency = 0.7
    ripple.BorderSizePixel = 0
    ripple.ZIndex = parent.ZIndex + 10
    ripple.ClipsDescendants = false
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(1, 0)
    corner.Parent = ripple
    ripple.Parent = parent
    local maxSize = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * 2.5
    local t = TweenService:Create(ripple, TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, maxSize, 0, maxSize),
        BackgroundTransparency = 1
    })
    t:Play()
    t.Completed:Connect(function() ripple:Destroy() end)
end

function AnimationManager:CancelAll()
    for inst, tween in pairs(self.ActiveTweens) do
        tween:Cancel()
    end
    self.ActiveTweens = {}
end

-- ============================================================
-- UTILITY FUNCTIONS
-- ============================================================

local Utils = {}

function Utils.Create(class, props, children)
    local inst = Instance.new(class)
    for k, v in pairs(props or {}) do
        if k ~= "Parent" then
            inst[k] = v
        end
    end
    for _, child in ipairs(children or {}) do
        child.Parent = inst
    end
    if props and props.Parent then
        inst.Parent = props.Parent
    end
    return inst
end

function Utils.AddCorner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = radius or CORNER_RADIUS
    c.Parent = parent
    return c
end

function Utils.AddPadding(parent, top, right, bottom, left)
    local p = Instance.new("UIPadding")
    p.PaddingTop    = UDim.new(0, top    or 8)
    p.PaddingRight  = UDim.new(0, right  or 8)
    p.PaddingBottom = UDim.new(0, bottom or 8)
    p.PaddingLeft   = UDim.new(0, left   or 8)
    p.Parent = parent
    return p
end

function Utils.AddListLayout(parent, dir, spacing, halign, valign)
    local l = Instance.new("UIListLayout")
    l.FillDirection         = dir     or Enum.FillDirection.Vertical
    l.Padding               = UDim.new(0, spacing or 6)
    l.HorizontalAlignment   = halign  or Enum.HorizontalAlignment.Left
    l.VerticalAlignment     = valign  or Enum.VerticalAlignment.Top
    l.SortOrder             = Enum.SortOrder.LayoutOrder
    l.Parent = parent
    return l
end

function Utils.AddStroke(parent, color, thickness, trans)
    local s = Instance.new("UIStroke")
    s.Color         = color     or Color3.fromRGB(55, 55, 75)
    s.Thickness     = thickness or 1
    s.Transparency  = trans     or 0
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = parent
    return s
end

function Utils.AddGradient(parent, color0, color1, rotation)
    local g = Instance.new("UIGradient")
    g.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, color0 or Color3.fromRGB(40, 40, 60)),
        ColorSequenceKeypoint.new(1, color1 or Color3.fromRGB(20, 20, 35))
    })
    g.Rotation = rotation or 90
    g.Parent = parent
    return g
end

function Utils.AddSizeConstraint(parent, minX, minY, maxX, maxY)
    local s = Instance.new("UISizeConstraint")
    if minX then s.MinSize = Vector2.new(minX, minY or minX) end
    if maxX then s.MaxSize = Vector2.new(maxX, maxY or maxX) end
    s.Parent = parent
    return s
end

function Utils.GetTextSize(text, fontSize, font, bounds)
    return game:GetService("TextService"):GetTextSize(
        text, fontSize, font, bounds or Vector2.new(1000, 1000)
    )
end

function Utils.Lerp(a, b, t)
    return a + (b - a) * t
end

function Utils.Round(n, decimals)
    local factor = 10 ^ (decimals or 0)
    return math.floor(n * factor + 0.5) / factor
end

function Utils.Clamp(v, min, max)
    return math.max(min, math.min(max, v))
end

function Utils.DeepCopy(original)
    local copy = {}
    for k, v in pairs(original) do
        if type(v) == "table" then
            copy[k] = Utils.DeepCopy(v)
        else
            copy[k] = v
        end
    end
    return copy
end

function Utils.Connect(connections, signal, callback)
    local conn = signal:Connect(callback)
    table.insert(connections, conn)
    return conn
end

function Utils.Disconnect(connections)
    for _, conn in ipairs(connections) do
        if conn and conn.Connected then
            conn:Disconnect()
        end
    end
    table.clear(connections)
end

function Utils.MakeScrolling(frame, canvasSize)
    frame.ScrollBarThickness = 4
    frame.ScrollBarImageColor3 = Color3.fromRGB(80, 80, 110)
    frame.ScrollingDirection = Enum.ScrollingDirection.Y
    frame.CanvasSize = canvasSize or UDim2.new(0, 0, 0, 0)
    frame.AutomaticCanvasSize = Enum.AutomaticSize.Y
    frame.BorderSizePixel = 0
    return frame
end

function Utils.AutoSize(listParent, targetFrame, extraPad)
    local layout = listParent:FindFirstChildOfClass("UIListLayout")
    if layout then
        local function update()
            targetFrame.CanvasSize = UDim2.new(0, 0, 0,
                layout.AbsoluteContentSize.Y + (extraPad or 16))
        end
        layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(update)
        update()
    end
end

-- ============================================================
-- INPUT HANDLER
-- ============================================================

local InputHandler = {}
InputHandler.__index = InputHandler

function InputHandler.new()
    local self = setmetatable({}, InputHandler)
    self.Binds       = {}
    self.Connections = {}
    self._listening  = false
    return self
end

function InputHandler:Start()
    if self._listening then return end
    self._listening = true
    local conn = UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        local key = input.KeyCode
        if self.Binds[key] then
            for _, cb in ipairs(self.Binds[key]) do
                pcall(cb, input)
            end
        end
    end)
    table.insert(self.Connections, conn)
end

function InputHandler:Bind(key, callback)
    if not self.Binds[key] then
        self.Binds[key] = {}
    end
    table.insert(self.Binds[key], callback)
    return function()
        self:Unbind(key, callback)
    end
end

function InputHandler:Unbind(key, callback)
    if not self.Binds[key] then return end
    for i, cb in ipairs(self.Binds[key]) do
        if cb == callback then
            table.remove(self.Binds[key], i)
            break
        end
    end
end

function InputHandler:Stop()
    Utils.Disconnect(self.Connections)
    self._listening = false
end

-- ============================================================
-- NOTIFICATION SYSTEM
-- ============================================================

local NotificationSystem = {}
NotificationSystem.__index = NotificationSystem

function NotificationSystem.new(theme, anim)
    local self = setmetatable({}, NotificationSystem)
    self.Theme       = theme
    self.Anim        = anim
    self.Queue       = {}
    self.Active      = {}
    self.MaxVisible  = 5
    self.Container   = nil
    self:_BuildContainer()
    return self
end

function NotificationSystem:_BuildContainer()
    local screenGui = Utils.Create("ScreenGui", {
        Name             = "NexusNotifications",
        ResetOnSpawn     = false,
        ZIndexBehavior   = Enum.ZIndexBehavior.Sibling,
        DisplayOrder     = 999,
    })
    pcall(function() screenGui.Parent = CoreGui end)
    if not screenGui.Parent then
        screenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
    end

    local container = Utils.Create("Frame", {
        Name                    = "Container",
        Size                    = UDim2.new(0, 320, 1, 0),
        Position                = UDim2.new(1, -330, 0, 0),
        AnchorPoint             = Vector2.new(0, 0),
        BackgroundTransparency  = 1,
        Parent                  = screenGui,
    })
    Utils.AddListLayout(container, Enum.FillDirection.Vertical, 8,
        Enum.HorizontalAlignment.Right, Enum.VerticalAlignment.Bottom)
    local padding = Instance.new("UIPadding")
    padding.PaddingBottom = UDim.new(0, 16)
    padding.PaddingRight  = UDim.new(0, 10)
    padding.Parent = container

    self.Container = container
    self.ScreenGui = screenGui
end

function NotificationSystem:_GetTypeColor(ntype)
    local map = {
        success = self.Theme:Get("Success"),
        warning = self.Theme:Get("Warning"),
        error   = self.Theme:Get("Error"),
        info    = self.Theme:Get("Info"),
    }
    return map[string.lower(ntype or "info")] or self.Theme:Get("Accent")
end

function NotificationSystem:Send(opts)
    local opts = opts or {}
    local title     = opts.Title    or "Notification"
    local text      = opts.Text     or ""
    local duration  = opts.Duration or 3
    local ntype     = opts.Type     or "info"
    local callback  = opts.Callback

    local accentColor = self:_GetTypeColor(ntype)
    local theme       = self.Theme

    local card = Utils.Create("Frame", {
        Name                    = "Notification",
        Size                    = UDim2.new(1, 0, 0, 80),
        BackgroundColor3        = theme:Get("Surface"),
        BackgroundTransparency  = 0,
        ClipsDescendants        = true,
        LayoutOrder             = -os.clock(),
    })
    Utils.AddCorner(card, CORNER_RADIUS)
    Utils.AddStroke(card, theme:Get("Border"))

    local accent = Utils.Create("Frame", {
        Name                    = "Accent",
        Size                    = UDim2.new(0, 3, 1, 0),
        BackgroundColor3        = accentColor,
        BorderSizePixel         = 0,
        Parent                  = card,
    })
    Utils.AddCorner(accent, UDim.new(0, 3))

    local content = Utils.Create("Frame", {
        Name                    = "Content",
        Size                    = UDim2.new(1, -16, 1, 0),
        Position                = UDim2.new(0, 12, 0, 0),
        BackgroundTransparency  = 1,
        Parent                  = card,
    })
    Utils.AddPadding(content, 10, 10, 10, 4)

    Utils.Create("TextLabel", {
        Name                    = "Title",
        Size                    = UDim2.new(1, 0, 0, 18),
        BackgroundTransparency  = 1,
        Text                    = title,
        TextColor3              = theme:Get("Text"),
        TextSize                = 14,
        Font                    = Enum.Font.GothamBold,
        TextXAlignment          = Enum.TextXAlignment.Left,
        Parent                  = content,
    })

    Utils.Create("TextLabel", {
        Name                    = "Body",
        Size                    = UDim2.new(1, 0, 0, 32),
        Position                = UDim2.new(0, 0, 0, 22),
        BackgroundTransparency  = 1,
        Text                    = text,
        TextColor3              = theme:Get("TextSecondary"),
        TextSize                = 12,
        Font                    = Enum.Font.Gotham,
        TextXAlignment          = Enum.TextXAlignment.Left,
        TextWrapped             = true,
        Parent                  = content,
    })

    local progress = Utils.Create("Frame", {
        Name                    = "Progress",
        Size                    = UDim2.new(1, 0, 0, 2),
        Position                = UDim2.new(0, 0, 1, -2),
        BackgroundColor3        = accentColor,
        BorderSizePixel         = 0,
        Parent                  = card,
    })

    card.Position = UDim2.new(0, 340, 0, 0)
    card.Parent = self.Container

    self.Anim:Play(card, {Position = UDim2.new(0, 0, 0, 0)}, TWEEN_SPRING)
    self.Anim:Play(progress, {Size = UDim2.new(0, 0, 0, 2)},
        TweenInfo.new(duration, Enum.EasingStyle.Linear))

    table.insert(self.Active, card)

    if callback then
        card.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                pcall(callback)
            end
        end)
    end

    task.delay(duration, function()
        self.Anim:Play(card, {
            Position = UDim2.new(0, 340, 0, 0),
            BackgroundTransparency = 1
        }, TWEEN_MEDIUM)
        task.delay(0.3, function()
            card:Destroy()
            for i, v in ipairs(self.Active) do
                if v == card then table.remove(self.Active, i) break end
            end
        end)
    end)
end

function NotificationSystem:Destroy()
    if self.ScreenGui then
        self.ScreenGui:Destroy()
    end
end


-- ============================================================
-- SLIDER  ← IMPLEMENTAÇÃO DEFINITIVA
--
-- Arquitetura:
-- 1. Visual (track/fill/thumb) no ScrollingFrame — apenas display
-- 2. hitBtn criado no ScreenGui (ZIndex 150) — fora de qualquer clip
-- 3. RenderStepped sincroniza posição do hitBtn com o track
-- 4. MouseButton1Down inicia loop de drag
-- 5. UIS.InputEnded (global) para o drag
-- 6. SliderMgr.Clear() destrói TODOS os hitBtns ao trocar de seção
-- ============================================================
function SUI:_Slider(par, ctrl)
    local mn  = ctrl.min    or 0
    local mx  = ctrl.max    or 100
    local inc = ctrl.step   or 1
    local fmt = ctrl.format or "%.2f"
    local val = ctrl._val ~= nil and ctrl._val or (ctrl.default or mn)

    local function Snap(v)
        if inc > 0 then v = math.round((v-mn)/inc)*inc+mn end
        return math.clamp(v, mn, mx)
    end

    -- Elemento visual (no ScrollingFrame — apenas visuais)
    local wrap = ElemF(par, 50)

    -- Nome + valor
    local topR = N("Frame",{Parent=wrap,BackgroundTransparency=1,
        Position=UDim2.new(0,12,0,6),Size=UDim2.new(1,-24,0,14),ZIndex=3})
    Lb(topR,ctrl.text or "",11,T.TSEC,Enum.Font.Gotham,
        Enum.TextXAlignment.Left,nil,UDim2.new(0.65,0,1,0),3)
    local vLbl = Lb(topR,string.format(fmt,val),11,T.TACC,Enum.Font.GothamBold,
        Enum.TextXAlignment.Right,UDim2.new(0.65,0,0,0),UDim2.new(0.35,0,1,0),3)

    -- Track
    local track = N("Frame",{Parent=wrap,BackgroundColor3=T.BRD2,
        Position=UDim2.new(0,12,0,29),Size=UDim2.new(1,-24,0,4),ZIndex=4})
    Cr(2,track)

    local pct = (val-mn)/(mx-mn)
    local fill = N("Frame",{Parent=track,BackgroundColor3=T.ACC,
        Size=UDim2.new(pct,0,1,0),ZIndex=5})
    Cr(2,fill)
    -- Gradiente no fill
    N("UIGradient",{Parent=fill,
        Color=ColorSequence.new{ColorSequenceKeypoint.new(0,T.ACC),ColorSequenceKeypoint.new(1,T.ACCHI)}})

    local thumb = N("Frame",{Parent=track,BackgroundColor3=T.WH,
        Position=UDim2.new(pct,-7,0.5,-7),Size=UDim2.new(0,14,0,14),ZIndex=6})
    Cr(7,thumb); Sk(T.ACC,1.5,thumb)

    -- Função de update (recebe X absoluto do mouse)
    local function Update(mouseX)
        local lo = track.AbsolutePosition.X
        local sz = track.AbsoluteSize.X
        if sz <= 0 then return end
        local p  = math.clamp((mouseX-lo)/sz, 0, 1)
        local v  = Snap(mn + p*(mx-mn))
        val=v; ctrl._val=v
        local np = (v-mn)/(mx-mn)
        fill.Size = UDim2.new(np,0,1,0)
        thumb.Position = UDim2.new(np,-7,0.5,-7)
        vLbl.Text = string.format(fmt,v)
        if ctrl.callback then ctrl.callback(v) end
    end

    -- ★ HITBTN NO SCREENGUI — nunca clipado
    local hitBtn = N("TextButton",{Parent=self.Gui,
        BackgroundTransparency=1,Text="",ZIndex=150})
    -- Tamanho inicial (será atualizado pelo sync)
    hitBtn.Size     = UDim2.new(0,100,0,30)
    hitBtn.Position = UDim2.new(0,0,0,0)

    local sliding  = false
    local dragConn = nil

    -- Sincroniza posição/tamanho do hitBtn com o track (a cada frame)
    local syncConn = RS.RenderStepped:Connect(function()
        -- Verifica se o track ainda existe e está na tela
        if not track:IsDescendantOf(game) then return end
        local ap = track.AbsolutePosition
        local as = track.AbsoluteSize
        -- Área de clique maior que o track visual (para facilitar)
        hitBtn.Position = UDim2.new(0, ap.X - 6,    0, ap.Y - 10)
        hitBtn.Size     = UDim2.new(0, as.X + 12,   0, as.Y + 20)
    end)

    -- Inicia drag
    hitBtn.MouseButton1Down:Connect(function()
        sliding = true
        if dragConn then dragConn:Disconnect(); dragConn=nil end
        dragConn = RS.RenderStepped:Connect(function()
            if not sliding then
                dragConn:Disconnect(); dragConn=nil; return
            end
            Update(UIS:GetMouseLocation().X)
        end)
        -- Update imediato no clique
        Update(UIS:GetMouseLocation().X)
    end)

    -- Para drag ao soltar (captura global)
    UIS.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            sliding = false
        end
    end)

    -- ★ Registra no SliderMgr para ser limpo quando a seção mudar
    SliderMgr:Add(hitBtn, syncConn, dragConn)

    local function Set(v)
        v=Snap(v); val=v; ctrl._val=v
        local p=(v-mn)/(mx-mn)
        fill.Size=UDim2.new(p,0,1,0)
        thumb.Position=UDim2.new(p,-7,0.5,-7)
        vLbl.Text=string.format(fmt,v)
        if ctrl.callback then ctrl.callback(v) end
    end
    ctrl._setValue=Set; ctrl._getValue=function() return val end
    return wrap
end


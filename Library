--[[
    UI:Toggle(section, side, config)
        section  – returned by AddSection
        side     – "left" | "right"
        config   – { text, default, callback, gear }
--]]
function ShadowUI:Toggle(section, side, config)
    config       = config or {}
    config.type  = "toggle"
    local list   = (side == "right") and section._right or section._left
    list[#list + 1] = config
    if section._active then
        local panel = (side == "right") and self.RightPanel or self.LeftPanel
        self:_BuildToggle(panel, config)
    end
    return config
end


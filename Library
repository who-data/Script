    local track = New("Frame",{
        Parent=wrap, BackgroundColor3=val and T.TogOn or T.TogOff,
        Position=UDim2.new(1,-30,0.5,-7),
        Size=UDim2.new(0,26,0,14),
        ZIndex=4, BorderSizePixel=0,
    })

-- ══════════════════════════════════════════════
--  PUBLIC API  (mesmos métodos de antes)
-- ══════════════════════════════════════════════
local function _AddCtrl(sec, side, cfg)
    local list = (side == "right") and sec._right or sec._left
    list[#list + 1] = cfg
    if sec._active then
        local ui    = sec._self
        local panel = (side == "right") and ui.RightPanel or ui.LeftPanel
        ui:_BuildControl(panel, cfg)
    end
    return cfg
end

function ShadowUI:Toggle(section, side, config)
    config = config or {}; config.type = "toggle"
    return _AddCtrl(section, side, config)
end

function ShadowUI:Slider(section, side, config)
    config = config or {}; config.type = "slider"
    return _AddCtrl(section, side, config)
end

function ShadowUI:Dropdown(section, side, config)
    config = config or {}; config.type = "dropdown"
    return _AddCtrl(section, side, config)
end

function ShadowUI:SectionHeader(section, side, config)
    config = config or {}; config.type = "section_header"
    return _AddCtrl(section, side, config)
end

function ShadowUI:Label(section, side, config)
    config = config or {}; config.type = "label"
    return _AddCtrl(section, side, config)
end

-- ──────────────────────────────────────────────
--  BIND TOGGLE KEY
-- ──────────────────────────────────────────────
function ShadowUI:BindToggleKey(keyCode)
    UserInputService.InputBegan:Connect(function(inp, gpe)
        if gpe then return end
        if inp.KeyCode == keyCode then
            self._visible       = not self._visible
            self.Window.Visible = self._visible
        end
    end)
end


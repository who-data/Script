        local function activate()
            if Win._active then
                Win._active._active=false
                Win._active._page.Visible=false
                Win._active._btn.BackgroundTransparency=1
                local ob=Win._active._btn:FindFirstChild("ActiveBar")
                if ob then ob.Visible=false end
                for _,v in ipairs(Win._active._btn:GetChildren()) do
                    if v:IsA("TextLabel") then tween(v,{TextColor3=C.TEXT_DIM}) end
                end
            end
            Win._active=Tab
            Tab._active=true
            page.Visible=true
            tween(btn,{BackgroundTransparency=0.88})
            btn.BackgroundColor3=C.ACCENT
            activebar.Visible=true
            tween(icnLbl,{TextColor3=C.ACCENT})
            tween(nameLbl,{TextColor3=C.WHITE})
        end

        btn.MouseEnter:Connect(function()
            if not Tab._active then
                tween(btn,{BackgroundTransparency=0.93})
                btn.BackgroundColor3=C.ACCENT
                tween(icnLbl,{TextColor3=C.TEXT})
                tween(nameLbl,{TextColor3=C.TEXT})
            end
        end)
        btn.MouseLeave:Connect(function()
            if not Tab._active then
                tween(btn,{BackgroundTransparency=1})
                tween(icnLbl,{TextColor3=C.TEXT_DIM})
                tween(nameLbl,{TextColor3=C.TEXT_DIM})
            end
        end)
        btn.MouseButton1Click:Connect(activate)
        table.insert(Win._tabs,Tab)
        if #Win._tabs==1 then activate() end

        -- ── item helpers ──────────────────────────────────────────────────────

        local function baseRow(lbl,sub,h,targetList)
            h=h or 46
            targetList=targetList or itemList
            local row=new("Frame",{
                Parent=targetList,BackgroundColor3=Color3.fromRGB(28,28,34),
                BackgroundTransparency=0,BorderSizePixel=0,Size=UDim2.new(1,0,0,h),
            })
            new("Frame",{Parent=row,BackgroundColor3=C.ITEM_DIV,BorderSizePixel=0,
                Position=UDim2.new(0,12,1,-1),Size=UDim2.new(1,-12,0,1)})
            row.MouseEnter:Connect(function() tween(row,{BackgroundColor3=Color3.fromRGB(34,34,42)}) end)
            row.MouseLeave:Connect(function() tween(row,{BackgroundColor3=Color3.fromRGB(28,28,34)}) end)
            if lbl then
                new("TextLabel",{Parent=row,BackgroundTransparency=1,
                    Position=UDim2.new(0,14,0,sub and 6 or 0),
                    Size=UDim2.new(0.65,0,sub and 0 or 1,sub and 18 or 0),
                    AutomaticSize=sub and Enum.AutomaticSize.None or Enum.AutomaticSize.Y,
                    Font=Enum.Font.Gotham,Text=lbl,
                    TextColor3=C.TEXT,TextSize=11,TextXAlignment=Enum.TextXAlignment.Left})
            end
            if sub then
                new("TextLabel",{Parent=row,BackgroundTransparency=1,
                    Position=UDim2.new(0,14,0,24),Size=UDim2.new(0.65,0,0,16),
                    Font=Enum.Font.Gotham,Text=sub,
                    TextColor3=C.TEXT_SUB,TextSize=9,TextXAlignment=Enum.TextXAlignment.Left})
            end
            return row
        end


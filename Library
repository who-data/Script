    local function getSelectedText()
        local keys = {}
        for k, v in pairs(selected) do
            if v then table.insert(keys, tostring(k)) end
        end
        if #keys == 0 then return "None" end
        return table.concat(keys, ", ")
    end

    local function buildList()
        for _, child in ipairs(listFrame:GetChildren()) do
            if child:IsA("Frame") then child:Destroy() end
        end
        for _, opt in ipairs(options) do
            local isSelected = selected[opt] == true
            local item = Utils.Create("Frame", {
                Name                    = "Item_" .. tostring(opt),
                Size                    = UDim2.new(1, 0, 0, 28),
                BackgroundColor3        = isSelected and theme:Get("SurfaceAlt") or theme:Get("Surface"),
                BorderSizePixel         = 0,
                ZIndex                  = 51,
                Parent                  = listFrame,
            })
            Utils.AddCorner(item, CORNER_SMALL)
            Utils.AddPadding(item, 0, 8, 0, 8)

            local checkFrame = Utils.Create("Frame", {
                Size                    = UDim2.new(0, 14, 0, 14),
                Position                = UDim2.new(0, 0, 0.5, -7),
                BackgroundColor3        = isSelected and theme:Get("Accent") or theme:Get("Border"),
                BorderSizePixel         = 0,
                ZIndex                  = 52,
                Parent                  = item,
            })
            Utils.AddCorner(checkFrame, UDim.new(0, 3))

            if isSelected then
                Utils.Create("TextLabel", {
                    Size                    = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency  = 1,
                    Text                    = "✓",
                    TextColor3              = theme:Get("White"),
                    TextSize                = 10,
                    Font                    = Enum.Font.GothamBold,
                    ZIndex                  = 53,
                    Parent                  = checkFrame,
                })
            end

            Utils.Create("TextLabel", {
                Size                    = UDim2.new(1, -22, 1, 0),
                Position                = UDim2.new(0, 20, 0, 0),
                BackgroundTransparency  = 1,
                Text                    = tostring(opt),
                TextColor3              = isSelected and theme:Get("Accent") or theme:Get("Text"),
                TextSize                = 12,
                Font                    = Enum.Font.Gotham,
                TextXAlignment          = Enum.TextXAlignment.Left,
                ZIndex                  = 52,
                Parent                  = item,
            })

            item.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    selected[opt] = not selected[opt]
                    selectedLabel.Text = getSelectedText()
                    local vals = {}
                    for k, v in pairs(selected) do if v then table.insert(vals, k) end end
                    if opts.Callback then pcall(opts.Callback, vals) end
                    buildList()
                end
            end)
        end
        listFrame.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 8)
    end

    buildList()
    selectedLabel.Text = getSelectedText()

    Utils.Connect(connections, frame.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            open = not open
            listFrame.Visible = true
            if open then
                self.Anim:Play(listFrame, {Size = UDim2.new(1, 0, 0, math.min(#options * 30 + 8, 160))}, TWEEN_MEDIUM)
                self.Anim:Play(arrowLabel, {Rotation = 180}, TWEEN_SHORT)
                wrapper.Size = UDim2.new(1, 0, 0, 36 + math.min(#options * 30 + 8, 160) + 4)
            else
                self.Anim:Play(listFrame, {Size = UDim2.new(1, 0, 0, 0)}, TWEEN_MEDIUM)
                self.Anim:Play(arrowLabel, {Rotation = 0}, TWEEN_SHORT)
                task.delay(0.25, function()
                    if not open then
                        listFrame.Visible = false
                        wrapper.Size = UDim2.new(1, 0, 0, 36)
                    end
                end)
            end
        end
    end)

    return {
        Frame     = wrapper,
        GetValue  = function()
            local vals = {}
            for k, v in pairs(selected) do if v then table.insert(vals, k) end end
            return vals
        end,
        Destroy   = function()
            Utils.Disconnect(connections)
            wrapper:Destroy()
        end,
    }
end


--  BREADCRUMB
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
function ShadowUI:_Bread(catName, secName)
    if not self.BreadFrame then return end
    local T = self._T
    for _, c in ipairs(self.BreadFrame:GetChildren()) do
        if c ~= self.BreadCat and not c:IsA("UIListLayout") then c:Destroy() end
    end
    self.BreadCat.Text = catName
    if secName then
        MkLbl(self.BreadFrame,"›",13,T.TextSec,Enum.Font.Gotham,
            Enum.TextXAlignment.Center,nil,UDim2.new(0,10,1,0),5)
        MkLbl(self.BreadFrame,secName,12,T.TextAccent,Enum.Font.GothamBold,
            Enum.TextXAlignment.Left,nil,UDim2.new(0,110,1,0),5)
    end
end

-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
--  ADD CATEGORY
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
function ShadowUI:AddCategory(name)
    -- Wait for UI to be built
    while not self.SideList do task.wait() end

    local T = self._T
    local cat = {Name=name, _sections={}, _expanded=false, _ui=self}

    local Row = New("TextButton",{
        Parent=self.SideList, BackgroundTransparency=1,
        Size=UDim2.new(1,0,0,32), Text="",
        AutoButtonColor=false, ZIndex=5,
    })
    Corn(4, Row)

    Row.MouseEnter:Connect(function()
        Tw(Row,{BackgroundColor3=T.RowHover},.08)
        Row.BackgroundTransparency=0
    end)
    Row.MouseLeave:Connect(function()
        if not cat._expanded then Row.BackgroundTransparency=1 end
    end)

    -- Icon
    New("Frame",{
        Parent=Row, BackgroundTransparency=1,
        Position=UDim2.new(0,9,0.5,-8), Size=UDim2.new(0,16,0,16), ZIndex=6,
    },{Corn(8), Stro(T.White,1.4)})
    New("Frame",{
        Parent=Row, BackgroundColor3=T.White,
        Position=UDim2.new(0,13,0.5,-4), Size=UDim2.new(0,8,0,8), ZIndex=7,
    },{Corn(4)})

    MkLbl(Row, name, 12, T.TextPri, Enum.Font.GothamBold,
        Enum.TextXAlignment.Left, UDim2.new(0,32,0,0), UDim2.new(1,-52,1,0), 6)

    local Chev = MkLbl(Row,"‹",14,T.TextSec,Enum.Font.GothamBold,
        Enum.TextXAlignment.Center, UDim2.new(1,-22,0,0), UDim2.new(0,18,1,0), 6)

    local SF = New("Frame",{
        Parent=self.SideList, BackgroundTransparency=1,
        Size=UDim2.new(1,0,0,0), ClipsDescendants=true, Visible=false, ZIndex=5,
    })
    local SL = List(SF)

    cat._row=Row; cat._sf=SF; cat._sl=SL; cat._chev=Chev

    Row.MouseButton1Click:Connect(function()
        cat._expanded = not cat._expanded
        if cat._expanded then
            SF.Visible=true
            SF.Size=UDim2.new(1,0,0,SL.AbsoluteContentSize.Y)
            Chev.Text="›"
            Row.BackgroundTransparency=0
            Row.BackgroundColor3=T.RowHover
            if #cat._sections>0 and not cat._sections[1]._active then
                cat._sections[1]._btn.MouseButton1Click:Fire()
            end
        else
            SF.Visible=false; SF.Size=UDim2.new(1,0,0,0)
            Chev.Text="‹"; Row.BackgroundTransparency=1
        end
    end)

    self._sidebar[#self._sidebar+1]=cat
    return cat
end

-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
--  ADD SECTION
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
function ShadowUI:AddSection(cat, name)
    while not self.SideList do task.wait() end

    local T = self._T
    local sec = {Name=name, _cat=cat, _active=false, _left={}, _right={}, _ui=self}

    local Btn = New("TextButton",{
        Parent=cat._sf, BackgroundTransparency=1,
        Size=UDim2.new(1,0,0,26), Text="",
        AutoButtonColor=false, ZIndex=6,
    })
    Corn(3, Btn)

    local AccBar = New("Frame",{
        Parent=Btn, BackgroundColor3=T.Accent,
        Position=UDim2.new(0,0,0.2,0), Size=UDim2.new(0,2,0.6,0),
        ZIndex=8, Visible=false,
    })
    Corn(1, AccBar)

    local Dia = New("Frame",{
        Parent=Btn, BackgroundColor3=T.AccentDim,
        Position=UDim2.new(0,18,0.5,-4), Size=UDim2.new(0,8,0,8),
        Rotation=45, ZIndex=7,
    })

    local Lbl_ = MkLbl(Btn, name, 11, T.TextSec, Enum.Font.Gotham,
        Enum.TextXAlignment.Left, UDim2.new(0,32,0,0), UDim2.new(1,-36,1,0), 7)

    sec._btn=Btn; sec._dia=Dia; sec._lbl=Lbl_; sec._accBar=AccBar

    Btn.MouseEnter:Connect(function()
        if not sec._active then
            Tw(Btn,{BackgroundColor3=T.RowHover},.08)
            Btn.BackgroundTransparency=0
        end
    end)
    Btn.MouseLeave:Connect(function()
        if not sec._active then Btn.BackgroundTransparency=1 end
    end)

    Btn.MouseButton1Click:Connect(function()
        if self._activeSec then
            local p=self._activeSec
            p._active=false; p._lbl.TextColor3=T.TextSec
            p._dia.BackgroundColor3=T.AccentDim
            p._accBar.Visible=false
            p._btn.BackgroundTransparency=1
        end
        sec._active=true
        Lbl_.TextColor3=T.TextAccent
        Dia.BackgroundColor3=T.Accent
        AccBar.Visible=true
        Btn.BackgroundColor3=Color3.fromRGB(22,20,36)
        Btn.BackgroundTransparency=0
        self._activeSec=sec
        self:_Bread(cat.Name, name)
        self:_Render(sec)
    end)

    cat._sections[#cat._sections+1]=sec
    cat._sf.Size=UDim2.new(1,0,0,cat._sl.AbsoluteContentSize.Y+26)
    return sec
end

-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
--  RENDER
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
function ShadowUI:_Render(sec)
    if not self.LeftScroll then return end
    for _, p in ipairs({self.LeftScroll,self.RightScroll}) do
        for _, c in ipairs(p:GetChildren()) do
            if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then c:Destroy() end
        end
    end
    for _, c in ipairs(self.TabList:GetChildren()) do
        if not c:IsA("UIListLayout") then c:Destroy() end
    end

    local T = self._T

    for _, s in ipairs(sec._cat._sections) do
        local act=(s==sec)
        local Tab = New("Frame",{
            Parent=self.TabList, BackgroundTransparency=1,
            Size=UDim2.new(0,82,1,0), ZIndex=3,
        })
        if act then
            New("Frame",{
                Parent=Tab, BackgroundColor3=T.Accent,
                Position=UDim2.new(0,0,1,-2), Size=UDim2.new(1,0,0,2), ZIndex=5,
            })
        end
        New("Frame",{
            Parent=Tab,
            BackgroundColor3=act and T.Accent or T.AccentDim,
            Position=UDim2.new(0,4,0.5,-3), Size=UDim2.new(0,7,0,7),
            Rotation=45, ZIndex=4,
        })
        MkLbl(Tab, s.Name, 11, act and T.TextAccent or T.TextSec,
            act and Enum.Font.GothamBold or Enum.Font.Gotham,
            Enum.TextXAlignment.Left, UDim2.new(0,16,0,0), UDim2.new(1,-16,1,0), 4)
    end

    for _, ctrl in ipairs(sec._left)  do self:_Build(self.LeftScroll,  ctrl) end
    for _, ctrl in ipairs(sec._right) do self:_Build(self.RightScroll, ctrl) end
end

-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
--  BUILD DISPATCHER
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
function ShadowUI:_Build(p, ctrl)
    if ctrl.type=="toggle"    then return self:_Toggle(p,ctrl)      end
    if ctrl.type=="slider"    then return self:_Slider(p,ctrl)      end
    if ctrl.type=="dropdown"  then return self:_Dropdown(p,ctrl)    end
    if ctrl.type=="header"    then return self:_Header(p,ctrl)      end
    if ctrl.type=="label"     then return self:_Label(p,ctrl)       end
    if ctrl.type=="configbtn" then return self:_BuildConfigBtn(p,ctrl) end
end

-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
--  TOGGLE
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
function ShadowUI:_Toggle(parent, ctrl)
    local T = self._T
    local val = ctrl._val~=nil and ctrl._val or (ctrl.default or false)
    local row = MkRow(parent, 30)

    local HBtn = New("TextButton",{
        Parent=row, BackgroundTransparency=1,
        Size=UDim2.new(1,0,1,0), Text="", ZIndex=5,
    })
    Corn(4, row)
    HBtn.MouseEnter:Connect(function()
        Tw(row,{BackgroundColor3=T.RowHover},.08)
        row.BackgroundTransparency=0
    end)
    HBtn.MouseLeave:Connect(function() row.BackgroundTransparency=1 end)

    local rOff=-38
    if ctrl.gear then
        local G=New("TextButton",{
            Parent=row, BackgroundTransparency=1,
            Position=UDim2.new(1,-54,0.5,-8), Size=UDim2.new(0,16,0,16),
            Font=Enum.Font.Gotham, Text="⚙",
            TextColor3=T.TextSec, TextSize=13, ZIndex=6,
        })
        G.MouseEnter:Connect(function() Tw(G,{TextColor3=T.TextAccent},.08) end)
        G.MouseLeave:Connect(function() Tw(G,{TextColor3=T.TextSec},.08) end)
        rOff=-58
    end

    local L=MkLbl(row, ctrl.text or "Toggle", 12,
        val and T.TextPri or T.TextDim,
        Enum.Font.Gotham, Enum.TextXAlignment.Left,
        UDim2.new(0,0,0,0), UDim2.new(1,rOff,1,0), 4)

    local Tr=New("Frame",{
        Parent=row, BackgroundColor3=val and T.ToggleOn or T.ToggleOff,
        Position=UDim2.new(1,-30,0.5,-7), Size=UDim2.new(0,26,0,14), ZIndex=4,
    })
    Corn(7, Tr)

    local Th=New("Frame",{
        Parent=Tr, BackgroundColor3=T.White,
        Position=val and UDim2.new(1,-13,0.5,-5) or UDim2.new(0,2,0.5,-5),
        Size=UDim2.new(0,10,0,10), ZIndex=5,
    })
    Corn(5, Th)

    local function Set(v)
        val=v; ctrl._val=v
        Tw(Tr,{BackgroundColor3=v and T.ToggleOn or T.ToggleOff},.12)
        Tw(Th,{Position=v and UDim2.new(1,-13,0.5,-5) or UDim2.new(0,2,0.5,-5)},.12)
        L.TextColor3=v and T.TextPri or T.TextDim
        if ctrl.callback then ctrl.callback(v) end
    end

    HBtn.MouseButton1Click:Connect(function() Set(not val) end)
    ctrl._setValue=Set; ctrl._getValue=function() return val end
    return row
end

-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
--  SLIDER  (corrigido — drag fluido)
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
function ShadowUI:_Slider(parent, ctrl)
    local T   = self._T
    local mn  = ctrl.min    or 0
    local mx  = ctrl.max    or 100
    local stp = ctrl.step   or 0
    local fmt = ctrl.format or "%.2f"
    local val = ctrl._val~=nil and ctrl._val or (ctrl.default or mn)

    local function Snap(v)
        if stp and stp>0 then
            v = math.round((v-mn)/stp)*stp+mn
        end
        return math.clamp(v, mn, mx)
    end

    local Wrap = MkRow(parent, 44)
    Corn(4, Wrap)

    local TR = New("Frame",{
        Parent=Wrap, BackgroundTransparency=1,
        Position=UDim2.new(0,0,0,3), Size=UDim2.new(1,0,0,15), ZIndex=3,
    })
    MkLbl(TR, ctrl.text or "Slider", 11, T.TextSec, Enum.Font.Gotham,
        Enum.TextXAlignment.Left, nil, UDim2.new(0.68,0,1,0), 3)

    local VL=MkLbl(TR, string.format(fmt,val), 11, T.TextAccent,
        Enum.Font.GothamBold, Enum.TextXAlignment.Right,
        UDim2.new(0.68,0,0,0), UDim2.new(0.32,0,1,0), 3)

    local Trk = New("Frame",{
        Parent=Wrap, BackgroundColor3=T.SliderTrack,
        Position=UDim2.new(0,0,0,26), Size=UDim2.new(1,0,0,4), ZIndex=3,
    })
    Corn(2, Trk)

    local pct = (val-mn)/(mx-mn)

    local Fill = New("Frame",{
        Parent=Trk, BackgroundColor3=T.SliderFill,
        Size=UDim2.new(pct,0,1,0), ZIndex=4,
    })
    Corn(2, Fill)

    local Th = New("Frame",{
        Parent=Trk, BackgroundColor3=T.SliderThumb,
        Position=UDim2.new(pct,-6,0.5,-6), Size=UDim2.new(0,12,0,12), ZIndex=5,
    })
    Corn(6, Th)
    Stro(T.Accent, 1.5, Th)

    local function Set(v)
        v=Snap(v); val=v; ctrl._val=v
        local p=(v-mn)/(mx-mn)
        Fill.Size   = UDim2.new(p,0,1,0)
        Th.Position = UDim2.new(p,-6,0.5,-6)
        VL.Text     = string.format(fmt,v)
        if ctrl.callback then ctrl.callback(v) end
    end

    local dragging = false

    local function GetPct(absX)
        local ap = Trk.AbsolutePosition.X
        local as = Trk.AbsoluteSize.X
        if as == 0 then return 0 end
        return math.clamp((absX - ap) / as, 0, 1)
    end

    -- Hit zone maior para facilitar clique
    local HitZone = New("TextButton",{
        Parent=Trk, BackgroundTransparency=1,
        Position=UDim2.new(0,0,0.5,-10),
        Size=UDim2.new(1,0,0,20),
        Text="", ZIndex=8,
    })

    HitZone.MouseButton1Down:Connect(function(x, _y)
        dragging = true
        Set(mn + GetPct(x)*(mx-mn))
        Tw(Th,{Size=UDim2.new(0,14,0,14), Position=UDim2.new(GetPct(x),-7,0.5,-7)},.06)
    end)

    -- Captura movimento global enquanto dragging
    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType==Enum.UserInputType.MouseMovement then
            Set(mn + GetPct(i.Position.X)*(mx-mn))
        end
    end)

    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 and dragging then
            dragging = false
            Tw(Th,{Size=UDim2.new(0,12,0,12), Position=UDim2.new(GetPct(HitZone.AbsolutePosition.X),-6,0.5,-6)},.06)
        end
    end)

    ctrl._setValue=Set; ctrl._getValue=function() return val end
    return Wrap
end

-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
--  DROPDOWN
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
function ShadowUI:_Dropdown(parent, ctrl)
    local T = self._T
    local opts=ctrl.options or {}
    local val=ctrl._val~=nil and ctrl._val or (ctrl.default or opts[1])

    local Wrap=MkRow(parent,46)

    MkLbl(Wrap, ctrl.text or "Dropdown", 11, T.TextSec, Enum.Font.Gotham,
        Enum.TextXAlignment.Left, UDim2.new(0,0,0,2), UDim2.new(1,0,0,12), 3)

    local Box=New("Frame",{
        Parent=Wrap, BackgroundColor3=T.DropBg,
        Position=UDim2.new(0,0,0,16), Size=UDim2.new(1,0,0,24), ZIndex=3,
    })
    Corn(5,Box); Stro(T.Border,1,Box)

    local Sel=MkLbl(Box, tostring(val), 12, T.TextPri, Enum.Font.Gotham,
        Enum.TextXAlignment.Left, UDim2.new(0,8,0,0), UDim2.new(1,-22,1,0), 4)

    MkLbl(Box,"▾",11,T.TextSec,Enum.Font.GothamBold,
        Enum.TextXAlignment.Center, UDim2.new(1,-18,0,0), UDim2.new(0,14,1,0), 4)

    local open=false
    local DropF=nil

    local function Close()
        if DropF then DropF:Destroy(); DropF=nil end
        open=false
        if _dropClose==Close then _dropClose=nil end
    end

    local function SetVal(v)
        val=v; ctrl._val=v; Sel.Text=tostring(v)
        Close()
        if ctrl.callback then ctrl.callback(v) end
    end

    local OBtn=New("TextButton",{
        Parent=Box, BackgroundTransparency=1,
        Size=UDim2.new(1,0,1,0), Text="", ZIndex=5,
    })

    OBtn.MouseEnter:Connect(function() Tw(Box,{BackgroundColor3=T.DropHover},.08) end)
    OBtn.MouseLeave:Connect(function() if not open then Tw(Box,{BackgroundColor3=T.DropBg},.08) end end)

    OBtn.MouseButton1Click:Connect(function()
        if _dropClose and _dropClose~=Close then _dropClose() end
        if open then Close(); return end
        open=true
        _dropClose=Close

        local currentOpts = ctrl.options or opts
        local itemH=22
        local listH=#currentOpts*itemH+6

        DropF=New("Frame",{
            Parent=self.Gui,
            BackgroundColor3=T.DropBg,
            Size=UDim2.new(0,Box.AbsoluteSize.X,0,listH),
            ZIndex=50, ClipsDescendants=true,
        })
        Corn(6,DropF); Stro(T.Accent,1,DropF)

        New("ImageLabel",{
            Parent=DropF, BackgroundTransparency=1,
            Position=UDim2.new(0,-8,0,-8), Size=UDim2.new(1,16,1,16), ZIndex=49,
            Image="rbxassetid://6014261993", ImageColor3=Color3.new(0,0,0),
            ImageTransparency=0.5, ScaleType=Enum.ScaleType.Slice,
            SliceCenter=Rect.new(49,49,450,450),
        })

        local function UpdatePos()
            local ap=Box.AbsolutePosition
            local as=Box.AbsoluteSize
            DropF.Position=UDim2.new(0,ap.X,0,ap.Y+as.Y+3)
            DropF.Size=UDim2.new(0,as.X,0,listH)
        end
        UpdatePos()

        List(DropF,nil,0)
        Pad(3,3,3,3,DropF)

        for _, opt in ipairs(currentOpts) do
            local isS=(opt==val)
            local Item=New("TextButton",{
                Parent=DropF,
                BackgroundColor3=isS and Color3.fromRGB(22,20,36) or T.DropBg,
                BackgroundTransparency=isS and 0 or 1,
                Size=UDim2.new(1,0,0,itemH),
                Font=isS and Enum.Font.GothamBold or Enum.Font.Gotham,
                Text=tostring(opt),
                TextColor3=isS and T.TextAccent or T.TextSec,
                TextSize=11,
                TextXAlignment=Enum.TextXAlignment.Left,
                AutoButtonColor=false, ZIndex=51,
            })
            Pad(8,0,0,0,Item); Corn(3,Item)

            Item.MouseEnter:Connect(function()
                Item.BackgroundTransparency=0
                Tw(Item,{BackgroundColor3=T.DropHover,TextColor3=T.TextPri},.08)
            end)
            Item.MouseLeave:Connect(function()
                if not isS then
                    Item.BackgroundTransparency=1
                    Item.TextColor3=T.TextSec
                else
                    Item.BackgroundTransparency=0
                    Item.BackgroundColor3=Color3.fromRGB(22,20,36)
                end
            end)
            Item.MouseButton1Click:Connect(function()
                task.defer(function() SetVal(opt) end)
            end)
        end

        local Ov=New("TextButton",{
            Parent=self.Gui, BackgroundTransparency=1,
            Size=UDim2.new(1,0,1,0), Text="", ZIndex=48,
        })
        local oldClose=Close
        Close = function()
            oldClose()
            if Ov and Ov.Parent then Ov:Destroy() end
        end
        _dropClose=Close
        Ov.MouseButton1Click:Connect(function()
            Close()
        end)
    end)

    ctrl._setValue=SetVal; ctrl._getValue=function() return val end
    return Wrap
end


function Window:_SetupDrag(handle, target)
    local dragging = false
    local dragStart, startPos

    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos  = target.Position
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            local newPos = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
            target.Position = newPos
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
end

function Window:CreateTab(opts)
    local opts = type(opts) == "string" and {Name = opts} or opts
    opts.LayoutOrder = #self.Tabs + 1

    local lib = self.Library
    opts.OnSelect = function()
        self:SelectTab(#self.Tabs + 1)
    end

    local tab = Tab.new(self.SidebarList, self.ContentArea, opts, lib.Factory)

    opts.OnSelect = function()
        self:SelectTab(tab)
    end
    -- reconnect properly
    tab.Button.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            self:SelectTab(tab)
        end
    end)

    table.insert(self.Tabs, tab)

    if #self.Tabs == 1 then
        self:SelectTab(tab)
    end

    return tab
end

function Window:SelectTab(tab)
    if self.ActiveTab == tab then return end
    if self.ActiveTab then
        self.ActiveTab:SetActive(false)
    end
    self.ActiveTab = tab
    tab:SetActive(true)
end

function Window:Minimize()
    if self.Minimized then return end
    self.Minimized = true
    self.Library.Anim:Play(self.Body, {Size = UDim2.new(1, 0, 0, 0)}, TWEEN_MEDIUM)
    self.Library.Anim:Play(self.Root, {Size = UDim2.new(
        self.Root.Size.X.Scale,
        self.Root.Size.X.Offset,
        0, 46
    )}, TWEEN_MEDIUM)
end

function Window:Restore()
    if not self.Minimized then return end
    self.Minimized = false
    local origSize = self.Root.Size
    self.Library.Anim:Play(self.Root, {Size = UDim2.new(
        origSize.X.Scale,
        origSize.X.Offset,
        0, 460
    )}, TWEEN_MEDIUM)
    task.delay(0.1, function()
        self.Library.Anim:Play(self.Body, {
            Size = UDim2.new(1, 0, 1, -46)
        }, TWEEN_MEDIUM)
    end)
end

function Window:Toggle()
    self.Visible = not self.Visible
    self.Root.Visible = self.Visible
end

function Window:Destroy()
    self.Library.Anim:Play(self.Root, {
        Size = UDim2.new(0, 0, 0, 0),
        BackgroundTransparency = 1
    }, TWEEN_MEDIUM)
    task.delay(0.3, function()
        if self.ScreenGui then
            self.ScreenGui:Destroy()
        end
    end)
end


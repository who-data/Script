local function New(cls,props)
    local o=Instance.new(cls)
    for k,v in pairs(props) do if k~="Parent" then o[k]=v end end
    if props.Parent then o.Parent=props.Parent end
    return o
end
local function Tw(obj,goals,t,style,dir)
    TS:Create(obj,TweenInfo.new(t or .14,style or Enum.EasingStyle.Quint,dir or Enum.EasingDirection.Out),goals):Play()
end
local function Corner(r,p) New("UICorner",{CornerRadius=UDim.new(0,r),Parent=p}) end
local function Stroke(c,th,p,tr)
    return New("UIStroke",{Color=c,Thickness=th or 1,Transparency=tr or 0,ApplyStrokeMode=Enum.ApplyStrokeMode.Border,Parent=p})
end
local function Pad(l,r,t,b,p)
    New("UIPadding",{PaddingLeft=UDim.new(0,l),PaddingRight=UDim.new(0,r),PaddingTop=UDim.new(0,t),PaddingBottom=UDim.new(0,b),Parent=p})
end
local function ListL(p,dir,gap)
    return New("UIListLayout",{Parent=p,FillDirection=dir or Enum.FillDirection.Vertical,SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,gap or 0)})
end
local function AutoCanvas(sf,ll,extra)
    local function upd() sf.CanvasSize=UDim2.new(0,0,0,ll.AbsoluteContentSize.Y+(extra or 8)) end
    ll:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(upd)
    task.defer(upd)
end
local function Lbl(p,txt,sz,col,fnt,ax,pos,size,z,wrap)
    return New("TextLabel",{
        Parent=p,BackgroundTransparency=1,
        Text=txt or "",TextSize=sz or 12,TextColor3=col or T.TxtPri,
        Font=fnt or Enum.Font.Gotham,
        TextXAlignment=ax or Enum.TextXAlignment.Left,
        TextYAlignment=Enum.TextYAlignment.Center,
        Position=pos or UDim2.new(0,0,0,0),
        Size=size or UDim2.new(1,0,1,0),
        ZIndex=z or 2,
        TextTruncate=wrap and Enum.TextTruncate.None or Enum.TextTruncate.AtEnd,
        TextWrapped=wrap or false,
    })
end
local function Card(p,h,z)
    local f=New("Frame",{Parent=p,BackgroundColor3=T.Card,Size=UDim2.new(1,0,0,h or 38),ZIndex=z or 2,BorderSizePixel=0})
    Corner(7,f); Stroke(T.CardBorder,1,f)
    return f
end
local function Glow(parent,col,trans)
    return New("ImageLabel",{
        Parent=parent,BackgroundTransparency=1,
        Position=UDim2.new(0,-8,0,-8),Size=UDim2.new(1,16,1,16),ZIndex=1,
        Image="rbxassetid://6014261993",
        ImageColor3=col or T.AccentGlow,ImageTransparency=trans or 0.88,
        ScaleType=Enum.ScaleType.Slice,SliceCenter=Rect.new(49,49,450,450),
    })
end
local function MakeDraggable(target,handle)
    local drag,startM,startP=false
    handle.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            drag=true;startM=i.Position;startP=target.Position
            i.Changed:Connect(function() if i.UserInputState==Enum.UserInputState.End then drag=false end end)
        end
    end)
    UIS.InputChanged:Connect(function(i)
        if not drag then return end
        if i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch then
            local d=i.Position-startM
            target.Position=UDim2.new(startP.X.Scale,startP.X.Offset+d.X,startP.Y.Scale,startP.Y.Offset+d.Y)
        end
    end)
end
local _closeDrop=nil
local function CloseAnyDrop() if _closeDrop then pcall(_closeDrop) end; _closeDrop=nil end
local function SafeWrite(path,data) pcall(function() if not isfolder(CFG_DIR) then makefolder(CFG_DIR) end; writefile(path,data) end) end
local function SafeRead(path) local ok,d=pcall(readfile,path); return ok and d or nil end
local function ListCfgs()
    local out={"default"}
    pcall(function()
        if not isfolder(CFG_DIR) then return end
        for _,f in ipairs(listfiles(CFG_DIR)) do
            local n=(f:match("[^/\\]+$") or f):gsub(CFG_EXT.."$","")
            if n~="default" and n~="__auto" then table.insert(out,n) end
        end
    end)
    return out
end


    local badge=New("Frame",{Parent=wrap,BackgroundColor3=T.Card,Position=UDim2.new(1,-88,.5,-11),Size=UDim2.new(0,82,0,22),ZIndex=4,BorderSizePixel=0}); Corner(6,badge)
    local bdgStr=Stroke(T.CardBorder,1,badge)
    local keyLbl=New("TextLabel",{Parent=badge,BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),Font=Enum.Font.GothamBold,Text=val.Name,TextColor3=T.TxtSec,TextSize=10,TextXAlignment=Enum.TextXAlignment.Center,ZIndex=5})
    local hit=New("TextButton",{Parent=wrap,BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),Text="",ZIndex=7})
    hit.MouseEnter:Connect(function() Tw(wrap,{BackgroundColor3=T.CardHov},.1); Tw(glow,{ImageTransparency=0.88},.15) end)
    hit.MouseLeave:Connect(function() Tw(wrap,{BackgroundColor3=T.Card},.1); Tw(glow,{ImageTransparency=1},.15) end)
    if ctrl.tooltip then self:_AttachTooltip(hit,ctrl.tooltip) end
    local inputConn
    hit.MouseButton1Click:Connect(function()
        if listening then return end; listening=true
        keyLbl.Text="..."; Tw(keyLbl,{TextColor3=T.ToastWrn},.1); Tw(bdgStr,{Color=T.Accent},.1)
        Tw(badge,{BackgroundColor3=T.AccentDim},.1); Tw(glow,{ImageTransparency=0.8},.15)
        if inputConn then inputConn:Disconnect() end
        inputConn=UIS.InputBegan:Connect(function(i,gpe)
            if gpe then return end
            if i.UserInputType==Enum.UserInputType.Keyboard then
                listening=false; val=i.KeyCode;ctrl._val=val; keyLbl.Text=val.Name
                Tw(keyLbl,{TextColor3=T.TxtAcc},.1); Tw(bdgStr,{Color=T.CardBorder},.1)
                Tw(badge,{BackgroundColor3=T.Card},.1); Tw(glow,{ImageTransparency=1},.2)
                inputConn:Disconnect(); if ctrl.callback then ctrl.callback(val,"changed") end
            end
        end)
    end)
    local pressConn=UIS.InputBegan:Connect(function(i,gpe)
        if gpe then return end
        if i.UserInputType==Enum.UserInputType.Keyboard and i.KeyCode==val and not listening then
            if ctrl.callback then ctrl.callback(val,"pressed") end
        end
    end)
    table.insert(self._conns,pressConn)
    ctrl._setValue=function(kc) val=kc;ctrl._val=kc;keyLbl.Text=kc.Name; if ctrl.callback then ctrl.callback(kc,"changed") end end
    ctrl._getValue=function() return val end
    return wrap
end


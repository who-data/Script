        Visible = false,
        Parent = container,
    })
    Util.AddCorner(list)
    Util.Stroke(list, Theme.Border)

    local listLayout = Util.Create("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Parent = list,
    })

    local function SetValue(v, silent)
        value = v
        dropLabel.Text = v
        if not silent then callback(v) end
    end

    local function BuildList()
        for _, child in pairs(list:GetChildren()) do
            if child:IsA("TextButton") then child:Destroy() end
        end
        for _, opt in ipairs(opts) do
            local item = Util.Create("TextButton", {
                Size = UDim2.new(1, 0, 0, 28),
                BackgroundTransparency = 1,
                Text = opt,
                TextColor3 = opt == value and Theme.TextAccent or Theme.TextSecondary,
                Font = Theme.Font,
                TextSize = 12,
                ZIndex = 11,
                Parent = list,
            })
            Util.AddPadding(item, 0, 0, 0, 10)

            item.MouseEnter:Connect(function()
                Util.Tween(item, { BackgroundColor3 = Color3.fromRGB(255, 60, 120) })
                item.BackgroundTransparency = 0.88
            end)
            item.MouseLeave:Connect(function()
                item.BackgroundTransparency = 1
            end)
            item.MouseButton1Click:Connect(function()
                SetValue(opt)
                -- close
                isOpen = false
                Util.Tween(list, { Size = UDim2.new(0, 140, 0, 0) }, 0.15)
                Util.Tween(arrow, { Rotation = 0 })
                task.delay(0.15, function() list.Visible = false end)
            end)
        end
        list.Size = UDim2.new(0, 140, 0, 0)
    end

    BuildList()

    dropBtn.MouseButton1Click:Connect(function()
        isOpen = not isOpen
        if isOpen then
            list.Visible = true
            local targetH = math.min(#opts * 28, 180)
            Util.Tween(list, { Size = UDim2.new(0, 140, 0, targetH) }, 0.18)
            Util.Tween(arrow, { Rotation = 180 })
        else
            Util.Tween(list, { Size = UDim2.new(0, 140, 0, 0) }, 0.15)
            Util.Tween(arrow, { Rotation = 0 })
            task.delay(0.15, function() list.Visible = false end)
        end
    end)

    return {
        Set = SetValue,
        Get = function() return value end,
        Refresh = function(newOpts)
            opts = newOpts
            BuildList()
        end,
    }
end


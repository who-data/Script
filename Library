-- ---- LABEL ----
function ComponentFactory:MakeLabel(parent, opts)
    local opts = opts or {}
    local frame = Utils.Create("Frame", {
        Name                    = "Label_" .. (opts.Name or ""),
        Size                    = UDim2.new(1, 0, 0, 28),
        BackgroundTransparency  = 1,
        LayoutOrder             = opts.LayoutOrder or 0,
        Parent                  = parent,
    })
    local label = Utils.Create("TextLabel", {
        Name                    = "Text",
        Size                    = UDim2.new(1, -16, 1, 0),
        Position                = UDim2.new(0, 8, 0, 0),
        BackgroundTransparency  = 1,
        Text                    = opts.Name or "Label",
        TextColor3              = self.Theme:Get("TextSecondary"),
        TextSize                = 13,
        Font                    = Enum.Font.Gotham,
        TextXAlignment          = Enum.TextXAlignment.Left,
        Parent                  = frame,
    })
    if opts.Tooltip then
        self.Tooltip:Attach(frame, opts.Tooltip)
    end
    return {
        Frame = frame,
        Label = label,
        SetText = function(_, text)
            label.Text = text
        end,
    }
end

-- ---- PARAGRAPH ----
function ComponentFactory:MakeParagraph(parent, opts)
    local opts = opts or {}
    local frame = Utils.Create("Frame", {
        Name                    = "Paragraph_" .. (opts.Title or ""),
        Size                    = UDim2.new(1, 0, 0, 48),
        BackgroundColor3        = self.Theme:Get("SurfaceAlt"),

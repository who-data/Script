function Window:AddTab(name, icon)
    local scroll = New("ScrollingFrame", {
        Size = UDim2.new(1, 0, 1, -36),
        Position = UDim2.new(0, 0, 0, 36),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = T.Accent,
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        CanvasSize = UDim2.new(0,0,0,0),
        Visible = false,
        Parent = self._contentArea,
    })
    Pad(scroll, 8, 12, 12, 14)
    List(scroll, 8)

    local isFirst = #self._tabs == 0

    -- sidebar button
    local tabBtn = New("TextButton", {
        Size = UDim2.new(1, 0, 0, 36),
        BackgroundTransparency = 1,
        Text = "",
        AutoButtonColor = false,
        Parent = self._tabList,
    })

    local bar = New("Frame", {
        Size = isFirst and UDim2.new(0, 2, 0.65, 0) or UDim2.new(0, 0, 0.65, 0),
        Position = UDim2.new(0, 0, 0.175, 0),
        BackgroundColor3 = T.Accent,
        BorderSizePixel = 0,
        Parent = tabBtn,
    })

    local iconLbl = New("TextLabel", {
        Size = UDim2.new(0, 22, 1, 0),
        Position = UDim2.new(0, 14, 0, 0),
        BackgroundTransparency = 1,
        Text = icon or "",
        TextColor3 = isFirst and T.TextAccent or T.TextSub,
        Font = T.Font,
        TextSize = 14,
        Parent = tabBtn,
    })

    local nameLbl = New("TextLabel", {
        Size = UDim2.new(1, -42, 1, 0),
        Position = UDim2.new(0, 40, 0, 0),
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = isFirst and T.TextAccent or T.TextSub,
        Font = T.FontSemi,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = tabBtn,
    })

    local hov = New("Frame", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = T.Accent,
        BackgroundTransparency = 1,
        ZIndex = 0,
        Parent = tabBtn,
    })

    local tabObj = Tab.new(scroll)

    if isFirst then
        scroll.Visible = true
        self._activeTab = tabObj
        self._tabTitleLbl.Text = name:upper()
    end

    tabBtn.MouseEnter:Connect(function()
        if self._activeTab ~= tabObj then
            Tween(hov, {BackgroundTransparency = 0.92})
        end
    end)
    tabBtn.MouseLeave:Connect(function()
        Tween(hov, {BackgroundTransparency = 1})
    end)

    tabBtn.MouseButton1Click:Connect(function()
        if self._activeTab == tabObj then return end

        -- deactivate old
        if self._activeTab then
            self._activeTab._scroll.Visible = false
            -- find old button
            for _, t in ipairs(self._tabs) do
                if t.obj == self._activeTab then
                    Tween(t.bar,  {Size = UDim2.new(0, 0, 0.65, 0)})
                    Tween(t.icon, {TextColor3 = T.TextSub})
                    Tween(t.name, {TextColor3 = T.TextSub})
                    break
                end
            end
        end

        self._activeTab = tabObj
        scroll.Visible = true
        self._tabTitleLbl.Text = name:upper()

        Tween(bar,     {Size = UDim2.new(0, 2, 0.65, 0)})
        Tween(iconLbl, {TextColor3 = T.TextAccent})
        Tween(nameLbl, {TextColor3 = T.TextAccent})
        Tween(hov,     {BackgroundTransparency = 1})
    end)

    table.insert(self._tabs, {obj=tabObj, bar=bar, icon=iconLbl, name=nameLbl})
    return tabObj
end

function Window:Destroy()
    self._gui:Destroy()

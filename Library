        Position=UDim2.new(0,10,0.5,-4), Size=UDim2.new(0,8,0,8), ZIndex=8,
    },{Corn(4)})

    MkTxt(Row, name, 12, T.TxtPri, Enum.Font.GothamBold,
        Enum.TextXAlignment.Left,
        UDim2.new(0,28,0,0), UDim2.new(1,-48,1,0), 7)

    local Chev = MkTxt(Row,"›",14,T.TxtDim,Enum.Font.GothamBold,
        Enum.TextXAlignment.Center,
        UDim2.new(1,-20,0,0), UDim2.new(0,16,1,0), 7)


function Components.ColorPicker(parent, name, options)
    options = options or {}
    local color = options.Default or Color3.fromRGB(255, 60, 120)
    local callback = options.Callback or function() end
    local isOpen = false

    local row = Util.Create("Frame", {
        Size = UDim2.new(1, 0, 0, Theme.RowHeight),
        BackgroundTransparency = 1,
        ClipsDescendants = false,
        Parent = parent,
    })

    Util.Create("TextLabel", {
        Size = UDim2.new(1, -80, 1, 0),
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = Theme.TextPrimary,
        Font = Theme.FontSemiBold,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = row,
    })

    local preview = Util.Create("TextButton", {
        Size = UDim2.new(0, 40, 0, 22),
        Position = UDim2.new(1, -40, 0.5, -11),
        BackgroundColor3 = color,
        Text = "",
        AutoButtonColor = false,
        Parent = row,
    })
    Util.AddCorner(preview)
    Util.Stroke(preview, Theme.Border)

    -- Simple RGB sliders panel
    local panel = Util.Create("Frame", {
        Size = UDim2.new(0, 200, 0, 100),
        Position = UDim2.new(1, -200, 0, Theme.RowHeight + 2),
        BackgroundColor3 = Theme.BGLight,
        Visible = false,
        ZIndex = 15,
        Parent = row,
    })
    Util.AddCorner(panel)
    Util.Stroke(panel, Theme.Border)
    Util.AddPadding(panel, 8, 8, 8, 8)

    local r, g, b = math.floor(color.R * 255), math.floor(color.G * 255), math.floor(color.B * 255)

    local function UpdateColor()
        color = Color3.fromRGB(r, g, b)
        preview.BackgroundColor3 = color
        callback(color)
    end

    for i, chan in ipairs({"R", "G", "B"}) do
        local val = i == 1 and r or (i == 2 and g or b)
        local label = Util.Create("TextLabel", {
            Size = UDim2.new(0, 14, 0, 12),
            Position = UDim2.new(0, 0, 0, (i-1)*28),
            BackgroundTransparency = 1,
            Text = chan,
            TextColor3 = i==1 and Color3.fromRGB(255,80,80) or (i==2 and Color3.fromRGB(80,255,80) or Color3.fromRGB(80,120,255)),
            Font = Theme.FontBold,
            TextSize = 11,
            ZIndex = 16,
            Parent = panel,
        })

        local trackBG = Util.Create("Frame", {
            Size = UDim2.new(1, -18, 0, 4),
            Position = UDim2.new(0, 18, 0, (i-1)*28 + 4),
            BackgroundColor3 = Theme.SliderTrack,
            BorderSizePixel = 0,
            ZIndex = 16,
            Parent = panel,
        })
        Util.AddCorner(trackBG, UDim.new(0,2))

        local fillColor = i==1 and Color3.fromRGB(255,80,80) or (i==2 and Color3.fromRGB(80,255,80) or Color3.fromRGB(80,120,255))
        local fill = Util.Create("Frame", {
            Size = UDim2.new(val/255, 0, 1, 0),
            BackgroundColor3 = fillColor,
            BorderSizePixel = 0,
            ZIndex = 16,
            Parent = trackBG,
        })
        Util.AddCorner(fill, UDim.new(0,2))

        local draggingChan = false
        trackBG.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                draggingChan = true
            end
        end)
        UserInputService.InputEnded:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then draggingChan = false end
        end)
        UserInputService.InputChanged:Connect(function(inp)
            if draggingChan and inp.UserInputType == Enum.UserInputType.MouseMovement then
                local pct = math.clamp((Mouse.X - trackBG.AbsolutePosition.X) / trackBG.AbsoluteSize.X, 0, 1)
                local newVal = math.floor(pct * 255)
                fill.Size = UDim2.new(pct, 0, 1, 0)
                if i == 1 then r = newVal
                elseif i == 2 then g = newVal
                else b = newVal end
                UpdateColor()
            end
        end)
    end

    preview.MouseButton1Click:Connect(function()
        isOpen = not isOpen
        panel.Visible = isOpen
    end)

    Util.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 1),
        Position = UDim2.new(0, 0, 1, -1),
        BackgroundColor3 = Theme.Separator,
        BorderSizePixel = 0,
        Parent = row,
    })

    return {
        Set = function(c)
            color = c
            r,g,b = math.floor(c.R*255),math.floor(c.G*255),math.floor(c.B*255)
            preview.BackgroundColor3 = c
        end,
        Get = function() return color end,
    }
end


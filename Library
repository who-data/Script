local InputHandler = {}
InputHandler.__index = InputHandler

function InputHandler.new()
    local self = setmetatable({
        _binds = {},
        _conns = {},
        _active = false,
    }, InputHandler)
    return self
end

function InputHandler:Start()
    if self._active then return end
    self._active = true
    local conn = UserInputService.InputBegan:Connect(function(inp, gp)
        if gp then return end
        local kc = inp.KeyCode
        if self._binds[kc] then
            for _, cb in ipairs(self._binds[kc]) do pcall(cb, inp) end
        end
    end)
    table.insert(self._conns, conn)
end

function InputHandler:Bind(key, cb)
    if not self._binds[key] then self._binds[key] = {} end
    table.insert(self._binds[key], cb)
    return function() self:Unbind(key, cb) end
end

function InputHandler:Unbind(key, cb)
    if not self._binds[key] then return end
    for i, f in ipairs(self._binds[key]) do
        if f == cb then table.remove(self._binds[key], i) return end
    end
end

function InputHandler:Stop()
    U.Disconn(self._conns)
    self._active = false
end


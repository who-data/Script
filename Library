        Size = UDim2.new(1, 0, 0, 0),
        Position = UDim2.new(0, 0, 1, 3),
        BackgroundColor3 = th:Get("BG4"),
        BorderSizePixel = 0,
        ClipsDescendants = true,
        Visible = false,
        ZIndex = Z.DROPDOWN,
        Parent = wrapper,
    })
    U.Corner(panel, CR_SM)
    U.Stroke(panel, th:Get("Border"), 1)
    U.Pad(panel, 8, 8, 8, 8)

    -- SV canvas (saturation/value 2D picker)
    local svCanvas = U.New("ImageLabel", {
        Name = "SVCanvas",
        Size = UDim2.new(1, 0, 0, 110),
        BackgroundColor3 = Color3.fromHSV(h, 1, 1),
        Image = "rbxassetid://4155801252",
        BorderSizePixel = 0,
        ZIndex = Z.DROPDOWN + 1,
        Parent = panel,
    })
    U.Corner(svCanvas, CR_SM)

    local svCursor = U.New("Frame", {
        Size = UDim2.new(0, 12, 0, 12),
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(s, 0, 1 - v, 0),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        BorderSizePixel = 0,
        ZIndex = Z.DROPDOWN + 2,
        Parent = svCanvas,
    })
    U.Corner(svCursor, CR_FULL)
    U.Stroke(svCursor, th:Get("Black"), 2)

    -- Hue slider bar
    local hueBar = U.New("Frame", {
        Name = "HueBar",
        Size = UDim2.new(1, 0, 0, 14),
        Position = UDim2.new(0, 0, 0, 118),
        BorderSizePixel = 0,
        ZIndex = Z.DROPDOWN + 1,
        Parent = panel,
    })
    U.Corner(hueBar, CR_FULL)
    local hueGrad = Instance.new("UIGradient")
    hueGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0,    Color3.fromRGB(255,0,0)),
        ColorSequenceKeypoint.new(0.166,Color3.fromRGB(255,255,0)),
        ColorSequenceKeypoint.new(0.333,Color3.fromRGB(0,255,0)),
        ColorSequenceKeypoint.new(0.5,  Color3.fromRGB(0,255,255)),
        ColorSequenceKeypoint.new(0.666,Color3.fromRGB(0,0,255)),
        ColorSequenceKeypoint.new(0.833,Color3.fromRGB(255,0,255)),
        ColorSequenceKeypoint.new(1,    Color3.fromRGB(255,0,0)),
    })
    hueGrad.Parent = hueBar

    local hueThumb = U.New("Frame", {
        Size = UDim2.new(0, 8, 1, 4),
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(h, 0, 0.5, 0),
        BackgroundColor3 = th:Get("White"),
        BorderSizePixel = 0,
        ZIndex = Z.DROPDOWN + 2,
        Parent = hueBar,
    })
    U.Corner(hueThumb, UDim.new(0, 4))
    U.Stroke(hueThumb, th:Get("Black"), 1)

    -- Hex input row
    local hexBg = U.New("Frame", {
        Name = "HexBg",
        Size = UDim2.new(1, 0, 0, 28),
        Position = UDim2.new(0, 0, 0, 140),
        BackgroundColor3 = th:Get("BG"),
        BorderSizePixel = 0,
        ZIndex = Z.DROPDOWN + 1,
        Parent = panel,
    })
    U.Corner(hexBg, CR_SM)
    U.Stroke(hexBg, th:Get("Border"), 1)
    U.Pad(hexBg, 0, 8, 0, 8)

    local hexInput = U.New("TextBox", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "#" .. U.ColorToHex(cur),
        TextColor3 = th:Get("TextHi"),
        TextSize = 11,
        Font = Enum.Font.Code,
        TextXAlignment = Enum.TextXAlignment.Center,
        ZIndex = Z.DROPDOWN + 2,
        Parent = hexBg,
    })

    local function updateColor()
        cur = Color3.fromHSV(h, s, v)
        preview.BackgroundColor3 = cur
        svCanvas.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
        svCursor.Position = UDim2.new(s, 0, 1 - v, 0)
        hueThumb.Position = UDim2.new(h, 0, 0.5, 0)
        hexInput.Text = "#" .. U.ColorToHex(cur)
        if opts.Callback then pcall(opts.Callback, cur) end
        if opts.Flag then self.config:SetFlag(opts.Flag, {cur.R, cur.G, cur.B}) end
    end

    local svDrag, hueDrag = false, false

    U.Connect(cn, svCanvas.InputBegan, function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            svDrag = true
            s = U.Clamp((inp.Position.X - svCanvas.AbsolutePosition.X) / svCanvas.AbsoluteSize.X, 0, 1)
            v = 1 - U.Clamp((inp.Position.Y - svCanvas.AbsolutePosition.Y) / svCanvas.AbsoluteSize.Y, 0, 1)
            updateColor()
        end
    end)
    U.Connect(cn, hueBar.InputBegan, function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            hueDrag = true
            h = U.Clamp((inp.Position.X - hueBar.AbsolutePosition.X) / hueBar.AbsoluteSize.X, 0, 1)
            updateColor()
        end
    end)
    U.Connect(cn, UserInputService.InputChanged, function(inp)
        if inp.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        if svDrag then
            s = U.Clamp((inp.Position.X - svCanvas.AbsolutePosition.X) / svCanvas.AbsoluteSize.X, 0, 1)
            v = 1 - U.Clamp((inp.Position.Y - svCanvas.AbsolutePosition.Y) / svCanvas.AbsoluteSize.Y, 0, 1)
            updateColor()
        elseif hueDrag then
            h = U.Clamp((inp.Position.X - hueBar.AbsolutePosition.X) / hueBar.AbsoluteSize.X, 0, 1)
            updateColor()
        end
    end)
    U.Connect(cn, UserInputService.InputEnded, function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            svDrag = false; hueDrag = false
        end
    end)
    U.Connect(cn, hexInput.FocusLost, function()
        local c = U.HexToColor(hexInput.Text)
        if c then
            cur = c
            h, s, v = Color3.toHSV(c)
            updateColor()
        end
    end)

    U.Connect(cn, header.InputBegan, function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            open = not open
            if open then
                panel.Visible = true
                self.anim:Play(panel, {Size = UDim2.new(1, 0, 0, 178)}, TI.Medium)
                wrapper.Size = UDim2.new(1, 0, 0, 38 + 181)
            else
                self.anim:Play(panel, {Size = UDim2.new(1, 0, 0, 0)}, TI.Medium)
                task.delay(0.24, function()
                    if not open and panel and panel.Parent then
                        panel.Visible = false
                        wrapper.Size = UDim2.new(1, 0, 0, 38)
                    end
                end)
            end
        end
    end)

    if opts.Tooltip then self.tooltip:Attach(header, opts.Tooltip) end

    return {
        Frame    = wrapper,
        GetColor = function() return cur end,
        SetColor = function(_, c)
            cur = c; h, s, v = Color3.toHSV(c); updateColor()
        end,
        Destroy  = function() U.Disconn(cn) wrapper:Destroy() end,
    }
end


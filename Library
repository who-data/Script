local CONFIG_DIR = "ShadowUI"
local CONFIG_EXT = ".json"

local function SafeWrite(path, data)
    pcall(function()
        if not isfolder(CONFIG_DIR) then makefolder(CONFIG_DIR) end
        writefile(path, data)
    end)
end
local function SafeRead(path)
    local ok, data = pcall(readfile, path)
    return ok and data or nil
end
local function ListConfigs()
    local list = { "default" }
    pcall(function()
        if not isfolder(CONFIG_DIR) then makefolder(CONFIG_DIR) return end
        for _, f in ipairs(listfiles(CONFIG_DIR)) do
            local name = f:match("[^/\\]+$") or f
            name = name:gsub(CONFIG_EXT.."$","")
            if name ~= "default" and name ~= "__autoload" then
                table.insert(list, name)
            end
        end
    end)
    return list
end


    if not gui.Parent then gui.Parent=LP:WaitForChild("PlayerGui") end
    self._gui=gui

    local main=ins("Frame",{Size=UDim2.new(0,W,0,H),Position=UDim2.new(0.5,-W/2,0.5,-H/2),

--  BREADCRUMB
-- ──────────────────────────────────────────────
function ShadowUI:_UpdateBreadcrumb(catName, secName)
    for _, c in ipairs(self.BreadcrumbFrame:GetChildren()) do
        if c ~= self.BreadCatLabel
            and not c:IsA("UIListLayout")
            and not c:IsA("UIPadding") then
            c:Destroy()
        end
    end
    self.BreadCatLabel.Text = catName
    if secName then
        Create("TextLabel", {
            Parent               = self.BreadcrumbFrame,
            BackgroundTransparency = 1,
            Size                 = UDim2.new(0, 12, 1, 0),
            Font                 = Enum.Font.Gotham,
            Text                 = "›",
            TextColor3           = Theme.TextSecondary,
            TextSize             = 13,
            TextXAlignment       = Enum.TextXAlignment.Center,
            ZIndex               = 4,
        })
        Create("TextLabel", {
            Parent               = self.BreadcrumbFrame,
            BackgroundTransparency = 1,
            Size                 = UDim2.new(0, 120, 1, 0),
            Font                 = Enum.Font.Gotham,
            Text                 = secName,
            TextColor3           = Theme.TextPrimary,
            TextSize             = 12,
            TextXAlignment       = Enum.TextXAlignment.Left,
            ZIndex               = 4,
        })
    end
end


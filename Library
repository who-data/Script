--  LIBRARY  (top-level API)
-- ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź
local Library = {}
Library.__index = Library

function Library.new()
    local self = setmetatable({
        _windows = {},
        _theme   = Theme.new(),
        _anim    = Anim.new(),
        _input   = InputHandler.new(),
        _config  = Config.new("NexusUI_v3"),
        _notifs  = nil,
        _tooltip = nil,
        _comps   = nil,
    }, Library)

    self._input:Start()
    self._notifs  = NotifSys.new(self._theme, self._anim)
    self._tooltip = TooltipSys.new(self._theme, self._anim)
    self._comps   = Components.new(
        self._theme, self._anim, self._tooltip, self._config, self._input)
    return self
end

-- ‚ĒÄ‚ĒÄ Public API ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

--- Set theme (full table or partial override)
function Library:SetTheme(tbl)
    self._theme:Set(tbl)
end

--- Apply a named preset
function Library:SetPreset(name)
    local p = Theme.Presets[name]
    if p then self._theme:Set(p) end
end

--- Create a new main window
function Library:CreateWindow(opts)
    local w = Window.new(opts, self)
    table.insert(self._windows, w)
    return w
end

--- Show key authentication screen (blocks until verified)
--- opts: { Title, Subtitle, Key="str"|{"k1","k2"}, Validate=fn,
---          MaxAttempts=5, Skippable=false, KeyLink="url" }
function Library:KeySystem(opts)
    return buildKeySystem(opts, self._theme, self._anim, opts and opts.OnSuccess)
end

--- Fire a notification
--- opts: { Title, Text, Type="info"|"success"|"warning"|"error", Duration=3.5, Callback }
function Library:Notify(opts)
    self._notifs:Send(opts)
end

--- Open a modal dialog
--- opts: { Title, Body, OnConfirm, OnCancel } OR { Buttons={{Text,Color,Callback}} }
function Library:Modal(opts)
    return buildModal(opts, self._theme, self._anim)
end

--- Config helpers
function Library:SaveConfig(name)
    self._config:Save(name)
    self:Notify({ Title="Config Saved", Text='Saved as "'..name..'"', Type="success", Duration=2 })
end

function Library:LoadConfig(name)
    local ok = self._config:Load(name)
    if ok then
        self:Notify({ Title="Config Loaded", Text='Loaded "'..name..'"', Type="success", Duration=2 })
    else
        self:Notify({ Title="Config Error", Text='No config named "'..name..'"', Type="error", Duration=3 })
    end
    return ok
end

function Library:GetConfigList()
    return self._config:List()
end

--- Destroy everything
function Library:Destroy()
    for _, w in ipairs(self._windows) do pcall(function() w:Destroy() end) end
    self._notifs:Destroy()
    self._tooltip:Destroy()
    self._input:Stop()
    self._anim:CancelAll()
    table.clear(self._windows)
end


    return row
end

-- ══════════════════════════════════════════════
--  SLIDER  — CORRIGIDO (PC + Mobile)
-- ══════════════════════════════════════════════
function ShadowUI:_BSlider(parent, ctrl)
    local mn  = ctrl.min    or 0
    local mx  = ctrl.max    or 100
    local stp = ctrl.step   or 0
    local fmt = ctrl.format or "%.2f"
    local val = ctrl._val~=nil and ctrl._val or (ctrl.default or mn)

    local function Snap(v)
        if stp and stp > 0 then
            v = math.round((v - mn) / stp) * stp + mn
        end
        return math.clamp(v, mn, mx)
    end

    local Wrap = MkRow(parent, 50)
    Corn(5, Wrap)

    -- Labels
    local TR = New("Frame", {
        Parent=Wrap, BackgroundTransparency=1,
        Position=UDim2.new(0,2,0,4), Size=UDim2.new(1,-4,0,16), ZIndex=3,
    })
    MkTxt(TR, ctrl.text or "Slider", 11, T.TxtSec, Enum.Font.Gotham,
        Enum.TextXAlignment.Left, nil, UDim2.new(0.65,0,1,0), 3)
    local VL = MkTxt(TR, string.format(fmt, val), 11, T.TxtAcc, Enum.Font.GothamBold,
        Enum.TextXAlignment.Right, UDim2.new(0.65,0,0,0), UDim2.new(0.35,0,1,0), 3)

    -- Track holder — zona clicável maior
    local TrkHolder = New("Frame", {
        Parent=Wrap, BackgroundTransparency=1,
        Position=UDim2.new(0,2,0,26), Size=UDim2.new(1,-4,0,20), ZIndex=3,
    })

    -- Track visível (centrado no holder)
    local Trk = New("Frame", {
        Parent=TrkHolder, BackgroundColor3=T.SlTrack,
        Position=UDim2.new(0,0,0.5,-3), Size=UDim2.new(1,0,0,6), ZIndex=4,
    })
    Corn(3, Trk)

    local pct = (val-mn)/(mx-mn)

    local Fill = New("Frame", {
        Parent=Trk, BackgroundColor3=T.SlFill,
        Size=UDim2.new(pct,0,1,0), ZIndex=5,
    })
    Corn(3, Fill)
    New("UIGradient", {
        Parent=Fill,
        Color=ColorSequence.new{
            ColorSequenceKeypoint.new(0, T.Accent),
            ColorSequenceKeypoint.new(1, T.AccentHi),
        },
    })

    local Th = New("Frame", {
        Parent=Trk, BackgroundColor3=T.SlThumb,
        Position=UDim2.new(pct,-7,0.5,-7), Size=UDim2.new(0,14,0,14), ZIndex=6,
    })
    Corn(7, Th)
    Stro(T.Accent, 1.5, Th)

    -- Função principal de update
    local function SetFromAbsX(absX)
        local ap = Trk.AbsolutePosition.X
        local as = Trk.AbsoluteSize.X
        if as <= 0 then return end
        local p  = math.clamp((absX - ap) / as, 0, 1)
        local v  = Snap(mn + p*(mx-mn))
        val = v; ctrl._val = v
        local np = (v-mn)/(mx-mn)
        Fill.Size   = UDim2.new(np, 0, 1, 0)
        Th.Position = UDim2.new(np, -7, 0.5, -7)
        VL.Text     = string.format(fmt, v)
        if ctrl.callback then ctrl.callback(v) end
    end

    -- Hit zone invisível sobre o holder inteiro
    local dragging = false
    local HZ = New("TextButton", {
        Parent=TrkHolder, BackgroundTransparency=1,
        Size=UDim2.new(1,0,1,0), Text="", ZIndex=10,
    })

    HZ.MouseButton1Down:Connect(function(x, _)
        dragging = true
        SetFromAbsX(x)
        Tw(Th, {Size=UDim2.new(0,16,0,16), Position=UDim2.new(
            math.clamp((x - Trk.AbsolutePosition.X) / math.max(Trk.AbsoluteSize.X,1), 0, 1),
            -8, 0.5, -8)}, .06)
    end)

    -- Touch support
    HZ.TouchLongPress:Connect(function(positions)
        if #positions > 0 then
            dragging = true
            SetFromAbsX(positions[1].X)
        end
    end)

    local moveConn = UIS.InputChanged:Connect(function(i)
        if not dragging then return end
        if i.UserInputType == Enum.UserInputType.MouseMovement or
           i.UserInputType == Enum.UserInputType.Touch then
            SetFromAbsX(i.Position.X)
        end
    end)

    local upConn = UIS.InputEnded:Connect(function(i)
        if (i.UserInputType == Enum.UserInputType.MouseButton1 or
            i.UserInputType == Enum.UserInputType.Touch) and dragging then
            dragging = false
            Tw(Th, {Size=UDim2.new(0,14,0,14)}, .08)
        end
    end)

    Wrap.AncestryChanged:Connect(function()
        if not Wrap.Parent then
            pcall(function() moveConn:Disconnect() end)
            pcall(function() upConn:Disconnect()   end)
        end
    end)

    local function Set(v)
        v=Snap(v); val=v; ctrl._val=v
        local p=(v-mn)/(mx-mn)
        Fill.Size   = UDim2.new(p,0,1,0)
        Th.Position = UDim2.new(p,-7,0.5,-7)
        VL.Text     = string.format(fmt,v)
        if ctrl.callback then ctrl.callback(v) end
    end

    ctrl._setValue=Set; ctrl._getValue=function() return val end
    return Wrap
end

-- ══════════════════════════════════════════════
--  DROPDOWN  — CORRIGIDO (mostra opções corretamente)
-- ══════════════════════════════════════════════
function ShadowUI:_BDropdown(parent, ctrl)
    local opts = ctrl.options or {}
    local val  = ctrl._val~=nil and ctrl._val or (ctrl.default or (opts[1] or ""))

    local Wrap = MkRow(parent, 50)

    MkTxt(Wrap, ctrl.text or "Dropdown", 10, T.TxtSec, Enum.Font.Gotham,
        Enum.TextXAlignment.Left, UDim2.new(0,2,0,3), UDim2.new(1,-4,0,13), 3)

    local Box = New("Frame", {
        Parent=Wrap, BackgroundColor3=T.DropBg,
        Position=UDim2.new(0,0,0,18), Size=UDim2.new(1,0,0,27), ZIndex=3,
    })
    Corn(5, Box)
    Stro(T.Border, 1, Box)

    local Sel = MkTxt(Box, tostring(val), 11, T.TxtPri, Enum.Font.Gotham,
        Enum.TextXAlignment.Left, UDim2.new(0,9,0,0), UDim2.new(1,-22,1,0), 4)

    local ArrowLbl = MkTxt(Box, "▾", 11, T.TxtSec, Enum.Font.GothamBold,
        Enum.TextXAlignment.Center, UDim2.new(1,-18,0,0), UDim2.new(0,14,1,0), 4)

    local open  = false
    local DropF = nil
    local OvF   = nil

    local function Close()
        open = false
        if DropF and DropF.Parent then DropF:Destroy() end
        if OvF  and OvF.Parent   then OvF:Destroy()   end
        DropF=nil; OvF=nil
        pcall(function() Stro(T.Border, 1, Box) end)
        Tw(Box, {BackgroundColor3=T.DropBg}, .08)
        Tw(ArrowLbl, {Rotation=0}, .12)
        if _activeDropClose == Close then _activeDropClose=nil end
    end

    local function SetVal(v)
        val=v; ctrl._val=v
        Sel.Text = tostring(v)
        task.defer(Close)
        if ctrl.callback then ctrl.callback(v) end
    end

    local OBtn = New("TextButton", {
        Parent=Box, BackgroundTransparency=1,
        Size=UDim2.new(1,0,1,0), Text="", ZIndex=5,
    })

    OBtn.MouseEnter:Connect(function()
        if not open then Tw(Box, {BackgroundColor3=T.DropHov}, .08) end
    end)
    OBtn.MouseLeave:Connect(function()
        if not open then Tw(Box, {BackgroundColor3=T.DropBg}, .08) end
    end)

    OBtn.MouseButton1Click:Connect(function()
        CloseActiveDropdown()
        if open then return end
        open=true; _activeDropClose=Close

        -- Destaca o box
        pcall(function() Stro(T.Accent, 1, Box) end)
        Tw(Box, {BackgroundColor3=T.DropHov}, .08)
        Tw(ArrowLbl, {Rotation=180}, .14)

        local itemH  = 26
        local maxVis = math.min(#opts, 6)
        local listH  = maxVis * itemH + 8

        -- Overlay fecha ao clicar fora
        OvF = New("TextButton", {
            Parent=self.Gui, BackgroundTransparency=1,
            Size=UDim2.new(1,0,1,0), Text="", ZIndex=48,
        })
        OvF.MouseButton1Click:Connect(Close)

        -- Calcula posição absoluta do Box
        local ap = Box.AbsolutePosition
        local as = Box.AbsoluteSize

        DropF = New("Frame", {
            Parent=self.Gui, BackgroundColor3=T.DropBg,
            Position=UDim2.new(0, ap.X, 0, ap.Y + as.Y + 4),
            Size=UDim2.new(0, as.X, 0, listH),
            ZIndex=50, ClipsDescendants=true,
        })
        Corn(6, DropF)
        Stro(T.Accent, 1, DropF)

        -- Sombra do dropdown
        New("ImageLabel", {
            Parent=DropF, BackgroundTransparency=1,
            Position=UDim2.new(0,-10,0,-10), Size=UDim2.new(1,20,1,20), ZIndex=49,
            Image="rbxassetid://6014261993", ImageColor3=Color3.new(0,0,0),
            ImageTransparency=0.45, ScaleType=Enum.ScaleType.Slice,
            SliceCenter=Rect.new(49,49,450,450),
        })

        -- Se mais de maxVis itens, usar ScrollingFrame
        local ItemParent
        if #opts > 6 then
            local SF = New("ScrollingFrame", {
                Parent=DropF, BackgroundTransparency=1, BorderSizePixel=0,
                Size=UDim2.new(1,0,1,0),
                ScrollBarThickness=2, ScrollBarImageColor3=T.AccentDim,
                CanvasSize=UDim2.new(0,0,0,#opts*itemH+8),
                ZIndex=51, ScrollingDirection=Enum.ScrollingDirection.Y,
            })
            Pad(3,3,3,3,SF)
            ListL(SF, nil, 0)
            ItemParent = SF
        else
            Pad(3,3,3,3,DropF)
            ListL(DropF, nil, 0)
            ItemParent = DropF
        end

        for _, opt in ipairs(opts) do
            local isS = (opt == val)
            local Item = New("TextButton", {
                Parent=ItemParent,
                BackgroundColor3=isS and T.RowHov or T.DropBg,
                BackgroundTransparency=isS and 0 or 1,
                Size=UDim2.new(1,0,0,itemH),
                Font=isS and Enum.Font.GothamBold or Enum.Font.Gotham,
                Text=tostring(opt),
                TextColor3=isS and T.TxtAcc or T.TxtSec,
                TextSize=11, TextXAlignment=Enum.TextXAlignment.Left,
                AutoButtonColor=false, ZIndex=52,
            })
            Pad(8,0,0,0, Item)
            Corn(4, Item)
            Item.MouseEnter:Connect(function()
                Item.BackgroundTransparency=0
                Tw(Item, {BackgroundColor3=T.DropHov, TextColor3=T.TxtPri}, .07)
            end)
            Item.MouseLeave:Connect(function()
                if opt ~= val then
                    Item.BackgroundTransparency=1
                    Item.TextColor3=T.TxtSec
                else
                    Item.BackgroundColor3=T.RowHov
                end
            end)
            Item.MouseButton1Click:Connect(function() SetVal(opt) end)
        end
    end)

    ctrl._setValue=SetVal; ctrl._getValue=function() return val end
    return Wrap
end

-- ══════════════════════════════════════════════
--  SECTION HEADER
-- ══════════════════════════════════════════════
function ShadowUI:_BHeader(parent, ctrl)
    local row = MkRow(parent, 30)
    local rOff = 0

    if ctrl.gear then
        local G = New("TextButton", {
            Parent=row, BackgroundTransparency=1,
            Position=UDim2.new(1,-20,0.5,-8), Size=UDim2.new(0,16,0,16),
            Font=Enum.Font.Gotham, Text="⚙",
            TextColor3=T.TxtDim, TextSize=13, ZIndex=4,
        })
        G.MouseEnter:Connect(function() Tw(G,{TextColor3=T.TxtAcc},.08) end)
        G.MouseLeave:Connect(function() Tw(G,{TextColor3=T.TxtDim},.08) end)
        rOff=22
    end

    if ctrl.toggle ~= nil then
        local tv = ctrl.toggle or false
        local TTr = New("Frame", {
            Parent=row, BackgroundColor3=tv and T.TogOn or T.TogOff,
            Position=UDim2.new(1,-(28+rOff),0.5,-7), Size=UDim2.new(0,26,0,14), ZIndex=4,
        })
        Corn(7, TTr)
        local TTh = New("Frame", {
            Parent=TTr, BackgroundColor3=T.White,
            Position=tv and UDim2.new(1,-13,0.5,-5) or UDim2.new(0,2,0.5,-5),
            Size=UDim2.new(0,9,0,9), ZIndex=5,
        })
        Corn(5, TTh)
        local TB = New("TextButton", {
            Parent=TTr, BackgroundTransparency=1,
            Size=UDim2.new(1,0,1,0), Text="", ZIndex=6,
        })
        TB.MouseButton1Click:Connect(function()
            tv=not tv
            Tw(TTr,{BackgroundColor3=tv and T.TogOn or T.TogOff},.13)
            Tw(TTh,{Position=tv and UDim2.new(1,-13,0.5,-5) or UDim2.new(0,2,0.5,-5)},.13)
            if ctrl.callback then ctrl.callback(tv) end
        end)
        rOff=rOff+30
    end

    MkTxt(row, ctrl.text or "", 11, T.TxtSec, Enum.Font.GothamMedium,
        Enum.TextXAlignment.Left, UDim2.new(0,0,0,0), UDim2.new(1,-(rOff+4),1,0), 3)
    New("Frame", {
        Parent=row, BackgroundColor3=T.Border,
        Position=UDim2.new(0,0,1,-1), Size=UDim2.new(1,0,0,1), ZIndex=3,
    })
    return row
end

-- ══════════════════════════════════════════════
--  LABEL

        -- Dropdown
        local function buildDropdown(parent, opts)
            opts = opts or {}
            local options  = opts.Options  or {}
            local selected = opts.Default  or (options[1] or "None")
            local cb       = opts.Callback or function() end
            local multi    = opts.Multi    or false

            local Row = makeItemBase(parent, opts.Name or "Dropdown", selected, 44)

            local SubText = Row:FindFirstChild("TextLabel", true)
            -- find the sub label (second textlabel)
            local labels = {}
            for _, v in ipairs(Row:GetDescendants()) do
                if v:IsA("TextLabel") then table.insert(labels, v) end
            end
            local SubLbl = labels[2]
            if SubLbl then SubLbl.Text = selected end

            local ArrowIcon = Create("TextLabel", {
                Parent = Row,
                BackgroundTransparency = 1,
                Position = UDim2.new(1, -28, 0, 0),
                Size = UDim2.new(0, 24, 1, 0),
                Font = Enum.Font.GothamBold,
                Text = "‚Äļ",
                TextColor3 = Theme.TextMuted,
                TextSize = 18,

        -- ── Dropdown ────────────────────────────────────────────────────────────
        function Tab:AddDropdown(o, tl)
            o  = o or {}
            tl = tl or mainList
            local opts = o.Options  or {}
            local sel  = o.Default  or opts[1] or "None"
            local cb   = o.Callback or function() end

            local row = baseRow(o.Name, sel, 46, tl)
            -- find sub-label (the description/value label we abuse)
            local subLbl
            for _, v in ipairs(row:GetDescendants()) do
                if v:IsA("TextLabel") and v.TextSize == 9 then
                    subLbl = v
                    break
                end
            end

            -- arrow icon
            local arrowLbl = new("TextLabel", {
                Parent               = row,
                BackgroundTransparency = 1,
                Position             = UDim2.new(1, -26, 0, 0),
                Size                 = UDim2.new(0, 22, 1, 0),
                Font                 = Enum.Font.GothamBold,
                Text                 = "›",
                TextColor3           = C.TEXT_DIM,
                TextSize             = 18,
                ZIndex               = 6,
            })
            row.MouseEnter:Connect(function() tween(arrowLbl, { TextColor3 = C.ACCENT }) end)
            row.MouseLeave:Connect(function() tween(arrowLbl, { TextColor3 = C.TEXT_DIM }) end)

            -- dropdown panel
            local panel = new("Frame", {
                Parent           = row,
                BackgroundColor3 = Color3.fromRGB(19, 19, 26),
                BorderSizePixel  = 0,
                Position         = UDim2.new(0, 0, 1, 1),
                Size             = UDim2.new(1, 0, 0, 0),
                Visible          = false,
                ZIndex           = 20,
                ClipsDescendants = true,
            })
            corner(7, panel)
            stroke(C.BORDER2, 1, panel)
            new("UIListLayout", {
                Parent        = panel,
                FillDirection = Enum.FillDirection.Vertical,
                Padding       = UDim.new(0, 0),
            })

            local open = false
            local function rebuild()
                for _, c in ipairs(panel:GetChildren()) do
                    if c:IsA("TextButton") or c:IsA("Frame") then c:Destroy() end
                end
                for _, opt in ipairs(opts) do
                    local isSelected = (opt == sel)
                    local ob = new("TextButton", {
                        Parent               = panel,
                        BackgroundColor3     = isSelected and C.ACCENT_DIM or Color3.fromRGB(19, 19, 26),
                        BackgroundTransparency = 0,
                        BorderSizePixel      = 0,
                        Size                 = UDim2.new(1, 0, 0, 30),
                        Font                 = isSelected and Enum.Font.GothamBold or Enum.Font.Gotham,
                        Text                 = "",
                        AutoButtonColor      = false,
                        ZIndex               = 21,
                        ClipsDescendants     = true,
                    })
                    -- check icon
                    new("TextLabel", {
                        Parent               = ob,
                        BackgroundTransparency = 1,
                        Position             = UDim2.new(0, 10, 0, 0),
                        Size                 = UDim2.new(0, 16, 1, 0),
                        Font                 = Enum.Font.GothamBold,
                        Text                 = isSelected and "✓" or "",
                        TextColor3           = C.ACCENT,
                        TextSize             = 10,
                        ZIndex               = 22,
                    })
                    new("TextLabel", {
                        Parent               = ob,
                        BackgroundTransparency = 1,
                        Position             = UDim2.new(0, 28, 0, 0),
                        Size                 = UDim2.new(1, -36, 1, 0),
                        Font                 = isSelected and Enum.Font.GothamBold or Enum.Font.Gotham,
                        Text                 = opt,
                        TextColor3           = isSelected and C.ACCENT2 or C.TEXT,
                        TextSize             = 10,
                        TextXAlignment       = Enum.TextXAlignment.Left,
                        ZIndex               = 22,
                    })
                    -- bottom divider
                    new("Frame", {
                        Parent           = ob,
                        BackgroundColor3 = C.BORDER,
                        BorderSizePixel  = 0,
                        Position         = UDim2.new(0, 8, 1, -1),
                        Size             = UDim2.new(1, -16, 0, 1),
                        ZIndex           = 22,
                    })
                    ob.MouseEnter:Connect(function()
                        if not isSelected then tween(ob, { BackgroundColor3 = Color3.fromRGB(28, 28, 38) }) end
                    end)
                    ob.MouseLeave:Connect(function()
                        if not isSelected then tween(ob, { BackgroundColor3 = Color3.fromRGB(19, 19, 26) }) end
                    end)
                    ob.MouseButton1Click:Connect(function()
                        sel = opt
                        if subLbl then subLbl.Text = opt end
                        pcall(cb, opt)
                        open = false
                        tween(panel, { Size = UDim2.new(1, 0, 0, 0) }, 0.15)
                        task.delay(0.16, function() panel.Visible = false end)
                        tween(arrowLbl, { Rotation = 0 })
                        rebuild()
                    end)
                end
            end
            rebuild()

            row.InputBegan:Connect(function(i)
                if i.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
                open = not open
                if open then
                    rebuild()
                    panel.Visible = true
                    panel.Size    = UDim2.new(1, 0, 0, 0)
                    tween(panel, { Size = UDim2.new(1, 0, 0, math.min(#opts * 30, 150)) }, 0.18)
                    tween(arrowLbl, { Rotation = 90 })
                else
                    tween(panel, { Size = UDim2.new(1, 0, 0, 0) }, 0.14)
                    task.delay(0.15, function() panel.Visible = false end)
                    tween(arrowLbl, { Rotation = 0 })
                end
            end)

            local D = {}
            function D:Set(v)  sel = v; if subLbl then subLbl.Text = v end; pcall(cb, v); rebuild() end
            function D:Get()   return sel end
            function D:SetOptions(t) opts = t; sel = t[1] or "None"; if subLbl then subLbl.Text = sel end; rebuild() end
            return D
        end


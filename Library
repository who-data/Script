    local arrow = Lbl(box,"▾",11,T.TxtSec,Enum.Font.GothamBold,
        Enum.TextXAlignment.Center,
        UDim2.new(1,-18,0,0),UDim2.new(0,14,1,0),4)

    local isOpen=false
    local dropF=nil
    local ovF=nil

    local function Close()
        isOpen=false
        if dropF and dropF.Parent then dropF:Destroy() end
        if ovF  and ovF.Parent   then ovF:Destroy()   end
        dropF=nil; ovF=nil
        boxStr.Color=T.Border
        Tw(box,{BackgroundColor3=T.DropBg},.08)
        arrow.Text="▾"
        if _closeDrop==Close then _closeDrop=nil end
    end

    local function SetVal(v)
        val=v; ctrl._val=v
        selLbl.Text=tostring(v)
        task.defer(Close)
        if ctrl.callback then ctrl.callback(v) end
    end

    local openBtn = New("TextButton",{
        Parent=box, BackgroundTransparency=1,
        Size=UDim2.new(1,0,1,0), Text="", ZIndex=5,
    })
    openBtn.MouseEnter:Connect(function()
        if not isOpen then Tw(box,{BackgroundColor3=T.DropHov},.08) end
    end)
    openBtn.MouseLeave:Connect(function()
        if not isOpen then Tw(box,{BackgroundColor3=T.DropBg},.08) end
    end)

    openBtn.MouseButton1Click:Connect(function()
        CloseAnyDrop()
        if isOpen then return end
        isOpen=true; _closeDrop=Close

        boxStr.Color=T.Accent
        Tw(box,{BackgroundColor3=T.DropHov},.08)
        arrow.Text="▴"

        local ITEM_H=28
        local PAD=4
        local maxVis=math.min(#opts,7)
        local winH=maxVis*ITEM_H+PAD*2

        ovF=New("TextButton",{
            Parent=self.Gui,
            BackgroundTransparency=1,
            Size=UDim2.new(1,0,1,0),
            Text="",ZIndex=98,
        })
        ovF.MouseButton1Click:Connect(Close)

        local ap=box.AbsolutePosition
        local as=box.AbsoluteSize

        -- Frame raiz: borda+sombra, SEM ClipsDescendants
        dropF=New("Frame",{
            Parent=self.Gui,
            BackgroundColor3=T.DropBg,
            Position=UDim2.new(0,ap.X,0,ap.Y+as.Y+4),
            Size=UDim2.new(0,as.X,0,winH),
            ZIndex=100, BorderSizePixel=0,
            ClipsDescendants=false,
        })
        Corner(6,dropF)
        Stroke(T.Accent,1,dropF)

        New("ImageLabel",{
            Parent=dropF, BackgroundTransparency=1,
            Position=UDim2.new(0,-14,0,-14),
            Size=UDim2.new(1,28,1,28),
            ZIndex=99,
            Image="rbxassetid://6014261993",
            ImageColor3=Color3.new(0,0,0),
            ImageTransparency=0.38,
            ScaleType=Enum.ScaleType.Slice,
            SliceCenter=Rect.new(49,49,450,450),
        })

        -- ScrollingFrame com ClipsDescendants=true
        local totalH=#opts*ITEM_H+PAD*2
        local sf=New("ScrollingFrame",{
            Parent=dropF,
            BackgroundTransparency=1,
            BorderSizePixel=0,
            Position=UDim2.new(0,0,0,0),
            Size=UDim2.new(1,0,1,0),
            CanvasSize=UDim2.new(0,0,0,totalH),
            ScrollBarThickness=3,
            ScrollBarImageColor3=T.AccentDim,
            ScrollingDirection=Enum.ScrollingDirection.Y,
            ZIndex=101,
            ClipsDescendants=true,
        })

        -- Itens com posicionamento absoluto manual
        for idx, opt in ipairs(opts) do
            local isSel=(tostring(opt)==tostring(val))
            local yPos=PAD+(idx-1)*ITEM_H

            local item=New("TextButton",{
                Parent=sf,
                BackgroundColor3=isSel and T.AccentDim or T.DropItem,
                BackgroundTransparency=0,
                Position=UDim2.new(0,PAD,0,yPos),
                Size=UDim2.new(1,-(PAD*2),0,ITEM_H-2),
                Font=isSel and Enum.Font.GothamBold or Enum.Font.Gotham,
                Text=tostring(opt),
                TextColor3=isSel and T.TxtAcc or T.TxtSec,
                TextSize=11,
                TextXAlignment=Enum.TextXAlignment.Left,
                AutoButtonColor=false,
                ZIndex=102, BorderSizePixel=0,
            })
            Corner(4,item)
            Pad(9,0,0,0,item)

            if isSel then
                New("Frame",{
                    Parent=item,
                    BackgroundColor3=T.Accent,
                    Position=UDim2.new(0,-1,0.5,-3),
                    Size=UDim2.new(0,2,0,6),
                    ZIndex=103, BorderSizePixel=0,
                })
                Corner(1,item:GetChildren()[#item:GetChildren()])
            end

            item.MouseEnter:Connect(function()
                Tw(item,{BackgroundColor3=T.DropHov,TextColor3=T.TxtPri},.07)
            end)
            item.MouseLeave:Connect(function()
                Tw(item,{
                    BackgroundColor3=isSel and T.AccentDim or T.DropItem,
                    TextColor3=isSel and T.TxtAcc or T.TxtSec,
                },.07)
            end)
            local _o=opt
            item.MouseButton1Click:Connect(function() SetVal(_o) end)
        end
    end)

    ctrl._setValue=function(v)
        val=v; ctrl._val=v; selLbl.Text=tostring(v)
    end
    ctrl._getValue=function() return val end
    return wrap
end


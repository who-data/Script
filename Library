    if ctrl.gear then
        local Gear = Create("TextButton", {
            Parent               = row,
            BackgroundTransparency = 1,
            Position             = UDim2.new(1, -48, 0.5, -9),
            Size                 = UDim2.new(0, 18, 0, 18),
            Font                 = Enum.Font.Gotham,
            Text                 = "⚙",
            TextColor3           = Theme.TextSecondary,
            TextSize             = 14,
            ZIndex               = 3,
        })
        Gear.MouseEnter:Connect(function() Gear.TextColor3 = Theme.TextPrimary end)
        Gear.MouseLeave:Connect(function() Gear.TextColor3 = Theme.TextSecondary end)
        labelRight = -72
    end

    local Lbl = Create("TextLabel", {
        Parent               = row,
        BackgroundTransparency = 1,
        Position             = UDim2.new(0, 0, 0, 0),
        Size                 = UDim2.new(1, labelRight, 1, 0),
        Font                 = Enum.Font.Gotham,
        Text                 = ctrl.text or "Toggle",
        TextColor3           = value and Theme.TextPrimary or Theme.TextDisabled,
        TextSize             = 12,
        TextXAlignment       = Enum.TextXAlignment.Left,
        ZIndex               = 3,
    })

    local Track = Create("Frame", {
        Parent           = row,
        BackgroundColor3 = value and Theme.ToggleOn or Theme.ToggleOff,
        BorderSizePixel  = 0,
        Position         = UDim2.new(1, -30, 0.5, -8),
        Size             = UDim2.new(0, 26, 0, 15),
        ZIndex           = 3,
    })
    Corner(8, Track)

    local Thumb = Create("Frame", {
        Parent           = Track,
        BackgroundColor3 = Theme.White,
        BorderSizePixel  = 0,
        Position         = value and UDim2.new(1, -13, 0.5, -5) or UDim2.new(0, 2, 0.5, -5),
        Size             = UDim2.new(0, 11, 0, 11),
        ZIndex           = 4,
    })
    Corner(6, Thumb)

    local function SetValue(v)
        value = v
        Tween(Track, { BackgroundColor3 = v and Theme.ToggleOn or Theme.ToggleOff }, 0.12)
        Tween(Thumb, { Position = v and UDim2.new(1, -13, 0.5, -5) or UDim2.new(0, 2, 0.5, -5) }, 0.12)
        Lbl.TextColor3 = v and Theme.TextPrimary or Theme.TextDisabled
        if ctrl.callback then ctrl.callback(v) end
    end

    local ClickBtn = Create("TextButton", {
        Parent               = row,
        BackgroundTransparency = 1,
        Size                 = UDim2.new(1, 0, 1, 0),
        Text                 = "",
        ZIndex               = 5,
    })
    ClickBtn.MouseButton1Click:Connect(function() SetValue(not value) end)

    ctrl._setValue = SetValue
    ctrl._getValue = function() return value end
    return row
end

-- ──────────────────────────────────────────────
--  SLIDER — drag real
-- ──────────────────────────────────────────────
function ShadowUI:_BuildSlider(parent, ctrl)
    local min   = ctrl.min     or 0
    local max   = ctrl.max     or 100
    local step  = ctrl.step    or 0
    local fmt   = ctrl.format  or "%.2f"
    local value = ctrl.default or min

    local function Snap(v)
        if step and step > 0 then
            v = math.round((v - min) / step) * step + min
        end
        return math.clamp(v, min, max)
    end

    local Wrap = MakeRow(parent, 46)

    local TopRow = Create("Frame", {
        Parent               = Wrap,
        BackgroundTransparency = 1,
        Position             = UDim2.new(0, 0, 0, 2),
        Size                 = UDim2.new(1, 0, 0, 16),
        ZIndex               = 3,
    })

    Create("TextLabel", {
        Parent               = TopRow,
        BackgroundTransparency = 1,
        Size                 = UDim2.new(0.72, 0, 1, 0),
        Font                 = Enum.Font.Gotham,
        Text                 = ctrl.text or "Slider",
        TextColor3           = Theme.TextSecondary,
        TextSize             = 11,
        TextXAlignment       = Enum.TextXAlignment.Left,
        ZIndex               = 3,
    })

    local ValLbl = Create("TextLabel", {
        Parent               = TopRow,
        BackgroundTransparency = 1,
        Position             = UDim2.new(0.72, 0, 0, 0),
        Size                 = UDim2.new(0.28, 0, 1, 0),
        Font                 = Enum.Font.GothamBold,
        Text                 = string.format(fmt, value),
        TextColor3           = Theme.TextPrimary,
        TextSize             = 11,
        TextXAlignment       = Enum.TextXAlignment.Right,
        ZIndex               = 3,
    })

    local Track = Create("Frame", {
        Parent           = Wrap,
        BackgroundColor3 = Theme.SliderTrack,
        BorderSizePixel  = 0,
        Position         = UDim2.new(0, 0, 0, 26),
        Size             = UDim2.new(1, 0, 0, 4),
        ZIndex           = 3,
    })
    Corner(2, Track)

    local pct  = (value - min) / (max - min)
    local Fill = Create("Frame", {
        Parent           = Track,
        BackgroundColor3 = Theme.SliderFill,
        BorderSizePixel  = 0,
        Size             = UDim2.new(pct, 0, 1, 0),
        ZIndex           = 4,
    })
    Corner(2, Fill)

    local Thumb = Create("Frame", {
        Parent           = Track,
        BackgroundColor3 = Theme.SliderThumb,
        BorderSizePixel  = 0,
        Position         = UDim2.new(pct, -6, 0.5, -6),
        Size             = UDim2.new(0, 12, 0, 12),
        ZIndex           = 5,
    })
    Corner(6, Thumb)

    local function SetValue(v)
        v      = Snap(v)
        value  = v
        local p = (v - min) / (max - min)
        Fill.Size      = UDim2.new(p, 0, 1, 0)
        Thumb.Position = UDim2.new(p, -6, 0.5, -6)
        ValLbl.Text    = string.format(fmt, v)
        if ctrl.callback then ctrl.callback(v) end
    end

    -- Drag real: clica em qualquer ponto do track e arrasta
    local dragging = false

    Track.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            local pos  = Track.AbsolutePosition.X
            local size = Track.AbsoluteSize.X
            SetValue(min + math.clamp((inp.Position.X - pos) / size, 0, 1) * (max - min))
        end
    end)

    UserInputService.InputChanged:Connect(function(inp)
        if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
            local pos  = Track.AbsolutePosition.X
            local size = Track.AbsoluteSize.X
            SetValue(min + math.clamp((inp.Position.X - pos) / size, 0, 1) * (max - min))
        end
    end)

    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    ctrl._setValue = SetValue
    ctrl._getValue = function() return value end
    return Wrap
end

-- ──────────────────────────────────────────────
--  DROPDOWN
-- ──────────────────────────────────────────────
function ShadowUI:_BuildDropdown(parent, ctrl)
    local opts  = ctrl.options or {}
    local value = ctrl.default or opts[1]

    local Wrap = MakeRow(parent, 50)

    Create("TextLabel", {
        Parent               = Wrap,
        BackgroundTransparency = 1,
        Position             = UDim2.new(0, 0, 0, 2),
        Size                 = UDim2.new(1, 0, 0, 14),
        Font                 = Enum.Font.Gotham,
        Text                 = ctrl.text or "Dropdown",
        TextColor3           = Theme.TextSecondary,
        TextSize             = 11,
        TextXAlignment       = Enum.TextXAlignment.Left,
        ZIndex               = 3,
    })

    local Box = Create("Frame", {
        Parent           = Wrap,
        BackgroundColor3 = Theme.Dropdown,
        BorderSizePixel  = 0,
        Position         = UDim2.new(0, 0, 0, 18),
        Size             = UDim2.new(1, 0, 0, 26),
        ZIndex           = 3,
    })
    Corner(5, Box)
    Stroke(Theme.Border, 1, Box)

    local SelLbl = Create("TextLabel", {
        Parent               = Box,
        BackgroundTransparency = 1,
        Position             = UDim2.new(0, 8, 0, 0),
        Size                 = UDim2.new(1, -24, 1, 0),
        Font                 = Enum.Font.Gotham,
        Text                 = tostring(value),
        TextColor3           = Theme.TextPrimary,
        TextSize             = 12,
        TextXAlignment       = Enum.TextXAlignment.Left,
        ZIndex               = 4,
    })
    Create("TextLabel", {
        Parent               = Box,
        BackgroundTransparency = 1,
        Position             = UDim2.new(1, -20, 0, 0),
        Size                 = UDim2.new(0, 16, 1, 0),
        Font                 = Enum.Font.GothamBold,
        Text                 = "▾",
        TextColor3           = Theme.TextSecondary,
        TextSize             = 12,
        ZIndex               = 4,
    })

    local open    = false
    local DropWin = nil

    local function CloseList()
        if DropWin then DropWin:Destroy() DropWin = nil end
        open = false
    end

    local function SetValue(v)
        value       = v
        SelLbl.Text = tostring(v)
        CloseList()
        if ctrl.callback then ctrl.callback(v) end
    end

    local ClickBtn = Create("TextButton", {
        Parent               = Box,
        BackgroundTransparency = 1,
        Size                 = UDim2.new(1, 0, 1, 0),
        Text                 = "",
        ZIndex               = 5,
    })
    ClickBtn.MouseButton1Click:Connect(function()
        if open then CloseList() return end
        open = true
        local itemH = 24
        DropWin = Create("Frame", {
            Parent           = Box,
            BackgroundColor3 = Theme.Dropdown,
            BorderSizePixel  = 0,
            Position         = UDim2.new(0, 0, 1, 3),
            Size             = UDim2.new(1, 0, 0, #opts * itemH + 4),
            ZIndex           = 20,
            ClipsDescendants = true,
        })
        Corner(5, DropWin)
        Stroke(Theme.Border, 1, DropWin)
        ListLayout(DropWin)
        Create("UIPadding", {
            PaddingLeft   = UDim.new(0, 2), PaddingRight  = UDim.new(0, 2),
            PaddingTop    = UDim.new(0, 2), PaddingBottom = UDim.new(0, 2),
            Parent        = DropWin,
        })
        for _, opt in ipairs(opts) do
            local Item = Create("TextButton", {
                Parent               = DropWin,
                BackgroundColor3     = Theme.Dropdown,
                BackgroundTransparency = 1,
                BorderSizePixel      = 0,
                Size                 = UDim2.new(1, 0, 0, itemH),
                Font                 = Enum.Font.Gotham,
                Text                 = tostring(opt),
                TextColor3           = (opt == value) and Theme.TextPrimary or Theme.TextSecondary,
                TextSize             = 12,
                TextXAlignment       = Enum.TextXAlignment.Left,
                AutoButtonColor      = false,
                ZIndex               = 21,
            })
            Create("UIPadding", { PaddingLeft = UDim.new(0, 8), Parent = Item })
            Item.MouseEnter:Connect(function()
                Item.BackgroundTransparency = 0
                Tween(Item, { BackgroundColor3 = Theme.DropdownHover }, 0.08)
            end)
            Item.MouseLeave:Connect(function()
                Item.BackgroundTransparency = 0
                Tween(Item, { BackgroundColor3 = Theme.Dropdown }, 0.08)
            end)
            Item.MouseButton1Click:Connect(function() SetValue(opt) end)
        end
    end)

    ctrl._setValue = SetValue
    ctrl._getValue = function() return value end
    return Wrap
end

-- ──────────────────────────────────────────────
--  SECTION HEADER  (ex: "Auto Curve ⚙ [toggle]")
-- ──────────────────────────────────────────────
function ShadowUI:_BuildSectionHeader(parent, ctrl)
    local row    = MakeRow(parent, 28)
    local rightOff = 0

    if ctrl.gear then
        local GearBtn = Create("TextButton", {
            Parent               = row,
            BackgroundTransparency = 1,
            Position             = UDim2.new(1, -20, 0.5, -9),
            Size                 = UDim2.new(0, 18, 0, 18),
            Font                 = Enum.Font.Gotham,
            Text                 = "⚙",
            TextColor3           = Theme.TextSecondary,
            TextSize             = 14,
            ZIndex               = 3,
        })
        GearBtn.MouseEnter:Connect(function() GearBtn.TextColor3 = Theme.TextPrimary end)
        GearBtn.MouseLeave:Connect(function() GearBtn.TextColor3 = Theme.TextSecondary end)
        rightOff = 22
    end

    if ctrl.toggle ~= nil then
        local tval = ctrl.toggle or false
        local TTrack = Create("Frame", {
            Parent           = row,
            BackgroundColor3 = tval and Theme.ToggleOn or Theme.ToggleOff,
            BorderSizePixel  = 0,
            Position         = UDim2.new(1, -(26 + rightOff), 0.5, -8),
            Size             = UDim2.new(0, 24, 0, 14),
            ZIndex           = 3,
        })
        Corner(7, TTrack)
        local TThumb = Create("Frame", {
            Parent           = TTrack,
            BackgroundColor3 = Theme.White,
            BorderSizePixel  = 0,
            Position         = tval and UDim2.new(1, -12, 0.5, -5) or UDim2.new(0, 2, 0.5, -5),
            Size             = UDim2.new(0, 10, 0, 10),
            ZIndex           = 4,
        })
        Corner(5, TThumb)
        local TBtn = Create("TextButton", {
            Parent               = TTrack,
            BackgroundTransparency = 1,
            Size                 = UDim2.new(1, 0, 1, 0),
            Text                 = "",
            ZIndex               = 5,
        })
        TBtn.MouseButton1Click:Connect(function()
            tval = not tval
            Tween(TTrack, { BackgroundColor3 = tval and Theme.ToggleOn or Theme.ToggleOff }, 0.12)
            Tween(TThumb, { Position = tval and UDim2.new(1, -12, 0.5, -5) or UDim2.new(0, 2, 0.5, -5) }, 0.12)
            if ctrl.callback then ctrl.callback(tval) end
        end)
        rightOff = rightOff + 28
    end

    Create("TextLabel", {
        Parent               = row,
        BackgroundTransparency = 1,
        Position             = UDim2.new(0, 0, 0, 0),
        Size                 = UDim2.new(1, -(rightOff + 4), 1, 0),
        Font                 = Enum.Font.Gotham,
        Text                 = ctrl.text or "",
        TextColor3           = Theme.TextSecondary,
        TextSize             = 11,
        TextXAlignment       = Enum.TextXAlignment.Left,
        ZIndex               = 3,
    })

    Create("Frame", {
        Parent           = row,
        BackgroundColor3 = Theme.Border,
        BorderSizePixel  = 0,
        Position         = UDim2.new(0, 0, 1, -1),
        Size             = UDim2.new(1, 0, 0, 1),
        ZIndex           = 3,
    })

    return row
end


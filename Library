-- ‚ĒÄ‚ĒÄ TOGGLE ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
function Components.Toggle(parent, name, options)
    options = options or {}
    local value = options.Default or false
    local callback = options.Callback or function() end
    local description = options.Description

    local row = Util.Create("Frame", {
        Size = UDim2.new(1, 0, 0, description and 46 or Theme.RowHeight),
        BackgroundTransparency = 1,
        Parent = parent,
    })

    -- label
    Util.Create("TextLabel", {
        Size = UDim2.new(1, -60, 0, 16),
        Position = UDim2.new(0, 0, 0, description and 6 or 11),
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = Theme.TextPrimary,
        Font = Theme.FontSemiBold,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = row,
    })

    if description then
        Util.Create("TextLabel", {
            Size = UDim2.new(1, -60, 0, 14),
            Position = UDim2.new(0, 0, 0, 24),
            BackgroundTransparency = 1,
            Text = description,
            TextColor3 = Theme.TextDim,
            Font = Theme.Font,
            TextSize = 11,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = row,
        })
    end

    -- separator
    Util.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 1),
        Position = UDim2.new(0, 0, 1, -1),
        BackgroundColor3 = Theme.Separator,
        BorderSizePixel = 0,
        Parent = row,
    })

    -- track
    local track = Util.Create("Frame", {
        Size = UDim2.new(0, 42, 0, 22),
        Position = UDim2.new(1, -42, 0.5, -11),
        BackgroundColor3 = value and Theme.ToggleOn or Theme.ToggleOff,
        BorderSizePixel = 0,
        Parent = row,
    })
    Util.AddCorner(track, UDim.new(0, 11))
    Util.Stroke(track, value and Theme.AccentGlow or Theme.Border)

    -- knob
    local knob = Util.Create("Frame", {
        Size = UDim2.new(0, 16, 0, 16),
        Position = value and UDim2.new(0, 22, 0.5, -8) or UDim2.new(0, 4, 0.5, -8),
        BackgroundColor3 = Theme.ToggleKnob,
        BorderSizePixel = 0,
        Parent = track,
    })
    Util.AddCorner(knob, UDim.new(1, 0))

    local function SetValue(v, silent)
        value = v
        Util.Tween(track, { BackgroundColor3 = v and Theme.ToggleOn or Theme.ToggleOff })
        Util.Tween(knob, { Position = v and UDim2.new(0, 22, 0.5, -8) or UDim2.new(0, 4, 0.5, -8) })
        local stroke = track:FindFirstChildOfClass("UIStroke")
        if stroke then
            Util.Tween(stroke, { Color = v and Theme.AccentGlow or Theme.Border })
        end
        if not silent then callback(v) end
    end

    -- click area
    local btn = Util.Create("TextButton", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        Parent = row,
    })
    btn.MouseButton1Click:Connect(function() SetValue(not value) end)

    -- hover
    btn.MouseEnter:Connect(function()
        Util.Tween(row, { BackgroundColor3 = Theme.BGHover })
        row.BackgroundTransparency = 0
    end)
    btn.MouseLeave:Connect(function()
        row.BackgroundTransparency = 1
    end)

    return {
        Set = SetValue,
        Get = function() return value end,
    }
end

-- ‚ĒÄ‚ĒÄ SLIDER ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
function Components.Slider(parent, name, options)
    options = options or {}
    local min = options.Min or 0
    local max = options.Max or 100
    local value = math.clamp(options.Default or min, min, max)
    local suffix = options.Suffix or ""
    local callback = options.Callback or function() end
    local decimals = options.Decimals or 0

    local function Round(n)
        local m = 10^decimals
        return math.floor(n * m + 0.5) / m
    end

    local row = Util.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 54),
        BackgroundTransparency = 1,
        Parent = parent,
    })

    -- top row: name + value
    Util.Create("TextLabel", {
        Size = UDim2.new(1, -60, 0, 16),
        Position = UDim2.new(0, 0, 0, 6),
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = Theme.TextPrimary,
        Font = Theme.FontSemiBold,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = row,
    })

    local valLabel = Util.Create("TextLabel", {
        Size = UDim2.new(0, 55, 0, 16),
        Position = UDim2.new(1, -55, 0, 6),
        BackgroundTransparency = 1,
        Text = tostring(Round(value)) .. suffix,
        TextColor3 = Theme.TextAccent,
        Font = Theme.FontSemiBold,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Right,
        Parent = row,
    })

    -- track bg
    local trackBG = Util.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 4),
        Position = UDim2.new(0, 0, 0, 34),
        BackgroundColor3 = Theme.SliderTrack,
        BorderSizePixel = 0,
        Parent = row,
    })
    Util.AddCorner(trackBG, UDim.new(0, 2))

    -- fill
    local fill = Util.Create("Frame", {
        Size = UDim2.new((value - min) / (max - min), 0, 1, 0),
        BackgroundColor3 = Theme.SliderFill,
        BorderSizePixel = 0,
        Parent = trackBG,
    })
    Util.AddCorner(fill, UDim.new(0, 2))

    -- knob
    local knob = Util.Create("Frame", {
        Size = UDim2.new(0, 14, 0, 14),
        Position = UDim2.new((value - min) / (max - min), -7, 0.5, -7),
        BackgroundColor3 = Theme.SliderKnob,
        BorderSizePixel = 0,
        ZIndex = 3,
        Parent = trackBG,
    })
    Util.AddCorner(knob, UDim.new(1, 0))
    Util.Stroke(knob, Theme.AccentGlow, 1.5)

    -- separator
    Util.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 1),
        Position = UDim2.new(0, 0, 1, -1),
        BackgroundColor3 = Theme.Separator,
        BorderSizePixel = 0,
        Parent = row,
    })

    local function SetValue(v, silent)
        v = Round(math.clamp(v, min, max))
        value = v
        local pct = (v - min) / (max - min)
        Util.Tween(fill, { Size = UDim2.new(pct, 0, 1, 0) })
        Util.Tween(knob, { Position = UDim2.new(pct, -7, 0.5, -7) })
        valLabel.Text = tostring(v) .. suffix
        if not silent then callback(v) end
    end

    -- drag
    local dragging = false
    local function UpdateFromMouse()
        local abs = trackBG.AbsolutePosition
        local size = trackBG.AbsoluteSize
        local pct = math.clamp((Mouse.X - abs.X) / size.X, 0, 1)
        SetValue(min + (max - min) * pct)
    end

    local inputBegan = trackBG.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            UpdateFromMouse()
        end
    end)

    local inputChanged = UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            UpdateFromMouse()
        end
    end)

    local inputEnded = UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    return {
        Set = SetValue,
        Get = function() return value end,
    }
end


        -- ── ColorPicker ──────────────────────────────────────────────────────────
        function Tab:AddColorPicker(o, tl)
            o   = o or {}
            tl  = tl or mainList
            local col = o.Default or C.ACCENT
            local cb  = o.Callback or function() end
            local row = baseRow(o.Name, nil, 46, tl)

            -- preview swatch
            local prevFrame = new("Frame", {
                Parent           = row,
                BackgroundColor3 = col,
                BorderSizePixel  = 0,
                Position         = UDim2.new(1, -56, 0.5, -13),
                Size             = UDim2.new(0, 42, 0, 26),
                ZIndex           = 6,
            })
            corner(5, prevFrame)
            stroke(C.BORDER2, 1, prevFrame)

            -- checkerboard pattern hint (tiny dots to signal transparency concept)
            local prevClick = new("TextButton", {
                Parent               = prevFrame,
                BackgroundTransparency = 1,
                BorderSizePixel      = 0,
                Size                 = UDim2.new(1, 0, 1, 0),
                Text                 = "",
                ZIndex               = 7,
            })

            -- panel
            local panel = new("Frame", {
                Parent               = row,
                BackgroundColor3     = Color3.fromRGB(18, 18, 25),
                BorderSizePixel      = 0,
                Position             = UDim2.new(0, 0, 1, 2),
                Size                 = UDim2.new(1, 0, 0, 0),
                Visible              = false,
                ZIndex               = 18,
                ClipsDescendants     = true,
            })
            corner(7, panel)
            stroke(C.BORDER2, 1, panel)

            local open = false
            prevClick.MouseButton1Click:Connect(function()
                open = not open
                if open then
                    panel.Visible = true
                    panel.Size    = UDim2.new(1, 0, 0, 0)
                    tween(panel, { Size = UDim2.new(1, 0, 0, 86) }, 0.18)
                else
                    tween(panel, { Size = UDim2.new(1, 0, 0, 0) }, 0.14)
                    task.delay(0.15, function() panel.Visible = false end)
                end
            end)

            local vals = { col.R * 255, col.G * 255, col.B * 255 }
            local chN  = { "R", "G", "B" }
            local chC  = {
                Color3.fromRGB(220, 55, 55),
                Color3.fromRGB(55, 200, 75),
                Color3.fromRGB(55, 100, 220),
            }
            for i = 1, 3 do
                local tr = new("Frame", {
                    Parent           = panel,
                    BackgroundColor3 = C.SLIDER_BG,
                    BorderSizePixel  = 0,
                    Position         = UDim2.new(0, 10, 0, 5 + (i - 1) * 26),
                    Size             = UDim2.new(1, -20, 0, 18),
                    ZIndex           = 19,
                })
                corner(100, tr)
                stroke(C.BORDER, 1, tr)
                local fl = new("Frame", {
                    Parent           = tr,
                    BackgroundColor3 = chC[i],
                    BorderSizePixel  = 0,
                    Size             = UDim2.new(vals[i] / 255, 0, 1, 0),
                    ZIndex           = 19,
                })
                corner(100, fl)
                new("TextLabel", {
                    Parent               = tr,
                    BackgroundTransparency = 1,
                    Position             = UDim2.new(0, 6, 0, 0),
                    Size                 = UDim2.new(0, 14, 1, 0),
                    Font                 = Enum.Font.GothamBold,
                    Text                 = chN[i],
                    TextColor3           = C.WHITE,
                    TextSize             = 8,
                    ZIndex               = 20,
                })
                local drag3 = false
                local ci, fi, tri = i, fl, tr
                local function upd2(x)
                    local p = math.clamp((x - tri.AbsolutePosition.X) / tri.AbsoluteSize.X, 0, 1)
                    vals[ci] = math.floor(p * 255)
                    fi.Size  = UDim2.new(p, 0, 1, 0)
                    prevFrame.BackgroundColor3 = Color3.fromRGB(vals[1], vals[2], vals[3])
                    pcall(cb, Color3.fromRGB(vals[1], vals[2], vals[3]))
                end
                tr.InputBegan:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                        drag3 = true
                        upd2(inp.Position.X)
                    end
                end)
                UserInputService.InputChanged:Connect(function(inp)
                    if drag3 and inp.UserInputType == Enum.UserInputType.MouseMovement then
                        upd2(inp.Position.X)
                    end
                end)
                UserInputService.InputEnded:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                        drag3 = false
                    end
                end)
            end

            local CP = {}
            function CP:Set(c)
                vals = { c.R * 255, c.G * 255, c.B * 255 }
                prevFrame.BackgroundColor3 = c
            end
            function CP:Get()
                return Color3.fromRGB(vals[1], vals[2], vals[3])
            end
            return CP
        end

        -- ════════════════════════════════════════════════════════════════════════
        -- ── Sub-Tabs ─────────────────────────────────────────────────────────────
        -- ════════════════════════════════════════════════════════════════════════
        function Tab:AddSubTab(name)
            -- Lazy-create the sub-tab bar on first call
            if not Tab._subBar then
                -- sub-tab bar frame (sits between header and content)
                local sb = new("Frame", {
                    Parent           = page,
                    BackgroundColor3 = C.SUBTAB_BG,
                    BackgroundTransparency = 0,
                    BorderSizePixel  = 0,
                    Position         = UDim2.new(0, 0, 0, 34),
                    Size             = UDim2.new(1, 0, 0, 32),
                    ZIndex           = 4,
                    ClipsDescendants = false,
                })
                -- left gradient tint
                local sbGr = new("Frame", {
                    Parent               = sb,
                    BackgroundColor3     = C.ACCENT,
                    BackgroundTransparency = 0.95,
                    BorderSizePixel      = 0,
                    Size                 = UDim2.new(0.5, 0, 1, 0),
                    ZIndex               = 3,
                })
                gradient(C.ACCENT, Color3.new(0, 0, 0), 0, sbGr)
                -- bottom border
                new("Frame", {
                    Parent           = sb,
                    BackgroundColor3 = C.BORDER,
                    BorderSizePixel  = 0,
                    Position         = UDim2.new(0, 0, 1, -1),
                    Size             = UDim2.new(1, 0, 0, 1),
                    ZIndex           = 5,
                })
                new("UIListLayout", {
                    Parent        = sb,
                    FillDirection = Enum.FillDirection.Horizontal,
                    Padding       = UDim.new(0, 0),
                })

                -- push main scroll down to make room
                mainScroll.Position = UDim2.new(0, 0, 0, 66)
                mainScroll.Size     = UDim2.new(1, 0, 1, -66)
                mainScroll.Visible  = false   -- hidden by default once subtabs exist

                Tab._subBar      = sb
                Tab._subActive   = nil
            end

            -- ── SubTab button ────────────────────────────────────────────────────
            local subBtn = new("Frame", {
                Parent               = Tab._subBar,
                BackgroundTransparency = 1,
                BorderSizePixel      = 0,
                Size                 = UDim2.new(0, 0, 1, 0),
                AutomaticSize        = Enum.AutomaticSize.X,
                ZIndex               = 5,
            })
            new("UIPadding", {
                PaddingLeft  = UDim.new(0, 14),
                PaddingRight = UDim.new(0, 14),
            }, subBtn)
            -- hover bg
            local subBtnBG = new("Frame", {
                Parent               = subBtn,
                BackgroundColor3     = C.ACCENT,
                BackgroundTransparency = 1,
                BorderSizePixel      = 0,
                Size                 = UDim2.new(1, 0, 1, 0),
                ZIndex               = 4,
            })
            -- label
            local subLbl = new("TextLabel", {
                Parent               = subBtn,
                BackgroundTransparency = 1,
                Size                 = UDim2.new(1, 0, 1, -3),
                Font                 = Enum.Font.Gotham,
                Text                 = name,
                TextColor3           = C.TEXT_DIM,
                TextSize             = 10,
                ZIndex               = 6,
            })
            -- active underline indicator
            local subInd = new("Frame", {
                Parent           = subBtn,
                BackgroundColor3 = C.ACCENT,
                BorderSizePixel  = 0,
                Position         = UDim2.new(0, 0, 1, -2),
                Size             = UDim2.new(1, 0, 0, 2),
                Visible          = false,
                ZIndex           = 7,
            })
            corner(2, subInd)
            gradient(C.ACCENT2, C.ACCENT, 0, subInd)

            -- clickable button overlay
            local subBtnClick = new("TextButton", {
                Parent               = subBtn,
                BackgroundTransparency = 1,
                BorderSizePixel      = 0,
                Size                 = UDim2.new(1, 0, 1, 0),
                Text                 = "",
                AutoButtonColor      = false,
                ZIndex               = 8,
            })

            -- ── SubTab scroll frame ─────────────────────────────────────────────
            local subScroll = new("ScrollingFrame", {
                Parent               = page,
                BackgroundTransparency = 1,
                BorderSizePixel      = 0,
                Position             = UDim2.new(0, 0, 0, 66),
                Size                 = UDim2.new(1, 0, 1, -66),
                ScrollBarThickness   = 3,
                ScrollBarImageColor3 = C.ACCENT,
                CanvasSize           = UDim2.new(0, 0, 0, 0),
                AutomaticCanvasSize  = Enum.AutomaticSize.Y,
                Visible              = false,
                ZIndex               = 3,
            })
            local subItemList = new("Frame", {
                Parent               = subScroll,
                BackgroundTransparency = 1,
                Size                 = UDim2.new(1, 0, 0, 0),
                AutomaticSize        = Enum.AutomaticSize.Y,
                ZIndex               = 3,
            })
            new("UIListLayout", {
                Parent              = subItemList,
                FillDirection       = Enum.FillDirection.Vertical,
                HorizontalAlignment = Enum.HorizontalAlignment.Center,
                Padding             = UDim.new(0, 0),
            })

            -- ── SubTab object ────────────────────────────────────────────────────
            local ST = {
                _scroll  = subScroll,
                _list    = subItemList,
                _btn     = subBtn,
                _lbl     = subLbl,
                _ind     = subInd,
                _active  = false,
            }

            local function subActivate()
                -- deactivate previous
                if Tab._subActive then
                    local prev = Tab._subActive
                    prev._active        = false
                    prev._scroll.Visible = false
                    prev._ind.Visible   = false
                    tween(prev._lbl, { TextColor3 = C.TEXT_DIM, Font = Enum.Font.Gotham })
                    tween(prev._btn:FindFirstChildOfClass("Frame"), { BackgroundTransparency = 1 })
                end
                -- activate this
                Tab._subActive    = ST
                ST._active        = true
                subScroll.Visible = true
                subInd.Visible    = true
                tween(subLbl, { TextColor3 = C.WHITE, Font = Enum.Font.GothamBold })
                tween(subBtnBG, { BackgroundTransparency = 0.9 })
            end

            subBtnClick.MouseEnter:Connect(function()
                if not ST._active then
                    tween(subBtnBG, { BackgroundTransparency = 0.95 })
                    tween(subLbl, { TextColor3 = C.TEXT_SUB })
                end
            end)
            subBtnClick.MouseLeave:Connect(function()
                if not ST._active then
                    tween(subBtnBG, { BackgroundTransparency = 1 })
                    tween(subLbl, { TextColor3 = C.TEXT_DIM })
                end
            end)
            subBtnClick.MouseButton1Click:Connect(subActivate)

            -- auto-activate first subtab
            if not Tab._subActive then subActivate() end

            -- ── Delegate all component methods to this sub-tab ───────────────────
            local methods = {
                "AddToggle", "AddSlider", "AddButton", "AddDropdown",
                "AddInput",  "AddLabel",  "AddSection","AddColorPicker",
            }
            for _, m in ipairs(methods) do
                ST[m] = function(self, o2)
                    return Tab[m](Tab, o2, subItemList)
                end
            end

            return ST
        end

        return Tab
    end

    -- ═══════════════════════════════════════════════════════════════════════════
    -- Notification system
    -- ═══════════════════════════════════════════════════════════════════════════
    local typeStyles = {
        info    = { color = Color3.fromRGB(70, 140, 255),  icon = "ℹ" },
        success = { color = Color3.fromRGB(60, 210, 100),  icon = "✓" },
        warning = { color = Color3.fromRGB(255, 175, 40),  icon = "⚠" },
        error   = { color = Color3.fromRGB(255, 60, 60),   icon = "✕" },
    }

    function Win:Notify(o)
        o = o or {}
        local style = typeStyles[o.Type or "info"] or typeStyles.info
        local ac    = style.color
        local icn   = style.icon
        local dur   = o.Duration or 4

        local nf = new("Frame", {
            Parent               = notifHolder,
            BackgroundColor3     = Color3.fromRGB(18, 18, 24),
            BackgroundTransparency = 1,
            BorderSizePixel      = 0,
            Size                 = UDim2.new(1, 0, 0, 62),
            ZIndex               = 100,
            ClipsDescendants     = true,
        })
        corner(8, nf)
        stroke(C.BORDER, 1, nf)

        -- left accent stripe
        local nfStripe = new("Frame", {
            Parent           = nf,
            BackgroundColor3 = ac,
            BorderSizePixel  = 0,
            Position         = UDim2.new(0, 0, 0, 0),
            Size             = UDim2.new(0, 3, 1, 0),
            ZIndex           = 101,
        })
        corner(3, nfStripe)

        -- icon circle
        local iconCircle = new("Frame", {
            Parent           = nf,
            BackgroundColor3 = ac,
            BackgroundTransparency = 0.8,
            BorderSizePixel  = 0,
            Position         = UDim2.new(0, 14, 0.5, -12),
            Size             = UDim2.new(0, 24, 0, 24),
            ZIndex           = 101,
        })
        corner(100, iconCircle)
        stroke(ac, 1, iconCircle)
        new("TextLabel", {
            Parent               = iconCircle,
            BackgroundTransparency = 1,
            Size                 = UDim2.new(1, 0, 1, 0),
            Font                 = Enum.Font.GothamBold,
            Text                 = icn,
            TextColor3           = ac,
            TextSize             = 11,
            ZIndex               = 102,
        })

        -- title
        new("TextLabel", {
            Parent               = nf,
            BackgroundTransparency = 1,
            Position             = UDim2.new(0, 48, 0, 8),
            Size                 = UDim2.new(1, -58, 0, 20),
            Font                 = Enum.Font.GothamBold,
            Text                 = o.Title or "Notification",
            TextColor3           = C.TEXT,
            TextSize             = 11,
            TextXAlignment       = Enum.TextXAlignment.Left,
            ZIndex               = 101,
        })
        -- message
        new("TextLabel", {
            Parent               = nf,
            BackgroundTransparency = 1,
            Position             = UDim2.new(0, 48, 0, 28),
            Size                 = UDim2.new(1, -58, 0, 22),
            Font                 = Enum.Font.Gotham,
            Text                 = o.Message or "",
            TextColor3           = C.TEXT_SUB,
            TextSize             = 9,
            TextXAlignment       = Enum.TextXAlignment.Left,
            TextWrapped          = true,
            ZIndex               = 101,
        })
        -- progress bar bg
        local pgBG = new("Frame", {
            Parent           = nf,
            BackgroundColor3 = C.SLIDER_BG,
            BorderSizePixel  = 0,
            Position         = UDim2.new(0, 14, 1, -7),
            Size             = UDim2.new(1, -28, 0, 3),
            ZIndex           = 101,
        })
        corner(100, pgBG)
        local pgFill = new("Frame", {
            Parent           = pgBG,
            BackgroundColor3 = ac,
            BorderSizePixel  = 0,
            Size             = UDim2.new(1, 0, 1, 0),
            ZIndex           = 102,
        })
        corner(100, pgFill)

        -- animate in
        tween(nf, { BackgroundTransparency = 0 }, 0.22)
        -- progress drain
        tween(pgFill, { Size = UDim2.new(0, 0, 1, 0) }, dur, Enum.EasingStyle.Linear)
        -- animate out
        task.delay(dur, function()
            tween(nf, { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 0) }, 0.22)
            task.delay(0.24, function() nf:Destroy() end)
        end)
    end

    -- ── Destroy / Toggle helpers ─────────────────────────────────────────────────
    function Win:Destroy() sg:Destroy() end
    function Win:Toggle()
        win.Visible = not win.Visible
    end

    return Win
end

return Library

-- ══════════════════════════════════════════════
--  PUBLIC API
-- ══════════════════════════════════════════════
local function Add(sec, side, cfg)
    local list=(side=="right") and sec._right or sec._left
    list[#list+1]=cfg
    if sec._active then
        local ui    = sec._ui
        local panel = (side=="right") and ui.RightScroll or ui.LeftScroll
        ui:_Build(panel, cfg)
    end
    return cfg
end

function ShadowUI:Toggle(s,side,cfg)      cfg=cfg or{};cfg.type="toggle";   return Add(s,side,cfg) end
function ShadowUI:Slider(s,side,cfg)      cfg=cfg or{};cfg.type="slider";   return Add(s,side,cfg) end
function ShadowUI:Dropdown(s,side,cfg)    cfg=cfg or{};cfg.type="dropdown"; return Add(s,side,cfg) end
function ShadowUI:SectionHeader(s,side,cfg) cfg=cfg or{};cfg.type="header"; return Add(s,side,cfg) end
function ShadowUI:Label(s,side,cfg)       cfg=cfg or{};cfg.type="label";    return Add(s,side,cfg) end

function ShadowUI:BindToggleKey(key)
    UserInputService.InputBegan:Connect(function(i,gpe)
        if gpe then return end
        if i.KeyCode==key then
            self.ToggleBtn.MouseButton1Click:Fire()
        end
    end)
end

function ShadowUI:Destroy() self.Gui:Destroy() end

-- ══════════════════════════════════════════════
return ShadowUI

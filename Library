local DB = {}

local Players          = game:GetService("Players")
local UIS              = game:GetService("UserInputService")
local TS               = game:GetService("TweenService")
local LP               = Players.LocalPlayer
local Mouse            = LP:GetMouse()

local C = {
    BG       = Color3.fromRGB(18, 18, 18),
    BGDark   = Color3.fromRGB(13, 13, 13),
    BGItem   = Color3.fromRGB(24, 24, 24),
    Accent   = Color3.fromRGB(255, 60, 120),
    AccentD  = Color3.fromRGB(190, 30, 80),
    AccentL  = Color3.fromRGB(255, 120, 165),
    Text     = Color3.fromRGB(215, 215, 215),
    TextSub  = Color3.fromRGB(110, 110, 110),
    TextDim  = Color3.fromRGB(55, 55, 55),
    TextAcc  = Color3.fromRGB(255, 100, 148),
    Border   = Color3.fromRGB(38, 38, 38),
    Sep      = Color3.fromRGB(26, 26, 26),
    Fb       = Enum.Font.GothamMedium,
    Fbold    = Enum.Font.GothamBold,
    Fsemi    = Enum.Font.GothamSemibold,
    Fmono    = Enum.Font.Code,
}

local function tw(o,p,t) TS:Create(o,TweenInfo.new(t or 0.15,Enum.EasingStyle.Quart),p):Play() end

local function ins(cls,props)
    local o=Instance.new(cls)
    for k,v in pairs(props) do if k~="Parent" then o[k]=v end end
    if props.Parent then o.Parent=props.Parent end
    return o
end

local function corner(p,r)
    local c=Instance.new("UICorner"); c.CornerRadius=r or UDim.new(0,6); c.Parent=p; return c
end

local function stroke(p,col,th)
    local s=Instance.new("UIStroke")
    s.Color=col or C.Border; s.Thickness=th or 1
    s.ApplyStrokeMode=Enum.ApplyStrokeMode.Border
    s.Parent=p; return s
end

local function pad(p,t,r,b,l)
    local u=Instance.new("UIPadding")
    u.PaddingTop=UDim.new(0,t or 0); u.PaddingRight=UDim.new(0,r or 0)
    u.PaddingBottom=UDim.new(0,b or 0); u.PaddingLeft=UDim.new(0,l or 0)
    u.Parent=p
end

local function vlist(p,sp)
    local l=Instance.new("UIListLayout")
    l.FillDirection=Enum.FillDirection.Vertical
    l.HorizontalAlignment=Enum.HorizontalAlignment.Left
    l.SortOrder=Enum.SortOrder.LayoutOrder
    l.Padding=UDim.new(0,sp or 0)
    l.Parent=p; return l
end

local function hlist(p,sp)
    local l=Instance.new("UIListLayout")
    l.FillDirection=Enum.FillDirection.Horizontal
    l.VerticalAlignment=Enum.VerticalAlignment.Center
    l.SortOrder=Enum.SortOrder.LayoutOrder
    l.Padding=UDim.new(0,sp or 0)
    l.Parent=p; return l
end

local function sep(p)
    ins("Frame",{Size=UDim2.new(1,0,0,1),BackgroundColor3=C.Sep,BorderSizePixel=0,Parent=p})
end

local function drag(frame,handle)
    local down,ds,dp=false
    handle.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then down=true;ds=i.Position;dp=frame.Position end
    end)
    handle.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then down=false end
    end)
    UIS.InputChanged:Connect(function(i)
        if down and i.UserInputType==Enum.UserInputType.MouseMovement then
            local d=i.Position-ds
            frame.Position=UDim2.new(dp.X.Scale,dp.X.Offset+d.X,dp.Y.Scale,dp.Y.Offset+d.Y)
        end
    end)
end

-- row with separator
local function makeRow(parent,h)
    local r=ins("Frame",{Size=UDim2.new(1,0,0,h or 40),BackgroundTransparency=1,Parent=parent})
    sep(r)
    return r
end

-- ── TOGGLE
local function Toggle(parent,name,opts)
    opts=opts or {}
    local val=opts.Default==true
    local cb=opts.Callback or function()end
    local desc=opts.Description
    local row=makeRow(parent,desc and 50 or 40)

    ins("TextLabel",{Size=UDim2.new(1,-56,0,16),Position=UDim2.new(0,0,0,desc and 8 or 12),
        BackgroundTransparency=1,Text=name,TextColor3=C.Text,Font=C.Fsemi,TextSize=13,
        TextXAlignment=Enum.TextXAlignment.Left,Parent=row})
    if desc then
        ins("TextLabel",{Size=UDim2.new(1,-56,0,13),Position=UDim2.new(0,0,0,27),
            BackgroundTransparency=1,Text=desc,TextColor3=C.TextDim,Font=C.Fb,TextSize=11,
            TextXAlignment=Enum.TextXAlignment.Left,Parent=row})
    end

    local track=ins("Frame",{Size=UDim2.new(0,40,0,20),Position=UDim2.new(1,-40,0.5,-10),
        BackgroundColor3=val and C.Accent or Color3.fromRGB(42,42,42),BorderSizePixel=0,Parent=row})
    corner(track,UDim.new(0,10))

    local knob=ins("Frame",{Size=UDim2.new(0,14,0,14),
        Position=val and UDim2.new(0,22,0.5,-7) or UDim2.new(0,4,0.5,-7),
        BackgroundColor3=Color3.fromRGB(255,255,255),BorderSizePixel=0,Parent=track})
    corner(knob,UDim.new(1,0))

    local function set(v,silent)
        val=v
        tw(track,{BackgroundColor3=v and C.Accent or Color3.fromRGB(42,42,42)})
        tw(knob,{Position=v and UDim2.new(0,22,0.5,-7) or UDim2.new(0,4,0.5,-7)})
        if not silent then cb(v) end
    end

    local btn=ins("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=2,Parent=row})
    btn.MouseButton1Click:Connect(function() set(not val) end)
    return {Set=set,Get=function()return val end}
end

-- ── SLIDER
local function Slider(parent,name,opts)
    opts=opts or {}
    local mn=opts.Min or 0; local mx=opts.Max or 100
    local val=math.clamp(opts.Default or mn,mn,mx)
    local suf=opts.Suffix or ""; local dec=opts.Decimals or 0
    local cb=opts.Callback or function()end
    local function rnd(n) local m=10^dec; return math.floor(n*m+0.5)/m end

    local row=makeRow(parent,54)

    ins("TextLabel",{Size=UDim2.new(1,-70,0,16),Position=UDim2.new(0,0,0,6),
        BackgroundTransparency=1,Text=name,TextColor3=C.Text,Font=C.Fsemi,TextSize=13,
        TextXAlignment=Enum.TextXAlignment.Left,Parent=row})

    local vlbl=ins("TextLabel",{Size=UDim2.new(0,65,0,16),Position=UDim2.new(1,-65,0,6),
        BackgroundTransparency=1,Text=tostring(rnd(val))..suf,
        TextColor3=C.TextAcc,Font=C.Fsemi,TextSize=12,
        TextXAlignment=Enum.TextXAlignment.Right,Parent=row})

    local bg=ins("Frame",{Size=UDim2.new(1,0,0,4),Position=UDim2.new(0,0,0,34),
        BackgroundColor3=Color3.fromRGB(36,36,36),BorderSizePixel=0,Parent=row})
    corner(bg,UDim.new(0,2))

    local fill=ins("Frame",{Size=UDim2.new((val-mn)/(mx-mn),0,1,0),
        BackgroundColor3=C.Accent,BorderSizePixel=0,Parent=bg})
    corner(fill,UDim.new(0,2))

    local kn=ins("Frame",{Size=UDim2.new(0,12,0,12),
        Position=UDim2.new((val-mn)/(mx-mn),-6,0.5,-6),
        BackgroundColor3=C.Accent,BorderSizePixel=0,ZIndex=2,Parent=bg})
    corner(kn,UDim.new(1,0))

    local function set(v,silent)
        v=rnd(math.clamp(v,mn,mx)); val=v
        local p=(v-mn)/(mx-mn)
        fill.Size=UDim2.new(p,0,1,0)
        kn.Position=UDim2.new(p,-6,0.5,-6)
        vlbl.Text=tostring(v)..suf
        if not silent then cb(v) end
    end

    local holding=false
    local function fromMouse()
        local abs=bg.AbsolutePosition; local sz=bg.AbsoluteSize
        set(mn+(mx-mn)*math.clamp((Mouse.X-abs.X)/sz.X,0,1))
    end
    bg.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then holding=true; fromMouse() end
    end)
    UIS.InputChanged:Connect(function(i)
        if holding and i.UserInputType==Enum.UserInputType.MouseMovement then fromMouse() end
    end)
    UIS.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then holding=false end
    end)
    return {Set=set,Get=function()return val end}
end

-- ── DROPDOWN
local function Dropdown(parent,name,opts)
    opts=opts or {}
    local options=opts.Options or {}
    local val=opts.Default or options[1] or "None"
    local cb=opts.Callback or function()end
    local open=false
    local row=makeRow(parent,40)

    ins("TextLabel",{Size=UDim2.new(1,-155,1,0),BackgroundTransparency=1,Text=name,
        TextColor3=C.Text,Font=C.Fsemi,TextSize=13,
        TextXAlignment=Enum.TextXAlignment.Left,Parent=row})

    local dbtn=ins("TextButton",{Size=UDim2.new(0,145,0,26),Position=UDim2.new(1,-145,0.5,-13),
        BackgroundColor3=C.BGDark,Text="",AutoButtonColor=false,Parent=row})
    corner(dbtn); stroke(dbtn,C.Border)

    local dlbl=ins("TextLabel",{Size=UDim2.new(1,-22,1,0),Position=UDim2.new(0,8,0,0),
        BackgroundTransparency=1,Text=val,TextColor3=C.TextSub,Font=C.Fb,TextSize=12,
        TextXAlignment=Enum.TextXAlignment.Left,Parent=dbtn})

    local arr=ins("TextLabel",{Size=UDim2.new(0,18,1,0),Position=UDim2.new(1,-20,0,0),
        BackgroundTransparency=1,Text="v",TextColor3=C.Accent,Font=C.Fbold,TextSize=10,Parent=dbtn})

    local list=ins("Frame",{Size=UDim2.new(0,145,0,0),Position=UDim2.new(1,-145,0,42),
        BackgroundColor3=Color3.fromRGB(20,20,20),ClipsDescendants=true,ZIndex=60,Visible=false,Parent=row})
    corner(list); stroke(list,C.Border)
    vlist(list,0)

    local function populate()
        for _,c in ipairs(list:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
        for _,opt in ipairs(options) do
            local it=ins("TextButton",{Size=UDim2.new(1,0,0,28),BackgroundTransparency=1,
                Text="  "..opt,TextColor3=opt==val and C.TextAcc or C.TextSub,
                Font=C.Fb,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=61,Parent=list})
            it.MouseEnter:Connect(function() it.BackgroundColor3=C.Accent; it.BackgroundTransparency=0.88 end)
            it.MouseLeave:Connect(function() it.BackgroundTransparency=1 end)
            it.MouseButton1Click:Connect(function()
                val=opt; dlbl.Text=opt; cb(opt)
                open=false
                tw(list,{Size=UDim2.new(0,145,0,0)},0.12)
                task.delay(0.13,function() list.Visible=false end)
                for _,c2 in ipairs(list:GetChildren()) do
                    if c2:IsA("TextButton") then
                        c2.TextColor3=(c2.Text:gsub("^%s+",""))==opt and C.TextAcc or C.TextSub
                    end
                end
            end)
        end
    end
    populate()

    dbtn.MouseButton1Click:Connect(function()
        open=not open
        if open then
            list.Visible=true
            tw(list,{Size=UDim2.new(0,145,0,math.min(#options*28,168))},0.15)
        else
            tw(list,{Size=UDim2.new(0,145,0,0)},0.12)
            task.delay(0.13,function() list.Visible=false end)
        end
    end)

    return {
        Set=function(v,s) val=v; dlbl.Text=v; if not s then cb(v) end end,
        Get=function()return val end,
        Refresh=function(o) options=o; populate() end,
    }
end

-- ── TEXTBOX
local function TextBox(parent,name,opts)
    opts=opts or {}
    local cb=opts.Callback or function()end
    local ph=opts.Placeholder or "Type here..."
    local row=makeRow(parent,56)

    ins("TextLabel",{Size=UDim2.new(1,0,0,16),Position=UDim2.new(0,0,0,4),
        BackgroundTransparency=1,Text=name,TextColor3=C.Text,Font=C.Fsemi,TextSize=13,
        TextXAlignment=Enum.TextXAlignment.Left,Parent=row})

    local box=ins("TextBox",{Size=UDim2.new(1,0,0,26),Position=UDim2.new(0,0,0,24),
        BackgroundColor3=C.BGDark,Text="",PlaceholderText=ph,PlaceholderColor3=C.TextDim,
        TextColor3=C.Text,Font=C.Fb,TextSize=12,ClearTextOnFocus=false,
        TextXAlignment=Enum.TextXAlignment.Left,Parent=row})
    corner(box); pad(box,0,0,0,8)
    local sk=stroke(box,C.Border)

    box.Focused:Connect(function() tw(sk,{Color=C.Accent}) end)
    box.FocusLost:Connect(function(enter)
        tw(sk,{Color=C.Border})
        if enter then cb(box.Text) end
    end)
    return {Set=function(v)box.Text=v end,Get=function()return box.Text end}
end

-- ── BUTTON
local function Button(parent,name,opts)
    opts=opts or {}
    local cb=opts.Callback or function()end
    local desc=opts.Description
    local row=makeRow(parent,desc and 52 or 46)

    if desc then
        ins("TextLabel",{Size=UDim2.new(1,-120,0,15),Position=UDim2.new(0,0,0,7),
            BackgroundTransparency=1,Text=name,TextColor3=C.Text,Font=C.Fsemi,TextSize=13,
            TextXAlignment=Enum.TextXAlignment.Left,Parent=row})
        ins("TextLabel",{Size=UDim2.new(1,-120,0,13),Position=UDim2.new(0,0,0,24),
            BackgroundTransparency=1,Text=desc,TextColor3=C.TextDim,Font=C.Fb,TextSize=11,
            TextXAlignment=Enum.TextXAlignment.Left,Parent=row})
    end

    local b=ins("TextButton",{
        Size=desc and UDim2.new(0,108,0,28) or UDim2.new(1,0,0,30),
        Position=desc and UDim2.new(1,-108,0.5,-14) or UDim2.new(0,0,0,8),
        BackgroundColor3=C.BGItem,Text=desc and "Execute" or name,
        TextColor3=C.Text,Font=C.Fsemi,TextSize=12,AutoButtonColor=false,Parent=row})
    corner(b); local bsk=stroke(b,C.Border)

    b.MouseEnter:Connect(function() tw(b,{BackgroundColor3=C.Accent}); tw(bsk,{Color=C.AccentL}); tw(b,{TextColor3=Color3.new(1,1,1)}) end)
    b.MouseLeave:Connect(function() tw(b,{BackgroundColor3=C.BGItem}); tw(bsk,{Color=C.Border}); tw(b,{TextColor3=C.Text}) end)
    b.MouseButton1Click:Connect(function()
        tw(b,{BackgroundColor3=C.AccentD},0.07)
        task.delay(0.1,function() tw(b,{BackgroundColor3=C.Accent}) end)
        cb()
    end)
    return {Fire=cb}
end

-- ── KEYBIND
local function Keybind(parent,name,opts)
    opts=opts or {}
    local key=opts.Default or Enum.KeyCode.Unknown
    local cb=opts.Callback or function()end
    local listening=false
    local row=makeRow(parent,40)

    ins("TextLabel",{Size=UDim2.new(1,-125,1,0),BackgroundTransparency=1,Text=name,
        TextColor3=C.Text,Font=C.Fsemi,TextSize=13,TextXAlignment=Enum.TextXAlignment.Left,Parent=row})

    local kb=ins("TextButton",{Size=UDim2.new(0,115,0,26),Position=UDim2.new(1,-115,0.5,-13),
        BackgroundColor3=C.BGDark,Text=key and key.Name or "None",
        TextColor3=C.TextAcc,Font=C.Fmono,TextSize=11,AutoButtonColor=false,Parent=row})
    corner(kb); stroke(kb,C.Border)

    local function setKey(k,silent)
        key=k; kb.Text=k and k.Name or "None"; kb.TextColor3=C.TextAcc
        if not silent then cb(k) end
    end

    kb.MouseButton1Click:Connect(function() listening=true; kb.Text="..."; kb.TextColor3=C.AccentL end)
    UIS.InputBegan:Connect(function(i,gp)
        if listening and not gp and i.UserInputType==Enum.UserInputType.Keyboard then
            listening=false; setKey(i.KeyCode)
        elseif not listening and key~=Enum.KeyCode.Unknown and i.KeyCode==key then
            cb(key)
        end
    end)
    return {Set=setKey,Get=function()return key end}
end

-- ── COLOR PICKER
local function ColorPicker(parent,name,opts)
    opts=opts or {}
    local color=opts.Default or Color3.fromRGB(255,60,120)
    local cb=opts.Callback or function()end
    local open=false
    local row=makeRow(parent,40)

    ins("TextLabel",{Size=UDim2.new(1,-52,1,0),BackgroundTransparency=1,Text=name,
        TextColor3=C.Text,Font=C.Fsemi,TextSize=13,TextXAlignment=Enum.TextXAlignment.Left,Parent=row})

    local pv=ins("TextButton",{Size=UDim2.new(0,42,0,22),Position=UDim2.new(1,-42,0.5,-11),
        BackgroundColor3=color,Text="",AutoButtonColor=false,Parent=row})
    corner(pv); stroke(pv,C.Border)

    local panel=ins("Frame",{Size=UDim2.new(0,190,0,108),Position=UDim2.new(1,-190,0,42),
        BackgroundColor3=Color3.fromRGB(20,20,20),Visible=false,ZIndex=50,Parent=row})
    corner(panel); stroke(panel,C.Border); pad(panel,8,8,8,8)

    local rv=math.floor(color.R*255)
    local gv=math.floor(color.G*255)
    local bv=math.floor(color.B*255)
    local chanC={Color3.fromRGB(255,80,80),Color3.fromRGB(80,210,80),Color3.fromRGB(80,130,255)}
    local chanN={"R","G","B"}
    local fills={}

    local function upd() color=Color3.fromRGB(rv,gv,bv); pv.BackgroundColor3=color; cb(color) end

    for i=1,3 do
        ins("TextLabel",{Size=UDim2.new(0,12,0,12),Position=UDim2.new(0,0,0,(i-1)*28+4),
            BackgroundTransparency=1,Text=chanN[i],TextColor3=chanC[i],
            Font=C.Fbold,TextSize=10,ZIndex=51,Parent=panel})
        local tr=ins("Frame",{Size=UDim2.new(1,-16,0,4),Position=UDim2.new(0,16,0,(i-1)*28+4),
            BackgroundColor3=Color3.fromRGB(36,36,36),BorderSizePixel=0,ZIndex=51,Parent=panel})
        corner(tr,UDim.new(0,2))
        local ini={rv,gv,bv}
        local fl=ins("Frame",{Size=UDim2.new(ini[i]/255,0,1,0),
            BackgroundColor3=chanC[i],BorderSizePixel=0,ZIndex=52,Parent=tr})
        corner(fl,UDim.new(0,2)); fills[i]=fl
        local dg=false
        tr.InputBegan:Connect(function(inp) if inp.UserInputType==Enum.UserInputType.MouseButton1 then dg=true end end)
        UIS.InputEnded:Connect(function(inp) if inp.UserInputType==Enum.UserInputType.MouseButton1 then dg=false end end)
        UIS.InputChanged:Connect(function(inp)
            if dg and inp.UserInputType==Enum.UserInputType.MouseMovement then
                local p=math.clamp((Mouse.X-tr.AbsolutePosition.X)/tr.AbsoluteSize.X,0,1)
                fl.Size=UDim2.new(p,0,1,0)
                local nv=math.floor(p*255)
                if i==1 then rv=nv elseif i==2 then gv=nv else bv=nv end
                upd()
            end
        end)
    end

    pv.MouseButton1Click:Connect(function() open=not open; panel.Visible=open end)
    return {
        Set=function(c)
            color=c; rv=math.floor(c.R*255); gv=math.floor(c.G*255); bv=math.floor(c.B*255)
            pv.BackgroundColor3=c
            for i,fl in ipairs(fills) do fl.Size=UDim2.new((i==1 and rv or i==2 and gv or bv)/255,0,1,0) end
        end,
        Get=function()return color end,
    }
end

-- ── LABEL
local function Label(parent,text,opts)

--- Creates a Roblox instance with properties applied cleanly.
--- Parent is set last to avoid layout flicker.
local function New(cls, props)
    local o = Instance.new(cls)
    for k, v in pairs(props) do
        if k ~= "Parent" then
            o[k] = v
        end
    end
    if props.Parent then o.Parent = props.Parent end
    return o
end

--- Plays a TweenService tween on `obj` toward `goals`.
--- Defaults: 0.14s, Quint, Out.
local function Tw(obj, goals, t, style, dir)
    TS:Create(obj,
        TweenInfo.new(
            t     or 0.14,
            style or Enum.EasingStyle.Quint,
            dir   or Enum.EasingDirection.Out
        ),
        goals):Play()
end

--- Adds a UICorner with `r` pixels radius to `p`.
local function Corner(r, p)
    New("UICorner", { CornerRadius = UDim.new(0, r), Parent = p })
end

--- Adds a UIStroke border to `p`. Returns the stroke instance.
local function Stroke(c, th, p)
    return New("UIStroke", {
        Color            = c,
        Thickness        = th or 1,
        ApplyStrokeMode  = Enum.ApplyStrokeMode.Border,
        Parent           = p,
    })
end

--- Applies UIPadding to `p` with individual side values (pixels).
local function Pad(l, r, t, b, p)
    New("UIPadding", {
        PaddingLeft   = UDim.new(0, l),
        PaddingRight  = UDim.new(0, r),
        PaddingTop    = UDim.new(0, t),
        PaddingBottom = UDim.new(0, b),
        Parent        = p,
    })
end

--- Creates a UIListLayout in `p`.
local function ListL(p, dir, gap)
    return New("UIListLayout", {
        Parent        = p,
        FillDirection = dir or Enum.FillDirection.Vertical,
        SortOrder     = Enum.SortOrder.LayoutOrder,
        Padding       = UDim.new(0, gap or 0),
    })
end

--- Keeps a ScrollingFrame canvas size in sync with its UIListLayout.
local function AutoCanvas(sf, ll, extra)
    local function upd()
        sf.CanvasSize = UDim2.new(0, 0, 0, ll.AbsoluteContentSize.Y + (extra or 8))
    end
    ll:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(upd)
    task.defer(upd)
end

--- Creates a styled TextLabel. All params optional.
local function Lbl(p, txt, sz, col, fnt, ax, pos, size, z, wrap)
    return New("TextLabel", {
        Parent              = p,
        BackgroundTransparency = 1,
        Text                = txt  or "",
        TextSize            = sz   or 12,
        TextColor3          = col  or T.TxtPri,
        Font                = fnt  or Enum.Font.Gotham,
        TextXAlignment      = ax   or Enum.TextXAlignment.Left,
        TextYAlignment      = Enum.TextYAlignment.Center,
        Position            = pos  or UDim2.new(0, 0, 0, 0),
        Size                = size or UDim2.new(1, 0, 1, 0),
        ZIndex              = z    or 2,
        TextTruncate        = wrap and Enum.TextTruncate.None or Enum.TextTruncate.AtEnd,
        TextWrapped         = wrap or false,
    })
end

--- Creates a transparent row frame inside a panel.
local function Row(p, h)
    return New("Frame", {
        Parent                = p,
        BackgroundTransparency = 1,
        Size                  = UDim2.new(1, 0, 0, h or 36),
        ZIndex                = 2,
    })
end

--- Makes a frame draggable by a handle (supports Mouse + Touch).
--- Dragging moves `target` (the clip/container), not the window itself.
local function MakeDraggable(target, handle)
    local dragging = false
    local startMouse, startPos

    handle.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1
        or i.UserInputType == Enum.UserInputType.Touch then
            dragging   = true
            startMouse = i.Position
            startPos   = target.Position
            i.Changed:Connect(function()
                if i.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    UIS.InputChanged:Connect(function(i)
        if not dragging then return end
        if i.UserInputType == Enum.UserInputType.MouseMovement
        or i.UserInputType == Enum.UserInputType.Touch then
            local d = i.Position - startMouse
            target.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + d.X,
                startPos.Y.Scale, startPos.Y.Offset + d.Y
            )
        end
    end)
end

-- Only one dropdown open at a time
local _closeDrop = nil
local function CloseAnyDrop()
    if _closeDrop then pcall(_closeDrop) end
    _closeDrop = nil
end

-- ── Config file helpers ──────────────────────────────────────────
local function SafeWrite(path, data)
    pcall(function()
        if not isfolder(CFG_DIR) then makefolder(CFG_DIR) end
        writefile(path, data)
    end)
end

local function SafeRead(path)
    local ok, d = pcall(readfile, path)
    return ok and d or nil
end

local function ListCfgs()
    local out = {"default"}
    pcall(function()
        if not isfolder(CFG_DIR) then return end
        for _, f in ipairs(listfiles(CFG_DIR)) do
            local n = (f:match("[^/\\]+$") or f):gsub(CFG_EXT .. "$", "")
            if n ~= "default" and n ~= "__auto" then
                table.insert(out, n)
            end
        end
    end)
    return out
end


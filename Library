    ob.MouseLeave:Connect(function() if not isOpen then TW(box,{BackgroundColor3=T.DBG}) end end)

    ob.MouseButton1Click:Connect(function()
        CloseDD()
        if isOpen then return end
        isOpen=true; _ddClose=Close; Sk(T.ACC,1,box)

        local IH = 24
        local pH = #opts*IH+8

        -- Overlay fecha ao clicar fora (ZIndex 58)
        ov = N("TextButton",{Parent=self.Gui,BackgroundTransparency=1,
            Size=UDim2.new(1,0,1,0),Text="",ZIndex=58})
        ov.MouseButton1Click:Connect(Close)

        -- Frame do dropdown no ScreenGui (ZIndex 60, nunca clipado)
        local ap = box.AbsolutePosition
        local as = box.AbsoluteSize
        df = N("Frame",{Parent=self.Gui,BackgroundColor3=T.DBG,
            Position=UDim2.new(0,ap.X,0,ap.Y+as.Y+4),
            Size=UDim2.new(0,as.X,0,pH),ZIndex=60,ClipsDescendants=true})
        Cr(6,df); Sk(T.ACC,1,df)
        -- Sombra
        N("ImageLabel",{Parent=df,BackgroundTransparency=1,ZIndex=59,
            Position=UDim2.new(0,-8,0,-8),Size=UDim2.new(1,16,1,16),
            Image="rbxassetid://6014261993",ImageColor3=Color3.new(0,0,0),
            ImageTransparency=0.52,ScaleType=Enum.ScaleType.Slice,
            SliceCenter=Rect.new(49,49,450,450)})
        Ly(df,nil,0); Pd(4,4,4,4,df)

        for _,opt in ipairs(opts) do
            local sel = (opt==val)
            local it = N("TextButton",{Parent=df,
                BackgroundColor3=sel and T.EHOV or T.DBG,
                BackgroundTransparency=sel and 0 or 1,
                Size=UDim2.new(1,0,0,IH),
                Font=sel and Enum.Font.GothamBold or Enum.Font.Gotham,
                Text=tostring(opt),
                TextColor3=sel and T.TACC or T.TSEC,
                TextSize=11,TextXAlignment=Enum.TextXAlignment.Left,
                AutoButtonColor=false,ZIndex=61})
            Pd(8,0,0,0,it); Cr(4,it)
            it.MouseEnter:Connect(function()
                it.BackgroundTransparency=0; TW(it,{BackgroundColor3=T.DHV,TextColor3=T.TPRI})
            end)
            it.MouseLeave:Connect(function()
                if sel then it.BackgroundColor3=T.EHOV; it.BackgroundTransparency=0
                else it.BackgroundTransparency=1; it.TextColor3=T.TSEC end
            end)
            it.MouseButton1Click:Connect(function() task.defer(function() Pick(opt) end) end)
        end
    end)

    ctrl._setValue=Pick; ctrl._getValue=function() return val end
    return wrap
end


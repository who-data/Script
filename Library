function Library:AddSection(cat, name)
    local sec={Name=name,_cat=cat,_active=false,_left={},_right={},_ui=self}

    local btn=New("TextButton",{Parent=cat._sf,BackgroundTransparency=1,
        Size=UDim2.new(1,0,0,26),Text="",AutoButtonColor=false,ZIndex=8})
    Corner(4,btn)

    local bar=New("Frame",{Parent=btn,BackgroundColor3=C.ACC,
        Position=UDim2.new(0,2,0.2,0),Size=UDim2.new(0,2,0.6,0),
        ZIndex=10,Visible=false})
    Corner(1,bar)

    local dia=New("Frame",{Parent=btn,BackgroundColor3=C.ACCDIM,
        Position=UDim2.new(0,16,0.5,-4),Size=UDim2.new(0,8,0,8),
        Rotation=45,ZIndex=9})

    local lbl=Label(btn,name,11,C.TSEC,Enum.Font.Gotham,
        Enum.TextXAlignment.Left,UDim2.new(0,30,0,0),UDim2.new(1,-34,1,0),9)

    sec._btn=btn; sec._dia=dia; sec._lbl=lbl; sec._bar=bar

    btn.MouseEnter:Connect(function()
        if not sec._active then TW(btn,{BackgroundColor3=C.HOVER},.08); btn.BackgroundTransparency=0 end
    end)
    btn.MouseLeave:Connect(function()
        if not sec._active then btn.BackgroundTransparency=1 end
    end)

    btn.MouseButton1Click:Connect(function()
        if self._active then
            local p=self._active
            p._active=false; p._lbl.TextColor3=C.TSEC
            p._dia.BackgroundColor3=C.ACCDIM; p._bar.Visible=false
            p._btn.BackgroundTransparency=1
        end
        sec._active=true; lbl.TextColor3=C.TACC
        dia.BackgroundColor3=C.ACC; bar.Visible=true
        TW(btn,{BackgroundColor3=C.HOVER},.08); btn.BackgroundTransparency=0
        self._active=sec
        self:_Bread(cat.Name,name)
        self:_Render(sec)
    end)

    cat._secs[#cat._secs+1]=sec
    cat._sf.Size=UDim2.new(1,0,0,cat._sl.AbsoluteContentSize.Y+26)
    return sec
end

-- =========================================================
--  RENDER
-- =========================================================
function Library:_Render(sec)
    CloseDropdown()
    for _,p in ipairs({self.LP,self.RP}) do
        for _,c in ipairs(p:GetChildren()) do
            if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then c:Destroy() end
        end
    end
    for _,c in ipairs(self.TabList:GetChildren()) do
        if not c:IsA("UIListLayout") then c:Destroy() end
    end

    for _,s in ipairs(sec._cat._secs) do
        local act=(s==sec)
        local t=New("Frame",{Parent=self.TabList,BackgroundTransparency=1,
            Size=UDim2.new(0,84,1,0),ZIndex=3})
        if act then
            New("Frame",{Parent=t,BackgroundColor3=C.ACC,
                Position=UDim2.new(0,0,1,-2),Size=UDim2.new(1,0,0,2),ZIndex=5})
        end
        New("Frame",{Parent=t,BackgroundColor3=act and C.ACC or C.ACCDIM,
            Position=UDim2.new(0,5,0.5,-3),Size=UDim2.new(0,7,0,7),
            Rotation=45,ZIndex=4})
        Label(t,s.Name,11,act and C.TACC or C.TSEC,
            act and Enum.Font.GothamBold or Enum.Font.Gotham,
            Enum.TextXAlignment.Left,UDim2.new(0,17,0,0),UDim2.new(1,-17,1,0),4)
    end

    for _,ctrl in ipairs(sec._left)  do self:_Build(self.LP,ctrl)  end
    for _,ctrl in ipairs(sec._right) do self:_Build(self.RP,ctrl) end
end

-- =========================================================
--  BUILD
-- =========================================================
function Library:_Build(p, ctrl)
    if ctrl.type=="toggle"   then return self:_BToggle(p,ctrl)   end
    if ctrl.type=="slider"   then return self:_BSlider(p,ctrl)   end
    if ctrl.type=="dropdown" then return self:_BDropdown(p,ctrl) end
    if ctrl.type=="header"   then return self:_BHeader(p,ctrl)   end
    if ctrl.type=="label"    then return self:_BLabel(p,ctrl)    end
    if ctrl.type=="raw"      then return ctrl.fn(p)              end
end

-- =========================================================
--  TOGGLE
-- =========================================================
function Library:_BToggle(parent, ctrl)
    local val = ctrl._val~=nil and ctrl._val or (ctrl.default or false)
    local r = Row(parent,30)
    Corner(4,r)

    local hit=New("TextButton",{Parent=r,BackgroundTransparency=1,
        Size=UDim2.new(1,0,1,0),Text="",ZIndex=6})
    hit.MouseEnter:Connect(function() TW(r,{BackgroundColor3=C.HOVER},.08); r.BackgroundTransparency=0 end)
    hit.MouseLeave:Connect(function() r.BackgroundTransparency=1 end)

    local off=-36
    if ctrl.gear then
        local g=New("TextButton",{Parent=r,BackgroundTransparency=1,
            Position=UDim2.new(1,-52,0.5,-8),Size=UDim2.new(0,16,0,16),
            Font=Enum.Font.Gotham,Text="⚙",TextColor3=C.TDIM,TextSize=13,ZIndex=7})
        g.MouseEnter:Connect(function() TW(g,{TextColor3=C.TACC},.08) end)
        g.MouseLeave:Connect(function() TW(g,{TextColor3=C.TDIM},.08) end)
        off=-56
    end

    local lbl=Label(r,ctrl.text or "Toggle",12,val and C.TPRI or C.TDIM,
        Enum.Font.Gotham,Enum.TextXAlignment.Left,
        UDim2.new(0,0,0,0),UDim2.new(1,off,1,0),4)

    local tr=New("Frame",{Parent=r,BackgroundColor3=val and C.TOGON or C.TOGOFF,
        Position=UDim2.new(1,-30,0.5,-7),Size=UDim2.new(0,26,0,14),ZIndex=4})
    Corner(7,tr)
    local th=New("Frame",{Parent=tr,BackgroundColor3=C.WHITE,
        Position=val and UDim2.new(1,-13,0.5,-5) or UDim2.new(0,2,0.5,-5),
        Size=UDim2.new(0,10,0,10),ZIndex=5})
    Corner(5,th)

    local function Set(v)
        val=v; ctrl._val=v
        TW(tr,{BackgroundColor3=v and C.TOGON or C.TOGOFF},.12)
        TW(th,{Position=v and UDim2.new(1,-13,0.5,-5) or UDim2.new(0,2,0.5,-5)},.12)
        lbl.TextColor3=v and C.TPRI or C.TDIM
        if ctrl.callback then ctrl.callback(v) end
    end
    hit.MouseButton1Click:Connect(function() Set(not val) end)
    ctrl._setValue=Set; ctrl._getValue=function() return val end
    return r
end

-- =========================================================
--  SLIDER  — padrão Rayfield (Location/clamp)
--  Slider.Main = frame do track
--  Usa UIS.InputChanged com Location e UIS.InputEnded
-- =========================================================
function Library:_BSlider(parent, ctrl)
    local mn  = ctrl.min    or 0
    local mx  = ctrl.max    or 100
    local inc = ctrl.step   or 1
    local fmt = ctrl.format or "%.2f"
    local val = ctrl._val~=nil and ctrl._val or (ctrl.default or mn)

    local function Snap(v)
        if inc>0 then v=math.round((v-mn)/inc)*inc+mn end
        return math.clamp(v,mn,mx)
    end

    -- Container
    local wrap = Row(parent,44)
    Corner(4,wrap)

    -- Nome + valor
    local top=New("Frame",{Parent=wrap,BackgroundTransparency=1,
        Position=UDim2.new(0,0,0,4),Size=UDim2.new(1,0,0,14),ZIndex=3})
    Label(top,ctrl.text or "Slider",11,C.TSEC,Enum.Font.Gotham,
        Enum.TextXAlignment.Left,nil,UDim2.new(0.65,0,1,0),3)
    local valLbl=Label(top,string.format(fmt,val),11,C.TACC,Enum.Font.GothamBold,
        Enum.TextXAlignment.Right,UDim2.new(0.65,0,0,0),UDim2.new(0.35,0,1,0),3)

    -- Track (Main no padrão Rayfield)
    local Main=New("Frame",{Parent=wrap,BackgroundColor3=C.SLTRK,
        Position=UDim2.new(0,0,0,26),Size=UDim2.new(1,0,0,4),ZIndex=3})
    Corner(2,Main)

    -- Fill
    local pct=(val-mn)/(mx-mn)
    local fill=New("Frame",{Parent=Main,BackgroundColor3=C.SLFILL,
        Size=UDim2.new(pct,0,1,0),ZIndex=4})
    Corner(2,fill)

    -- Thumb
    local thumb=New("Frame",{Parent=Main,BackgroundColor3=C.SLTHUMB,
        Position=UDim2.new(pct,-6,0.5,-6),Size=UDim2.new(0,12,0,12),ZIndex=5})
    Corner(6,thumb); Stroke(C.ACC,1.5,thumb)

    -- Função de atualização — baseada em Rayfield:
    -- Current = mouse X, clampado entre AbsolutePosition.X e AbsolutePosition.X + AbsoluteSize.X
    local function UpdateSlider(Current)
        local lo = Main.AbsolutePosition.X
        local hi = lo + Main.AbsoluteSize.X
        if Current < lo then Current = lo end
        if Current > hi then Current = hi end
        local p = (Current - lo) / (hi - lo)
        local v = Snap(mn + p*(mx-mn))
        val=v; ctrl._val=v
        local np=(v-mn)/(mx-mn)
        -- Atualiza fill e thumb
        TW(fill,{Size=UDim2.new(np,0,1,0)},.05)
        TW(thumb,{Position=UDim2.new(np,-6,0.5,-6)},.05)
        valLbl.Text=string.format(fmt,v)
        if ctrl.callback then ctrl.callback(v) end
    end

    -- Sliding state
    local sliding = false

    -- O TextButton de interação cobre o track inteiro com altura generosa
    local interact=New("TextButton",{Parent=wrap,BackgroundTransparency=1,
        Position=UDim2.new(0,-4,0,18),Size=UDim2.new(1,8,0,22),
        Text="",ZIndex=10})

    -- MouseButton1Down inicia o slide e faz update imediato
    interact.MouseButton1Down:Connect(function()
        sliding=true
        local loc = UIS:GetMouseLocation()
        UpdateSlider(loc.X)
    end)

    -- UIS.InputChanged captura movimento (padrão Rayfield)
    UIS.InputChanged:Connect(function(inp)
        if sliding and inp.UserInputType==Enum.UserInputType.MouseMovement then
            local loc = UIS:GetMouseLocation()
            UpdateSlider(loc.X)
        end
    end)

    -- UIS.InputEnded para de slidar
    UIS.InputEnded:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 then
            sliding=false
        end
    end)

    local function Set(v)
        v=Snap(v); val=v; ctrl._val=v
        local p=(v-mn)/(mx-mn)
        fill.Size=UDim2.new(p,0,1,0)
        thumb.Position=UDim2.new(p,-6,0.5,-6)
        valLbl.Text=string.format(fmt,v)
        if ctrl.callback then ctrl.callback(v) end
    end
    ctrl._setValue=Set; ctrl._getValue=function() return val end
    return wrap
end

-- =========================================================
--  DROPDOWN
--  Renderiza o menu no ScreenGui (ZIndex 60)
--  Overlay ZIndex 58 fecha ao clicar fora
-- =========================================================
function Library:_BDropdown(parent, ctrl)
    local opts = ctrl.options or {}
    local val  = ctrl._val~=nil and ctrl._val or (ctrl.default or opts[1])

    local wrap = Row(parent,46)

    -- Label topo
    Label(wrap,ctrl.text or "Select",11,C.TSEC,Enum.Font.Gotham,
        Enum.TextXAlignment.Left,UDim2.new(0,0,0,2),UDim2.new(1,0,0,12),3)

    -- Caixa do dropdown
    local box=New("Frame",{Parent=wrap,BackgroundColor3=C.DBHG or C.DBG,
        Position=UDim2.new(0,0,0,16),Size=UDim2.new(1,0,0,24),ZIndex=4})
    box.BackgroundColor3 = Color3.fromRGB(18,18,24)
    Corner(5,box); Stroke(C.BORDER,1,box)

    local selLbl=Label(box,tostring(val or ""),12,C.TPRI,Enum.Font.Gotham,
        Enum.TextXAlignment.Left,UDim2.new(0,8,0,0),UDim2.new(1,-22,1,0),5)
    Label(box,"▾",11,C.TSEC,Enum.Font.GothamBold,
        Enum.TextXAlignment.Center,UDim2.new(1,-18,0,0),UDim2.new(0,14,1,0),5)

    local isOpen=false
    local dropF,ovF=nil,nil

    local function Close()
        isOpen=false
        if dropF and dropF.Parent then dropF:Destroy() end
        if ovF  and ovF.Parent  then ovF:Destroy()  end
        dropF=nil; ovF=nil
        Stroke(C.BORDER,1,box)
        if _dropClose==Close then _dropClose=nil end
    end

    local function Pick(v)
        val=v; ctrl._val=v; selLbl.Text=tostring(v)
        task.defer(Close)
        if ctrl.callback then ctrl.callback(v) end
    end

    local obtn=New("TextButton",{Parent=box,BackgroundTransparency=1,
        Size=UDim2.new(1,0,1,0),Text="",ZIndex=6})
    obtn.MouseEnter:Connect(function()
        if not isOpen then box.BackgroundColor3=Color3.fromRGB(24,24,32) end
    end)
    obtn.MouseLeave:Connect(function()
        if not isOpen then box.BackgroundColor3=Color3.fromRGB(18,18,24) end
    end)

    obtn.MouseButton1Click:Connect(function()
        CloseDropdown()
        if isOpen then return end
        isOpen=true; _dropClose=Close
        Stroke(C.ACC,1,box)

        local IH=22
        local listH=#opts*IH+8

        -- Overlay
        ovF=New("TextButton",{Parent=self.Gui,BackgroundTransparency=1,
            Size=UDim2.new(1,0,1,0),Text="",ZIndex=58})
        ovF.MouseButton1Click:Connect(Close)

        -- Posição absoluta da caixa
        local ap=box.AbsolutePosition
        local as=box.AbsoluteSize

        -- Frame do dropdown no ScreenGui
        dropF=New("Frame",{Parent=self.Gui,
            BackgroundColor3=Color3.fromRGB(18,18,24),
            Position=UDim2.new(0,ap.X,0,ap.Y+as.Y+4),
            Size=UDim2.new(0,as.X,0,listH),
            ZIndex=60,ClipsDescendants=true})
        Corner(6,dropF); Stroke(C.ACC,1,dropF)

        -- Sombra do dropdown
        New("ImageLabel",{Parent=dropF,BackgroundTransparency=1,ZIndex=59,
            Position=UDim2.new(0,-8,0,-8),Size=UDim2.new(1,16,1,16),
            Image="rbxassetid://6014261993",ImageColor3=Color3.new(0,0,0),
            ImageTransparency=0.55,ScaleType=Enum.ScaleType.Slice,
            SliceCenter=Rect.new(49,49,450,450)})

        Layout(dropF,nil,0)
        Padding(4,4,4,4,dropF)

        for _,opt in ipairs(opts) do
            local sel=(opt==val)
            local item=New("TextButton",{Parent=dropF,
                BackgroundColor3=sel and C.HOVER or Color3.fromRGB(18,18,24),
                BackgroundTransparency=sel and 0 or 1,
                Size=UDim2.new(1,0,0,IH),
                Font=sel and Enum.Font.GothamBold or Enum.Font.Gotham,
                Text=tostring(opt),
                TextColor3=sel and C.TACC or C.TSEC,
                TextSize=11,
                TextXAlignment=Enum.TextXAlignment.Left,
                AutoButtonColor=false,ZIndex=61})
            Padding(8,0,0,0,item); Corner(3,item)

            item.MouseEnter:Connect(function()
                item.BackgroundTransparency=0
                TW(item,{BackgroundColor3=C.DHOV,TextColor3=C.TPRI},.08)
            end)
            item.MouseLeave:Connect(function()
                if sel then
                    item.BackgroundColor3=C.HOVER
                else
                    item.BackgroundTransparency=1
                    item.TextColor3=C.TSEC
                end
            end)
            item.MouseButton1Click:Connect(function()
                task.defer(function() Pick(opt) end)
            end)
        end
    end)

    ctrl._setValue=Pick; ctrl._getValue=function() return val end
    return wrap
end

-- =========================================================
--  SECTION HEADER
-- =========================================================
function Library:_BHeader(parent, ctrl)
    local r=Row(parent,28)
    local rOff=0
    if ctrl.gear then
        local g=New("TextButton",{Parent=r,BackgroundTransparency=1,
            Position=UDim2.new(1,-20,0.5,-8),Size=UDim2.new(0,16,0,16),
            Font=Enum.Font.Gotham,Text="⚙",TextColor3=C.TDIM,TextSize=13,ZIndex=4})
        g.MouseEnter:Connect(function() TW(g,{TextColor3=C.TACC},.08) end)
        g.MouseLeave:Connect(function() TW(g,{TextColor3=C.TDIM},.08) end)
        rOff=22
    end
    if ctrl.toggle~=nil then
        local tv=ctrl.toggle or false
        local ttr=New("Frame",{Parent=r,BackgroundColor3=tv and C.TOGON or C.TOGOFF,
            Position=UDim2.new(1,-(26+rOff),0.5,-7),Size=UDim2.new(0,24,0,13),ZIndex=4})
        Corner(7,ttr)
        local tth=New("Frame",{Parent=ttr,BackgroundColor3=C.WHITE,
            Position=tv and UDim2.new(1,-12,0.5,-5) or UDim2.new(0,2,0.5,-5),
            Size=UDim2.new(0,9,0,9),ZIndex=5})
        Corner(5,tth)
        New("TextButton",{Parent=ttr,BackgroundTransparency=1,
            Size=UDim2.new(1,0,1,0),Text="",ZIndex=6})
            .MouseButton1Click:Connect(function()
                tv=not tv
                TW(ttr,{BackgroundColor3=tv and C.TOGON or C.TOGOFF},.12)
                TW(tth,{Position=tv and UDim2.new(1,-12,0.5,-5) or UDim2.new(0,2,0.5,-5)},.12)
                if ctrl.callback then ctrl.callback(tv) end
            end)
        rOff=rOff+28
    end
    Label(r,ctrl.text or "",11,C.TSEC,Enum.Font.Gotham,
        Enum.TextXAlignment.Left,nil,UDim2.new(1,-(rOff+4),1,0),3)
    New("Frame",{Parent=r,BackgroundColor3=C.BORDER,
        Position=UDim2.new(0,0,1,-1),Size=UDim2.new(1,0,0,1),ZIndex=3})
    return r
end


        Name = "Close",
        Size = UDim2.new(0, 20, 0, 20),
        Position = UDim2.new(1, -24, 0, 6),
        BackgroundTransparency = 1,
        Text = "√ó",
        TextColor3 = th:Get("TextMuted"),
        TextSize = 16,
        Font = Enum.Font.GothamBold,
        ZIndex = 3,
        Parent = card,
    })

    -- Start offscreen right
    card.Position = UDim2.new(0, 360, 0, 0)
    card.Parent = self._container

    -- Slide in
    self.anim:Play(card, {Position = UDim2.new(0, 0, 0, 0)}, TI.Spring)

    -- Progress drain
    self.anim:Play(progress,
        {Size = UDim2.new(0, 0, 0, 2)},
        TweenInfo.new(dur, Enum.EasingStyle.Linear))

    local function dismiss()
        self.anim:Play(card, {
            Position = UDim2.new(0, 360, 0, 0),
        }, TI.Medium)
        task.delay(0.25, function()
            if card and card.Parent then card:Destroy() end
        end)
    end

    -- Hover: pause not implemented but freeze glow
    if onClick then
        card.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                pcall(onClick)
                dismiss()
            end
        end)
    end

    closeBtn.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then dismiss() end
    end)

    task.delay(dur, function()
        if card and card.Parent then dismiss() end
    end)
end

function NotifSys:Destroy()
    if self._sg then self._sg:Destroy() end
end


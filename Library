            TextColor3=T.TextSec, TextSize=13, ZIndex=6,
        })
        G.MouseEnter:Connect(function() Tw(G,{TextColor3=T.TextAccent},.08) end)
        G.MouseLeave:Connect(function() Tw(G,{TextColor3=T.TextSec},.08) end)
        rOff=-58
    end

    local L=MkLbl(row, ctrl.text or "Toggle", 12,
        val and T.TextPri or T.TextDim,
        Enum.Font.Gotham, Enum.TextXAlignment.Left,
        UDim2.new(0,0,0,0), UDim2.new(1,rOff,1,0), 4)

    -- Track
    local Tr=New("Frame",{
        Parent=row, BackgroundColor3=val and T.ToggleOn or T.ToggleOff,

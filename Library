local function AddCtrl(sec,side,cfg)
    local list=(side=="right") and sec._right or sec._left
    list[#list+1]=cfg
    if sec._active then
        local ui=sec._ui; local panel=(side=="right") and ui.RightScroll or ui.LeftScroll
        ui:_Build(panel,cfg)
    end
    return cfg
end

function ShadowUI:Toggle(s,side,cfg)
    cfg=cfg or{}; cfg.type="toggle"; local c=AddCtrl(s,side,cfg)
    if cfg.id then self._controls[#self._controls+1]=c end; return c
end
function ShadowUI:Slider(s,side,cfg)
    cfg=cfg or{}; cfg.type="slider"; local c=AddCtrl(s,side,cfg)
    if cfg.id then self._controls[#self._controls+1]=c end; return c
end
function ShadowUI:Dropdown(s,side,cfg)
    cfg=cfg or{}; cfg.type="dropdown"; local c=AddCtrl(s,side,cfg)
    if cfg.id then self._controls[#self._controls+1]=c end; return c
end
function ShadowUI:SectionHeader(s,side,cfg) cfg=cfg or{}; cfg.type="header"; return AddCtrl(s,side,cfg) end
function ShadowUI:Label(s,side,cfg)         cfg=cfg or{}; cfg.type="label";   return AddCtrl(s,side,cfg) end

function ShadowUI:BindToggleKey(key)
    UserInputService.InputBegan:Connect(function(i,gpe)
        if gpe then return end
        if i.KeyCode==key then self.ToggleBtn.MouseButton1Click:Fire() end
    end)
end

function ShadowUI:Destroy() self.Gui:Destroy() end

return ShadowUI

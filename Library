-- TAB / SUB-TAB BUILDER
-- ============================================================
local Tab = {}
Tab.__index = Tab

function Tab.new(tabBtn, scrollFrame)
    local self = setmetatable({}, Tab)
    self._btn = tabBtn
    self._scroll = scrollFrame
    self._subTabs = {}
    self._activeSubTab = nil
    self._subTabBar = nil
    self._subContent = {}
    return self
end

function Tab:_EnsureSubTabBar()
    if self._subTabBar then return end

    self._subTabBar = Util.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 32),
        BackgroundTransparency = 1,
        LayoutOrder = -9999,
        Parent = self._scroll,
    })
    Util.AddListLayout(self._subTabBar, 4, Enum.FillDirection.Horizontal, Enum.HorizontalAlignment.Left, Enum.VerticalAlignment.Center)
    Util.AddPadding(self._subTabBar, 0, 0, 0, 0)

    Util.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 1),
        Position = UDim2.new(0, 0, 1, -1),
        BackgroundColor3 = Theme.Border,
        BorderSizePixel = 0,
        Parent = self._subTabBar,
    })
end

function Tab:AddSubTab(name)
    self:_EnsureSubTabBar()

    local isFirst = #self._subTabs == 0

    local btn = Util.Create("TextButton", {
        Size = UDim2.new(0, 0, 1, -4),
        AutomaticSize = Enum.AutomaticSize.X,
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = isFirst and Theme.TextAccent or Theme.TextDim,
        Font = Theme.FontSemiBold,
        TextSize = 12,
        AutoButtonColor = false,
        Parent = self._subTabBar,
    })
    Util.AddPadding(btn, 0, 12, 0, 12)

    local indicator = Util.Create("Frame", {
        Size = isFirst and UDim2.new(1, 0, 0, 2) or UDim2.new(0, 0, 0, 2),
        Position = UDim2.new(0, 0, 1, 2),
        BackgroundColor3 = Theme.Accent,
        BorderSizePixel = 0,
        Parent = btn,
    })

    -- content holder
    local contentHolder = Util.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 0),
        BackgroundTransparency = 1,
        Visible = isFirst,
        Parent = self._scroll,
    })
    local contentLayout = Util.AddListLayout(contentHolder, 8)
    Util.AddPadding(contentHolder, 4, 0, 4, 0)
    Util.AutoSize(contentHolder, contentLayout)

    contentLayout.Changed:Connect(function()
        contentHolder.Size = UDim2.new(1, 0, 0, contentLayout.AbsoluteContentSize.Y + 8)
    end)

    local subTab = {
        btn = btn,
        indicator = indicator,
        content = contentHolder,
    }

    if isFirst then self._activeSubTab = subTab end

    table.insert(self._subTabs, subTab)

    btn.MouseButton1Click:Connect(function()
        if self._activeSubTab == subTab then return end
        -- deactivate old
        if self._activeSubTab then
            self._activeSubTab.content.Visible = false
            Util.Tween(self._activeSubTab.btn, { TextColor3 = Theme.TextDim })
            Util.Tween(self._activeSubTab.indicator, { Size = UDim2.new(0, 0, 0, 2) })
        end
        self._activeSubTab = subTab
        subTab.content.Visible = true
        Util.Tween(btn, { TextColor3 = Theme.TextAccent })
        Util.Tween(indicator, { Size = UDim2.new(1, 0, 0, 2) })
    end)

    -- Return a section-like interface
    local subSection = Section.new(contentHolder, nil)
    -- Proxy methods to section but also attach to the subtab content
    local proxy = {}
    for k, v in pairs(Section) do
        if type(v) == "function" then
            proxy[k] = v
        end
    end
    setmetatable(proxy, { __index = subSection })
    return subSection
end

function Tab:AddSection(title)

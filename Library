-- ─── Tween Helper ──────────────────────────────────────────────────────────────
local function tween(obj, props, t, style, dir)
    TweenService:Create(obj,
        TweenInfo.new(t or 0.18, style or Enum.EasingStyle.Quart, dir or Enum.EasingDirection.Out),
        props):Play()
end

local function tweenBack(obj, props, t)
    tween(obj, props, t or 0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
end

-- ─── Instance Helper ───────────────────────────────────────────────────────────
local function new(cls, props, parent)
    local o = Instance.new(cls)
    for k, v in pairs(props or {}) do
        o[k] = v
    end
    if parent then o.Parent = parent end
    return o
end

-- ─── Shortcut Helpers ──────────────────────────────────────────────────────────
local function corner(r, p)
    new("UICorner", { CornerRadius = UDim.new(0, r) }, p)
end

local function padding(t, b, l, r, p)
    new("UIPadding", {
        PaddingTop    = UDim.new(0, t or 0),
        PaddingBottom = UDim.new(0, b or 0),
        PaddingLeft   = UDim.new(0, l or 0),
        PaddingRight  = UDim.new(0, r or 0),
    }, p)
end

local function stroke(color, thick, p)
    return new("UIStroke", { Color = color, Thickness = thick or 1 }, p)
end

local function gradient(c0, c1, rot, p)
    return new("UIGradient", {
        Color    = ColorSequence.new(c0, c1),
        Rotation = rot or 90,
    }, p)
end

-- ─── Draggable ──────────────────────────────────────────────────────────────────
local function makeDraggable(root, handle)
    local drag, ds, dp = false, nil, nil
    handle.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            drag = true
            ds   = i.Position
            dp   = root.Position
        end
    end)
    handle.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if drag and i.UserInputType == Enum.UserInputType.MouseMovement then
            local d = i.Position - ds
            root.Position = UDim2.new(
                dp.X.Scale, dp.X.Offset + d.X,
                dp.Y.Scale, dp.Y.Offset + d.Y
            )
        end
    end)
end

-- ─── Ripple Effect ──────────────────────────────────────────────────────────────
local function ripple(parent, x, y, color)
    color = color or Color3.fromRGB(255, 255, 255)
    local r = new("Frame", {
        Parent              = parent,
        BackgroundColor3    = color,
        BackgroundTransparency = 0.75,
        BorderSizePixel     = 0,
        Size                = UDim2.new(0, 0, 0, 0),
        AnchorPoint         = Vector2.new(0.5, 0.5),
        Position            = UDim2.new(0, x - parent.AbsolutePosition.X, 0, y - parent.AbsolutePosition.Y),
        ZIndex              = parent.ZIndex + 10,
        ClipsDescendants    = false,
    })
    corner(100, r)
    local sz = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * 2.2
    tween(r, { Size = UDim2.new(0, sz, 0, sz), BackgroundTransparency = 1 }, 0.45, Enum.EasingStyle.Quad)
    task.delay(0.46, function() r:Destroy() end)
end


local TooltipSystem = {}
TooltipSystem.__index = TooltipSystem

function TooltipSystem.new(theme, anim, parent)
    local self = setmetatable({}, TooltipSystem)
    self.Theme       = theme
    self.Anim        = anim
    self.Tooltip     = nil
    self.Connections = {}
    self:_Build(parent)
    return self
end

function TooltipSystem:_Build(parent)
    local tt = Utils.Create("Frame", {
        Name                    = "Tooltip",
        Size                    = UDim2.new(0, 160, 0, 32),
        BackgroundColor3        = self.Theme:Get("SurfaceAlt"),
        BackgroundTransparency  = 0,
        BorderSizePixel         = 0,
        Visible                 = false,
        ZIndex                  = 999,
        Parent                  = parent,
    })
    Utils.AddCorner(tt, CORNER_SMALL)
    Utils.AddStroke(tt, self.Theme:Get("Border"))
    Utils.AddPadding(tt, 6, 10, 6, 10)

    local label = Utils.Create("TextLabel", {
        Name                    = "Label",
        Size                    = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency  = 1,
        Text                    = "",
        TextColor3              = self.Theme:Get("TextSecondary"),
        TextSize                = 11,
        Font                    = Enum.Font.Gotham,
        TextXAlignment          = Enum.TextXAlignment.Left,
        TextWrapped             = true,
        ZIndex                  = 1000,
        Parent                  = tt,
    })

    self.Tooltip = tt
    self.Label   = label
end

function TooltipSystem:Attach(instance, text)
    if not text or text == "" then return end
    local connections = {}

    Utils.Connect(connections, instance.MouseEnter, function()
        self.Label.Text = text
        local ts = Utils.GetTextSize(text, 11, Enum.Font.Gotham, Vector2.new(200, 100))
        self.Tooltip.Size = UDim2.new(0, math.min(ts.X + 24, 220), 0, math.max(ts.Y + 14, 32))
        self.Tooltip.Visible = true
        self.Tooltip.BackgroundTransparency = 1
        self.Label.TextTransparency = 1
        self.Anim:Play(self.Tooltip, {BackgroundTransparency = 0}, TWEEN_SHORT)
        self.Anim:Play(self.Label, {TextTransparency = 0}, TWEEN_SHORT)
    end)

    Utils.Connect(connections, instance.MouseLeave, function()
        self.Tooltip.Visible = false
    end)

    Utils.Connect(connections, instance.MouseMoved, function(x, y)
        local screenSize = workspace.CurrentCamera.ViewportSize
        local ttSize = self.Tooltip.AbsoluteSize
        local px = math.min(x + 14, screenSize.X - ttSize.X - 4)
        local py = math.min(y + 14, screenSize.Y - ttSize.Y - 4)
        self.Tooltip.Position = UDim2.new(0, px, 0, py)
    end)

    return function()
        Utils.Disconnect(connections)
    end
end

-- ============================================================
-- CONFIG SYSTEM
-- ============================================================

local ConfigSystem = {}
ConfigSystem.__index = ConfigSystem

function ConfigSystem.new(libraryName)
    local self = setmetatable({}, ConfigSystem)
    self.LibraryName = libraryName or "NexusUI"
    self.Flags       = {}
    self.AutoLoad    = false
    self.FolderPath  = self.LibraryName .. "_Configs"
    self:_EnsureFolder()
    return self
end

function ConfigSystem:_EnsureFolder()
    pcall(function()
        if not isfolder(self.FolderPath) then
            makefolder(self.FolderPath)
        end
    end)
end

function ConfigSystem:_Serialize()
    local data = {}
    for flag, info in pairs(self.Flags) do
        data[flag] = info.Value
    end
    return HttpService:JSONEncode(data)
end

function ConfigSystem:Register(flag, defaultValue, setter)
    self.Flags[flag] = {
        Value   = defaultValue,
        Default = defaultValue,
        Setter  = setter,
    }
end

function ConfigSystem:SetFlag(flag, value)
    if self.Flags[flag] then
        self.Flags[flag].Value = value
    end
end

function ConfigSystem:GetFlag(flag)
    if self.Flags[flag] then
        return self.Flags[flag].Value
    end
    return nil
end

function ConfigSystem:Save(name)
    local name = name or "default"
    local path = self.FolderPath .. "/" .. name .. ".json"
    pcall(function()
        writefile(path, self:_Serialize())
    end)
end

function ConfigSystem:Load(name)
    local name = name or "default"
    local path = self.FolderPath .. "/" .. name .. ".json"
    local ok, data = pcall(function()
        return HttpService:JSONDecode(readfile(path))
    end)
    if ok and data then
        for flag, value in pairs(data) do
            if self.Flags[flag] then
                self.Flags[flag].Value = value
                if self.Flags[flag].Setter then
                    pcall(self.Flags[flag].Setter, value)
                end
            end
        end
        return true
    end
    return false
end

function ConfigSystem:List()
    local configs = {}
    pcall(function()
        for _, file in ipairs(listfiles(self.FolderPath)) do
            local name = file:match("([^/\\]+)%.json$")
            if name then table.insert(configs, name) end
        end
    end)
    return configs
end

function ConfigSystem:Delete(name)
    pcall(function()
        delfile(self.FolderPath .. "/" .. name .. ".json")
    end)
end


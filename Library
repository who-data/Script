-- ══════════════════════════════════════════════
--  SLIDER
-- ══════════════════════════════════════════════
function ShadowUI:_BSlider(panel, ctrl)
    local mn  = ctrl.min    or 0
    local mx  = ctrl.max    or 100
    local stp = ctrl.step   or 0
    local fmt = ctrl.format or "%.2f"
    local val = ctrl._val~=nil and ctrl._val or (ctrl.default or mn)

    local function Snap(v)
        if stp>0 then v=math.round((v-mn)/stp)*stp+mn end
        return math.clamp(v,mn,mx)
    end

    local wrap = Row(panel, 56)
    Corner(9,wrap)

    -- Borda sutil
    local wStr = Stroke(T.Border, 1, wrap)
    wStr.Transparency = 0.65

    -- Fundo hover
    local bg = New("Frame",{
        Parent=wrap, BackgroundColor3=T.RowHov,
        BackgroundTransparency=1,
        Size=UDim2.new(1,0,1,0), ZIndex=2, BorderSizePixel=0,
    })
    Corner(9,bg)

    local hdr = New("Frame",{
        Parent=wrap, BackgroundTransparency=1,
        Position=UDim2.new(0,8,0,6),
        Size=UDim2.new(1,-16,0,18), ZIndex=3,
    })
    Lbl(hdr, ctrl.text or "Slider", 11, T.TxtSec, Enum.Font.Gotham,
        Enum.TextXAlignment.Left, nil, UDim2.new(0.65,0,1,0), 3)
    local valLbl = Lbl(hdr, string.format(fmt,val), 11, T.TxtAcc, Enum.Font.GothamBold,
        Enum.TextXAlignment.Right,
        UDim2.new(0.65,0,0,0), UDim2.new(0.35,0,1,0), 3)

    local holder = New("Frame",{
        Parent=wrap, BackgroundTransparency=1,
        Position=UDim2.new(0,8,0,30),
        Size=UDim2.new(1,-16,0,22), ZIndex=3,
    })
    local track = New("Frame",{
        Parent=holder, BackgroundColor3=T.SlTrack,
        Position=UDim2.new(0,0,0.5,-4),
        Size=UDim2.new(1,0,0,8),
        ZIndex=4, BorderSizePixel=0,
    })
    Corner(4,track)

    local pct = (val-mn)/(mx-mn)
    local fill = New("Frame",{
        Parent=track, BackgroundColor3=T.Accent,
        Size=UDim2.new(pct,0,1,0),
        ZIndex=5, BorderSizePixel=0,
    })
    Corner(4,fill)
    New("UIGradient",{
        Parent=fill,
        Color=ColorSequence.new{
            ColorSequenceKeypoint.new(0,T.Accent),
            ColorSequenceKeypoint.new(1,T.AccentHi),
        },
    })

    local thumb = New("Frame",{
        Parent=track, BackgroundColor3=T.White,
        Position=UDim2.new(pct,-8,0.5,-8),
        Size=UDim2.new(0,16,0,16),
        ZIndex=6, BorderSizePixel=0,
    })
    Corner(8,thumb)
    Stroke(T.Accent,2,thumb)

    local function Update(absX)
        local ap=track.AbsolutePosition.X
        local as=track.AbsoluteSize.X
        if as<=0 then return end
        local p=math.clamp((absX-ap)/as,0,1)
        local v=Snap(mn+p*(mx-mn))
        val=v; ctrl._val=v
        local np=(v-mn)/(mx-mn)
        fill.Size      =UDim2.new(np,0,1,0)
        thumb.Position =UDim2.new(np,-8,0.5,-8)
        valLbl.Text    =string.format(fmt,v)
        if ctrl.callback then ctrl.callback(v) end
    end

    local dragging=false
    local hitZ = New("TextButton",{
        Parent=holder, BackgroundTransparency=1,
        Size=UDim2.new(1,0,1,0), Text="", ZIndex=10,
    })
    hitZ.MouseButton1Down:Connect(function(x) dragging=true; Update(x) end)
    hitZ.MouseEnter:Connect(function() Tw(bg,{BackgroundTransparency=0.8},.1) end)
    hitZ.MouseLeave:Connect(function() Tw(bg,{BackgroundTransparency=1},.1) end)

    local mc=UIS.InputChanged:Connect(function(i)
        if not dragging then return end
        if i.UserInputType==Enum.UserInputType.MouseMovement
        or i.UserInputType==Enum.UserInputType.Touch then
            Update(i.Position.X)
        end
    end)
    local uc=UIS.InputEnded:Connect(function(i)
        if dragging and (
            i.UserInputType==Enum.UserInputType.MouseButton1 or
            i.UserInputType==Enum.UserInputType.Touch) then
            dragging=false
        end
    end)
    wrap.AncestryChanged:Connect(function()
        if not wrap.Parent then
            pcall(function() mc:Disconnect() end)
            pcall(function() uc:Disconnect() end)
        end
    end)

    ctrl._setValue=function(v)
        v=Snap(v); val=v; ctrl._val=v
        local np=(v-mn)/(mx-mn)
        fill.Size=UDim2.new(np,0,1,0)
        thumb.Position=UDim2.new(np,-8,0.5,-8)
        valLbl.Text=string.format(fmt,v)
        if ctrl.callback then ctrl.callback(v) end
    end
    ctrl._getValue=function() return val end
    return wrap
end


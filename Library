                Parent               = inputFrame,
                BackgroundTransparency = 1,
                Position             = UDim2.new(0, 9, 0, 0),
                Size                 = UDim2.new(1, -18, 1, 0),
                Font                 = Enum.Font.Gotham,
                PlaceholderText      = o.PlaceHolder or "Type here...",
                PlaceholderColor3    = C.TEXT_MUTED,
                Text                 = o.Default or "",
                TextColor3           = C.TEXT,
                TextSize             = 10,
                TextXAlignment       = Enum.TextXAlignment.Left,
                ClearTextOnFocus     = false,
                ZIndex               = 6,
            })
            tb.Focused:Connect(function()
                tween(inputStroke, { Color = C.ACCENT })
                tween(inputFrame, { BackgroundColor3 = Color3.fromRGB(32, 32, 44) })
            end)
            tb.FocusLost:Connect(function(enter)
                tween(inputStroke, { Color = C.BORDER })
                tween(inputFrame, { BackgroundColor3 = C.INPUT_BG })
                if enter then pcall(cb, tb.Text) end
            end)
            local I = {}
            function I:Set(v) tb.Text = v end
            function I:Get() return tb.Text end
            return I
        end

        -- ── Label ───────────────────────────────────────────────────────────────

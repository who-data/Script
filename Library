function ShadowUI:_Bread(catName, secName)
    for _, c in ipairs(self.BreadFrame:GetChildren()) do
        if c ~= self.BreadCat and not c:IsA("UIListLayout") then c:Destroy() end
    end
    self.BreadCat.Text = catName
    if secName then
        MkLbl(self.BreadFrame,"›",13,T.TextSec,Enum.Font.Gotham,
            Enum.TextXAlignment.Center,nil,UDim2.new(0,10,1,0),5)
        MkLbl(self.BreadFrame,secName,12,T.TextAccent,Enum.Font.GothamBold,
            Enum.TextXAlignment.Left,nil,UDim2.new(0,110,1,0),5)
    end
end

-- ──────────────────────────────────────────────
--  ADD CATEGORY
-- ──────────────────────────────────────────────
function ShadowUI:AddCategory(name)
    local cat = {Name=name, _sections={}, _expanded=false, _ui=self}

    local Row = New("TextButton",{
        Parent=self.SideList, BackgroundTransparency=1,
        Size=UDim2.new(1,0,0,32), Text="",
        AutoButtonColor=false, ZIndex=5,
    })
    Corn(4, Row)

    Row.MouseEnter:Connect(function()
        Tw(Row,{BackgroundColor3=T.RowHover},.08)
        Row.BackgroundTransparency=0
    end)
    Row.MouseLeave:Connect(function()
        if not cat._expanded then Row.BackgroundTransparency=1 end
    end)

    -- Ícone
    New("Frame",{
        Parent=Row, BackgroundTransparency=1,
        Position=UDim2.new(0,9,0.5,-8), Size=UDim2.new(0,16,0,16), ZIndex=6,
    },{Corn(8), Stro(T.White,1.4)})
    New("Frame",{
        Parent=Row, BackgroundColor3=T.White,
        Position=UDim2.new(0,13,0.5,-4), Size=UDim2.new(0,8,0,8), ZIndex=7,
    },{Corn(4)})

    MkLbl(Row, name, 12, T.TextPri, Enum.Font.GothamBold,
        Enum.TextXAlignment.Left, UDim2.new(0,32,0,0), UDim2.new(1,-52,1,0), 6)

    local Chev = MkLbl(Row,"‹",14,T.TextSec,Enum.Font.GothamBold,
        Enum.TextXAlignment.Center, UDim2.new(1,-22,0,0), UDim2.new(0,18,1,0), 6)

    local SF = New("Frame",{
        Parent=self.SideList, BackgroundTransparency=1,
        Size=UDim2.new(1,0,0,0), ClipsDescendants=true, Visible=false, ZIndex=5,
    })
    local SL = List(SF)

    cat._row=Row; cat._sf=SF; cat._sl=SL; cat._chev=Chev

    Row.MouseButton1Click:Connect(function()
        cat._expanded = not cat._expanded
        if cat._expanded then
            SF.Visible=true
            SF.Size=UDim2.new(1,0,0,SL.AbsoluteContentSize.Y)
            Chev.Text="›"
            Row.BackgroundTransparency=0
            Row.BackgroundColor3=T.RowHover
            if #cat._sections>0 and not cat._sections[1]._active then
                cat._sections[1]._btn.MouseButton1Click:Fire()
            end
        else
            SF.Visible=false; SF.Size=UDim2.new(1,0,0,0)
            Chev.Text="‹"; Row.BackgroundTransparency=1
        end
    end)

    self._sidebar[#self._sidebar+1]=cat
    return cat
end

-- ──────────────────────────────────────────────
--  ADD SECTION
-- ──────────────────────────────────────────────
function ShadowUI:AddSection(cat, name)
    local sec = {Name=name, _cat=cat, _active=false, _left={}, _right={}, _ui=self}

    local Btn = New("TextButton",{
        Parent=cat._sf, BackgroundTransparency=1,
        Size=UDim2.new(1,0,0,26), Text="",
        AutoButtonColor=false, ZIndex=6,
    })
    Corn(3, Btn)

    -- Barra lateral accent
    local AccBar = New("Frame",{
        Parent=Btn, BackgroundColor3=T.Accent,
        Position=UDim2.new(0,0,0.2,0), Size=UDim2.new(0,2,0.6,0),
        ZIndex=8, Visible=false,
    })
    Corn(1, AccBar)

    -- Diamond
    local Dia = New("Frame",{
        Parent=Btn, BackgroundColor3=T.AccentDim,
        Position=UDim2.new(0,18,0.5,-4), Size=UDim2.new(0,8,0,8),
        Rotation=45, ZIndex=7,
    })

    local Lbl_ = MkLbl(Btn, name, 11, T.TextSec, Enum.Font.Gotham,
        Enum.TextXAlignment.Left, UDim2.new(0,32,0,0), UDim2.new(1,-36,1,0), 7)

    sec._btn=Btn; sec._dia=Dia; sec._lbl=Lbl_; sec._accBar=AccBar

    Btn.MouseEnter:Connect(function()
        if not sec._active then
            Tw(Btn,{BackgroundColor3=T.RowHover},.08)
            Btn.BackgroundTransparency=0
        end
    end)
    Btn.MouseLeave:Connect(function()
        if not sec._active then Btn.BackgroundTransparency=1 end
    end)

    Btn.MouseButton1Click:Connect(function()
        if self._activeSec then
            local p=self._activeSec
            p._active=false; p._lbl.TextColor3=T.TextSec
            p._dia.BackgroundColor3=T.AccentDim
            p._accBar.Visible=false
            p._btn.BackgroundTransparency=1
        end
        sec._active=true
        Lbl_.TextColor3=T.TextAccent
        Dia.BackgroundColor3=T.Accent
        AccBar.Visible=true
        Btn.BackgroundColor3=Color3.fromRGB(22,20,36)
        Btn.BackgroundTransparency=0
        self._activeSec=sec
        self:_Bread(cat.Name, name)
        self:_Render(sec)
    end)

    cat._sections[#cat._sections+1]=sec
    cat._sf.Size=UDim2.new(1,0,0,cat._sl.AbsoluteContentSize.Y+26)
    return sec
end

-- ──────────────────────────────────────────────
--  RENDER
-- ──────────────────────────────────────────────
function ShadowUI:_Render(sec)
    for _, p in ipairs({self.LeftScroll,self.RightScroll}) do
        for _, c in ipairs(p:GetChildren()) do
            if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then c:Destroy() end
        end
    end
    for _, c in ipairs(self.TabList:GetChildren()) do
        if not c:IsA("UIListLayout") then c:Destroy() end
    end

    for _, s in ipairs(sec._cat._sections) do
        local act=(s==sec)
        local Tab = New("Frame",{
            Parent=self.TabList, BackgroundTransparency=1,
            Size=UDim2.new(0,82,1,0), ZIndex=3,
        })
        if act then
            New("Frame",{
                Parent=Tab, BackgroundColor3=T.Accent,
                Position=UDim2.new(0,0,1,-2), Size=UDim2.new(1,0,0,2), ZIndex=5,
            })
        end
        New("Frame",{
            Parent=Tab,
            BackgroundColor3=act and T.Accent or T.AccentDim,
            Position=UDim2.new(0,4,0.5,-3), Size=UDim2.new(0,7,0,7),
            Rotation=45, ZIndex=4,
        })
        MkLbl(Tab, s.Name, 11, act and T.TextAccent or T.TextSec,
            act and Enum.Font.GothamBold or Enum.Font.Gotham,
            Enum.TextXAlignment.Left, UDim2.new(0,16,0,0), UDim2.new(1,-16,1,0), 4)
    end

    for _, ctrl in ipairs(sec._left)  do self:_Build(self.LeftScroll,  ctrl) end
    for _, ctrl in ipairs(sec._right) do self:_Build(self.RightScroll, ctrl) end
end

-- ──────────────────────────────────────────────
--  BUILD
-- ──────────────────────────────────────────────
function ShadowUI:_Build(p, ctrl)
    if ctrl.type=="toggle"   then return self:_Toggle(p,ctrl)   end
    if ctrl.type=="slider"   then return self:_Slider(p,ctrl)   end
    if ctrl.type=="dropdown" then return self:_Dropdown(p,ctrl) end
    if ctrl.type=="header"   then return self:_Header(p,ctrl)   end
    if ctrl.type=="label"    then return self:_Label(p,ctrl)    end
end

-- ──────────────────────────────────────────────
--  TOGGLE
-- ──────────────────────────────────────────────
function ShadowUI:_Toggle(parent, ctrl)
    local val = ctrl._val~=nil and ctrl._val or (ctrl.default or false)
    local row = MkRow(parent, 30)

    local HBtn = New("TextButton",{
        Parent=row, BackgroundTransparency=1,
        Size=UDim2.new(1,0,1,0), Text="", ZIndex=5,
    })
    Corn(4, row)
    HBtn.MouseEnter:Connect(function()

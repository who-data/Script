        TextTruncate=Enum.TextTruncate.AtEnd,TextXAlignment=Enum.TextXAlignment.Left,Parent=av})
    ins("TextLabel",{Size=UDim2.new(1,-54,0,12),Position=UDim2.new(0,52,0,32),BackgroundTransparency=1,
        Text=sub,TextColor3=C.Accent,Font=C.Fb,TextSize=10,TextXAlignment=Enum.TextXAlignment.Left,Parent=av})
    ins("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-1),BackgroundColor3=C.Border,BorderSizePixel=0,Parent=av})

    local tabList=ins("Frame",{Size=UDim2.new(1,0,1,-94),Position=UDim2.new(0,0,0,62),
        BackgroundTransparency=1,ClipsDescendants=true,Parent=sb})
    vlist(tabList,2)


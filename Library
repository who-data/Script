    local lbl = Lb(btn,name,11,T.TSEC,Enum.Font.Gotham,
        Enum.TextXAlignment.Left,UDim2.new(0,31,0,0),UDim2.new(1,-35,1,0),9)
    sec._btn=btn; sec._dia=dia; sec._lbl=lbl; sec._bar=bar

    btn.MouseEnter:Connect(function()
        if not sec._active then TW(btn,{BackgroundColor3=T.EHOV},.08); btn.BackgroundTransparency=0 end
    end)
    btn.MouseLeave:Connect(function()

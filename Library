-- COLOR PICKER
function ShadowUI:_BColorPicker(panel,ctrl)
    local val=ctrl._val or ctrl.default or Color3.fromRGB(255,255,255)
    local r,g,b=math.floor(val.R*255),math.floor(val.G*255),math.floor(val.B*255)
    local h=(ctrl.description and 138 or 124); local wrap=Card(panel,h)
    local headerRow=New("Frame",{Parent=wrap,BackgroundTransparency=1,Position=UDim2.new(0,10,0,6),Size=UDim2.new(1,-14,0,18),ZIndex=3})
    Lbl(headerRow,ctrl.text or "Color",11,T.TxtSec,Enum.Font.Gotham,Enum.TextXAlignment.Left,nil,UDim2.new(1,-34,1,0),3)
    local swatch=New("Frame",{Parent=headerRow,BackgroundColor3=val,AnchorPoint=Vector2.new(1,.5),Position=UDim2.new(1,0,.5,0),Size=UDim2.new(0,22,0,16),ZIndex=4,BorderSizePixel=0}); Corner(4,swatch); Stroke(T.CardBorder,1,swatch)
    if ctrl.description then Lbl(wrap,ctrl.description,10,T.TxtDim,Enum.Font.Gotham,Enum.TextXAlignment.Left,UDim2.new(0,10,0,24),UDim2.new(1,-14,0,14),3) end
    local startY=ctrl.description and 40 or 28
    local function MkChan(label,col,initVal,yOff,cb)
        local rowF=New("Frame",{Parent=wrap,BackgroundTransparency=1,Position=UDim2.new(0,10,0,startY+yOff),Size=UDim2.new(1,-14,0,24),ZIndex=3})
        New("TextLabel",{Parent=rowF,BackgroundTransparency=1,Size=UDim2.new(0,12,1,0),Font=Enum.Font.GothamBold,Text=label,TextColor3=col,TextSize=10,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=3})
        local valLbl=Lbl(rowF,tostring(initVal),10,T.TxtAcc,Enum.Font.GothamBold,Enum.TextXAlignment.Right,UDim2.new(1,-26,0,0),UDim2.new(0,22,1,0),3)
        local trackF=New("Frame",{Parent=rowF,BackgroundColor3=T.SlTrack,Position=UDim2.new(0,14,.5,-2),Size=UDim2.new(1,-42,0,4),ZIndex=4,BorderSizePixel=0}); Corner(2,trackF)
        local pct=initVal/255
        local fill=New("Frame",{Parent=trackF,BackgroundColor3=col,Size=UDim2.new(pct,0,1,0),ZIndex=5,BorderSizePixel=0}); Corner(2,fill)
        local thumb=New("Frame",{Parent=trackF,BackgroundColor3=T.White,Position=UDim2.new(pct,-5,.5,-5),Size=UDim2.new(0,10,0,10),ZIndex=6,BorderSizePixel=0}); Corner(5,thumb); Stroke(col,1.5,thumb)
        local cur=initVal
        local function Upd(absX)
            local ap=trackF.AbsolutePosition.X; local as=trackF.AbsoluteSize.X
            if as<=0 then return end
            local p=math.clamp((absX-ap)/as,0,1); cur=math.floor(p*255)
            fill.Size=UDim2.new(p,0,1,0); thumb.Position=UDim2.new(p,-5,.5,-5); valLbl.Text=tostring(cur); cb(cur)
        end
        local drag=false
        local hitB=New("TextButton",{Parent=rowF,BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),Text="",ZIndex=8})
        hitB.MouseButton1Down:Connect(function(x) drag=true;Upd(x) end)
        local mc=UIS.InputChanged:Connect(function(i) if not drag then return end; if i.UserInputType==Enum.UserInputType.MouseMovement then Upd(i.Position.X) end end)
        local uc=UIS.InputEnded:Connect(function(i) if drag and i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end end)
        wrap.AncestryChanged:Connect(function() if not wrap.Parent then pcall(function()mc:Disconnect()end);pcall(function()uc:Disconnect()end) end end)
        return function(newV) cur=newV; local np=newV/255; fill.Size=UDim2.new(np,0,1,0); thumb.Position=UDim2.new(np,-5,.5,-5); valLbl.Text=tostring(newV) end
    end
    local function Update() val=Color3.fromRGB(r,g,b);ctrl._val=val; swatch.BackgroundColor3=val; if ctrl.callback then ctrl.callback(val) end end
    local setR=MkChan("R",Color3.fromRGB(255,80,80),r, 0,function(v) r=v;Update() end)
    local setG=MkChan("G",Color3.fromRGB(80,210,120),g,26,function(v) g=v;Update() end)
    local setB=MkChan("B",Color3.fromRGB(80,160,255),b,52,function(v) b=v;Update() end)
    ctrl._setValue=function(c) val=c;ctrl._val=c; r=math.floor(c.R*255);g=math.floor(c.G*255);b=math.floor(c.B*255); setR(r);setG(g);setB(b); swatch.BackgroundColor3=c; if ctrl.callback then ctrl.callback(c) end end
    ctrl._getValue=function() return val end
    return wrap
end


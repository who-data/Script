    row.MouseEnter:Connect(function()
        if not cat._open then
            row.BackgroundTransparency=0
            Tw(row,{BackgroundColor3=T.RowHov},.1)
        end
    end)
    row.MouseLeave:Connect(function()
        if not cat._open then row.BackgroundTransparency=1 end
    end)

    -- Icon ring
    local ring = New("Frame",{
        Parent=row, BackgroundTransparency=1,
        Position=UDim2.new(0,6,0.5,-8), Size=UDim2.new(0,16,0,16),
        ZIndex=11,
    })
    Corner(8,ring)
    cat._icoStroke = Stroke(T.TxtSec, 1.2, ring)

    local dot = New("Frame",{
        Parent=ring, BackgroundColor3=T.TxtSec,
        AnchorPoint=Vector2.new(0.5,0.5),
        Position=UDim2.new(0.5,0,0.5,0), Size=UDim2.new(0,8,0,8),
        ZIndex=12, BorderSizePixel=0,
    })
    Corner(4,dot)
    cat._dot = dot

    Lbl(row, name, 11, T.TxtPri, Enum.Font.GothamBold,
        Enum.TextXAlignment.Left,
        UDim2.new(0,27,0,0), UDim2.new(1,-44,1,0), 11)

    cat._chev = Lbl(row,"›",14,T.TxtDim,Enum.Font.GothamBold,
        Enum.TextXAlignment.Center,
        UDim2.new(1,-20,0,0),UDim2.new(0,16,1,0),11)

    -- Section frame (contém as pills)
    local sf = New("Frame",{
        Parent=self.SideScroll,
        BackgroundTransparency=1,
        Size=UDim2.new(1,0,0,0),
        ClipsDescendants=true, Visible=false,
        ZIndex=10,
    })
    -- Linha vertical conectora: amarra visualmente as pills à categoria
    New("Frame",{
        Parent=sf,
        BackgroundColor3=T.Border,
        Position=UDim2.new(0,22,0,2),
        Size=UDim2.new(0,1,1,-4),
        ZIndex=11, BorderSizePixel=0,
    })
    local sl = ListL(sf, nil, 2)
    Pad(0,0,3,4,sf)
    cat._row=row; cat._sf=sf; cat._sl=sl

    row.MouseButton1Click:Connect(function()
        cat._open = not cat._open
        if cat._open then
            sf.Visible=true
            sf.Size=UDim2.new(1,0,0,sl.AbsoluteContentSize.Y)
            cat._chev.Text="↓"
            row.BackgroundTransparency=0
            Tw(row,{BackgroundColor3=T.RowHov},.1)
            cat._icoStroke.Color=T.Accent
            cat._dot.BackgroundColor3=T.Accent
            if #cat._secs>0 and not cat._secs[1]._active then
                task.defer(function() cat._secs[1]._btn.MouseButton1Click:Fire() end)
            end
        else
            sf.Visible=false
            sf.Size=UDim2.new(1,0,0,0)
            cat._chev.Text="›"
            row.BackgroundTransparency=1
            cat._icoStroke.Color=T.TxtSec
            cat._dot.BackgroundColor3=T.TxtSec
        end
    end)

    self._cats[#self._cats+1]=cat
    return cat
end

-- ══════════════════════════════════════════════
--  ADD SECTION  — pill compacto (sub-tab visual)
-- ══════════════════════════════════════════════
function ShadowUI:AddSection(cat, name)
    local sec={Name=name,_cat=cat,_active=false,_left={},_right={}}

    -- Row invisível que serve de hitbox + posicionamento
    local btn = New("TextButton",{
        Parent=cat._sf,
        BackgroundTransparency=1,
        Size=UDim2.new(1,0,0,26),
        Text="", AutoButtonColor=false,
        ZIndex=11,
    })

    -- ── Pill — pequeno, indentado, claramente sub-item ──
    local pill = New("Frame",{
        Parent=btn,
        BackgroundColor3=T.AccentDim,
        BackgroundTransparency=1,
        -- indentação fixa: 18px da esquerda, não ocupa a borda direita toda
        Position=UDim2.new(0,18,0.5,-10),
        Size=UDim2.new(1,-22,0,20),
        ZIndex=12, BorderSizePixel=0,
    })
    Corner(10, pill)   -- totalmente arredondado = pill shape

    local pillStr = Stroke(T.Border, 1, pill)
    pillStr.Transparency = 0.4

    -- Bolinha de status dentro da pill
    local dot = New("Frame",{
        Parent=pill,
        BackgroundColor3=T.TxtDim,
        AnchorPoint=Vector2.new(0,0.5),
        Position=UDim2.new(0,7,0.5,0),
        Size=UDim2.new(0,5,0,5),
        ZIndex=13, BorderSizePixel=0,
    })
    Corner(3, dot)

    -- Texto da pill — menor e mais sutil
    local lbl = Lbl(pill, name, 10, T.TxtSec, Enum.Font.Gotham,
        Enum.TextXAlignment.Left,
        UDim2.new(0,17,0,0), UDim2.new(1,-19,1,0), 13)

    sec._btn=btn; sec._pill=pill; sec._pillStr=pillStr; sec._dot=dot; sec._lbl=lbl

    btn.MouseEnter:Connect(function()
        if not sec._active then
            pill.BackgroundColor3=T.RowHov
            Tw(pill,{BackgroundTransparency=0.7},.1)
            Tw(pillStr,{Transparency=0.2,Color=T.BorderHi},.1)
            Tw(lbl,{TextColor3=T.TxtPri},.1)
        end
    end)
    btn.MouseLeave:Connect(function()
        if not sec._active then
            Tw(pill,{BackgroundTransparency=1},.1)
            Tw(pillStr,{Transparency=0.4,Color=T.Border},.1)
            Tw(lbl,{TextColor3=T.TxtSec},.1)
        end
    end)

    btn.MouseButton1Click:Connect(function()
        -- deseleciona anterior
        if self._active then
            local p=self._active
            p._active=false
            p._lbl.Font=Enum.Font.Gotham
            Tw(p._lbl,{TextColor3=T.TxtSec},.12)
            Tw(p._dot,{BackgroundColor3=T.TxtDim},.12)
            Tw(p._pill,{BackgroundTransparency=1},.12)
            p._pillStr.Color=T.Border
            p._pillStr.Transparency=0.4
        end
        -- ativa novo
        sec._active=true
        lbl.Font=Enum.Font.GothamBold
        Tw(lbl,{TextColor3=T.TxtAcc},.12)
        Tw(dot,{BackgroundColor3=T.Accent},.12)
        pill.BackgroundColor3=T.AccentDim
        Tw(pill,{BackgroundTransparency=0.2},.12)
        pillStr.Color=T.Accent
        pillStr.Transparency=0
        self._active=sec
        self:_Bread(cat.Name, name)
        self:_Render(sec)
    end)

    cat._secs[#cat._secs+1]=sec
    -- tamanho = 26px por pill + 4px padding extra
    cat._sf.Size=UDim2.new(1,0,0,cat._sl.AbsoluteContentSize.Y+26)
    return sec
end

-- ══════════════════════════════════════════════
--  RENDER
-- ══════════════════════════════════════════════
function ShadowUI:_Render(sec)
    CloseAnyDrop()
    for _, pnl in ipairs({self.LeftPanel,self.RightPanel}) do
        for _, c in ipairs(pnl:GetChildren()) do
            if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then
                c:Destroy()
            end
        end
    end
    for _, c in ipairs(self.TabList:GetChildren()) do
        if not c:IsA("UIListLayout") then c:Destroy() end
    end

    -- Tabs
    for _, s in ipairs(sec._cat._secs) do
        local act = (s==sec)
        local tab = New("Frame",{
            Parent=self.TabList,
            BackgroundColor3=act and T.AccentDim or T.TabBar,
            BackgroundTransparency=act and 0.6 or 1,
            Size=UDim2.new(0,88,0,28), ZIndex=7,
            Position=UDim2.new(0,0,0.5,-14),
        })
        Corner(7, tab)
        if act then
            -- Underline accent com cantos arredondados
            local tUnder = New("Frame",{
                Parent=tab, BackgroundColor3=T.Accent,
                Position=UDim2.new(0,8,1,-2),
                Size=UDim2.new(1,-16,0,2),
                ZIndex=9, BorderSizePixel=0,
            })
            Corner(2,tUnder)
            New("UIGradient",{
                Parent=tUnder,
                Transparency=NumberSequence.new{
                    NumberSequenceKeypoint.new(0, 0.4),
                    NumberSequenceKeypoint.new(0.5, 0),
                    NumberSequenceKeypoint.new(1, 0.4),
                },
            })
        end
        -- Dot diamante substituído por círculo premium
        local tDot = New("Frame",{
            Parent=tab,
            BackgroundColor3=act and T.Accent or T.AccentDim,
            Position=UDim2.new(0,9,0.5,-3),
            Size=UDim2.new(0,6,0,6),
            ZIndex=8, BorderSizePixel=0,
        })
        Corner(3,tDot)
        Lbl(tab, s.Name, 10,
            act and T.TxtAcc or T.TxtSec,
            act and Enum.Font.GothamBold or Enum.Font.Gotham,
            Enum.TextXAlignment.Left,
            UDim2.new(0,20,0,0), UDim2.new(1,-22,1,0), 8)
        local th = New("TextButton",{
            Parent=tab, BackgroundTransparency=1,
            Size=UDim2.new(1,0,1,0), Text="", ZIndex=10,
        })
        th.MouseEnter:Connect(function()
            if not act then Tw(tab,{BackgroundTransparency=0.85},.1) end
        end)
        th.MouseLeave:Connect(function()
            if not act then Tw(tab,{BackgroundTransparency=1},.1) end
        end)
        local _s=s
        th.MouseButton1Click:Connect(function() _s._btn.MouseButton1Click:Fire() end)
    end

    for _, ctrl in ipairs(sec._left)  do self:_Build(self.LeftPanel,  ctrl) end
    for _, ctrl in ipairs(sec._right) do self:_Build(self.RightPanel, ctrl) end
end

-- ══════════════════════════════════════════════
--  BUILD
-- ══════════════════════════════════════════════
function ShadowUI:_Build(panel, ctrl)
    if ctrl.type=="toggle"   then return self:_BToggle(panel,ctrl)   end
    if ctrl.type=="slider"   then return self:_BSlider(panel,ctrl)   end
    if ctrl.type=="dropdown" then return self:_BDropdown(panel,ctrl) end
    if ctrl.type=="header"   then return self:_BHeader(panel,ctrl)   end
    if ctrl.type=="label"    then return self:_BLabel(panel,ctrl)    end
    if ctrl.type=="button"   then return self:_BButton(panel,ctrl)   end
    if ctrl.type=="_custom"  then return ctrl._fn(panel)             end
end


    })
    Utils.AddCorner(preview, CORNER_SMALL)
    Utils.AddStroke(preview, theme:Get("Border"))

    local pickerFrame = Utils.Create("Frame", {
        Name                    = "Picker",
        Size                    = UDim2.new(1, 0, 0, 0),
        Position                = UDim2.new(0, 0, 1, 4),
        BackgroundColor3        = theme:Get("Surface"),
        BorderSizePixel         = 0,
        Visible                 = false,
        ClipsDescendants        = true,
        ZIndex                  = 60,
        Parent                  = wrapper,
    })
    Utils.AddCorner(pickerFrame, CORNER_SMALL)
    Utils.AddStroke(pickerFrame, theme:Get("Border"))
    Utils.AddPadding(pickerFrame, 8, 8, 8, 8)

    -- Saturation/Value picker
    local svCanvas = Utils.Create("ImageLabel", {
        Name                    = "SVCanvas",
        Size                    = UDim2.new(1, 0, 0, 100),
        BackgroundColor3        = Color3.fromHSV(hue, 1, 1),
        BorderSizePixel         = 0,
        Image                   = "rbxassetid://4155801252",
        ZIndex                  = 61,
        Parent                  = pickerFrame,
    })
    Utils.AddCorner(svCanvas, CORNER_SMALL)

    local svThumb = Utils.Create("Frame", {
        Name                    = "SVThumb",
        Size                    = UDim2.new(0, 10, 0, 10),
        AnchorPoint             = Vector2.new(0.5, 0.5),
        BackgroundColor3        = Color3.fromRGB(255, 255, 255),
        BorderSizePixel         = 0,
        ZIndex                  = 62,
        Parent                  = svCanvas,
    })
    Utils.AddCorner(svThumb, UDim.new(1, 0))
    Utils.AddStroke(svThumb, Color3.fromRGB(0, 0, 0), 2)

    local hueBarBg = Utils.Create("Frame", {
        Name                    = "HueBar",
        Size                    = UDim2.new(1, 0, 0, 14),
        Position                = UDim2.new(0, 0, 0, 108),
        BorderSizePixel         = 0,
        ZIndex                  = 61,
        Parent                  = pickerFrame,
    })
    Utils.AddCorner(hueBarBg, CORNER_SMALL)

    local hueGrad = Instance.new("UIGradient")
    hueGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0,    Color3.fromRGB(255,0,0)),
        ColorSequenceKeypoint.new(0.17, Color3.fromRGB(255,255,0)),
        ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0,255,0)),
        ColorSequenceKeypoint.new(0.5,  Color3.fromRGB(0,255,255)),
        ColorSequenceKeypoint.new(0.67, Color3.fromRGB(0,0,255)),
        ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255,0,255)),
        ColorSequenceKeypoint.new(1,    Color3.fromRGB(255,0,0)),
    })
    hueGrad.Rotation = 0
    hueGrad.Parent = hueBarBg

    local hueThumb = Utils.Create("Frame", {
        Name                    = "HueThumb",
        Size                    = UDim2.new(0, 6, 1, 2),
        AnchorPoint             = Vector2.new(0.5, 0.5),
        Position                = UDim2.new(hue, 0, 0.5, 0),
        BackgroundColor3        = Color3.fromRGB(255, 255, 255),
        BorderSizePixel         = 0,
        ZIndex                  = 62,
        Parent                  = hueBarBg,
    })
    Utils.AddCorner(hueThumb, UDim.new(0, 3))
    Utils.AddStroke(hueThumb, Color3.fromRGB(0, 0, 0), 1)

    local hexBg = Utils.Create("Frame", {
        Name                    = "HexBg",
        Size                    = UDim2.new(1, 0, 0, 26),
        Position                = UDim2.new(0, 0, 0, 130),
        BackgroundColor3        = theme:Get("Background"),
        BorderSizePixel         = 0,
        ZIndex                  = 61,
        Parent                  = pickerFrame,
    })
    Utils.AddCorner(hexBg, CORNER_SMALL)
    Utils.AddPadding(hexBg, 0, 6, 0, 6)

    local hexInput = Utils.Create("TextBox", {
        Size                    = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency  = 1,
        Text                    = string.format("#%02X%02X%02X",
            math.floor(currentColor.R*255),
            math.floor(currentColor.G*255),
            math.floor(currentColor.B*255)),
        TextColor3              = theme:Get("Text"),
        TextSize                = 12,
        Font                    = Enum.Font.Code,
        ZIndex                  = 62,
        Parent                  = hexBg,
    })

    local function updateColor()
        currentColor = Color3.fromHSV(hue, sat, val)
        preview.BackgroundColor3 = currentColor
        svCanvas.BackgroundColor3 = Color3.fromHSV(hue, 1, 1)
        svThumb.Position = UDim2.new(sat, 0, 1 - val, 0)
        hueThumb.Position = UDim2.new(hue, 0, 0.5, 0)
        hexInput.Text = string.format("#%02X%02X%02X",
            math.floor(currentColor.R*255),
            math.floor(currentColor.G*255),
            math.floor(currentColor.B*255))
        if opts.Callback then pcall(opts.Callback, currentColor) end
    end

    local svDragging = false
    local hueDragging = false

    Utils.Connect(connections, svCanvas.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            svDragging = true
        end
    end)
    Utils.Connect(connections, UserInputService.InputEnded, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            svDragging = false
            hueDragging = false
        end
    end)
    Utils.Connect(connections, UserInputService.InputChanged, function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            if svDragging then
                local relX = Utils.Clamp((input.Position.X - svCanvas.AbsolutePosition.X) / svCanvas.AbsoluteSize.X, 0, 1)
                local relY = Utils.Clamp((input.Position.Y - svCanvas.AbsolutePosition.Y) / svCanvas.AbsoluteSize.Y, 0, 1)
                sat = relX
                val = 1 - relY
                updateColor()
            elseif hueDragging then
                local relX = Utils.Clamp((input.Position.X - hueBarBg.AbsolutePosition.X) / hueBarBg.AbsoluteSize.X, 0, 1)
                hue = relX
                updateColor()
            end
        end
    end)
    Utils.Connect(connections, hueBarBg.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            hueDragging = true
            local relX = Utils.Clamp((input.Position.X - hueBarBg.AbsolutePosition.X) / hueBarBg.AbsoluteSize.X, 0, 1)
            hue = relX
            updateColor()
        end
    end)

    Utils.Connect(connections, hexInput.FocusLost, function()
        local hex = hexInput.Text:gsub("#", "")
        if #hex == 6 then
            local r = tonumber(hex:sub(1,2), 16)
            local g = tonumber(hex:sub(3,4), 16)
            local b = tonumber(hex:sub(5,6), 16)
            if r and g and b then
                currentColor = Color3.fromRGB(r, g, b)
                hue, sat, val = Color3.toHSV(currentColor)
                updateColor()
            end
        end
    end)

    Utils.Connect(connections, frame.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            open = not open
            pickerFrame.Visible = true
            if open then
                self.Anim:Play(pickerFrame, {Size = UDim2.new(1, 0, 0, 168)}, TWEEN_MEDIUM)
                wrapper.Size = UDim2.new(1, 0, 0, 36 + 172)
            else
                self.Anim:Play(pickerFrame, {Size = UDim2.new(1, 0, 0, 0)}, TWEEN_MEDIUM)
                task.delay(0.25, function()
                    if not open then
                        pickerFrame.Visible = false
                        wrapper.Size = UDim2.new(1, 0, 0, 36)
                    end
                end)
            end
        end
    end)

    return {
        Frame    = wrapper,
        GetColor = function() return currentColor end,
        SetColor = function(_, color)
            currentColor = color
            hue, sat, val = Color3.toHSV(color)
            updateColor()
        end,
        Destroy  = function()
            Utils.Disconnect(connections)
            wrapper:Destroy()
        end,
    }
end


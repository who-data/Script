    end

    New("TextLabel", {
        Parent               = btnFrame,
        BackgroundTransparency = 1,
        Position             = UDim2.new(0, labelX + 6, 0, 0),
        Size                 = UDim2.new(1, -(labelX + 12), 1, 0),

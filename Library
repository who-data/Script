function ShadowUI:_BLabel(parent, ctrl)
    local row = MkRow(parent, 22)
    MkTxt(row, ctrl.text or "", 11, ctrl.color or T.TxtSec, Enum.Font.Gotham,
        Enum.TextXAlignment.Left, nil, UDim2.new(1,0,1,0), 3)
    return row
end

-- ══════════════════════════════════════════════
--  ABA CONFIG
-- ══════════════════════════════════════════════
function ShadowUI:_BuildConfigTab()
    local cat = self:AddCategory("⚙  Config")
    local sec = self:AddSection(cat, "Settings")

    local themeNames = {}
    for k in pairs(Themes) do table.insert(themeNames, k) end
    table.sort(themeNames)

    local themeDrop = {
        type="dropdown", text="UI Theme",
        options=themeNames, default=self._currentTheme,
        callback=function(v) self:_ApplyTheme(v) end,
    }

    local cfgDrop = {
        type="dropdown", text="Config",
        options=ListConfigs(), default="default",
    }

    local function RefreshCfgList()
        cfgDrop.options = ListConfigs()
    end

    self._cfgDropCtrl = cfgDrop
    self._cfgSection  = sec

    -- Botão helper
    local function CfgBtnCtrl(label, bgCol, hoverCol, cb)
        return {
            type="__custom",
            _build=function(parent)
                local row = MkRow(parent, 30)
                local Btn = New("TextButton", {
                    Parent=row, BackgroundColor3=bgCol or T.Accent,
                    Size=UDim2.new(1,0,1,0), Text=label,
                    Font=Enum.Font.GothamBold, TextColor3=T.White,
                    TextSize=11, AutoButtonColor=false, ZIndex=3,
                })
                Corn(5, Btn); Stro(T.Border, 1, Btn)
                Btn.MouseEnter:Connect(function() Tw(Btn,{BackgroundColor3=hoverCol or T.AccentHi},.08) end)
                Btn.MouseLeave:Connect(function() Tw(Btn,{BackgroundColor3=bgCol or T.Accent},.08) end)
                Btn.MouseButton1Click:Connect(function() if cb then cb() end end)
                return row
            end,
        }
    end

    -- Botões duplos lado a lado
    local function DualBtn(lLabel, lBg, lHov, lCb, rLabel, rBg, rHov, rCb)
        return {
            type="__custom",
            _build=function(parent)
                local row = MkRow(parent, 30)
                local function MkHalf(pos, sz, label, bg, hov, cb)
                    local f = New("Frame",{Parent=row,BackgroundTransparency=1,Position=pos,Size=sz,ZIndex=3})
                    local Btn = New("TextButton",{
                        Parent=f, BackgroundColor3=bg, Size=UDim2.new(1,0,1,0),
                        Text=label, Font=Enum.Font.GothamBold, TextColor3=T.White,
                        TextSize=11, AutoButtonColor=false, ZIndex=4,
                    })
                    Corn(5,Btn); Stro(T.Border,1,Btn)
                    Btn.MouseEnter:Connect(function() Tw(Btn,{BackgroundColor3=hov},.08) end)
                    Btn.MouseLeave:Connect(function() Tw(Btn,{BackgroundColor3=bg},.08) end)
                    Btn.MouseButton1Click:Connect(function() if cb then cb() end end)
                end
                MkHalf(UDim2.new(0,0,0,0),    UDim2.new(0.5,-3,1,0), lLabel, lBg, lHov, lCb)
                MkHalf(UDim2.new(0.5,3,0,0),  UDim2.new(0.5,-3,1,0), rLabel, rBg, rHov, rCb)
                return row
            end,
        }
    end

    sec._left = {
        themeDrop,
        {type="header", text="Config Files"},
        cfgDrop,
        DualBtn(
            "💾  Save",  T.Accent,                T.AccentHi,
            function()
                local name = cfgDrop._getValue and cfgDrop._getValue() or "default"
                self:SaveConfig(name); RefreshCfgList()
            end,
            "📂  Load", T.DropBg, T.RowHov,
            function()
                local name = cfgDrop._getValue and cfgDrop._getValue() or "default"
                self:LoadConfig(name)
            end
        ),
        DualBtn(
            "✏  New",  T.DropBg, T.RowHov,
            function()
                local name = "config_"..tostring(os.time())
                self:SaveConfig(name); RefreshCfgList()
                if cfgDrop._setValue then cfgDrop._setValue(name) end
            end,
            "🗑  Delete", Color3.fromRGB(175,38,38), Color3.fromRGB(215,58,58),
            function()
                local name = cfgDrop._getValue and cfgDrop._getValue() or "default"
                if name ~= "default" then
                    pcall(delfile, CONFIG_DIR.."/"..name..CONFIG_EXT)
                    RefreshCfgList()
                    if cfgDrop._setValue then cfgDrop._setValue("default") end
                end
            end
        ),
        {type="header", text="Auto Load"},
        {
            type="toggle", text="Auto Load on Start",
            default=self:_GetAutoLoad(),
            callback=function(v) self:_SetAutoLoad(v) end,
        },
    }

    task.defer(function()
        if self:_GetAutoLoad() then
            local name = self:_GetAutoLoadName()
            if name then self:LoadConfig(name) end
        end
    end)
end

-- ══════════════════════════════════════════════
--  THEME APPLY
-- ══════════════════════════════════════════════
function ShadowUI:_ApplyTheme(themeName)
    local th = Themes[themeName]
    if not th then return end
    self._currentTheme = themeName
    for k, v in pairs(th) do T[k]=v end
    -- Reaplica cores principais
    pcall(function()
        self.Win.BackgroundColor3    = T.Bg
        self.Header.BackgroundColor3 = T.Header
        self.Sidebar.BackgroundColor3= T.Sidebar
        self.Content.BackgroundColor3= T.Bg
        self.TabBar.BackgroundColor3 = T.SubHdr
        self._accLine.BackgroundColor3= T.Accent
        self.FloatBtn.BackgroundColor3= T.Accent
    end)
    if self._activeSec then self:_Render(self._activeSec) end
end

-- ══════════════════════════════════════════════
--  SAVE / LOAD
-- ══════════════════════════════════════════════
function ShadowUI:_CollectValues()
    local data = {theme=self._currentTheme, values={}}
    for id, ctrl in pairs(self._controls) do
        if ctrl._getValue then
            data.values[id] = ctrl._getValue()
        end
    end
    return data
end

function ShadowUI:SaveConfig(name)
    name = name or "default"
    local data = self:_CollectValues()
    local ok, json = pcall(HttpService.JSONEncode, HttpService, data)
    if ok then SafeWrite(CONFIG_DIR.."/"..name..CONFIG_EXT, json) end
end

function ShadowUI:LoadConfig(name)
    name = name or "default"
    local raw = SafeRead(CONFIG_DIR.."/"..name..CONFIG_EXT)
    if not raw then return end
    local ok, data = pcall(HttpService.JSONDecode, HttpService, raw)
    if not ok or type(data)~="table" then return end
    if data.theme then self:_ApplyTheme(data.theme) end
    if data.values then
        for id, v in pairs(data.values) do
            local ctrl = self._controls[id]
            if ctrl and ctrl._setValue then ctrl._setValue(v) end
        end
    end
end

function ShadowUI:_GetAutoLoad()
    local raw = SafeRead(CONFIG_DIR.."/__autoload"..CONFIG_EXT)
    if not raw then return false end
    local ok, d = pcall(HttpService.JSONDecode, HttpService, raw)
    return ok and d and d.enabled or false
end

function ShadowUI:_GetAutoLoadName()
    local raw = SafeRead(CONFIG_DIR.."/__autoload"..CONFIG_EXT)
    if not raw then return nil end
    local ok, d = pcall(HttpService.JSONDecode, HttpService, raw)
    return ok and d and d.config or nil
end

function ShadowUI:_SetAutoLoad(enabled, configName)
    local d = {enabled=enabled, config=configName or "default"}
    local ok, json = pcall(HttpService.JSONEncode, HttpService, d)
    if ok then SafeWrite(CONFIG_DIR.."/__autoload"..CONFIG_EXT, json) end
end

-- ══════════════════════════════════════════════
--  PUBLIC API
-- ══════════════════════════════════════════════
local function AddCtrl(sec, side, cfg)
    local list = (side=="right") and sec._right or sec._left
    list[#list+1] = cfg
    if sec._active then
        local ui    = sec._ui
        local panel = (side=="right") and ui.RightScroll or ui.LeftScroll
        ui:_Build(panel, cfg)
    end
    return cfg
end

function ShadowUI:Toggle(sec, side, cfg)
    cfg=cfg or{}; cfg.type="toggle"
    if cfg.id then self._controls[cfg.id]=cfg end
    return AddCtrl(sec, side, cfg)
end

function ShadowUI:Slider(sec, side, cfg)
    cfg=cfg or{}; cfg.type="slider"
    if cfg.id then self._controls[cfg.id]=cfg end
    return AddCtrl(sec, side, cfg)
end

function ShadowUI:Dropdown(sec, side, cfg)
    cfg=cfg or{}; cfg.type="dropdown"
    if cfg.id then self._controls[cfg.id]=cfg end
    return AddCtrl(sec, side, cfg)
end

function ShadowUI:SectionHeader(sec, side, cfg)
    cfg=cfg or{}; cfg.type="header"
    return AddCtrl(sec, side, cfg)
end

function ShadowUI:Label(sec, side, cfg)
    cfg=cfg or{}; cfg.type="label"
    return AddCtrl(sec, side, cfg)
end

function ShadowUI:BindToggleKey(key)
    UIS.InputBegan:Connect(function(i, gpe)
        if gpe then return end
        if i.KeyCode==key then self:_ToggleVisible() end
    end)
end

function ShadowUI:OpenFirst()
    for _, cat in ipairs(self._sidebar) do
        if cat.Name ~= "⚙  Config" then
            cat._row.MouseButton1Click:Fire()
            return
        end
    end
end

function ShadowUI:Destroy()
    self.Gui:Destroy()
end

-- ══════════════════════════════════════════════
return ShadowUI

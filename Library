        -- ── Activate function ────────────────────────────────────────────────────
        local function activate()
            if Win._active then
                local pa = Win._active
                pa._active = false
                pa._page.Visible = false
                pa._btn.BackgroundTransparency = 1
                tween(pa._btnBG, { BackgroundTransparency = 1 })
                pa._btn:FindFirstChild("ActiveBar", true).Visible = false
                tween(pa._btn:FindFirstChildOfClass("TextLabel"), { TextColor3 = C.TEXT_DIM })
                for _, v in ipairs(pa._btn:GetChildren()) do
                    if v:IsA("TextLabel") then
                        tween(v, { TextColor3 = C.TEXT_DIM })
                    end
                end
            end
            Win._active = Tab
            Tab._active = true
            page.Visible = true
            tween(btnBG, { BackgroundTransparency = 0.88 })
            activeBar.Visible = true
            tween(icnLbl, { TextColor3 = C.ACCENT })
            tween(nameLbl, { TextColor3 = C.WHITE, Font = Enum.Font.GothamBold })
        end

        btnClick.MouseEnter:Connect(function()
            if not Tab._active then
                tween(btnBG, { BackgroundTransparency = 0.95 })
                tween(icnLbl, { TextColor3 = C.TEXT_SUB })
                tween(nameLbl, { TextColor3 = C.TEXT_SUB })
            end
        end)
        btnClick.MouseLeave:Connect(function()
            if not Tab._active then
                tween(btnBG, { BackgroundTransparency = 1 })
                tween(icnLbl, { TextColor3 = C.TEXT_DIM })
                tween(nameLbl, { TextColor3 = C.TEXT_DIM })
            end
        end)
        btnClick.MouseButton1Click:Connect(function()
            ripple(btn, UserInputService:GetMouseLocation().X, UserInputService:GetMouseLocation().Y, C.ACCENT)
            activate()
        end)

        table.insert(Win._tabs, Tab)
        if #Win._tabs == 1 then activate() end


-- ══════════════════════════════════════════════
function ShadowUI:_Bread(catName, secName)
    for _, c in ipairs(self.BreadFrame:GetChildren()) do
        if c ~= self.BreadCat and not c:IsA("UIListLayout") then c:Destroy() end
    end
    self.BreadCat.Text = catName or ""
    if secName then
        MkTxt(self.BreadFrame, "›", 14, T.TxtDim, Enum.Font.Gotham,
            Enum.TextXAlignment.Center, nil, UDim2.new(0,10,1,0), 6)
        MkTxt(self.BreadFrame, secName, 11, T.TxtAcc, Enum.Font.GothamBold,
            Enum.TextXAlignment.Left, nil, UDim2.new(0,120,1,0), 6)
    end
end


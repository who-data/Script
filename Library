function Window:AddTab(name, icon)
    local contentFrame = Util.Create("ScrollingFrame", {
        Size = UDim2.new(1, 0, 1, -36),
        Position = UDim2.new(0, 0, 0, 36),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = Theme.Accent,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        Visible = false,
        Parent = self._contentArea,
    })
    Util.AddPadding(contentFrame, 8, 12, 12, 16)
    Util.AddListLayout(contentFrame, 8)

    local isFirst = #self._tabs == 0

    -- sidebar button
    local tabBtn = Util.Create("TextButton", {
        Size = UDim2.new(1, 0, 0, 36),
        BackgroundTransparency = 1,
        Text = "",
        AutoButtonColor = false,
        Parent = self._tabList,
    })

    local activeBar = Util.Create("Frame", {
        Size = isFirst and UDim2.new(0, 2, 0.7, 0) or UDim2.new(0, 0, 0.7, 0),
        Position = UDim2.new(0, 0, 0.15, 0),
        BackgroundColor3 = Theme.Accent,
        BorderSizePixel = 0,
        Parent = tabBtn,
    })

    local iconLabel = Util.Create("TextLabel", {
        Size = UDim2.new(0, 22, 1, 0),
        Position = UDim2.new(0, 16, 0, 0),
        BackgroundTransparency = 1,
        Text = icon or "",
        TextColor3 = isFirst and Theme.TextAccent or Theme.TextSecondary,
        Font = Theme.Font,
        TextSize = 14,
        Parent = tabBtn,
    })

    local nameLabel = Util.Create("TextLabel", {
        Size = UDim2.new(1, -44, 1, 0),
        Position = UDim2.new(0, 40, 0, 0),
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = isFirst and Theme.TextAccent or Theme.TextSecondary,
        Font = Theme.FontSemiBold,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = tabBtn,
    })

    -- BG hover
    local hoverBG = Util.Create("Frame", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = Theme.Accent,
        BackgroundTransparency = 1,
        ZIndex = -1,
        Parent = tabBtn,
    })

    local tabObj = Tab.new(tabBtn, contentFrame)

    if isFirst then
        contentFrame.Visible = true
        self._activeTab = tabObj
        self._tabTitleLabel.Text = name:upper()
    end

    tabBtn.MouseEnter:Connect(function()
        if self._activeTab ~= tabObj then
            Util.Tween(hoverBG, { BackgroundTransparency = 0.93 })
        end
    end)
    tabBtn.MouseLeave:Connect(function()
        Util.Tween(hoverBG, { BackgroundTransparency = 1 })
    end)

    tabBtn.MouseButton1Click:Connect(function()
        if self._activeTab == tabObj then return end

        -- deactivate old
        if self._activeTab then
            self._activeTab._scroll.Visible = false
            local oldBtn = self._activeTab._btn
            local oldName = oldBtn:FindFirstChild("TextLabel") -- nameLabel proxy
            Util.Tween(activeBar, { Size = UDim2.new(0, 0, 0.7, 0) })
            for _, c in ipairs(oldBtn:GetChildren()) do
                if c:IsA("TextLabel") then
                    Util.Tween(c, { TextColor3 = Theme.TextSecondary })
                end
            end
        end

        self._activeTab = tabObj
        contentFrame.Visible = true
        self._tabTitleLabel.Text = name:upper()

        Util.Tween(activeBar, { Size = UDim2.new(0, 2, 0.7, 0) })
        Util.Tween(iconLabel, { TextColor3 = Theme.TextAccent })
        Util.Tween(nameLabel, { TextColor3 = Theme.TextAccent })
        Util.Tween(hoverBG, { BackgroundTransparency = 1 })
    end)

    table.insert(self._tabs, tabObj)
    return tabObj
end

function Window:SetTheme(customTheme)
    for k, v in pairs(customTheme) do
        Theme[k] = v
    end
end

function Window:Destroy()
    self._gui:Destroy()
end


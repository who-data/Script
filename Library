    local ic2=New("Frame",{Parent=toast,BackgroundColor3=ac,BackgroundTransparency=0.82,Position=UDim2.new(0,10,.5,-9),Size=UDim2.new(0,18,0,18),ZIndex=602,BorderSizePixel=0}); Corner(9,ic2)

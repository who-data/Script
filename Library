ThemeManager.__index = ThemeManager

ThemeManager.Defaults = {
    Background      = Color3.fromRGB(12, 12, 16),
    BackgroundAlt   = Color3.fromRGB(18, 18, 24),
    Surface         = Color3.fromRGB(22, 22, 30),
    SurfaceAlt      = Color3.fromRGB(28, 28, 38),
    Border          = Color3.fromRGB(40, 40, 55),
    BorderLight     = Color3.fromRGB(55, 55, 75),
    Accent          = Color3.fromRGB(120, 80, 255),
    AccentDark      = Color3.fromRGB(85, 55, 185),
    AccentLight     = Color3.fromRGB(150, 110, 255),
    AccentGlow      = Color3.fromRGB(120, 80, 255),
    Text            = Color3.fromRGB(240, 240, 250),
    TextSecondary   = Color3.fromRGB(160, 160, 180),
    TextMuted       = Color3.fromRGB(100, 100, 120),
    TextDisabled    = Color3.fromRGB(70, 70, 85),
    Success         = Color3.fromRGB(80, 200, 120),
    Warning         = Color3.fromRGB(255, 180, 50),
    Error           = Color3.fromRGB(255, 80, 80),
    Info            = Color3.fromRGB(80, 160, 255),
    White           = Color3.fromRGB(255, 255, 255),
    Black           = Color3.fromRGB(0, 0, 0),

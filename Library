-- ══════════════════════════════════════════════
--  TOGGLE VISIBILIDADE
-- ══════════════════════════════════════════════
function ShadowUI:_ToggleVisible()
    self._visible = not self._visible
    if self._visible then
        self.Win.Visible = true
        Tw(self.Win, {Size=UDim2.new(0,790,0,450)}, .18)
        self.FloatIcon.Text = "◀"
    else
        Tw(self.Win, {Size=UDim2.new(0,0,0,450)}, .18)
        task.delay(.19, function() if not self._visible then self.Win.Visible=false end end)
        self.FloatIcon.Text = "▶"
    end
end


            local mx  = o.Max     or 100
            local val = o.Default or 0
            local sfx = o.Suffix  or ""
            local cb  = o.Callback or function() end

            local row = new("Frame", {
                Parent           = tl,
                BackgroundColor3 = C.ITEM_BG,

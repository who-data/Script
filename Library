function TooltipSys.new(theme, anim)
    local self = setmetatable({ theme = theme, anim = anim, visible = false }, TooltipSys)

    local sg = U.New("ScreenGui", {
        Name = "NexusTooltip", ResetOnSpawn = false,
        DisplayOrder = Z.TOOLTIP, ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
    })
    pcall(function() sg.Parent = game:GetService("CoreGui") end)
    if not sg.Parent then sg.Parent = LocalPlayer:WaitForChild("PlayerGui") end

    local canvas = U.New("Frame", { Size=UDim2.new(1,0,1,0), BackgroundTransparency=1, Parent=sg })

    local box = U.New("Frame", {
        Size = UDim2.new(0, 10, 0, 24),
        BackgroundColor3 = theme:Get("BG4"),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ZIndex = Z.TOOLTIP,
        Visible = false,
        Parent = canvas,
    })
    U.Corner(box, CR_SM)
    U.Stroke(box, theme:Get("Border"), 1)
    U.Pad(box, 5, 10, 5, 10)

    local lbl = U.New("TextLabel", {
        Size = UDim2.new(1,0,1,0),
        BackgroundTransparency = 1,
        TextColor3 = theme:Get("TextLo"),
        TextSize = 11,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        ZIndex = Z.TOOLTIP + 1,
        Parent = box,
    })

    self._sg     = sg
    self._box    = box
    self._label  = lbl
    self._canvas = canvas
    return self
end

function TooltipSys:Attach(inst, text)
    if not text or text == "" then return end
    local conns = {}
    local box   = self._box
    local lbl   = self._label

    U.Connect(conns, inst.MouseEnter, function()
        lbl.Text = text
        local ts = U.MeasureText(text, 11, Enum.Font.Gotham)
        box.Size = UDim2.new(0, math.clamp(ts.X + 24, 60, 240), 0, math.max(ts.Y + 12, 24))
        box.Visible = true
        box.BackgroundTransparency = 1
        lbl.TextTransparency = 1
        self.anim:Play(box, {BackgroundTransparency = 0}, TI.Fast)
        self.anim:Play(lbl, {TextTransparency = 0}, TI.Fast)
    end)

    U.Connect(conns, inst.MouseLeave, function()
        box.Visible = false
        lbl.TextTransparency = 1
        box.BackgroundTransparency = 1
    end)

    U.Connect(conns, inst.MouseMoved, function(x, y)
        local vp  = U.GetViewport()
        local sz  = box.AbsoluteSize
        local px  = math.min(x + 16, vp.X - sz.X - 4)
        local py  = math.min(y + 16, vp.Y - sz.Y - 4)
        box.Position = UDim2.new(0, px, 0, py)
    end)

    return function() U.Disconn(conns) end
end

function TooltipSys:Destroy()
    if self._sg then self._sg:Destroy() end
end


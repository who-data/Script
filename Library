-- ══════════════════════════════════════════════════════════════════
--  CONFIG PANEL  ← redesigned: buttons instead of toggles
-- ══════════════════════════════════════════════════════════════════
function ShadowUI:_BuildConfig(parent, ctrl)
    -- Header
    self:_BuildSectionHeader(parent, { name = ctrl.name or "Config Manager" })

    -- ── Config name input ──────────────────────────────────────
    local InputWrap = Create("Frame", {
        Parent           = parent,
        BackgroundColor3 = Theme.ControlBg,
        BorderSizePixel  = 0,
        Size             = UDim2.new(1, 0, 0, 38),
    })
    RoundCorner(InputWrap, 8)
    Create("UIStroke", { Color = Theme.Border, Thickness = 1, Parent = InputWrap })

    Create("TextLabel", {
        Parent               = InputWrap,
        BackgroundTransparency = 1,
        Position             = UDim2.new(0, 12, 0, 0),
        Size                 = UDim2.new(0, 85, 1, 0),
        Font                 = Enum.Font.Gotham,
        Text                 = "Config Name",
        TextColor3           = Theme.TextSecondary,
        TextSize             = 11,
        TextXAlignment       = Enum.TextXAlignment.Left,
    })

    local NameBox = Create("TextBox", {
        Parent               = InputWrap,
        BackgroundColor3     = Theme.Panel,
        BorderSizePixel      = 0,
        Position             = UDim2.new(0, 98, 0.5, -11),
        Size                 = UDim2.new(1, -110, 0, 22),
        Font                 = Enum.Font.Gotham,
        PlaceholderText      = "Enter config name...",
        PlaceholderColor3    = Theme.TextDisabled,
        Text                 = "",
        TextColor3           = Theme.TextPrimary,
        TextSize             = 11,
        ClearTextOnFocus     = false,
    })
    RoundCorner(NameBox, 5)
    Create("UIStroke", { Color = Theme.Border, Thickness = 1, Parent = NameBox })
    Create("UIPadding", { PaddingLeft = UDim.new(0, 6), Parent = NameBox })

    -- Spacer
    Create("Frame", { Parent = parent, BackgroundTransparency = 1, BorderSizePixel = 0, Size = UDim2.new(1, 0, 0, 4) })

    -- ── Buttons row ───────────────────────────────────────────
    local BtnRow = Create("Frame", {
        Parent               = parent,
        BackgroundTransparency = 1,
        BorderSizePixel      = 0,
        Size                 = UDim2.new(1, 0, 0, 34),
    })
    Create("UIListLayout", {
        Parent            = BtnRow,
        FillDirection     = Enum.FillDirection.Horizontal,
        SortOrder         = Enum.SortOrder.LayoutOrder,
        Padding           = UDim.new(0, 6),
        VerticalAlignment = Enum.VerticalAlignment.Center,
    })
    Create("UIPadding", { PaddingLeft = UDim.new(0, 2), PaddingRight = UDim.new(0, 2), Parent = BtnRow })

    -- Helper to create a config action button
    local function ConfigBtn(label, accent, callback)
        local bg  = accent and Theme.ButtonAccent or Theme.ButtonBg
        local fg  = accent and Theme.Background   or Theme.TextPrimary
        local btn = Create("TextButton", {
            Parent           = BtnRow,
            BackgroundColor3 = bg,
            BorderSizePixel  = 0,
            Size             = UDim2.new(0.25, -5, 0, 28),
            Font             = Enum.Font.GothamBold,
            Text             = label,
            TextColor3       = fg,
            TextSize         = 11,
            AutoButtonColor  = false,
        })
        RoundCorner(btn, 7)
        if not accent then
            Create("UIStroke", { Color = Theme.Border, Thickness = 1, Parent = btn })
        end
        btn.MouseEnter:Connect(function()
            Tween(btn, { BackgroundColor3 = accent and Theme.AccentColor or Theme.ButtonHover }, 0.12)
        end)
        btn.MouseLeave:Connect(function()
            Tween(btn, { BackgroundColor3 = bg }, 0.12)
        end)
        btn.MouseButton1Down:Connect(function()
            Tween(btn, { Size = UDim2.new(0.25, -7, 0, 26) }, 0.08)
        end)
        btn.MouseButton1Up:Connect(function()
            Tween(btn, { Size = UDim2.new(0.25, -5, 0, 28) }, 0.1)
        end)
        btn.MouseButton1Click:Connect(function()
            if callback then callback(NameBox.Text) end
        end)
        return btn
    end

    -- Create (accent/primary)
    ConfigBtn("✦ Create", true, function(name)
        if ctrl.onCreate then ctrl.onCreate(name) end
    end)
    -- Load
    ConfigBtn("⇣ Load", false, function(name)
        if ctrl.onLoad then ctrl.onLoad(name) end
    end)
    -- Save
    ConfigBtn("⇡ Save", false, function(name)
        if ctrl.onSave then ctrl.onSave(name) end
    end)
    -- Delete
    local delBtn = Create("TextButton", {
        Parent           = BtnRow,
        BackgroundColor3 = Color3.fromRGB(80, 25, 25),
        BorderSizePixel  = 0,
        Size             = UDim2.new(0.25, -5, 0, 28),
        Font             = Enum.Font.GothamBold,
        Text             = "✕ Delete",
        TextColor3       = Color3.fromRGB(255, 120, 120),
        TextSize         = 11,
        AutoButtonColor  = false,
    })
    RoundCorner(delBtn, 7)
    Create("UIStroke", { Color = Color3.fromRGB(120, 40, 40), Thickness = 1, Parent = delBtn })
    delBtn.MouseEnter:Connect(function()
        Tween(delBtn, { BackgroundColor3 = Color3.fromRGB(110, 35, 35) }, 0.12)
    end)
    delBtn.MouseLeave:Connect(function()
        Tween(delBtn, { BackgroundColor3 = Color3.fromRGB(80, 25, 25) }, 0.12)
    end)
    delBtn.MouseButton1Down:Connect(function()
        Tween(delBtn, { Size = UDim2.new(0.25, -7, 0, 26) }, 0.08)
    end)
    delBtn.MouseButton1Up:Connect(function()
        Tween(delBtn, { Size = UDim2.new(0.25, -5, 0, 28) }, 0.1)
    end)
    delBtn.MouseButton1Click:Connect(function()
        if ctrl.onDelete then ctrl.onDelete(NameBox.Text) end
    end)

    -- Spacer
    Create("Frame", { Parent = parent, BackgroundTransparency = 1, BorderSizePixel = 0, Size = UDim2.new(1, 0, 0, 6) })

    ctrl._nameBox = NameBox
end

-- ══════════════════════════════════════════════════════════════════
--  PUBLIC CONTROL ADDERS
-- ══════════════════════════════════════════════════════════════════
function ShadowUI:AddToggle(section, side, name, default, callback, description)
    local t = { type = "toggle", name = name, default = default, callback = callback, description = description }
    if side == "left" then
        section._left[#section._left + 1] = t
    else
        section._right[#section._right + 1] = t
    end
    return t
end

function ShadowUI:AddSlider(section, side, name, min, max, default, step, callback)
    local t = { type = "slider", name = name, min = min, max = max, default = default, step = step, callback = callback }
    if side == "left" then
        section._left[#section._left + 1] = t
    else
        section._right[#section._right + 1] = t
    end
    return t
end

function ShadowUI:AddDropdown(section, side, name, options, default, callback)
    local t = { type = "dropdown", name = name, options = options, default = default, callback = callback }
    if side == "left" then
        section._left[#section._left + 1] = t
    else
        section._right[#section._right + 1] = t
    end
    return t
end

function ShadowUI:AddSectionHeader(section, side, name)
    local t = { type = "section_header", name = name }
    if side == "left" then
        section._left[#section._left + 1] = t
    else
        section._right[#section._right + 1] = t
    end
    return t
end

function ShadowUI:AddLabel(section, side, text, color, size, height)
    local t = { type = "label", text = text, color = color, size = size, height = height }
    if side == "left" then
        section._left[#section._left + 1] = t
    else
        section._right[#section._right + 1] = t
    end
    return t
end

function ShadowUI:AddConfig(section, side, name, onCreate, onLoad, onSave, onDelete)
    local t = {
        type     = "config",
        name     = name,
        onCreate = onCreate,
        onLoad   = onLoad,
        onSave   = onSave,
        onDelete = onDelete,
    }
    if side == "left" then
        section._left[#section._left + 1] = t
    else
        section._right[#section._right + 1] = t
    end
    return t
end

-- ══════════════════════════════════════════════════════════════════
--  OPEN / CLOSE
-- ══════════════════════════════════════════════════════════════════
function ShadowUI:Open()
    self.Window.Visible = true
    self._visible       = true
    Tween(self.Window, { Size = UDim2.new(0, 900, 0, 460) }, 0.22, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
end

function ShadowUI:Close()
    Tween(self.Window, { Size = UDim2.new(0, 900, 0, 0) }, 0.18, Enum.EasingStyle.Quint)
    task.delay(0.2, function() self.Window.Visible = false end)
    self._visible = false
end

function ShadowUI:Toggle()
    if self._visible then self:Close() else self:Open() end
end

-- ══════════════════════════════════════════════════════════════════
return ShadowUI

function ComponentFactory:MakeDropdown(parent, opts)
    local opts = opts or {}
    local options   = opts.Options  or {}
    local value     = opts.Default  or options[1]
    local connections = {}
    local theme = self.Theme
    local open = false

    local wrapper = Utils.Create("Frame", {
        Name                    = "Dropdown_" .. (opts.Name or ""),
        Size                    = UDim2.new(1, 0, 0, 36),
        BackgroundTransparency  = 1,
        ClipsDescendants        = false,
        LayoutOrder             = opts.LayoutOrder or 0,
        Parent                  = parent,
    })

    local frame = Utils.Create("Frame", {
        Name                    = "Main",
        Size                    = UDim2.new(1, 0, 0, 36),
        BackgroundColor3        = theme:Get("SurfaceAlt"),
        BorderSizePixel         = 0,
        Parent                  = wrapper,
    })
    Utils.AddCorner(frame, CORNER_SMALL)
    Utils.AddPadding(frame, 0, 10, 0, 10)

    Utils.Create("TextLabel", {
        Name                    = "Name",
        Size                    = UDim2.new(0.55, 0, 1, 0),
        BackgroundTransparency  = 1,
        Text                    = opts.Name or "Dropdown",
        TextColor3              = theme:Get("Text"),
        TextSize                = 13,
        Font                    = Enum.Font.Gotham,
        TextXAlignment          = Enum.TextXAlignment.Left,
        Parent                  = frame,
    })

    local selectedLabel = Utils.Create("TextLabel", {
        Name                    = "Selected",
        Size                    = UDim2.new(0.4, 0, 1, 0),
        Position                = UDim2.new(0.55, 0, 0, 0),
        BackgroundTransparency  = 1,
        Text                    = tostring(value or "Select..."),
        TextColor3              = theme:Get("Accent"),
        TextSize                = 12,
        Font                    = Enum.Font.GothamBold,
        TextXAlignment          = Enum.TextXAlignment.Right,
        TextTruncate            = Enum.TextTruncate.AtEnd,
        Parent                  = frame,
    })

    local arrowLabel = Utils.Create("TextLabel", {
        Name                    = "Arrow",
        Size                    = UDim2.new(0, 20, 1, 0),
        Position                = UDim2.new(1, -20, 0, 0),
        BackgroundTransparency  = 1,
        Text                    = "▾",
        TextColor3              = theme:Get("TextMuted"),
        TextSize                = 14,
        Font                    = Enum.Font.Gotham,
        Parent                  = frame,
    })

    local listFrame = Utils.Create("ScrollingFrame", {
        Name                    = "List",
        Size                    = UDim2.new(1, 0, 0, 0),
        Position                = UDim2.new(0, 0, 1, 4),
        BackgroundColor3        = theme:Get("Surface"),
        BorderSizePixel         = 0,
        Visible                 = false,
        ZIndex                  = 50,
        ClipsDescendants        = true,
        ScrollBarThickness      = 3,
        ScrollBarImageColor3    = theme:Get("Accent"),
        Parent                  = wrapper,
    })
    Utils.AddCorner(listFrame, CORNER_SMALL)
    Utils.AddStroke(listFrame, theme:Get("Border"))
    Utils.MakeScrolling(listFrame)

    local listLayout = Utils.AddListLayout(listFrame, Enum.FillDirection.Vertical, 2)
    Utils.AddPadding(listFrame, 4, 4, 4, 4)

    local function buildList()
        for _, child in ipairs(listFrame:GetChildren()) do
            if child:IsA("Frame") then child:Destroy() end
        end
        for _, opt in ipairs(options) do
            local item = Utils.Create("Frame", {
                Name                    = "Item_" .. tostring(opt),
                Size                    = UDim2.new(1, 0, 0, 28),
                BackgroundColor3        = theme:Get("Surface"),
                BorderSizePixel         = 0,
                ZIndex                  = 51,
                Parent                  = listFrame,
            })
            Utils.AddCorner(item, CORNER_SMALL)
            Utils.AddPadding(item, 0, 8, 0, 8)

            local itl = Utils.Create("TextLabel", {
                Size                    = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency  = 1,
                Text                    = tostring(opt),
                TextColor3              = (opt == value) and theme:Get("Accent") or theme:Get("Text"),
                TextSize                = 12,
                Font                    = Enum.Font.Gotham,
                TextXAlignment          = Enum.TextXAlignment.Left,
                ZIndex                  = 52,
                Parent                  = item,
            })

            item.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    value = opt
                    selectedLabel.Text = tostring(opt)
                    if opts.Callback then pcall(opts.Callback, value) end
                    if opts.Flag then self.Config:SetFlag(opts.Flag, value) end
                    buildList()
                end
            end)
            item.MouseEnter:Connect(function()
                self.Anim:Play(item, {BackgroundColor3 = theme:Get("SurfaceAlt")}, TWEEN_SHORT)
            end)
            item.MouseLeave:Connect(function()
                self.Anim:Play(item, {BackgroundColor3 = theme:Get("Surface")}, TWEEN_SHORT)
            end)
        end
        local totalH = math.min(#options * 30 + 8, 160)
        listFrame.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 8)
        listFrame.Size = UDim2.new(1, 0, 0, totalH)
    end

    buildList()

    local function toggle()
        open = not open
        listFrame.Visible = true
        if open then
            self.Anim:Play(listFrame, {Size = UDim2.new(1, 0, 0, math.min(#options * 30 + 8, 160))}, TWEEN_MEDIUM)
            self.Anim:Play(arrowLabel, {Rotation = 180}, TWEEN_SHORT)
            wrapper.Size = UDim2.new(1, 0, 0, 36 + math.min(#options * 30 + 8, 160) + 4)
        else
            self.Anim:Play(listFrame, {Size = UDim2.new(1, 0, 0, 0)}, TWEEN_MEDIUM)
            self.Anim:Play(arrowLabel, {Rotation = 0}, TWEEN_SHORT)
            task.delay(0.25, function()
                if not open then
                    listFrame.Visible = false
                    wrapper.Size = UDim2.new(1, 0, 0, 36)
                end
            end)
        end
    end

    Utils.Connect(connections, frame.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            toggle()
        end
    end)

    Utils.Connect(connections, frame.MouseEnter, function()
        self.Anim:Play(frame, {BackgroundColor3 = theme:Get("Surface")}, TWEEN_SHORT)
    end)
    Utils.Connect(connections, frame.MouseLeave, function()
        self.Anim:Play(frame, {BackgroundColor3 = theme:Get("SurfaceAlt")}, TWEEN_SHORT)
    end)

    if opts.Tooltip then self.Tooltip:Attach(frame, opts.Tooltip) end

    if opts.Flag then
        self.Config:Register(opts.Flag, value, function(v)
            value = v
            selectedLabel.Text = tostring(v)
        end)
    end

    return {
        Frame     = wrapper,
        GetValue  = function() return value end,
        SetOptions = function(_, newOpts)
            options = newOpts
            buildList()
        end,
        SetValue  = function(_, v)
            value = v
            selectedLabel.Text = tostring(v)
            buildList()
        end,
        Destroy   = function()
            Utils.Disconnect(connections)
            wrapper:Destroy()
        end,
    }
end


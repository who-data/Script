            Text = name,
            TextColor3 = T.Text,
            Font = T.FontSemi,
            TextSize = 13,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = row,
        })
        New("TextLabel", {
            Size = UDim2.new(1, -120, 0, 13),
            Position = UDim2.new(0, 0, 0, 24),
            BackgroundTransparency = 1,
            Text = desc,
            TextColor3 = T.TextDim,
            Font = T.Font,
            TextSize = 11,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = row,
        })
    end

    local b = New("TextButton", {
        Size = desc and UDim2.new(0, 110, 0, 28) or UDim2.new(1, 0, 0, 30),
        Position = desc and UDim2.new(1, -110, 0.5, -14) or UDim2.new(0, 0, 0, 7),
        BackgroundColor3 = T.BGLight,
        Text = desc and "Execute" or name,
        TextColor3 = T.Text,
        Font = T.FontSemi,
        TextSize = 12,
        AutoButtonColor = false,
        Parent = row,
    })
    Corner(b)
    local bsk = Stroke(b, T.Border)

    b.MouseEnter:Connect(function()
        Tween(b, { BackgroundColor3 = T.Accent })
        Tween(bsk, { Color = T.AccentLight })
        Tween(b, { TextColor3 = Color3.fromRGB(255,255,255) })
    end)
    b.MouseLeave:Connect(function()
        Tween(b, { BackgroundColor3 = T.BGLight })
        Tween(bsk, { Color = T.Border })
        Tween(b, { TextColor3 = T.Text })
    end)
    b.MouseButton1Click:Connect(function()
        Tween(b, { BackgroundColor3 = T.AccentDark }, 0.07)
        task.delay(0.1, function() Tween(b, { BackgroundColor3 = T.Accent }) end)
        cb()
    end)

    Separator(row)
    return { Fire = cb }
end

-- ── KEYBIND ─────────────────────────────────────────────────
local function MakeKeybind(parent, name, opts)
    opts = opts or {}
    local key  = opts.Default or Enum.KeyCode.Unknown
    local cb   = opts.Callback or function() end
    local listening = false

    local row = New("Frame", {
        Size = UDim2.new(1, 0, 0, 38),
        BackgroundTransparency = 1,
        Parent = parent,
    })

    New("TextLabel", {
        Size = UDim2.new(1, -125, 1, 0),
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = T.Text,
        Font = T.FontSemi,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = row,
    })

    local kb = New("TextButton", {
        Size = UDim2.new(0, 115, 0, 26),
        Position = UDim2.new(1, -115, 0.5, -13),
        BackgroundColor3 = T.BGDark,
        Text = key and key.Name or "None",
        TextColor3 = T.TextAccent,
        Font = Enum.Font.Code,
        TextSize = 11,
        AutoButtonColor = false,
        Parent = row,
    })
    Corner(kb)
    Stroke(kb, T.Border)

    Separator(row)

    local function SetKey(k, silent)
        key = k
        kb.Text = k and k.Name or "None"
        kb.TextColor3 = T.TextAccent
        if not silent then cb(k) end
    end

    kb.MouseButton1Click:Connect(function()
        listening = true
        kb.Text = "..."
        kb.TextColor3 = T.AccentLight
    end)

    UserInputService.InputBegan:Connect(function(i, gp)
        if listening and not gp then
            if i.UserInputType == Enum.UserInputType.Keyboard then
                listening = false
                SetKey(i.KeyCode)
            end
        elseif not listening and key ~= Enum.KeyCode.Unknown and i.KeyCode == key then
            cb(key)
        end
    end)

    return {
        Set = SetKey,
        Get = function() return key end,
    }
end


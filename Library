-- ══════════════════════════════════════════
-- UTILITÁRIOS
-- ══════════════════════════════════════════
local function Create(cls, props)
    local obj = Instance.new(cls)
    for k, v in pairs(props or {}) do
        if k ~= "Parent" then obj[k] = v end
    end
    if props and props.Parent then obj.Parent = props.Parent end
    return obj
end

local function Tween(obj, t, props)
    TweenService:Create(obj, TweenInfo.new(t, Enum.EasingStyle.Quad), props):Play()
end

local function Corner(r, parent)
    return Create("UICorner", { CornerRadius = UDim.new(0, r), Parent = parent })
end

local function Stroke(color, thick, parent)
    return Create("UIStroke", { Color = color, Thickness = thick or 1, Parent = parent })
end

local function Frame(props)
    local f = Create("Frame", props)
    return f
end

local function RFrame(radius, color, size, pos, parent, zi, clips)
    local f = Frame({
        BackgroundColor3 = color,
        Size = size,
        Position = pos or UDim2.new(0,0,0,0),
        BorderSizePixel = 0,
        Parent = parent,
        ZIndex = zi or 1,
        ClipsDescendants = clips == nil and false or clips,
    })
    Corner(radius, f)
    return f
end

local function Circle(size, color, parent, pos, zi)
    local f = Frame({
        Size = UDim2.new(0,size,0,size),
        Position = pos,
        BackgroundColor3 = color,
        BorderSizePixel = 0,
        Parent = parent,
        ZIndex = zi or 2,
    })
    Corner(math.ceil(size/2), f)
    return f
end

local function CircleOutline(size, color, thick, parent, pos, zi)
    local f = Frame({
        Size = UDim2.new(0,size,0,size),
        Position = pos,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Parent = parent,
        ZIndex = zi or 2,
    })
    Corner(math.ceil(size/2), f)
    Stroke(color, thick or 1.5, f)
    return f
end

local function DiamondOutline(size, color, thick, parent, pos, zi)
    local wrap = Frame({
        Size = UDim2.new(0,size,0,size),
        Position = pos,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Parent = parent,
        ZIndex = zi or 2,
    })
    local inner = Frame({
        Size = UDim2.new(1,0,1,0),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Rotation = 45,
        Parent = wrap,
        ZIndex = zi or 2,
    })
    Stroke(color, thick or 1.5, inner)
    return wrap
end

local function TLabel(text, size, color, font, parent, pos, sz, zi, xalign)
    return Create("TextLabel", {
        Text = text,
        TextSize = size or 13,
        TextColor3 = color or T.TextPrimary,
        Font = font or Enum.Font.GothamMedium,
        BackgroundTransparency = 1,
        Size = sz or UDim2.new(1,0,0,20),
        Position = pos or UDim2.new(0,0,0,0),
        BorderSizePixel = 0,
        Parent = parent,
        ZIndex = zi or 3,
        TextXAlignment = xalign or Enum.TextXAlignment.Left,
        TextTruncate = Enum.TextTruncate.AtEnd,
    })
end

local function MakeDraggable(frame, handle)
    handle = handle or frame
    local drag, ds, sp = false, nil, nil
    handle.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            drag = true; ds = i.Position; sp = frame.Position
        end
    end)
    handle.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if drag and i.UserInputType == Enum.UserInputType.MouseMovement then
            local d = i.Position - ds
            frame.Position = UDim2.new(sp.X.Scale, sp.X.Offset+d.X, sp.Y.Scale, sp.Y.Offset+d.Y)
        end
    end)
end


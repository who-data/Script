-- ── TOGGLE ──────────────────────────────────────────────────
local function MakeToggle(parent, name, opts)
    opts = opts or {}
    local val = opts.Default or false
    local cb  = opts.Callback or function() end
    local desc = opts.Description

    local height = desc and 48 or 38

    local row = New("Frame", {
        Size = UDim2.new(1, 0, 0, height),
        BackgroundTransparency = 1,
        Parent = parent,
    })

    New("TextLabel", {
        Size = UDim2.new(1, -58, 0, 16),
        Position = UDim2.new(0, 0, 0, desc and 7 or 11),
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = T.Text,
        Font = T.FontSemi,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = row,
    })

    if desc then
        New("TextLabel", {
            Size = UDim2.new(1, -58, 0, 13),
            Position = UDim2.new(0, 0, 0, 26),
            BackgroundTransparency = 1,
            Text = desc,
            TextColor3 = T.TextDim,
            Font = T.Font,
            TextSize = 11,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = row,
        })
    end

    Separator(row)

    local track = New("Frame", {
        Size = UDim2.new(0, 42, 0, 22),
        Position = UDim2.new(1, -42, 0.5, -11),
        BackgroundColor3 = val and T.Accent or Color3.fromRGB(45, 45, 45),
        BorderSizePixel = 0,
        Parent = row,
    })
    Corner(track, UDim.new(0, 11))

    local knob = New("Frame", {
        Size = UDim2.new(0, 16, 0, 16),
        Position = val and UDim2.new(0, 22, 0.5, -8) or UDim2.new(0, 4, 0.5, -8),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        BorderSizePixel = 0,
        Parent = track,
    })
    Corner(knob, UDim.new(1, 0))

    local function Set(v, silent)
        val = v
        Tween(track, { BackgroundColor3 = v and T.Accent or Color3.fromRGB(45, 45, 45) })
        Tween(knob, { Position = v and UDim2.new(0, 22, 0.5, -8) or UDim2.new(0, 4, 0.5, -8) })
        if not silent then cb(v) end
    end

    local btn = New("TextButton", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        ZIndex = 2,
        Parent = row,
    })
    btn.MouseButton1Click:Connect(function() Set(not val) end)

    return { Set = Set, Get = function() return val end }
end

-- ── SLIDER ──────────────────────────────────────────────────
local function MakeSlider(parent, name, opts)
    opts = opts or {}
    local min  = opts.Min or 0
    local max  = opts.Max or 100
    local val  = math.clamp(opts.Default or min, min, max)
    local suf  = opts.Suffix or ""
    local dec  = opts.Decimals or 0
    local cb   = opts.Callback or function() end

    local function Rnd(n) local m = 10^dec; return math.floor(n*m+0.5)/m end

    local row = New("Frame", {
        Size = UDim2.new(1, 0, 0, 52),
        BackgroundTransparency = 1,
        Parent = parent,
    })

    New("TextLabel", {
        Size = UDim2.new(1, -70, 0, 16),
        Position = UDim2.new(0, 0, 0, 6),
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = T.Text,
        Font = T.FontSemi,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = row,
    })

    local valLbl = New("TextLabel", {
        Size = UDim2.new(0, 65, 0, 16),
        Position = UDim2.new(1, -65, 0, 6),
        BackgroundTransparency = 1,
        Text = tostring(Rnd(val)) .. suf,
        TextColor3 = T.TextAccent,
        Font = T.FontSemi,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Right,
        Parent = row,
    })

    local bg = New("Frame", {
        Size = UDim2.new(1, 0, 0, 4),
        Position = UDim2.new(0, 0, 0, 34),
        BackgroundColor3 = Color3.fromRGB(38, 38, 38),
        BorderSizePixel = 0,
        Parent = row,
    })
    Corner(bg, UDim.new(0, 2))

    local fill = New("Frame", {
        Size = UDim2.new((val-min)/(max-min), 0, 1, 0),
        BackgroundColor3 = T.Accent,
        BorderSizePixel = 0,
        Parent = bg,
    })
    Corner(fill, UDim.new(0, 2))

    local knob = New("Frame", {
        Size = UDim2.new(0, 14, 0, 14),
        Position = UDim2.new((val-min)/(max-min), -7, 0.5, -7),
        BackgroundColor3 = T.Accent,
        BorderSizePixel = 0,
        ZIndex = 3,
        Parent = bg,
    })
    Corner(knob, UDim.new(1, 0))

    Separator(row)

    local function Set(v, silent)
        v = Rnd(math.clamp(v, min, max))
        val = v
        local p = (v-min)/(max-min)
        fill.Size = UDim2.new(p, 0, 1, 0)
        knob.Position = UDim2.new(p, -7, 0.5, -7)
        valLbl.Text = tostring(v) .. suf
        if not silent then cb(v) end
    end

    local dragging = false

    bg.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            local p = math.clamp((Mouse.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
            Set(min + (max-min)*p)
        end
    end)

    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            local p = math.clamp((Mouse.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
            Set(min + (max-min)*p)
        end
    end)

    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    return { Set = Set, Get = function() return val end }
end

-- ── DROPDOWN ────────────────────────────────────────────────
local function MakeDropdown(parent, name, opts)
    opts = opts or {}
    local options = opts.Options or {}
    local val  = opts.Default or options[1] or ""
    local cb   = opts.Callback or function() end
    local open = false

    local wrapper = New("Frame", {
        Size = UDim2.new(1, 0, 0, 38),
        BackgroundTransparency = 1,
        ClipsDescendants = false,
        ZIndex = 1,
        Parent = parent,
    })

    local row = New("Frame", {
        Size = UDim2.new(1, 0, 0, 38),
        BackgroundTransparency = 1,
        Parent = wrapper,
    })

    New("TextLabel", {
        Size = UDim2.new(1, -155, 1, 0),
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = T.Text,
        Font = T.FontSemi,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = row,
    })

    local btn = New("TextButton", {
        Size = UDim2.new(0, 145, 0, 26),
        Position = UDim2.new(1, -145, 0.5, -13),
        BackgroundColor3 = T.BGDark,
        Text = "",
        AutoButtonColor = false,
        Parent = row,
    })
    Corner(btn)
    Stroke(btn, T.Border)

    local lbl = New("TextLabel", {
        Size = UDim2.new(1, -24, 1, 0),
        Position = UDim2.new(0, 10, 0, 0),
        BackgroundTransparency = 1,
        Text = val,
        TextColor3 = T.TextSub,
        Font = T.Font,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = btn,
    })

    local arrow = New("TextLabel", {
        Size = UDim2.new(0, 20, 1, 0),
        Position = UDim2.new(1, -22, 0, 0),
        BackgroundTransparency = 1,
        Text = "▾",
        TextColor3 = T.Accent,
        Font = T.FontBold,
        TextSize = 11,
        Parent = btn,
    })

    Separator(row)

    -- dropdown list (reparented to parent's parent to avoid clipping)
    local list = New("Frame", {
        Size = UDim2.new(0, 145, 0, 0),
        BackgroundColor3 = Color3.fromRGB(22, 22, 22),
        ClipsDescendants = true,
        ZIndex = 50,
        Visible = false,
        Parent = parent,
    })
    Corner(list)
    Stroke(list, T.Border)

    local listLayout = List(list, 0)

    local function UpdateListPos()
        local abs = btn.AbsolutePosition
        local scrAbs = parent.AbsolutePosition
        list.Position = UDim2.new(0, abs.X - scrAbs.X, 0, abs.Y - scrAbs.Y + 30)
    end

    local function Populate()
        for _, c in ipairs(list:GetChildren()) do
            if c:IsA("TextButton") then c:Destroy() end
        end
        for _, opt in ipairs(options) do
            local item = New("TextButton", {
                Size = UDim2.new(1, 0, 0, 28),
                BackgroundTransparency = 1,
                Text = "  " .. opt,
                TextColor3 = opt == val and T.TextAccent or T.TextSub,
                Font = T.Font,
                TextSize = 12,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 51,
                Parent = list,
            })
            item.MouseEnter:Connect(function()
                item.BackgroundTransparency = 0.88
                item.BackgroundColor3 = T.Accent
            end)
            item.MouseLeave:Connect(function()
                item.BackgroundTransparency = 1
            end)
            item.MouseButton1Click:Connect(function()
                val = opt
                lbl.Text = opt
                cb(opt)
                -- close
                open = false
                Tween(list, { Size = UDim2.new(0, 145, 0, 0) }, 0.12)
                Tween(arrow, { Rotation = 0 })
                task.delay(0.13, function() list.Visible = false end)
                -- refresh colors
                for _, c2 in ipairs(list:GetChildren()) do
                    if c2:IsA("TextButton") then
                        c2.TextColor3 = c2.Text:gsub("^%s+","") == opt and T.TextAccent or T.TextSub
                    end
                end
            end)
        end
    end

    Populate()

    btn.MouseButton1Click:Connect(function()
        open = not open
        UpdateListPos()
        if open then
            list.Visible = true
            local h = math.min(#options * 28, 168)
            Tween(list, { Size = UDim2.new(0, 145, 0, h) }, 0.15)
            Tween(arrow, { Rotation = 180 })
        else
            Tween(list, { Size = UDim2.new(0, 145, 0, 0) }, 0.12)
            Tween(arrow, { Rotation = 0 })
            task.delay(0.13, function() list.Visible = false end)
        end
    end)

    return {
        Set = function(v, silent)
            val = v; lbl.Text = v
            if not silent then cb(v) end
        end,
        Get = function() return val end,
        Refresh = function(newOpts)
            options = newOpts
            Populate()
        end,
    }
end

-- ── TEXTBOX ─────────────────────────────────────────────────
local function MakeTextBox(parent, name, opts)
    opts = opts or {}
    local cb    = opts.Callback or function() end
    local ph    = opts.Placeholder or "Type here..."
    local clear = opts.ClearOnFocus ~= false

    local row = New("Frame", {
        Size = UDim2.new(1, 0, 0, 54),
        BackgroundTransparency = 1,
        Parent = parent,
    })

    New("TextLabel", {
        Size = UDim2.new(1, 0, 0, 16),
        Position = UDim2.new(0, 0, 0, 5),
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = T.Text,
        Font = T.FontSemi,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = row,
    })

    local box = New("TextBox", {
        Size = UDim2.new(1, 0, 0, 26),
        Position = UDim2.new(0, 0, 0, 23),
        BackgroundColor3 = T.BGDark,
        Text = "",
        PlaceholderText = ph,
        PlaceholderColor3 = T.TextDim,
        TextColor3 = T.Text,
        Font = T.Font,
        TextSize = 12,
        ClearTextOnFocus = clear,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = row,
    })
    Corner(box)
    Pad(box, 0, 0, 0, 10)
    local sk = Stroke(box, T.Border)

    box.Focused:Connect(function() Tween(sk, { Color = T.Accent }) end)
    box.FocusLost:Connect(function(enter)
        Tween(sk, { Color = T.Border })
        if enter then cb(box.Text) end
    end)

    Separator(row)

    return {
        Set = function(v) box.Text = v end,
        Get = function() return box.Text end,
    }
end


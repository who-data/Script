function ShadowUI:_Render(sec)
    for _,p in ipairs({self.LeftScroll,self.RightScroll}) do
        for _,c in ipairs(p:GetChildren()) do
            if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then c:Destroy() end
        end
    end
    for _,c in ipairs(self.TabList:GetChildren()) do if not c:IsA("UIListLayout") then c:Destroy() end end
    for _,s in ipairs(sec._cat._sections) do
        local act=(s==sec)
        local Tab=New("Frame",{Parent=self.TabList,BackgroundTransparency=1,Size=UDim2.new(0,82,1,0),ZIndex=3})
        if act then New("Frame",{Parent=Tab,BackgroundColor3=T.Accent,Position=UDim2.new(0,0,1,-2),Size=UDim2.new(1,0,0,2),ZIndex=5}) end
        New("Frame",{Parent=Tab,BackgroundColor3=act and T.Accent or T.AccentDim,Position=UDim2.new(0,4,0.5,-3),Size=UDim2.new(0,7,0,7),Rotation=45,ZIndex=4})
        MkLbl(Tab,s.Name,11,act and T.TextAccent or T.TextSec,act and Enum.Font.GothamBold or Enum.Font.Gotham,Enum.TextXAlignment.Left,UDim2.new(0,16,0,0),UDim2.new(1,-16,1,0),4)
    end
    for _,ctrl in ipairs(sec._left)  do self:_Build(self.LeftScroll,ctrl)  end
    for _,ctrl in ipairs(sec._right) do self:_Build(self.RightScroll,ctrl) end
end

-- ──────────────────────────────────────────────
--  BUILD
-- ──────────────────────────────────────────────
function ShadowUI:_Build(p,ctrl)
    if ctrl.type=="toggle"   then return self:_Toggle(p,ctrl)   end

    end

    local startY = ctrl.description and 36 or 24

    -- Helper to build a single channel mini-slider
    local function MkChanSlider(label, initVal, yOff, callback)
        local rowF = New("Frame", {
            Parent               = wrap,
            BackgroundTransparency = 1,
            Position             = UDim2.new(0, 0, 0, startY + yOff),
            Size                 = UDim2.new(1, 0, 0, 22),
            ZIndex               = 3,
        })
        Lbl(rowF, label, 10, T.TxtSec, Enum.Font.GothamBold,
            Enum.TextXAlignment.Left,
            nil, UDim2.new(0, 14, 1, 0), 3)

        local valLbl = Lbl(rowF, tostring(initVal), 10, T.TxtAcc, Enum.Font.GothamBold,
            Enum.TextXAlignment.Right,
            UDim2.new(1, -28, 0, 0), UDim2.new(0, 24, 1, 0), 3)

        local trackF = New("Frame", {
            Parent           = rowF,
            BackgroundColor3 = T.SlTrack,
            Position         = UDim2.new(0, 16, 0.5, -2),
            Size             = UDim2.new(1, -44, 0, 4),
            ZIndex           = 4,
            BorderSizePixel  = 0,
        })
        Corner(2, trackF)

        local pct  = initVal / 255
        local fill = New("Frame", {
            Parent           = trackF,
            BackgroundColor3 = T.Accent,
            Size             = UDim2.new(pct, 0, 1, 0),
            ZIndex           = 5,
            BorderSizePixel  = 0,
        })
        Corner(2, fill)

        local thumb = New("Frame", {
            Parent           = trackF,
            BackgroundColor3 = T.White,
            Position         = UDim2.new(pct, -5, 0.5, -5),
            Size             = UDim2.new(0, 10, 0, 10),
            ZIndex           = 6,
            BorderSizePixel  = 0,
        })
        Corner(5, thumb)

        local curVal = initVal
        local function Update(absX)
            local ap = trackF.AbsolutePosition.X
            local as = trackF.AbsoluteSize.X
            if as <= 0 then return end
            local p   = math.clamp((absX - ap) / as, 0, 1)
            curVal    = math.floor(p * 255)
            fill.Size = UDim2.new(p, 0, 1, 0)
            thumb.Position = UDim2.new(p, -5, 0.5, -5)
            valLbl.Text = tostring(curVal)
            callback(curVal)
        end

        local dragging = false
        local hitB = New("TextButton", {
            Parent               = rowF,
            BackgroundTransparency = 1,
            Size                 = UDim2.new(1, 0, 1, 0),
            Text                 = "",
            ZIndex               = 8,
        })
        hitB.MouseButton1Down:Connect(function(x) dragging = true; Update(x) end)

        local mc = UIS.InputChanged:Connect(function(i)
            if not dragging then return end
            if i.UserInputType == Enum.UserInputType.MouseMovement then
                Update(i.Position.X)
            end
        end)
        local uc = UIS.InputEnded:Connect(function(i)
            if dragging and i.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end)
        wrap.AncestryChanged:Connect(function()
            if not wrap.Parent then
                pcall(function() mc:Disconnect() end)
                pcall(function() uc:Disconnect() end)
            end
        end)

        return function(newV)
            curVal = newV
            local np = newV / 255
            fill.Size      = UDim2.new(np, 0, 1, 0)
            thumb.Position = UDim2.new(np, -5, 0.5, -5)
            valLbl.Text    = tostring(newV)
        end
    end

    local function Update()
        val = Color3.fromRGB(r, g, b)
        ctrl._val = val
        swatch.BackgroundColor3 = val
        if ctrl.callback then ctrl.callback(val) end
    end

    local setR = MkChanSlider("R", r,  0, function(v) r = v; Update() end)
    local setG = MkChanSlider("G", g, 24, function(v) g = v; Update() end)
    local setB = MkChanSlider("B", b, 48, function(v) b = v; Update() end)

    ctrl._setValue = function(c)
        val = c; ctrl._val = c
        r = math.floor(c.R * 255)
        g = math.floor(c.G * 255)
        b = math.floor(c.B * 255)
        setR(r); setG(g); setB(b)
        swatch.BackgroundColor3 = c
        if ctrl.callback then ctrl.callback(c) end
    end
    ctrl._getValue = function() return val end
    return wrap
end

-- ══════════════════════════════════════════════════════════════════
--  ⑨ KEYBIND CONTROL  (NEW in v5)
-- ══════════════════════════════════════════════════════════════════
--[[
    cfg fields:
        text        string
        default     Enum.KeyCode   (default Enum.KeyCode.Unknown)
        description string
        id          string
        callback    fn(KeyCode)     — fired when key changes AND when bound key is pressed
]]
function ShadowUI:_BKeybind(panel, ctrl)
    local val      = ctrl._val or ctrl.default or Enum.KeyCode.Unknown
    local listening = false

    local wrapH = ctrl.description and 54 or 38
    local wrap  = Row(panel, wrapH)
    Corner(5, wrap)

    local bg = New("Frame", {
        Parent               = wrap,
        BackgroundColor3     = T.RowHov,
        BackgroundTransparency = 1,
        Size                 = UDim2.new(1, 0, 1, 0),
        ZIndex               = 2,
        BorderSizePixel      = 0,
    })
    Corner(5, bg)

    Lbl(wrap, ctrl.text or "Keybind", 11, T.TxtSec, Enum.Font.Gotham,
        Enum.TextXAlignment.Left,
        UDim2.new(0, 5, 0, 0), UDim2.new(1, -90, 1, 0), 4)

    if ctrl.description then
        wrap.Size = UDim2.new(1, 0, 0, 54)
        Lbl(wrap, ctrl.description, 10, T.TxtDim, Enum.Font.Gotham,
            Enum.TextXAlignment.Left,
            UDim2.new(0, 5, 0, 22), UDim2.new(1, -90, 0, 16), 4)
    end

    -- Key badge
    local badge = New("Frame", {
        Parent           = wrap,
        BackgroundColor3 = T.BtnBg,
        Position         = UDim2.new(1, -82, 0.5, -12),
        Size             = UDim2.new(0, 76, 0, 24),
        ZIndex           = 4,
        BorderSizePixel  = 0,
    })
    Corner(5, badge)
    Stroke(T.Border, 1, badge)

    local keyLbl = New("TextLabel", {
        Parent               = badge,
        BackgroundTransparency = 1,
        Size                 = UDim2.new(1, 0, 1, 0),
        Font                 = Enum.Font.GothamBold,
        Text                 = val.Name,
        TextColor3           = T.TxtAcc,
        TextSize             = 10,
        TextXAlignment       = Enum.TextXAlignment.Center,
        ZIndex               = 5,
    })

    local hit = New("TextButton", {
        Parent               = wrap,
        BackgroundTransparency = 1,
        Size                 = UDim2.new(1, 0, 1, 0),
        Text                 = "",
        ZIndex               = 7,
    })
    hit.MouseEnter:Connect(function() Tw(bg, { BackgroundTransparency = 0.82 }, 0.08) end)
    hit.MouseLeave:Connect(function() Tw(bg, { BackgroundTransparency = 1 }, 0.08) end)

    if ctrl.tooltip then self:_AttachTooltip(hit, ctrl.tooltip) end

    -- Listen for new key
    local inputConn
    hit.MouseButton1Click:Connect(function()
        if listening then return end
        listening      = true
        keyLbl.Text    = "..."
        keyLbl.TextColor3 = T.ToastWrn
        Tw(badge, { BackgroundColor3 = T.AccentDim }, 0.1)
        Stroke(T.Accent, 1.5, badge)

        if inputConn then inputConn:Disconnect() end
        inputConn = UIS.InputBegan:Connect(function(i, gpe)
            if gpe then return end
            if i.UserInputType == Enum.UserInputType.Keyboard then
                listening = false
                val = i.KeyCode; ctrl._val = val
                keyLbl.Text = val.Name
                keyLbl.TextColor3 = T.TxtAcc
                Tw(badge, { BackgroundColor3 = T.BtnBg }, 0.1)
                inputConn:Disconnect()
                if ctrl.callback then ctrl.callback(val, "changed") end
            end
        end)
    end)

    -- Fire callback when bound key is pressed
    local pressConn = UIS.InputBegan:Connect(function(i, gpe)
        if gpe then return end
        if i.UserInputType == Enum.UserInputType.Keyboard
        and i.KeyCode == val and not listening then
            if ctrl.callback then ctrl.callback(val, "pressed") end
        end
    end)
    table.insert(self._conns, pressConn)

    ctrl._setValue = function(kc)
        val = kc; ctrl._val = kc
        keyLbl.Text = kc.Name
        if ctrl.callback then ctrl.callback(kc, "changed") end
    end
    ctrl._getValue = function() return val end
    return wrap
end

-- ══════════════════════════════════════════════════════════════════
--  CONFIG TAB  (built automatically in Finalize)
-- ══════════════════════════════════════════════════════════════════
function ShadowUI:_BuildConfig()
    local cat = self:AddCategory({ name = "Config", icon = "⚙" })
    local sec = self:AddSection(cat, "Settings")

    -- Sort theme names
    local tNames = {}
    for k in pairs(Themes) do table.insert(tNames, k) end
    table.sort(tNames)

    -- Config file dropdown
    local cfgDrop = {
        type    = "dropdown",
        text    = "Config File",
        options = ListCfgs(),
        default = "default",
        id      = "_cfg_file",
    }
    self._ctrls["_cfg_file"] = cfgDrop

    -- New config name input
    local cfgName = {
        type        = "textinput",
        text        = "New Config Name",
        placeholder = "my_config",
        default     = "",
        id          = "_cfg_newname",
    }
    self._ctrls["_cfg_newname"] = cfgName

    sec._left = {
        {
            type     = "header",
            text     = "Theme",
        },
        {
            type     = "dropdown",
            text     = "UI Theme",
            options  = tNames,
            default  = self._theme,
            tooltip  = "Switch the colour theme of the entire UI",
            callback = function(v) self:_Theme(v) end,
        },
        {
            type     = "header",
            text     = "Config Files",
        },
        cfgDrop,
        cfgName,
        {
            type     = "button",
            text     = "💾  Save Config",
            style    = "accent",
            tooltip  = "Save current settings to the selected config file",
            callback = function()
                local nameCtrl = self._ctrls["_cfg_newname"]
                local fileCtrl = self._ctrls["_cfg_file"]
                local name = (nameCtrl and nameCtrl._getValue and nameCtrl._getValue() ~= "")
                    and nameCtrl._getValue()
                    or  (fileCtrl and fileCtrl._getValue and fileCtrl._getValue() or "default")
                self:SaveConfig(name)
                -- Refresh file list
                if fileCtrl then
                    fileCtrl.options = ListCfgs()
                end
                self:Notify("Config Saved", "Saved as '"..name.."'", "success", 3)
            end,
        },
        {
            type     = "button",
            text     = "📂  Load Config",
            style    = "ghost",
            tooltip  = "Load settings from the selected config file",
            callback = function()
                local c = self._ctrls["_cfg_file"]
                local n = c and c._getValue and c._getValue() or "default"
                self:LoadConfig(n)
                self:Notify("Config Loaded", "Loaded '"..n.."'", "info", 3)
            end,
        },
        {
            type     = "button",
            text     = "🗑  Delete Config",
            style    = "danger",
            tooltip  = "Permanently delete the selected config file",
            callback = function()
                local c = self._ctrls["_cfg_file"]
                local n = c and c._getValue and c._getValue() or "default"
                if n ~= "default" then
                    pcall(delfile, CFG_DIR .. "/" .. n .. CFG_EXT)
                    c.options = ListCfgs()
                    if c._setValue then c._setValue("default") end
                    self:Notify("Config Deleted", "'"..n.."' removed", "warning", 3)
                else
                    self:Notify("Cannot Delete", "The 'default' config cannot be deleted", "error", 3)
                end
            end,
        },
        {
            type     = "header",
            text     = "Auto Load",
        },
        {
            type     = "toggle",
            text     = "Auto Load on Start",
            description = "Automatically load the default config when the script starts",
            default  = self:_AutoLoadGet(),
            callback = function(v) self:_AutoLoadSet(v) end,
        },
    }

    for _, ctrl in ipairs(sec._left) do
        if ctrl.id then self._ctrls[ctrl.id] = ctrl end
    end

    -- Auto-load on next frame
    task.defer(function()
        if self:_AutoLoadGet() then
            local n = self:_AutoLoadName()
            if n then self:LoadConfig(n) end
        end
    end)
end

-- ══════════════════════════════════════════════════════════════════
--  THEME APPLICATION
-- ══════════════════════════════════════════════════════════════════
function ShadowUI:_Theme(name)
    local th = Themes[name]
    if not th then return end
    self._theme = name
    for k, v in pairs(th) do T[k] = v end

    -- Apply to structural elements
    pcall(function()
        self.Win.BackgroundColor3         = T.Bg
        self.Hdr.BackgroundColor3         = T.Header
        self.Sidebar.BackgroundColor3     = T.Sidebar
        self.Content.BackgroundColor3     = T.Panel
        self.TabBar.BackgroundColor3      = T.TabBar
        self._accentLine.BackgroundColor3 = T.Accent
        self.FloatBtn.BackgroundColor3    = T.Accent
        self._sideStripe.BackgroundColor3 = T.Accent
        self._winStroke.Color             = T.Border
        self._logoStroke.Color            = T.Accent
        self._logoDot.BackgroundColor3    = T.Accent
        if self._watermark then
            self._watermark.BackgroundColor3 = T.Bg
        end
    end)

    if self._active then self:_Render(self._active) end
end

-- ══════════════════════════════════════════════════════════════════
--  SAVE / LOAD CONFIG
-- ══════════════════════════════════════════════════════════════════
function ShadowUI:SaveConfig(name)
    name = name or "default"
    local d = { theme = self._theme, v = {}, version = VERSION }
    for id, c in pairs(self._ctrls) do
        if c._getValue then
            local v = c._getValue()
            -- Serialize Color3 and KeyCode
            if typeof(v) == "Color3" then
                v = { _t = "Color3", r = v.R, g = v.G, b = v.B }
            elseif typeof(v) == "EnumItem" then
                v = { _t = "KeyCode", n = v.Name }
            end
            d.v[id] = v
        end
    end
    local ok, j = pcall(HS.JSONEncode, HS, d)
    if ok then SafeWrite(CFG_DIR .. "/" .. name .. CFG_EXT, j) end
end

function ShadowUI:LoadConfig(name)
    name = name or "default"
    local raw = SafeRead(CFG_DIR .. "/" .. name .. CFG_EXT)
    if not raw then return end
    local ok, d = pcall(HS.JSONDecode, HS, raw)
    if not ok or type(d) ~= "table" then return end
    if d.theme then self:_Theme(d.theme) end
    if d.v then
        for id, v in pairs(d.v) do
            local c = self._ctrls[id]
            if c and c._setValue then
                -- Deserialize special types
                if type(v) == "table" and v._t == "Color3" then
                    v = Color3.new(v.r, v.g, v.b)
                elseif type(v) == "table" and v._t == "KeyCode" then
                    v = Enum.KeyCode[v.n] or Enum.KeyCode.Unknown
                end
                c._setValue(v)
            end
        end
    end
end

function ShadowUI:_AutoLoadGet()
    local r = SafeRead(CFG_DIR .. "/__auto" .. CFG_EXT)
    if not r then return false end
    local ok, d = pcall(HS.JSONDecode, HS, r)
    return ok and d and d.on or false
end

function ShadowUI:_AutoLoadName()
    local r = SafeRead(CFG_DIR .. "/__auto" .. CFG_EXT)
    if not r then return nil end
    local ok, d = pcall(HS.JSONDecode, HS, r)
    return ok and d and d.cfg or nil
end

function ShadowUI:_AutoLoadSet(on, cfg)
    local ok, j = pcall(HS.JSONEncode, HS, { on = on, cfg = cfg or "default" })
    if ok then SafeWrite(CFG_DIR .. "/__auto" .. CFG_EXT, j) end
end


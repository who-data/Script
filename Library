-- Finalize: adiciona Config SEMPRE por último, abre primeira cat
function ShadowUI:Finalize()
    self:_BuildConfig()
    for _, cat in ipairs(self._cats) do
        if cat.Name ~= "Config" then
            task.defer(function() cat._row.MouseButton1Click:Fire() end)
            return
        end
    end
end


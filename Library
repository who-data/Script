function ComponentFactory:MakeToggle(parent, opts)
    local opts = opts or {}
    local value = opts.Default or false
    local connections = {}
    local theme = self.Theme

    local frame = Utils.Create("Frame", {
        Name                    = "Toggle_" .. (opts.Name or ""),
        Size                    = UDim2.new(1, 0, 0, 36),
        BackgroundColor3        = theme:Get("SurfaceAlt"),
        BackgroundTransparency  = 0,
        LayoutOrder             = opts.LayoutOrder or 0,
        Parent                  = parent,
    })
    Utils.AddCorner(frame, CORNER_SMALL)
    Utils.AddPadding(frame, 0, 10, 0, 10)

    local nameLabel = Utils.Create("TextLabel", {
        Name                    = "Name",
        Size                    = UDim2.new(1, -54, 1, 0),
        BackgroundTransparency  = 1,
        Text                    = opts.Name or "Toggle",
        TextColor3              = theme:Get("Text"),
        TextSize                = 13,
        Font                    = Enum.Font.Gotham,
        TextXAlignment          = Enum.TextXAlignment.Left,
        Parent                  = frame,
    })

    local trackBg = Utils.Create("Frame", {
        Name                    = "Track",
        Size                    = UDim2.new(0, 38, 0, 20),
        Position                = UDim2.new(1, -38, 0.5, -10),
        BackgroundColor3        = theme:Get("Border"),
        BorderSizePixel         = 0,
        Parent                  = frame,
    })
    Utils.AddCorner(trackBg, UDim.new(1, 0))

    local thumb = Utils.Create("Frame", {
        Name                    = "Thumb",
        Size                    = UDim2.new(0, 14, 0, 14),
        Position                = UDim2.new(0, 3, 0.5, -7),
        BackgroundColor3        = theme:Get("Text"),
        BorderSizePixel         = 0,
        Parent                  = trackBg,
    })
    Utils.AddCorner(thumb, UDim.new(1, 0))

    local function updateVisual(v, animate)
        local targetPos = v and UDim2.new(1, -17, 0.5, -7) or UDim2.new(0, 3, 0.5, -7)
        local targetColor = v and theme:Get("Accent") or theme:Get("Border")
        if animate then
            self.Anim:Play(thumb, {Position = targetPos}, TWEEN_SHORT)
            self.Anim:Play(trackBg, {BackgroundColor3 = targetColor}, TWEEN_SHORT)
        else
            thumb.Position = targetPos
            trackBg.BackgroundColor3 = targetColor
        end
    end

    updateVisual(value, false)

    local function toggle()
        value = not value
        updateVisual(value, true)
        if opts.Callback then pcall(opts.Callback, value) end
        if opts.Flag then self.Config:SetFlag(opts.Flag, value) end
    end

    Utils.Connect(connections, frame.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            self.Anim:Ripple(frame, input.Position.X - frame.AbsolutePosition.X,
                input.Position.Y - frame.AbsolutePosition.Y, theme:Get("Accent"))
            toggle()
        end
    end)

    Utils.Connect(connections, frame.MouseEnter, function()
        self.Anim:Play(frame, {BackgroundColor3 = theme:Get("Surface")}, TWEEN_SHORT)
    end)
    Utils.Connect(connections, frame.MouseLeave, function()
        self.Anim:Play(frame, {BackgroundColor3 = theme:Get("SurfaceAlt")}, TWEEN_SHORT)
    end)

    if opts.Keybind then
        self.InputHandler:Bind(opts.Keybind, toggle)
    end

    if opts.Tooltip then self.Tooltip:Attach(frame, opts.Tooltip) end

    if opts.Flag then
        self.Config:Register(opts.Flag, value, function(v)
            value = v
            updateVisual(v, true)
        end)
    end

    return {
        Frame    = frame,
        GetValue = function() return value end,
        SetValue = function(_, v)
            value = v
            updateVisual(v, true)
            if opts.Callback then pcall(opts.Callback, value) end
        end,
        Destroy  = function()
            Utils.Disconnect(connections)
            frame:Destroy()
        end,
    }
end


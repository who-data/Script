--  PUBLIC API — ADD CONTROLS
-- ══════════════════════════════════════════════════════════════════

--- Internal helper: registers and optionally live-builds a control.
local function _addCtrl(self, sec, side, cfg)
    if cfg.id then self._ctrls[cfg.id] = cfg end
    local list = side == "right" and sec._right or sec._left
    list[#list + 1] = cfg
    if sec._active then
        local panel = side == "right" and self.RightPanel or self.LeftPanel
        self:_Build(panel, cfg)
    end
    return cfg
end

--- Adds a Toggle switch.
function ShadowUI:Toggle(sec, side, cfg)
    cfg = cfg or {}; cfg.type = "toggle"
    return _addCtrl(self, sec, side, cfg)
end

--- Adds a Slider.
function ShadowUI:Slider(sec, side, cfg)
    cfg = cfg or {}; cfg.type = "slider"
    return _addCtrl(self, sec, side, cfg)
end

--- Adds a Dropdown selector.
function ShadowUI:Dropdown(sec, side, cfg)
    cfg = cfg or {}; cfg.type = "dropdown"
    return _addCtrl(self, sec, side, cfg)
end

--- Adds a section Header (with optional inline toggle or gear).
function ShadowUI:SectionHeader(sec, side, cfg)
    cfg = cfg or {}; cfg.type = "header"
    return _addCtrl(self, sec, side, cfg)
end

--- Adds a static Label.
function ShadowUI:Label(sec, side, cfg)
    cfg = cfg or {}; cfg.type = "label"
    return _addCtrl(self, sec, side, cfg)
end

--- Adds a clickable Button.
function ShadowUI:Button(sec, side, cfg)
    cfg = cfg or {}; cfg.type = "button"
    return _addCtrl(self, sec, side, cfg)
end

--- Adds a TextInput box.
function ShadowUI:TextInput(sec, side, cfg)
    cfg = cfg or {}; cfg.type = "textinput"
    return _addCtrl(self, sec, side, cfg)
end

--- Adds an RGB ColorPicker.
function ShadowUI:ColorPicker(sec, side, cfg)
    cfg = cfg or {}; cfg.type = "colorpicker"
    return _addCtrl(self, sec, side, cfg)
end

--- Adds a Keybind binding widget.
function ShadowUI:Keybind(sec, side, cfg)
    cfg = cfg or {}; cfg.type = "keybind"
    return _addCtrl(self, sec, side, cfg)
end

--- Injects a fully custom builder function.
--- fn(panel) should create and parent its own instances to `panel`.
function ShadowUI:Custom(sec, side, fn)
    return _addCtrl(self, sec, side, { type = "_custom", _fn = fn })
end

-- ══════════════════════════════════════════════════════════════════
--  BIND TOGGLE KEY
-- ══════════════════════════════════════════════════════════════════
function ShadowUI:BindToggleKey(key)
    local conn = UIS.InputBegan:Connect(function(i, gpe)
        if gpe then return end
        if i.KeyCode == key then self:_Toggle() end
    end)
    table.insert(self._conns, conn)
end

-- ══════════════════════════════════════════════════════════════════
--  FINALIZE  — builds Config tab, opens first non-config category
-- ══════════════════════════════════════════════════════════════════
function ShadowUI:Finalize()
    self:_BuildConfig()
    for _, cat in ipairs(self._cats) do
        if cat.Name ~= "Config" then
            task.defer(function()
                cat._row.MouseButton1Click:Fire()
            end)
            return
        end
    end
end

-- ══════════════════════════════════════════════════════════════════
--  DESTROY  — full cleanup
-- ══════════════════════════════════════════════════════════════════
function ShadowUI:Destroy()
    -- Disconnect all tracked connections
    for _, conn in ipairs(self._conns) do
        pcall(function() conn:Disconnect() end)
    end
    self._conns = {}
    -- Destroy GUI
    pcall(function() self.Gui:Destroy() end)
end


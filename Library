    MkBtn(R2,"🗑  Delete",function()
        local name=self._currentConfig or "default"
        if name=="default" then self:_Notify("Cannot delete default",false); return end
        if SaveSystem.Delete(name) then
            local nl=SaveSystem.List()
            if self._configDropCfg then
                self._configDropCfg.options=nl; self._configDropCfg._val="default"
                self._currentConfig="default"
                if self._configDropCfg._setValue then self._configDropCfg._setValue("default") end
            end
            self:_Notify("Deleted: "..name,true)
        else self:_Notify("Delete failed",false) end
    end,false)
    return Wrap
end


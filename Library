-- ──────────────────────────────────────────────
--  BREADCRUMB
-- ──────────────────────────────────────────────
function ShadowUI:_Bread(catName, secName)
    for _, c in ipairs(self.BreadFrame:GetChildren()) do
        if c ~= self.BreadCat and not c:IsA("UIListLayout") then c:Destroy() end
    end
    self.BreadCat.Text = catName
    if secName then
        Lbl(self.BreadFrame, "›", 13, T.TextSec, Enum.Font.Gotham,
            Enum.TextXAlignment.Center, nil, UDim2.new(0,10,1,0), 4)
        Lbl(self.BreadFrame, secName, 12, T.TextPri, Enum.Font.Gotham,
            Enum.TextXAlignment.Left, nil, UDim2.new(0,100,1,0), 4)
    end
end


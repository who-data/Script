--  ANIMATION ENGINE
-- ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź
local Anim = {}
Anim.__index = Anim

function Anim.new()
    return setmetatable({ _active = {} }, Anim)
end

function Anim:Play(inst, props, info)
    info = info or TI.Medium
    if self._active[inst] then
        self._active[inst]:Cancel()
        self._active[inst] = nil
    end
    if not inst or not inst.Parent then return end
    local t = TweenService:Create(inst, info, props)
    self._active[inst] = t
    t:Play()
    t.Completed:Connect(function(state)
        if self._active[inst] == t then
            self._active[inst] = nil
        end
    end)
    return t
end

function Anim:Stop(inst)
    if self._active[inst] then
        self._active[inst]:Cancel()
        self._active[inst] = nil
    end
end

function Anim:CancelAll()
    for inst, t in pairs(self._active) do pcall(function() t:Cancel() end) end
    table.clear(self._active)
end

-- Ripple effect: spawns expanding circle on click
function Anim:Ripple(parent, cx, cy, color, maxMult)
    if not parent or not parent.Parent then return end
    maxMult = maxMult or 2.8
    local rip = Instance.new("Frame")
    rip.AnchorPoint  = Vector2.new(0.5, 0.5)
    rip.Size         = UDim2.new(0, 0, 0, 0)
    rip.Position     = UDim2.new(0, cx, 0, cy)
    rip.BackgroundColor3   = color or Color3.fromRGB(255,255,255)
    rip.BackgroundTransparency = 0.72
    rip.BorderSizePixel = 0
    rip.ZIndex       = (parent.ZIndex or 1) + 20
    local corner = Instance.new("UICorner")
    corner.CornerRadius = CR_FULL
    corner.Parent = rip
    rip.Parent = parent
    -- Clip rip inside parent
    local maxDim = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * maxMult
    local t = TweenService:Create(rip,
        TweenInfo.new(0.52, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, maxDim, 0, maxDim),
        BackgroundTransparency = 1,
    })
    t:Play()
    t.Completed:Connect(function() rip:Destroy() end)
end

-- Micro-pulse: briefly flash a property
function Anim:Pulse(inst, propA, propB, prop, dur)
    prop = prop or "BackgroundColor3"
    dur  = dur  or 0.12
    self:Play(inst, { [prop] = propB }, TI.Linear(dur))
    task.delay(dur, function()
        if inst and inst.Parent then
            self:Play(inst, { [prop] = propA }, TI.Linear(dur))
        end
    end)
end


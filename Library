        BackgroundTransparency = 1,
        Text = "",
        TextColor3 = th:Get("Error"),
        TextSize = 10,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = Z.KEYUI + 2,
        Parent = card,
    })

    -- Submit button
    local submitBtn = U.New("Frame", {
        Name = "Submit",
        Size = UDim2.new(1, 0, 0, 38),
        Position = UDim2.new(0, 0, 0, 140),
        BackgroundColor3 = th:Get("Accent"),
        BorderSizePixel = 0,
        ClipsDescendants = true,
        ZIndex = Z.KEYUI + 2,
        Parent = card,
    })
    U.Corner(submitBtn, CR_SM)
    U.Gradient(submitBtn, th:Get("AccentHi"), th:Get("AccentLo"), 115)

    local submitLbl = U.New("TextLabel", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "Verify Key ‚Üí",
        TextColor3 = Color3.fromRGB(255,255,255),
        TextSize = 13,
        Font = Enum.Font.GothamBold,
        ZIndex = Z.KEYUI + 3,
        Parent = submitBtn,
    })

    -- Skip button (if opts.Skippable)
    if opts.Skippable then
        local skipLbl = U.New("TextLabel", {
            Name = "Skip",
            Size = UDim2.new(1, 0, 0, 16),
            Position = UDim2.new(0, 0, 0, 186),
            BackgroundTransparency = 1,
            Text = "Skip (demo mode)",
            TextColor3 = th:Get("TextMuted"),
            TextSize = 10,
            Font = Enum.Font.Gotham,
            ZIndex = Z.KEYUI + 2,
            Parent = card,
        })
        skipLbl.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                anim:Play(card, {Size = UDim2.new(0,0,0,0), BackgroundTransparency=1}, TI.Medium)
                task.delay(0.25, function()
                    sg:Destroy()
                    if onSuccess then pcall(onSuccess) end
                end)
            end
        end)
    end

    -- Get-key link
    if opts.KeyLink then
        local linkLbl = U.New("TextLabel", {
            Name = "Link",
            Size = UDim2.new(1, 0, 0, 14),
            Position = UDim2.new(0, 0, 0, opts.Skippable and 206 or 186),
            BackgroundTransparency = 1,
            Text = "Get key ‚Üí  " .. opts.KeyLink,
            TextColor3 = th:Get("Accent"),
            TextSize = 10,
            Font = Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = Z.KEYUI + 2,
            Parent = card,
        })
    end

    -- Animate card open
    overlay.BackgroundTransparency = 1
    anim:Play(overlay, {BackgroundTransparency = 0.45}, TI.Medium)
    card.BackgroundTransparency = 1
    card.Size = UDim2.new(0, 0, 0, 0)
    task.defer(function()
        anim:Play(card, {
            Size = UDim2.new(0, 420, 0, opts.KeyLink and 210 or 196),
            BackgroundTransparency = 0,
        }, TI.Spring)
    end)

    local attempts = 0
    local maxAttempts = opts.MaxAttempts or 5

    local function tryVerify()
        local entered = keyBox.Text
        attempts = attempts + 1
        -- Check key(s)
        local valid = false
        if opts.Key then
            if type(opts.Key) == "table" then
                for _, k in ipairs(opts.Key) do
                    if entered == k then valid = true; break end
                end
            elseif entered == opts.Key then
                valid = true
            end
        elseif opts.Validate then
            valid = pcall(opts.Validate, entered)
        else
            valid = true  -- no key requirement = auto pass
        end

        if valid then
            statusLbl.Text = "‚úď  Key accepted! Loading..."
            statusLbl.TextColor3 = th:Get("Success")
            anim:Play(submitBtn, {BackgroundColor3 = th:Get("Success")}, TI.Fast)
            task.delay(0.9, function()
                anim:Play(card, {Size = UDim2.new(0,0,0,0), BackgroundTransparency = 1}, TI.Medium)
                anim:Play(overlay, {BackgroundTransparency = 1}, TI.Medium)
                task.delay(0.28, function()
                    sg:Destroy()
                    if onSuccess then pcall(onSuccess) end
                end)
            end)
        else
            local left = maxAttempts - attempts
            statusLbl.Text = "‚úó  Invalid key. " .. left .. " attempt(s) left."
            statusLbl.TextColor3 = th:Get("Error")
            anim:Pulse(submitBtn, th:Get("Accent"), Color3.fromRGB(180,40,40), "BackgroundColor3", 0.1)
            anim:Pulse(inputBg, th:Get("BG"), Color3.fromRGB(60,20,20), "BackgroundColor3", 0.12)
            if left <= 0 then
                statusLbl.Text = "Too many failed attempts."
                submitBtn.BackgroundColor3 = th:Get("BG5")
                submitLbl.Text = "Locked"
                submitLbl.TextColor3 = th:Get("TextMuted")
            end
        end
    end

    submitBtn.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 and attempts < maxAttempts then
            local rx = inp.Position.X - submitBtn.AbsolutePosition.X
            local ry = inp.Position.Y - submitBtn.AbsolutePosition.Y
            anim:Ripple(submitBtn, rx, ry, Color3.fromRGB(255,255,255))
            tryVerify()
        end
    end)
    keyBox.FocusLost:Connect(function(enter)
        if enter and attempts < maxAttempts then tryVerify() end
    end)

    submitBtn.MouseEnter:Connect(function()
        anim:Play(submitBtn, {BackgroundColor3 = th:Get("AccentHi")}, TI.Fast)
    end)
    submitBtn.MouseLeave:Connect(function()
        anim:Play(submitBtn, {BackgroundColor3 = th:Get("Accent")}, TI.Fast)
    end)

    return { Gui = sg }
end


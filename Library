        -- Slider
        local function buildSlider(parent, opts)
            opts = opts or {}
            local min  = opts.Min     or 0
            local max  = opts.Max     or 100
            local val  = opts.Default or min
            local cb   = opts.Callback or function() end
            local suffix = opts.Suffix or ""

            local Row = makeItemBase(parent, opts.Name or "Slider", nil, 50)

            local ValLabel = Create("TextLabel", {
                Parent = Row,
                BackgroundTransparency = 1,
                Position = UDim2.new(1, -52, 0, 0),
                Size = UDim2.new(0, 44, 0.5, 0),
                Font = Enum.Font.GothamBold,
                Text = tostring(val)..suffix,
                TextColor3 = Theme.Accent,
                TextSize = 11,
                TextXAlignment = Enum.TextXAlignment.Right,
            })

            local Track = Create("Frame", {
                Parent = Row,
                BackgroundColor3 = Theme.SliderBack,
                BorderSizePixel = 0,
                Position = UDim2.new(0, 12, 1, -16),
                Size = UDim2.new(1, -24, 0, 5),
            })
            Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Track })

            local pct = (val - min) / (max - min)
            local Fill = Create("Frame", {
                Parent = Track,
                BackgroundColor3 = Theme.SliderFill,
                BorderSizePixel = 0,
                Size = UDim2.new(pct, 0, 1, 0),
            })
            Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Fill })

            local Knob = Create("Frame", {
                Parent = Track,
                BackgroundColor3 = Theme.White,
                Position = UDim2.new(pct, -6, 0.5, -6),
                Size = UDim2.new(0, 12, 0, 12),
            })
            Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Knob })

            local Slider = {}
            local draggingSlider = false

            local function updateSlider(inputX)
                local abs = Track.AbsolutePosition
                local sz  = Track.AbsoluteSize
                local p   = math.clamp((inputX - abs.X) / sz.X, 0, 1)
                local newVal = math.floor(min + p * (max - min) + 0.5)
                p = (newVal - min) / (max - min)
                Fill.Size     = UDim2.new(p, 0, 1, 0)
                Knob.Position = UDim2.new(p, -6, 0.5, -6)
                ValLabel.Text = tostring(newVal)..suffix
                val = newVal
                pcall(cb, newVal)
            end

            Track.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingSlider = true
                    updateSlider(input.Position.X)
                end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if draggingSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
                    updateSlider(input.Position.X)
                end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingSlider = false
                end
            end)

            function Slider:Set(v)
                val = math.clamp(v, min, max)
                local p = (val - min) / (max - min)
                Fill.Size     = UDim2.new(p, 0, 1, 0)
                Knob.Position = UDim2.new(p, -6, 0.5, -6)
                ValLabel.Text = tostring(val)..suffix
                pcall(cb, val)
            end

            function Slider:Get() return val end

            return Slider
        end

